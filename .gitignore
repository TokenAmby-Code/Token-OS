# ====================================================
# SECRETS & SENSITIVE DATA
# ====================================================
.env
*.env
.env.*
!.env.example

# Config files with secrets
config.json
mesh-pipe/config.json

# MacroDroid binary exports (contain GPS geofences, webhook URLs, IPs)
*.mdr

# ====================================================
# RUNTIME STATE & DATA
# ====================================================
*state*.json
session_registry.json
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# ====================================================
# LOGS
# ====================================================
*.log
logs/
mesh-pipe/logs/

# ====================================================
# PYTHON
# ====================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.eggs/
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ====================================================
# NODE.JS
# ====================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ====================================================
# IDE & EDITORS
# ====================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ====================================================
# DEPLOYMENT ARTIFACTS
# ====================================================
.claude-deploy.log
.claude-deploy-signal
.claude-local-server-state.json

# Per-worktree dev server artifacts (.worktree-dev.log is covered by *.log;
# the pid file was untracked and tripped pr-create's clean-tree guard)
.worktree-dev.pid

# Runtime-writable queue: the discord-daemon / token-api /send path enqueues
# JSON jobs here at runtime, and runtime-write-protect.sh (re)creates it 0755
# inside the otherwise read-only deploy tree. Keep it untracked so the runtime
# checkout stays clean (a dirty runtime aborts deploys).
/pending/

# Relocated out of the deploy tree to ~/.claude/restart_state.json; ignore any
# stragglers so a stale copy never re-enters the frozen tree.
/token-api/restart_state.json

# ====================================================
# COMPILED / BINARY
# ====================================================
*.exe
*.dll
*.bin
daemon.pid
