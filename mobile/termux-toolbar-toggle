#!/data/data/com.termux/files/usr/bin/bash
# termux-toolbar-toggle — select a local-only Termux toolbar profile.
# Invoke with one of: mobile, mobile-nav, dex. With no argument it cycles.

set -euo pipefail

PROPS="$HOME/.termux/termux.properties"
MODE_FILE="$HOME/.toolbar-mode"
current=$(cat "$MODE_FILE" 2>/dev/null || echo "mobile")
requested=${1:-}

if [[ -z "$requested" ]]; then
    case "$current" in
        mobile)     requested="mobile-nav" ;;
        mobile-nav) requested="dex" ;;
        *)          requested="mobile" ;;
    esac
fi

case "$requested" in
mobile)
    # Former mobile-tmux: the compact tmux-control profile used on phone.
    cat > "$PROPS" <<'TOOLBAR'
extra-keys = [ \
  [{macro: "\u0000h", display: '←h', popup: {macro: "\u00001", display: '1'}}, {macro: "\u0000j", display: '↓j', popup: {macro: "\u00002", display: '2'}}, {macro: "\u0000k", display: '↑k', popup: {macro: "\u00003", display: '3'}}, {macro: "\u0000l", display: '→l', popup: {macro: "\u00004", display: '4'}}, {macro: "\u0000|", display: 'v-split'}, {macro: "\u0000-", display: 'h-split'}, {key: 'KEYBOARD', display: '⌨', popup: 'ENTER'}], \
  [{macro: "\u00001", display: '1'}, {macro: "\u00002", display: '2'}, {macro: "\u00003", display: '3'}, {macro: "\u00004", display: '4'}, {macro: "\u0000n", display: '→next'}, {macro: "\u0000p", display: '←prev'}, 'ESC'], \
  [{macro: "\u0000e", display: 'expand'}, {macro: "\u0000d", display: 'detach'}, {macro: "\u0000,", display: 'rename'}, {macro: "\u0000x", display: 'kill'}, {macro: "\u0000y", display: '📋'}, 'ESC', {macro: "\u0000", display: '^␣'}] \
]
extra-keys-style = key-height:40,key-gap:0,key-border:0
TOOLBAR
    ;;
mobile-nav)
    cat > "$PROPS" <<'TOOLBAR'
extra-keys = [ \
  [{key: 'DRAWER', popup: {macro: "\u00001", display: '1'}}, {macro: "\u001b[Z", display: '⇧Tab', popup: {macro: "\u00002", display: '2'}}, {macro: "\u0012", display: '^R', popup: {macro: "\u00003", display: '3'}}, {macro: "\u0003", display: '^C', popup: {macro: "\u00004", display: '4'}}, {key: 'TAB', popup: {macro: "\u0000e", display: 'e'}}, {macro: "\u0000", display: '^␣'}, {key: 'KEYBOARD', display: '⌨', popup: 'ENTER'}], \
  ['ESC', 'SHIFT', 'ALT', {key: 'CTRL', popup: 'PASTE'}, {key: 'HOME', popup: {macro: "\u0000y", display: '📋'}}, {key: 'UP', popup: {macro: "claude\n", display: 'claude↩'}}, {key: 'END', popup: 'PASTE'}], \
  [{key: '|', popup: ':'}, {key: '~', popup: '&&'}, {key: '/', popup: '\\\\'}, {key: '-', popup: '_'}, 'LEFT', {key: 'DOWN', popup: {macro: "exit\n", display: 'exit↩'}}, 'RIGHT'] \
]
extra-keys-style = key-height:40,key-gap:0,key-border:0
TOOLBAR
    ;;
dex)
    # Former portable-nav: one large row for the external DeX display.
    cat > "$PROPS" <<'TOOLBAR'
extra-keys = [ \
  [{key: 'ESC', popup: {macro: "\u00001", display: '1'}}, {key: 'CTRL', popup: {macro: "\u00002", display: '2'}}, {key: 'ALT', popup: {macro: "\u00003", display: '3'}}, {macro: "\u0012", display: '^R', popup: {macro: "\u00004", display: '4'}}, {macro: "\u0003", display: '^C'}, 'TAB', {macro: "\u0000", display: '^␣'}, {key: 'KEYBOARD', display: '⌨', popup: 'ENTER'}], \
  [{key: '|', popup: ':'}, {key: '~', popup: '&&'}, {key: '/', popup: '\\\\'}, {key: '-', popup: '_'}, 'LEFT', {key: 'UP', popup: {macro: "claude\n", display: 'claude↩'}}, {key: 'DOWN', popup: {macro: "exit\n", display: 'exit↩'}}, 'RIGHT', {key: 'END', popup: 'PASTE'}] \
]
extra-keys-style = key-height:90,key-gap:4,key-border:1
TOOLBAR
    ;;
*)
    echo "usage: $0 [mobile|mobile-nav|dex]" >&2
    exit 2
    ;;
esac

cat >> "$PROPS" <<'EOF'
terminal-transcript-rows = 10000
enforce-char-based-input = true
volume-keys = volume
allow-external-apps = true
EOF
echo "$requested" > "$MODE_FILE"
termux-reload-settings
