      {
        "m_classType": "ShellScriptAction",
        "m_SIGUID": -989999999997672555,
        "disableLogging": false,
        "m_comment": "",
        "m_constraintList": [],
        "m_isDisabled": false,
        "m_isOrCondition": false,
        "blockNextAction": true,
        "m_nonRoot": true,
        "m_script": "echo \"$(date +%H:%M:%S) [TTS_LOCAL_CONTROL] echo command={http_param=command} session={http_param=session_id} playback={http_param=playback_id} speed={http_param=speed}\" >> /storage/emulated/0/MacroDroid/logs/debug.log\n",
