  "macro": {
    "m_name": "03 TTS Local Echo Control",
    "m_enabled": true,
    "m_completed": true,
    "m_GUID": 0,
    "m_category": "TTS",
    "aiGenerated": 1,
    "m_description": "Private Token-OS echo endpoint; mutates local MacroDroid chunk loop after authoritative control is recorded.",
    "m_triggerList": [
      {
        "identifier": "tts-local-control",
        "ipAddressWhiteList": [],
        "queryParamsDictionaryName": "request",
