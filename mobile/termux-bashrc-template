            ;;
        *)
            echo "_write_termux_props: unknown mode '$mode'" >&2
            return 1
            ;;
    esac
    echo "$mode" > "$HOME/.toolbar-mode"
    termux-reload-settings
    echo "Toolbar: $mode"
}

# toggle-toolbar: swap between portable-nav and portable-pager toolbars.
# Called by the ⇄ button in both portable toolbars.
toggle-toolbar() {
    local current
    current=$(cat "$HOME/.toolbar-mode" 2>/dev/null || echo "portable-nav")
    if [[ "$current" == "portable-nav" ]]; then
        _write_termux_props portable-pager
    else
        _write_termux_props portable-nav
    fi
}

# portable-monitor: manual override for is_portable_monitor detection.
# on: portable-nav toolbar (large keys) + reconnect to main session.
# off: mobile-nav toolbar (original keys) + reconnect to phone session.
# auto: clear overrides, restore auto-detection.
# Usage: portable-monitor on|off|auto
portable-monitor() {
    case "$1" in
        on)
            touch "$HOME/.portable_monitor"
            rm -f "$HOME/.no_portable_monitor"
            echo "Portable monitor: ON"
            _write_termux_props portable-nav
            # Sync state to Mac for TUI sliver (skip if called from Mac via SSH)
            [[ -z "$SSH_CONNECTION" ]] && ssh mini "echo on > ~/.portable_monitor_state" 2>/dev/null &
            ;;
        off)
            touch "$HOME/.no_portable_monitor"
            rm -f "$HOME/.portable_monitor"
            echo "Portable monitor: OFF"
            _write_termux_props mobile-nav
            # Sync state to Mac for TUI sliver (skip if called from Mac via SSH)
            [[ -z "$SSH_CONNECTION" ]] && ssh mini "echo off > ~/.portable_monitor_state" 2>/dev/null &
            ;;
        auto|"")
            rm -f "$HOME/.portable_monitor" "$HOME/.no_portable_monitor"
            echo "Portable monitor: AUTO ($(is_portable_monitor && echo detected || echo not detected))"
            return 0
            ;;
        *)
            echo "Usage: portable-monitor on|off|auto" >&2
            return 1
            ;;
    esac

    # If called remotely (e.g. Mac SSHing in to flip the flag), skip reconnect —
    # the caller is already in the right session and just wants the flag + toolbar updated.
    [[ -n "$SSH_CONNECTION" ]] && return 0

    # Reconnect to mac with updated mode.
    # In tx pane: respawn this pane with mac — kills current process, restarts clean.
    # Bare Termux: call mac() directly (full session selection path).
    if [[ -n "$TMUX" ]]; then
        tmux respawn-pane -k -t "$TMUX_PANE" "bash -ic mac"
    else
        echo "Reconnecting..."
        mac
    fi
}

# tx / t: local tmux with 2 vertically-split raw terminals. No SSH, no remote attach.
tx() {
    if tmux has-session -t local 2>/dev/null; then
        tmux attach -t local
        return
    fi

    tmux new-session -d -s local
    tmux split-window -v -t local:0
    tmux select-pane -t local:0.0
    tmux attach -t local
}
alias t=tx

# Mac attach state. Default is assertive: `mac` means "get me to the Mac tmux
# workspace", including from local tx panes and after dropped/reloaded sessions.
# `not-mac` disables the remembered preference for the next `mac` call. That
# call re-enables the default for future reconnects, but honors the one-shot
# opt-out by opening a plain Mac shell instead of attaching tmux.
MAC_INSIST_TMUX_FILE="$HOME/.mac-insist-tmux"
MAC_NOT_MAC_FILE="$HOME/.not-mac"
if [[ -f "$MAC_NOT_MAC_FILE" ]]; then
    export MAC_INSIST_TMUX=false
else
    export MAC_INSIST_TMUX="${MAC_INSIST_TMUX:-true}"
fi

_mac_insist_tmux_enabled() {
    [[ "${MAC_INSIST_TMUX:-true}" == "true" ]] && [[ ! -f "$MAC_NOT_MAC_FILE" ]]
}

_mac_set_insist_tmux() {
    export MAC_INSIST_TMUX=true
    rm -f "$MAC_NOT_MAC_FILE"
    : > "$MAC_INSIST_TMUX_FILE"
}

not-mac() {
    export MAC_INSIST_TMUX=false
    rm -f "$MAC_INSIST_TMUX_FILE"
    : > "$MAC_NOT_MAC_FILE"
    echo "Mac tmux auto-attach disabled for the next 'mac'. Run 'mac' to re-enable."
}

# _mac_reconnect_plan ATTEMPT BURST_MAX DEEP_DONE
# Pure decision helper for the sticky reconnect ladder — no sleeping, no ssh, so
# it is unit-testable in isolation (see tests/test_mac_reconnect_ladder.py).
# Given the current 1-based consecutive-failure ATTEMPT, the last attempt of the
# 1s aggressive burst (BURST_MAX), and whether the deeper restart already fired
# this outage (DEEP_DONE=0|1), it prints three space-separated tokens:
#     <next_delay_secs> <do_print:0|1> <do_deep_restart:0|1>
# Schedule:
#     attempt 1               -> 0 0 0   instant, silent re-tap
#     attempt 2               -> 1 1 0   1s wait, print the reconnect line once
#     attempts 3..BURST_MAX   -> 1 0 0   aggressive 1s burst continues
#     attempt BURST_MAX+1     -> 0 0 1   deeper restart (once), zero delay
#     thereafter              -> exponential backoff 2,4,8 capped at 8s
_mac_reconnect_plan() {
    local attempt="$1" burst_max="$2" deep_done="$3"
    local delay=0 do_print=0 do_deep=0
    if (( attempt <= 1 )); then
        delay=0
    elif (( attempt <= burst_max )); then
        delay=1
        (( attempt == 2 )) && do_print=1
    elif (( deep_done == 0 )); then
        delay=0
        do_deep=1
    else
        # Exponential backoff past the burst + deeper restart: 2, 4, 8, cap 8.
        local n=$(( attempt - burst_max - 1 ))   # 1, 2, 3, ...
        delay=$(( 1 << n ))
        (( delay > 8 )) && delay=8
    fi
    printf '%s %s %s\n' "$delay" "$do_print" "$do_deep"
}

# mac: SSH to Mac. Assertively attach tmux by default, even from tx panes.
# Portable monitor → main session (full workspace).
# Phone → grouped session 'phone' on main:warp with keyboard auto-zoom hook.
# SSH connects first; tmux is best-effort (fails gracefully to interactive shell).
mac() {
    local insist_tmux=true
    _mac_insist_tmux_enabled || insist_tmux=false

    # Running `mac` always restores the assertive default for future prompts.
    # If `not-mac` set a one-shot opt-out, honor it for this invocation only.
    _mac_set_insist_tmux

    if [[ "$insist_tmux" != "true" ]]; then
        ssh -t mac "exec zsh -il"
        return
    fi

    if [[ -n "$TMUX" ]]; then
        # Session selection even from tx pane — respects portable monitor flag.
        if is_portable_monitor; then
            ssh -t mac "zsh -il -c 'tmux attach -t main 2>/dev/null || exec zsh -il'"
        else
            ssh -t mac "$(_mac_phone_tmux_attach_cmd)"
        fi
        return
    fi

    local _mac_attach
    if is_portable_monitor; then
        _mac_attach="zsh -il -c 'tmux attach -t main 2>/dev/null || exec zsh -il'"
    else
        _mac_attach="$(_mac_phone_tmux_attach_cmd)"
    fi

    # Bare Termux: stay glued to the Mac tmux workspace. A dropped SSH (screen
    # lock, network blip, Wi-Fi↔LTE roam) lands back here and reconnects forever
    # instead of dumping to the local Termux shell. Two deliberate ways out:
    #   * Clean tmux detach (prefix + d → exit 0) — you meant to leave.
    #   * Ctrl-C while it's waiting to reconnect — aborts the loop to the shell.
    #
    # Retry ladder (see _mac_reconnect_plan for the schedule). The old loop
    # climbed an exponential backoff and *never* reset it: because a reconnect
    # was never registered at the wrapper, every drop after the first started
    # deep in the ladder and ate multi-second waits — torment mid-thought. The
    # rework:
    #   1. attempt 1 re-taps instantly and silently (most drops are momentary);
    #   2. attempt 2 waits 1s and prints once;
    #   3. attempts 3..6 keep hammering at 1s (the aggressive burst);
    #   4. after the burst, one "deeper restart" — the exact reset a fresh `mac`
    #      invocation does by hand (rebuild the attach env + a zero-delay ssh
    #      with a tight ConnectTimeout). This is why Ctrl-C then re-typing `mac`
    #      reconnects when the in-loop retry looks wedged: the fresh call resets
    #      the ladder and drops the stalled attempt; nothing in the old loop did;
    #   5. only then fall into exponential backoff (2→4→8s, capped) so a genuine
    #      long outage doesn't hammer SSH while still reconnecting forever.
    # Success is registered by timing each ssh: a session that lasted a real
    # interval connected and only now dropped, so the ladder resets to attempt 1.
    # Each attempt is bounded so a half-open / blackholed TCP can't wedge the
    # loop: ConnectTimeout caps the handshake, and ServerAlive* tears a silently
    # dead session down and returns non-zero → falls through to the ladder.
    local _mac_ssh_opts_relaxed=(-o ConnectTimeout=10 -o ServerAliveInterval=5 -o ServerAliveCountMax=3)
    local _mac_ssh_opts_tight=(-o ConnectTimeout=4 -o ServerAliveInterval=3 -o ServerAliveCountMax=2)
    local _mac_ssh_opts=("${_mac_ssh_opts_relaxed[@]}")
    local _burst_max=6       # attempts 1..6 = the 0s + five 1s aggressive burst
    local _connect_ok=15     # an ssh lasting >= this counts as a real attach
    local attempt=0 printed=false deep_done=false
    while true; do
        local _t0=$SECONDS
        ssh "${_mac_ssh_opts[@]}" -t mac "$_mac_attach"
        local exit_code=$?
        local _elapsed=$(( SECONDS - _t0 ))

        # Exit code 0 = clean detach / clean remote logout. You asked to leave.
        [[ $exit_code -eq 0 ]] && break

        # A session that lasted a real interval connected successfully and only
        # now dropped. Register that success the old wrapper never did: reset the
        # whole ladder so this drop is treated as attempt 1 (instant, silent),
        # not a continuation of a stale backoff. (Connect *failures* return well
        # under _connect_ok, so they don't trip this.)
        if (( _elapsed >= _connect_ok )); then
            attempt=0; printed=false; deep_done=false
            _mac_ssh_opts=("${_mac_ssh_opts_relaxed[@]}")
        fi

        ((attempt++))
        local _plan _delay _do_print _do_deep
        _plan=$(_mac_reconnect_plan "$attempt" "$_burst_max" "$([[ $deep_done == true ]] && echo 1 || echo 0)")
        read -r _delay _do_print _do_deep <<< "$_plan"

        if (( _do_print )) && [[ "$printed" != true ]]; then
            echo "Connection dropped — reconnecting (Ctrl-C to stop)..."
            printed=true
        fi

        if (( _do_deep )); then
            # Deeper restart: replicate a fresh `mac` invocation without dropping
            # the wrapper — rebuild the attach env, tighten the ssh handshake so
            # a wedged/blackholed socket is abandoned in ~4s, retry immediately.
            echo "  ...deeper restart (fresh attach)..."
            _mac_set_insist_tmux
            if is_portable_monitor; then
                _mac_attach="zsh -il -c 'tmux attach -t main 2>/dev/null || exec zsh -il'"
            else
                _mac_attach="$(_mac_phone_tmux_attach_cmd)"
            fi
            _mac_ssh_opts=("${_mac_ssh_opts_tight[@]}")
            deep_done=true
        fi

        (( _delay > 0 )) && sleep "$_delay"
    done
}

# wsl: SSH to WSL. From tx panes → plain SSH. Standalone → SSH then attach tmux.
# Portable monitor → main session (full workspace).
# Phone → grouped session 'phone' on main:warp with keyboard auto-zoom hook.
# SSH connects first; tmux is best-effort (fails gracefully to interactive shell).
wsl() {
    if [[ -n "$TMUX" ]]; then
        ssh wsl
    elif is_portable_monitor; then
        ssh -t wsl "bash -ic 'tmux attach -t main 2>/dev/null || exec bash -il'"
    else
        ssh -t wsl "tmux attach -t phone 2>/dev/null || tmux new-session -t main -s phone \\; select-window -t warp 2>/dev/null || exec bash -il"
    fi
}

