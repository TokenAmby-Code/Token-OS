# ~/.bashrc for Termux (phone)
# Minimal quality-of-life setup + token-api integration

# ====================================================
# ENVIRONMENT CONFIGURATION
# ====================================================
# Mac Mini IP for Token-API HTTP endpoints
MINI_IP="100.95.109.23"

# Source local .env file for optional overrides
# Store secrets here (e.g. CLAUDE_CODE_OAUTH_TOKEN from `claude setup-token`)
if [[ -f "$HOME/.env" ]]; then
    set -a
    source "$HOME/.env"
    set +a
fi

# ====================================================
# STANDARDIZED SSH (via SSH config + redirect-on-exit)
# ====================================================
# SSH config (~/.ssh/config) defines: desktop, wsl, mac, mini, phone
# All use key-based authentication with id_ed25519
#
# When SSH'd into a host and you run ssh-wsl (for example), instead of
# nesting (phone→mac→wsl), this redirects: closes the mac session and
# connects directly from phone to wsl. Use --proxy to nest intentionally.

_ssh_target_to_host() {
    case "$1" in
        mac)   echo "mini" ;;
        wsl)   echo "wsl" ;;
        phone) echo "phone" ;;
        *)     echo "" ;;
    esac
}

_ssh_ip_to_host() {
    case "$1" in
        100.95.109.23)  echo "mini" ;;
        100.69.198.87)  echo "desktop" ;;
        100.66.10.74)   echo "wsl" ;;
        100.102.92.24)  echo "phone" ;;
        *)              echo "" ;;
    esac
}

ssh-connect() {
    local TARGET="$1"; shift
    local PROXY=false
    [[ "$1" == "--proxy" ]] && { PROXY=true; shift; }

    local HOST=$(_ssh_target_to_host "$TARGET")
    if [[ -z "$HOST" ]]; then
        echo "Unknown target: $TARGET (expected mac, wsl, or phone)"
        return 1
    fi

    # Redirect-on-exit: if in SSH session and not --proxy
    if [[ -n "$SSH_CONNECTION" ]] && ! $PROXY; then
        local origin_ip="${SSH_CLIENT%% *}"
        local origin_host=$(_ssh_ip_to_host "$origin_ip")
        if [[ -n "$origin_host" ]]; then
            echo "Redirecting: closing this session → connecting to $TARGET from origin..."
            if ssh -o ConnectTimeout=3 -o BatchMode=yes "$origin_host" \
                "echo $TARGET > \$HOME/.ssh-next" 2>/dev/null; then
                # Kill parent shell to close SSH session automatically
                kill -HUP $PPID 2>/dev/null
                exit 0
            fi
            echo "Reverse SSH to origin failed, falling back to direct connection..."
        fi
        exec ssh "$HOST" "$@"
    fi

    # Direct connection with redirect loop
    while true; do
        if [[ $# -gt 0 ]]; then
            ssh "$HOST" -t "$*"
            break
        else
            ssh "$HOST"
        fi
        if [[ -f ~/.ssh-next ]]; then
            local next=$(cat ~/.ssh-next)
            rm -f ~/.ssh-next
            HOST=$(_ssh_target_to_host "$next")
            TARGET="$next"
            if [[ -z "$HOST" ]]; then
                echo "Invalid redirect target: $next"
                break
            fi
            echo "Redirecting to $TARGET..."
        else
            break
        fi
    done
}

ssh-mac() { ssh-connect mac "$@"; }
ssh-wsl() { ssh-connect wsl "$@"; }

# Backwards-compatible aliases
alias sshpc="ssh-wsl"
alias sshmac="ssh-mac"
alias sshmini="ssh-mac"

# Pull configs from NAS (reverse path via Mac — inefficient but reliable backup)
fetch-mobile() { ssh -t mac "push-mobile -b"; }
alias fetch-bashrc="fetch-mobile"


# ====================================================
# On Termux shell exit/app close, ask the Mac tmux server to drop only this
# shell's phone client. Reopen uses the normal sticky mac() auto-reconnect path below.
TERMUX_MAC_TMUX_CLIENT_TAG="${TERMUX_MAC_TMUX_CLIENT_TAG:-termux-${USER:-phone}-$$}"
TERMUX_MAC_TMUX_CLIENT_TAG="${TERMUX_MAC_TMUX_CLIENT_TAG//[^A-Za-z0-9_.-]/_}"

_termux_detach_mac_tmux_client() {
    [[ -n "${TERMUX_SKIP_TMUX_DETACH:-}" ]] && return 0
    ssh -o BatchMode=yes -o ConnectTimeout=2 mac "client=\$(cat ~/.termux-mac-tmux-client-${TERMUX_MAC_TMUX_CLIENT_TAG} 2>/dev/null || true); rm -f ~/.termux-mac-tmux-client-${TERMUX_MAC_TMUX_CLIENT_TAG}; [[ -n \"\$client\" ]] && tmux detach-client -t \"\$client\" 2>/dev/null || true" >/dev/null 2>&1 &
}
trap _termux_detach_mac_tmux_client EXIT

_mac_phone_tmux_attach_cmd() {
    printf '%s\n' \
        "tag='${TERMUX_MAC_TMUX_CLIENT_TAG}'" \
        'file="$HOME/.termux-mac-tmux-client-$tag"' \
        'tty > "$file" 2>/dev/null || true' \
        'trap '\''rm -f "$file"'\'' EXIT' \
        'tmux attach -t phone 2>/dev/null || tmux new-session -t main -s phone \; select-window -t warp 2>/dev/null || exec zsh -il'
}

# TMUX — local session + remote attach
# ====================================================
# is_portable_monitor: true when terminal is wide enough to be an external display.
# Threshold 150 cols: phone portrait ~80, landscape ~130, portable monitor 200+.
# tput cols queries the terminal directly — avoids stale COLUMNS at launch time.
# Manual override: ~/.portable_monitor forces on; ~/.no_portable_monitor forces off.
is_portable_monitor() {
    [[ -f "$HOME/.portable_monitor" ]] && return 0
    [[ -f "$HOME/.no_portable_monitor" ]] && return 1
    local cols
    cols=$(tput cols 2>/dev/null) || cols=${COLUMNS:-0}
    [[ "$cols" -gt 150 ]]
}

# _write_termux_props MODE — write a complete termux.properties and reload settings.
# Modes: mobile-nav (true mobile, small keys), portable-nav (monitor, large keys),
#        portable-pager (monitor, window-number keys + nav, large keys).
# The swap button in portable toolbars uses ^U + command so it fires cleanly at a prompt.
_write_termux_props() {
    local mode="$1"
    local f="$HOME/.termux/termux.properties"
    case "$mode" in
        mobile-nav)
            cat > "$f" << 'PROPS'
# ~/.termux/termux.properties — mobile-nav toolbar (true mobile, 3 rows, key-height:40)
extra-keys = [ \
  [{key: 'DRAWER', popup: {macro: "\u00001", display: '1'}}, {macro: "\u001b[Z", display: '⇧Tab', popup: {macro: "\u00002", display: '2'}}, {macro: "\u0012", display: '^R', popup: {macro: "\u00003", display: '3'}}, {macro: "\u0003", display: '^C', popup: {macro: "\u00004", display: '4'}}, {key: 'TAB', popup: {macro: "\u0000e", display: 'e'}}, {macro: "\u0000", display: '^␣', popup: {macro: "\u0000T", display: '⇄'}}, {key: 'KEYBOARD', display: '⌨', popup: 'ENTER'}], \
  ['ESC', 'SHIFT', 'ALT', {key: 'CTRL', popup: 'PASTE'}, {key: 'HOME', popup: {macro: "\u0000y", display: '📋'}}, {key: 'UP', popup: {macro: "claude\n", display: 'claude↩'}}, {key: 'END', popup: 'PASTE'}], \
  [{key: '|', popup: ':'}, {key: '~', popup: '&&'}, {key: '/', popup: '\\\\'}, {key: '-', popup: '_'}, 'LEFT', {key: 'DOWN', popup: {macro: "exit\n", display: 'exit↩'}}, 'RIGHT'] \
