# ~/.bashrc for Termux (phone)
# Minimal quality-of-life setup + token-api integration

# ====================================================
# ENVIRONMENT CONFIGURATION
# ====================================================
# Source local .env file for optional overrides
# Store secrets here (e.g. CLAUDE_CODE_OAUTH_TOKEN from `claude setup-token`)
if [[ -f "$HOME/.env" ]]; then
    set -a
    source "$HOME/.env"
    set +a
fi

# ====================================================
# K12 ATTACH
# ====================================================
# `tx` is explicit: new Termux sessions remain local until it is invoked.
# Set K12_SSH_HOST in ~/.env to override the SSH-config host (default: k12-personal).
K12_SSH_HOST="${K12_SSH_HOST:-k12-personal}"
TX_RECONNECT_FILE="${TX_RECONNECT_FILE:-$HOME/.tx-reconnect-enabled}"
TX_RECONNECT_FIFO="${TX_RECONNECT_FIFO:-$HOME/.tx-reconnect-wake}"
TX_ATTACH_LOCK="${TX_ATTACH_LOCK:-$HOME/.tx-attach.lock}"

_tx_reconnect_enabled() { [[ "$(cat "$TX_RECONNECT_FILE" 2>/dev/null || printf false)" == true ]]; }
_tx_wait_for_reconnect_enabled() {
    while ! _tx_reconnect_enabled; do
        rm -f "$TX_RECONNECT_FIFO"; mkfifo "$TX_RECONNECT_FIFO"
        printf 'K12 reconnect paused; waiting for Termux or DeX activity...\n'
        IFS= read -r _ < "$TX_RECONNECT_FIFO" || true
    done
}
_tx_release_lock() {
    [[ -f "$TX_ATTACH_LOCK/pid" && "$(cat "$TX_ATTACH_LOCK/pid" 2>/dev/null)" == "$$" ]] && rm -rf "$TX_ATTACH_LOCK"
}
_tx_acquire_lock() {
    if mkdir "$TX_ATTACH_LOCK" 2>/dev/null; then printf '%s\n' "$$" > "$TX_ATTACH_LOCK/pid"; return 0; fi
    local owner; owner=$(cat "$TX_ATTACH_LOCK/pid" 2>/dev/null || true)
    if [[ "$owner" =~ ^[0-9]+$ ]] && kill -0 "$owner" 2>/dev/null; then
        printf 'tx is already attached (owner PID %s); this shell remains local.\n' "$owner" >&2; return 1
    fi
    rm -rf "$TX_ATTACH_LOCK"; mkdir "$TX_ATTACH_LOCK" && printf '%s\n' "$$" > "$TX_ATTACH_LOCK/pid"
}
tx() {
    _tx_acquire_lock || return 1
    trap '_tx_release_lock; trap - EXIT INT TERM HUP; return 130' INT TERM HUP
    trap '_tx_release_lock' EXIT
    local exit_code=0
    while true; do
        _tx_wait_for_reconnect_enabled
        ssh -o ConnectTimeout=10 -o ServerAliveInterval=5 -o ServerAliveCountMax=3 -t "$K12_SSH_HOST"
        exit_code=$?; [[ $exit_code -eq 0 ]] && break
        _tx_reconnect_enabled || continue
        printf 'K12 connection dropped; reconnecting... (Ctrl-C to stop)\n'; sleep 1
    done
    trap - EXIT INT TERM HUP; _tx_release_lock; return "$exit_code"
}
alias t=tx

# Exactly one interactive shell per Termux app launch becomes the attach owner.
# If MacroDroid reaches the lifecycle script after this shell starts, it wakes the
# owner through the reconnect FIFO; New Session shells see the owner lock and stay local.
TX_FIRST_SHELL_LOCK="${TX_FIRST_SHELL_LOCK:-$HOME/.tx-first-shell.lock}"
_tx_autostart_first_shell() {
    [[ $- == *i* && -z "${SSH_CONNECTION:-}" && -z "${TMUX:-}" ]] || return 0
    mkdir "$TX_FIRST_SHELL_LOCK" 2>/dev/null || return 0
    printf '%s\n' "$$" > "$TX_FIRST_SHELL_LOCK/pid"
    _tx_wait_for_reconnect_enabled
    tx
}

# ====================================================
# TMUX — local session + remote attach
# ====================================================
# is_portable_monitor: true when terminal is wide enough to be an external display.
# Threshold 150 cols: phone portrait ~80, landscape ~130, portable monitor 200+.
# tput cols queries the terminal directly — avoids stale COLUMNS at launch time.
# Manual override: ~/.portable_monitor forces on; ~/.no_portable_monitor forces off.
is_portable_monitor() {
    [[ -f "$HOME/.portable_monitor" ]] && return 0
    [[ -f "$HOME/.no_portable_monitor" ]] && return 1
    local cols
    cols=$(tput cols 2>/dev/null) || cols=${COLUMNS:-0}
    [[ "$cols" -gt 150 ]]
}

# _write_termux_props MODE — write a complete termux.properties and reload settings.
# Modes: mobile-nav (true mobile, small keys), portable-nav (monitor, large keys),
#        portable-pager (monitor, window-number keys + nav, large keys).
# The swap button in portable toolbars uses ^U + command so it fires cleanly at a prompt.
_write_termux_props() {
    local mode="$1"
    local f="$HOME/.termux/termux.properties"
    case "$mode" in
        mobile-nav)
            cat > "$f" << 'PROPS'
# ~/.termux/termux.properties — mobile-nav toolbar (true mobile, 3 rows, key-height:40)
extra-keys = [ \
  [{key: 'DRAWER', popup: {macro: "\u00001", display: '1'}}, {macro: "\u001b[Z", display: '⇧Tab', popup: {macro: "\u00002", display: '2'}}, {macro: "\u0012", display: '^R', popup: {macro: "\u00003", display: '3'}}, {macro: "\u0003", display: '^C', popup: {macro: "\u00004", display: '4'}}, {key: 'TAB', popup: {macro: "\u0000e", display: 'e'}}, {macro: "\u0000", display: '^␣', popup: {macro: "\u0000T", display: '⇄'}}, {key: 'KEYBOARD', display: '⌨', popup: 'ENTER'}], \
  ['ESC', 'SHIFT', 'ALT', {key: 'CTRL', popup: 'PASTE'}, {key: 'HOME', popup: {macro: "\u0000y", display: '📋'}}, {key: 'UP', popup: {macro: "claude\n", display: 'claude↩'}}, {key: 'END', popup: 'PASTE'}], \
  [{key: '|', popup: ':'}, {key: '~', popup: '&&'}, {key: '/', popup: '\\\\'}, {key: '-', popup: '_'}, 'LEFT', {key: 'DOWN', popup: {macro: "exit\n", display: 'exit↩'}}, 'RIGHT'] \
]
extra-keys-style = key-height:40,key-gap:0,key-border:0
terminal-transcript-rows = 10000
enforce-char-based-input = true
volume-keys = volume
PROPS
            ;;
        portable-nav)
            cat > "$f" << 'PROPS'
# ~/.termux/termux.properties — portable-nav toolbar (portable monitor, 2 rows, large keys)
# ⇄ swaps to portable-pager toolbar (window numbers + nav keys)
# 2 rows (vs 3 on mobile) with tall keys + visible borders = unmistakable difference
extra-keys = [ \
  [{macro: "\u0000T", display: '⇄'}, {key: 'ESC', popup: {macro: "\u00001", display: '1'}}, {key: 'CTRL', popup: {macro: "\u00002", display: '2'}}, {key: 'ALT', popup: {macro: "\u00003", display: '3'}}, {macro: "\u0012", display: '^R', popup: {macro: "\u00004", display: '4'}}, {macro: "\u0003", display: '^C'}, 'TAB', {macro: "\u0000", display: '^␣', popup: {macro: "\u0000T", display: '⇄'}}, {key: 'KEYBOARD', display: '⌨', popup: 'ENTER'}], \
  [{key: '|', popup: ':'}, {key: '~', popup: '&&'}, {key: '/', popup: '\\\\'}, {key: '-', popup: '_'}, 'LEFT', {key: 'UP', popup: {macro: "claude\n", display: 'claude↩'}}, {key: 'DOWN', popup: {macro: "exit\n", display: 'exit↩'}}, 'RIGHT', {key: 'END', popup: 'PASTE'}] \
]
extra-keys-style = key-height:90,key-gap:4,key-border:1
terminal-transcript-rows = 10000
enforce-char-based-input = true
volume-keys = volume
PROPS
            ;;
        portable-pager)
            cat > "$f" << 'PROPS'
# ~/.termux/termux.properties — portable-pager toolbar (window numbers + nav, large keys)
# Row 1: tmux windows 1-5, ⇄ swaps back to portable-nav
# Row 2: prev/next window, detach, zoom, rename, kill-pane, ESC
# All tmux keys use prefix (\u0000 = ^Space)
extra-keys = [ \
  [{macro: "\u00001", display: '1'}, {macro: "\u00002", display: '2'}, {macro: "\u00003", display: '3'}, {macro: "\u00004", display: '4'}, {macro: "\u00005", display: '5'}, {macro: "\u0000T", display: '⇄'}, {key: 'KEYBOARD', display: '⌨', popup: 'ENTER'}], \
  [{macro: "\u0000p", display: '←prev'}, {macro: "\u0000n", display: '→next'}, {macro: "\u0000d", display: 'detach'}, {macro: "\u0000e", display: 'expand'}, {macro: "\u0000,", display: 'rename'}, {macro: "\u0000x", display: 'kill'}, 'ESC'] \
]
extra-keys-style = key-height:90,key-gap:4,key-border:1
terminal-transcript-rows = 10000
enforce-char-based-input = true
volume-keys = volume
PROPS
            ;;
        *)
            echo "_write_termux_props: unknown mode '$mode'" >&2
            return 1
            ;;
    esac
    echo "$mode" > "$HOME/.toolbar-mode"
    termux-reload-settings
    echo "Toolbar: $mode"
}

# toggle-toolbar: swap between portable-nav and portable-pager toolbars.
# Called by the ⇄ button in both portable toolbars.
toggle-toolbar() {
    local current
    current=$(cat "$HOME/.toolbar-mode" 2>/dev/null || echo "portable-nav")
    if [[ "$current" == "portable-nav" ]]; then
        _write_termux_props portable-pager
    else
        _write_termux_props portable-nav
    fi
}

# portable-monitor: manual override for is_portable_monitor detection.
# on: portable-nav toolbar (large keys) + reconnect to main session.
# off: mobile-nav toolbar (original keys) + reconnect to phone session.
# auto: clear overrides, restore auto-detection.
# Usage: portable-monitor on|off|auto
portable-monitor() {
    case "$1" in
        on)
            touch "$HOME/.portable_monitor"
            rm -f "$HOME/.no_portable_monitor"
            echo "Portable monitor: ON"
            _write_termux_props portable-nav
            ;;
        off)
            touch "$HOME/.no_portable_monitor"
            rm -f "$HOME/.portable_monitor"
            echo "Portable monitor: OFF"
            _write_termux_props mobile-nav
            ;;
        auto|"")
            rm -f "$HOME/.portable_monitor" "$HOME/.no_portable_monitor"
            echo "Portable monitor: AUTO ($(is_portable_monitor && echo detected || echo not detected))"
            return 0
            ;;
        *)
            echo "Usage: portable-monitor on|off|auto" >&2
            return 1
            ;;
    esac

    # Profile selection is local; it never starts or redirects an SSH session.

}

# wsl: SSH to WSL. From tx panes → plain SSH. Standalone → SSH then attach tmux.
# Portable monitor → main session (full workspace).
# Phone → grouped session 'phone' on main:warp with keyboard auto-zoom hook.
# SSH connects first; tmux is best-effort (fails gracefully to interactive shell).
wsl() {
    if [[ -n "$TMUX" ]]; then
        ssh wsl
    elif is_portable_monitor; then
        ssh -t wsl "bash -ic 'tmux attach -t main 2>/dev/null || exec bash -il'"
    else
        ssh -t wsl "tmux attach -t phone 2>/dev/null || tmux new-session -t main -s phone \\; select-window -t warp 2>/dev/null || exec bash -il"
    fi
}

