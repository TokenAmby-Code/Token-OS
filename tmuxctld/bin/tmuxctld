#!/usr/bin/env bash
# tmuxctld — entrypoint for the standalone HTTP-loopback tmux control-plane daemon.
#
# Interpreter probe + PYTHONPATH=tmuxctld/lib:cli-tools/lib for the root tmuxctld home.
# This script is the SINGLE SOURCE OF TRUTH
# for the interpreter the launchd plist invokes (the plist ProgramArguments point
# at this file in the runtime checkout). Stdlib only — no venv.
set -euo pipefail
_BIN_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
_REPO_ROOT="${TOKEN_OS:-$(cd "${_BIN_DIR}/../.." && pwd)}"
_LIB_DIR="${TMUXCTLD_LIB:-${_REPO_ROOT}/tmuxctld/lib}"
_CLI_LIB_DIR="${_REPO_ROOT}/cli-tools/lib"

tmuxctl_python() {
    local candidate
    for candidate in python3.14 python3.13 python3.12 python3.11 python3; do
        if command -v "$candidate" >/dev/null 2>&1 && "$candidate" -c 'from datetime import UTC' >/dev/null 2>&1; then
            command -v "$candidate"
            return 0
        fi
    done
    echo "tmuxctld requires Python 3.11+" >&2
    return 1
}

PYTHONPATH="${_LIB_DIR}:${_CLI_LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" exec "$(tmuxctl_python)" -m tmuxctl.daemon "$@"
