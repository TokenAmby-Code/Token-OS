# Regression hook: Imperial Guard voice routing should target selected tmux pane and give audible error on failure.
python3 -c "import os,pathlib; root=pathlib.Path(os.environ.get('TOKEN_OS','/Volumes/Imperium/Token-OS')); s=(root/'token-api/main.py').read_text(); assert 'async def _resolve_selected_tmux_pane' in s; assert 'tmux-dictate' in s; assert 'Voice [imperial_guard] active-pane injection failed' in s; assert 'Voice not received. No active tmux pane could be targeted.' in s; print('imperial_guard routing fallback and audible error path present')" | output confirms imperial_guard routing fallback and audible error path present
