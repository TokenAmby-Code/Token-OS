# Regression hook: Imperial Guard voice routing should target selected tmux pane and give audible error on failure.
python3 -c "import os,pathlib; root=pathlib.Path(os.environ.get('TOKEN_OS','/Volumes/Imperium/Token-OS')); main=(root/'token-api/main.py').read_text(); daemon=(root/'discord-daemon/daemon.js').read_text(); voice=(root/'discord-daemon/voice.js').read_text(); assert 'transcriber.handleAudioFrame?.(userId, pcmChunk, botName, meta)' in daemon; assert 'tmuxExecOptions' in voice and 'const { TMUX, ...env } = process.env' in voice; assert 'resolveFallbackTmuxPane' in voice and \"sessionName === 'discord-daemon'\" in voice; assert 'Voice: falling back to active' in voice; assert 'config.voice_auto_leave_grace_ms ?? 5000' in voice; assert \"'-c',\" in voice and 'client.clientName' in voice; assert 'Voice [imperial_guard] active-pane injection failed' in main; assert 'Voice not received. No active tmux pane could be targeted.' in main; print('imperial_guard routing metadata, tmux-context isolation, fallback targeting, auto-leave grace, and audible error paths present')" | output confirms imperial_guard routing metadata, tmux-context isolation, fallback targeting, auto-leave grace, and audible error paths present
