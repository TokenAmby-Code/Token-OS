#!/usr/bin/env bash
# tmux-legion-prompt — Capture a prompt, open a fresh legion pane, and launch via d
# TAGS: tmux, legion, launcher, prompt
# AUDIENCE: human

set -euo pipefail

SESSION="${TMUX_LEGION_PROMPT_SESSION:-main}"
WINDOW="${TMUX_LEGION_PROMPT_WINDOW:-legion}"

log() { printf '%s\n' "$*" >&2; }

usage() {
    cat <<'USAGE'
Usage:
  tmux-legion-prompt
  tmux-legion-prompt --prompt "text"
  tmux-legion-prompt --prompt-file /path/to/prompt
  tmux-legion-prompt --stdin
  tmux-legion-prompt --dry-run --prompt "text"

Captures prompt text, creates a new managed main:legion shell, then sends:
  cd ~ && d "text"
USAGE
}

PROMPT_TEXT=""
PROMPT_FILE=""
DRY_RUN=false
READ_STDIN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --prompt)
            PROMPT_TEXT="${2:-}"
            shift 2
            ;;
        --prompt-file)
            PROMPT_FILE="${2:-}"
            shift 2
            ;;
        --stdin)
            READ_STDIN=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            log "Unknown option: $1"
            usage
            exit 1
            ;;
    esac
done

if [[ -n "$PROMPT_FILE" ]]; then
    if [[ ! -f "$PROMPT_FILE" ]]; then
        log "Prompt file not found: $PROMPT_FILE"
        exit 1
    fi
    PROMPT_TEXT="$(cat "$PROMPT_FILE")"
elif [[ "$READ_STDIN" == true ]]; then
    PROMPT_TEXT="$(cat)"
elif [[ -z "$PROMPT_TEXT" ]]; then
    # Fallback for direct script use. The tmux keybinding uses command-prompt so
    # Enter submits without the popup newline/delay artifact.
    printf 'dispatch> ' > /dev/tty
    IFS= read -r PROMPT_TEXT < /dev/tty || exit 130
fi

if ! printf '%s\n' "$PROMPT_TEXT" | grep -vE '^[[:space:]]*$' >/dev/null; then
    log "No prompt entered; cancelled."
    exit 130
fi

if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    log "tmux session not found: $SESSION"
    exit 1
fi

if ! tmux list-windows -t "$SESSION" -F '#{window_name}' 2>/dev/null | grep -qE "^${WINDOW}(\([0-9]*\))?$"; then
    tmux new-window -t "$SESSION" -n "$WINDOW" -d -c "$HOME"
fi

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="${SCRIPT_DIR}/../lib"

printf -v PROMPT_Q '%q' "$PROMPT_TEXT"
DISPATCH_BIN="${SCRIPT_DIR}/dispatch"
# Use the dispatch binary directly. A fresh managed pane may not have the `d`
# shell function loaded yet; TOKEN_API_DISPATCH_ORIGIN=d preserves human-surface
# behavior, including the fzf selector/aspirant policy.
LAUNCH_CMD="cd ~ && TOKEN_API_DISPATCH_ORIGIN=d ${DISPATCH_BIN} --prompt ${PROMPT_Q}"

if $DRY_RUN; then
    log "DRY RUN"
    log "session: $SESSION"
    log "window:  $WINDOW"
    log "command: $LAUNCH_CMD"
    log "layout:  tmuxctl stack dispatch legion"
    exit 0
fi

PANE_ID="$(
    PYTHONPATH="${LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" \
        python3 -m tmuxctl.cli stack dispatch legion \
            --session "$SESSION" \
            --cwd "$HOME" \
            --command "$LAUNCH_CMD"
)"
tmux display-message "Legion dispatch prompt launched in ${PANE_ID}"
