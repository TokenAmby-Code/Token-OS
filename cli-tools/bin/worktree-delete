#!/usr/bin/env bash
# Worktree Delete - remove git worktrees and clean up associated resources
# TAGS: git, worktree, nas
# AUDIENCE: human, agent
#
# Usage: worktree-delete <branch-name> [options]
#
# Removes the worktree directory, prunes git worktree references,
# optionally deletes the branch, and cleans up the cd quick alias.
# Works with NAS-hosted bare repos via project config.
#
# Config: ~/.config/worktrees/<project>.conf
#
# Examples:
#   worktree-delete feature-auth          # Remove worktree, keep branch
#   worktree-delete feature-auth -b       # Remove worktree AND delete branch
#   worktree-delete feature-auth --project Scripts
#   worktree-delete feature-auth --dry-run

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Defaults
DRY_RUN=false
DELETE_BRANCH=false
PROJECT="askCivic"

usage() {
    cat << 'EOF'
Worktree Delete - remove git worktrees and clean up associated resources

Usage: worktree-delete <branch-name> [options]

Arguments:
  branch-name         Branch/worktree to remove

Options:
  -b, --delete-branch  Also delete the local branch
  -p, --project NAME   Project config to use (default: askCivic)
  -n, --dry-run        Show what would happen without making changes
  -h, --help           Show this help message

Cleanup performed:
  - Kills any Claude session running from the worktree (ghost prevention)
  - Removes the worktree directory
  - Prunes git worktree references
  - Removes the cd quick alias (~/.cd_quick_aliases)
  - Optionally deletes the local branch (-b)

Examples:
  worktree-delete feature-auth              # Remove worktree, keep branch
  worktree-delete feature-auth -b           # Also delete the branch
  worktree-delete feature-auth --project Scripts
  worktree-delete feature-auth --dry-run
EOF
    exit 0
}

log_info() { echo -e "${BLUE}→${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}!${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }

load_config() {
    local project="${1:-askCivic}"
    local config="$HOME/.config/worktrees/${project}.conf"
    if [[ ! -f "$config" ]]; then
        log_error "Project config not found: $config"
        echo "  Create it with: worktree-setup --init $project"
        exit 1
    fi
    # shellcheck disable=SC1090
    source "$config"
    for var in BARE_REPO WORKTREE_PARENT SECRETS_DIR; do
        if [[ -z "${!var:-}" ]]; then
            log_error "$var not set in $config"
            exit 1
        fi
    done
    # NAS mount check
    if [[ ! -d "$BARE_REPO" ]]; then
        log_error "Bare repo not found: $BARE_REPO (is NAS mounted?)"
        exit 1
    fi
    if [[ "$(git --git-dir="$BARE_REPO" rev-parse --is-bare-repository 2>/dev/null)" != "true" ]]; then
        log_error "$BARE_REPO is not a bare git repository"
        exit 1
    fi
    mkdir -p "$WORKTREE_PARENT"
}

# Parse arguments
BRANCH_NAME=""
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help) usage ;;
        -n|--dry-run) DRY_RUN=true; shift ;;
        -b|--delete-branch) DELETE_BRANCH=true; shift ;;
        -p|--project)
            if [[ $# -lt 2 ]]; then
                log_error "--project requires a name"
                exit 1
            fi
            PROJECT="$2"
            shift 2
            ;;
        -*)
            log_error "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
        *)
            if [[ -z "$BRANCH_NAME" ]]; then
                BRANCH_NAME="$1"
            else
                log_error "Too many arguments"
                exit 1
            fi
            shift
            ;;
    esac
done

if [[ -z "$BRANCH_NAME" ]]; then
    log_error "Branch name required"
    echo "Usage: worktree-delete <branch-name> [options]"
    exit 1
fi

# Load project config (validates NAS mounts, bare repo, etc.)
load_config "$PROJECT"

WORKTREE_DIR="$WORKTREE_PARENT/wt-$BRANCH_NAME"

# Verify worktree exists
if [[ ! -d "$WORKTREE_DIR" ]]; then
    # Still try to clean up alias and prune
    log_warn "Worktree directory not found: $WORKTREE_DIR"
    log_info "Will still clean up alias and prune references..."
fi

CD_QUICK_ALIASES_FILE="$HOME/.cd_quick_aliases"
HAS_ALIAS=false
if grep -q "^${BRANCH_NAME}=" "$CD_QUICK_ALIASES_FILE" 2>/dev/null; then
    HAS_ALIAS=true
fi

# Show plan
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo " Worktree Delete Plan"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "  Project:       $PROJECT"
echo "  Bare repo:     $BARE_REPO"
echo "  Branch:        $BRANCH_NAME"
echo "  Worktree:      $WORKTREE_DIR"
echo "  Delete branch: $(if $DELETE_BRANCH; then echo "yes"; else echo "no"; fi)"
echo "  CD alias:      $(if $HAS_ALIAS; then echo "will remove"; else echo "none found"; fi)"
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo ""

if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "Dry run - no changes made"
    exit 0
fi

# Kill any Claude session running from the worktree (ghost prevention)
if [[ -d "$WORKTREE_DIR" ]]; then
    GHOST_PID=""
    for entry in /proc/[0-9]*; do
        pid=$(basename "$entry")
        comm=$(cat "/proc/$pid/comm" 2>/dev/null) || continue
        [[ "$comm" == "claude" ]] || continue
        cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null) || continue
        if [[ "${cwd%/}" == "${WORKTREE_DIR%/}" ]]; then
            GHOST_PID="$pid"
            break
        fi
    done

    if [[ -n "$GHOST_PID" ]]; then
        log_warn "Claude session running from worktree (PID $GHOST_PID)"
        log_info "Sending SIGINT to gracefully stop..."
        kill -INT "$GHOST_PID" 2>/dev/null || true
        sleep 1
        if kill -0 "$GHOST_PID" 2>/dev/null; then
            kill -INT "$GHOST_PID" 2>/dev/null || true
            sleep 2
        fi
        if kill -0 "$GHOST_PID" 2>/dev/null; then
            log_warn "Force killing PID $GHOST_PID"
            kill -KILL "$GHOST_PID" 2>/dev/null || true
        fi
        log_success "Claude session terminated"
        # Clean up session PID cache
        rm -f "${HOME}/.claude/session-pids/${GHOST_PID}" 2>/dev/null || true
    fi
fi

# Remove worktree
if [[ -d "$WORKTREE_DIR" ]]; then
    log_info "Removing worktree..."
    git --git-dir="$BARE_REPO" worktree remove "$WORKTREE_DIR" --force
    log_success "Worktree removed: $WORKTREE_DIR"
else
    log_info "Pruning stale worktree references..."
    git --git-dir="$BARE_REPO" worktree prune
    log_success "Pruned worktree references"
fi

# Delete branch if requested
if [[ "$DELETE_BRANCH" == "true" ]]; then
    if git --git-dir="$BARE_REPO" branch --list "$BRANCH_NAME" | grep -q .; then
        log_info "Deleting local branch..."
        git --git-dir="$BARE_REPO" branch -D "$BRANCH_NAME"
        log_success "Branch deleted: $BRANCH_NAME"
    else
        log_warn "Branch '$BRANCH_NAME' not found locally (may already be deleted)"
    fi
fi

# Remove cd quick alias
if $HAS_ALIAS; then
    log_info "Removing cd alias..."
    sed -i '' "/^${BRANCH_NAME}=/d" "$CD_QUICK_ALIASES_FILE" 2>/dev/null || \
    sed -i "/^${BRANCH_NAME}=/d" "$CD_QUICK_ALIASES_FILE"
    log_success "CD alias removed: $BRANCH_NAME"
fi

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo -e " ${GREEN}Worktree cleaned up!${NC}"
echo "═══════════════════════════════════════════════════════════════"
echo ""
