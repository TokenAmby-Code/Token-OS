#!/usr/bin/env bash
# Worktree Delete - remove git worktrees and clean up associated resources
# TAGS: git, worktree, nas
# AUDIENCE: human, agent
#
# Usage: worktree-delete <branch-name> [options]
#
# Removes the worktree directory, prunes git worktree references,
# optionally deletes the branch, and cleans up the cd quick alias.
# Works with NAS-hosted bare repos via project config.
#
# Config: ~/.config/worktrees/<project>.conf
#
# Examples:
#   worktree-delete feature-auth          # Remove worktree, keep branch
#   worktree-delete feature-auth -b       # Remove worktree AND delete branch
#   worktree-delete feature-auth --project Scripts
#   worktree-delete feature-auth --dry-run

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/worktree-ports.sh" 2>/dev/null || true

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Detect default project from PWD (vault → project mapping)
detect_default_project() {
    case "$PWD" in
        */Imperium-ENV*) echo "Token-OS" ;;
        */Pax-ENV*)      echo "askCivic" ;;
        *)               echo "askCivic" ;;
    esac
}

# Defaults
DRY_RUN=false
DELETE_BRANCH=false
DELETE_REMOTE=false
FORCE=false
PROJECT="$(detect_default_project)"

usage() {
    cat << 'EOF'
Worktree Delete - remove git worktrees and clean up associated resources

Usage: worktree-delete <branch-name> [options]

Arguments:
  branch-name         Branch/worktree to remove

Options:
  -b, --delete-branch   Also delete the local branch (refused if unmerged,
                        unless --force)
  --delete-remote       Also delete the branch on origin (best-effort)
  -f, --force           Delete the local branch even if unmerged
  -p, --project NAME    Project config to use (default: askCivic)
  -n, --dry-run         Show what would happen without making changes
  -h, --help            Show this help message

Cleanup performed:
  - Kills any Claude session running from the worktree (ghost prevention)
  - Frees the worktree's assigned dev port (returned to pool)
  - Prunes port-registry entries whose worktree dirs are gone
  - Archives the worktree entry in its session doc (if registered)
  - Removes the worktree directory
  - Prunes git worktree references
  - Removes the cd quick alias (~/.cd_quick_aliases)
  - Optionally deletes the local branch (-b) and remote branch (--delete-remote)

Examples:
  worktree-delete feature-auth              # Remove worktree, keep branch
  worktree-delete feature-auth -b           # Also delete the branch
  worktree-delete feature-auth -b --delete-remote   # Full one-shot teardown
  worktree-delete feature-auth --project Scripts
  worktree-delete feature-auth --dry-run
EOF
    exit 0
}

log_info() { echo -e "${BLUE}→${NC} $1" >&2; }
log_success() { echo -e "${GREEN}✓${NC} $1" >&2; }
log_warn() { echo -e "${YELLOW}!${NC} $1" >&2; }
log_error() { echo -e "${RED}✗${NC} $1" >&2; }

load_config() {
    local project="${1:-askCivic}"
    local config="$HOME/.config/worktrees/${project}.conf"
    if [[ ! -f "$config" ]]; then
        log_error "Project config not found: $config"
        echo "  Create it with: worktree-setup --init $project" >&2
        exit 1
    fi
    # shellcheck disable=SC1090
    source "$config"
    for var in BARE_REPO WORKTREE_PARENT SECRETS_DIR; do
        if [[ -z "${!var:-}" ]]; then
            log_error "$var not set in $config"
            exit 1
        fi
    done
    # NAS mount check
    if [[ ! -d "$BARE_REPO" ]]; then
        log_error "Bare repo not found: $BARE_REPO (is NAS mounted?)"
        exit 1
    fi
    if [[ "$(git --git-dir="$BARE_REPO" rev-parse --is-bare-repository 2>/dev/null)" != "true" ]]; then
        log_error "$BARE_REPO is not a bare git repository"
        exit 1
    fi
    mkdir -p "$WORKTREE_PARENT"
}

# Parse arguments
BRANCH_NAME=""
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help) usage ;;
        -n|--dry-run) DRY_RUN=true; shift ;;
        -b|--delete-branch) DELETE_BRANCH=true; shift ;;
        --delete-remote) DELETE_REMOTE=true; shift ;;
        -f|--force) FORCE=true; shift ;;
        -p|--project)
            if [[ $# -lt 2 ]]; then
                log_error "--project requires a name"
                exit 1
            fi
            PROJECT="$2"
            shift 2
            ;;
        -*)
            log_error "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
        *)
            if [[ -z "$BRANCH_NAME" ]]; then
                BRANCH_NAME="$1"
            else
                log_error "Too many arguments"
                exit 1
            fi
            shift
            ;;
    esac
done

if [[ -z "$BRANCH_NAME" ]]; then
    log_error "Branch name required"
    echo "Usage: worktree-delete <branch-name> [options]"
    exit 1
fi

# Load project config (validates NAS mounts, bare repo, etc.)
load_config "$PROJECT"

WORKTREE_DIR="$WORKTREE_PARENT/wt-$BRANCH_NAME"

# The conventional dir is wt-<branch>, but dispatch can name the dir from its
# --worktree argument while the branch inside was created/renamed differently
# (e.g. wt-purge-legacy-… holding fix-voice-send-keys-…). When the conventional
# dir is absent, resolve the branch's real worktree from git itself.
if [[ ! -d "$WORKTREE_DIR" ]]; then
    _REGISTERED_WT="$(git --git-dir="$BARE_REPO" worktree list --porcelain 2>/dev/null \
        | awk -v b="refs/heads/$BRANCH_NAME" '/^worktree /{p=substr($0,10)} /^branch /{if (substr($0,8)==b) print p}' \
        || true)"
    if [[ -n "$_REGISTERED_WT" && -d "$_REGISTERED_WT" ]]; then
        WORKTREE_DIR="$_REGISTERED_WT"
        log_warn "Conventional dir wt-$BRANCH_NAME missing; using the branch's registered worktree: $WORKTREE_DIR"
    fi
fi

# Verify worktree exists
if [[ ! -d "$WORKTREE_DIR" ]]; then
    # Still try to clean up alias and prune
    log_warn "Worktree directory not found: $WORKTREE_DIR"
    log_info "Will still clean up alias and prune references..."
fi

CD_QUICK_ALIASES_FILE="$HOME/.cd_quick_aliases"
# Literal prefix match (awk index, not a regex): branch names may contain
# regex/sed metacharacters — `fix/...` broke the old `sed "/^$BRANCH=/d"`.
HAS_ALIAS=false
if awk -v p="${BRANCH_NAME}=" 'index($0, p) == 1 {found=1} END {exit !found}' \
    "$CD_QUICK_ALIASES_FILE" 2>/dev/null; then
    HAS_ALIAS=true
fi

# Show plan
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo " Worktree Delete Plan"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "  Project:       $PROJECT"
echo "  Bare repo:     $BARE_REPO"
echo "  Branch:        $BRANCH_NAME"
echo "  Worktree:      $WORKTREE_DIR"
echo "  Delete branch: $(if $DELETE_BRANCH; then echo "yes"; else echo "no"; fi)"
echo "  Delete remote: $(if $DELETE_REMOTE; then echo "yes"; else echo "no"; fi)"
echo "  CD alias:      $(if $HAS_ALIAS; then echo "will remove"; else echo "none found"; fi)"
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo ""

if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "Dry run - no changes made"
    exit 0
fi

# Find a Claude process whose cwd is the worktree. /proc on Linux; pgrep+lsof
# on macOS, where /proc does not exist and the old loop silently never matched.
find_ghost_claude() {
    local worktree_dir="$1" pid comm cwd
    if [[ -d /proc ]]; then
        for entry in /proc/[0-9]*; do
            pid=$(basename "$entry")
            comm=$(cat "/proc/$pid/comm" 2>/dev/null) || continue
            [[ "$comm" == "claude" ]] || continue
            cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null) || continue
            if [[ "${cwd%/}" == "${worktree_dir%/}" ]]; then
                echo "$pid"
                return 0
            fi
        done
        return 0
    fi
    if command -v pgrep &>/dev/null && command -v lsof &>/dev/null; then
        for pid in $(pgrep -x claude 2>/dev/null || true); do
            cwd=$(lsof -a -p "$pid" -d cwd -Fn 2>/dev/null | sed -n 's/^n//p' | head -n1)
            if [[ -n "$cwd" && "${cwd%/}" == "${worktree_dir%/}" ]]; then
                echo "$pid"
                return 0
            fi
        done
    fi
    return 0
}

# Kill any Claude session running from the worktree (ghost prevention)
if [[ -d "$WORKTREE_DIR" ]]; then
    GHOST_PID="$(find_ghost_claude "$WORKTREE_DIR")"

    if [[ -n "$GHOST_PID" ]]; then
        log_warn "Claude session running from worktree (PID $GHOST_PID)"
        log_info "Sending SIGINT to gracefully stop..."
        kill -INT "$GHOST_PID" 2>/dev/null || true
        sleep 1
        if kill -0 "$GHOST_PID" 2>/dev/null; then
            kill -INT "$GHOST_PID" 2>/dev/null || true
            sleep 2
        fi
        if kill -0 "$GHOST_PID" 2>/dev/null; then
            log_warn "Force killing PID $GHOST_PID"
            kill -KILL "$GHOST_PID" 2>/dev/null || true
        fi
        log_success "Claude session terminated"
        # Clean up session PID cache
        rm -f "${HOME}/.claude/session-pids/${GHOST_PID}" 2>/dev/null || true
    fi
fi

# Free the port assigned to this worktree (kills bound process).
if command -v free_port &>/dev/null; then
    if FREED=$(free_port "$WORKTREE_DIR" 2>/dev/null) && [[ -n "$FREED" ]]; then
        log_success "Freed port $FREED (returned to pool)"
    fi
fi

# Opportunistically reap registry entries for worktrees deleted out-of-band
# (rm -rf'd without worktree-delete) so the pool can't exhaust on ghosts.
if command -v prune_ports &>/dev/null; then
    PRUNED=$(prune_ports 2>/dev/null || true)
    if [[ -n "$PRUNED" ]]; then
        while IFS= read -r line; do
            log_success "Pruned stale port ${line%% *} (${line#* } is gone)"
        done <<< "$PRUNED"
    fi
fi

# Archive this worktree's entry in its session doc (Phase 3 registry), BEFORE the
# directory (and its .worktree.env) is removed. Entries are flipped active→archived,
# never deleted. Best-effort: unreachable token-api never blocks teardown.
if [[ -f "$WORKTREE_DIR/.worktree.env" ]]; then
    # `|| true` is load-bearing: under set -euo pipefail, a .worktree.env without
    # a SESSION_DOC_ID line (every dispatch-created worktree) made grep's rc=1
    # abort the whole teardown here — after the port was freed, before the
    # worktree/branch/alias were removed. Half-deleted worktrees ensued.
    _SESSION_DOC_ID="$(grep -E '^SESSION_DOC_ID=' "$WORKTREE_DIR/.worktree.env" 2>/dev/null | head -n1 | cut -d= -f2- || true)"
    if [[ -n "$_SESSION_DOC_ID" ]]; then
        _wt_api="${TOKEN_API_URL:-http://localhost:7777}"
        _wt_body=$(printf '{"action":"archive","path":"%s"}' "$WORKTREE_DIR")
        if curl -fsS -m 5 -X POST \
            -H "Content-Type: application/json" \
            -d "$_wt_body" \
            "$_wt_api/api/session-docs/$_SESSION_DOC_ID/worktrees" >/dev/null 2>&1; then
            log_success "Archived worktree entry in session doc $_SESSION_DOC_ID"
        else
            log_warn "Could not archive worktree entry in session doc $_SESSION_DOC_ID (token-api unreachable?)"
        fi
    fi
fi

# Remove worktree
if [[ -d "$WORKTREE_DIR" ]]; then
    log_info "Removing worktree..."
    if git --git-dir="$BARE_REPO" worktree remove "$WORKTREE_DIR" --force 2>/dev/null; then
        log_success "Worktree removed: $WORKTREE_DIR"
    else
        # Orphaned dir: the registration is already gone (external `git
        # worktree remove`/prune raced us — pr-merge does this) but the
        # directory survived. Only ever rm a path inside WORKTREE_PARENT.
        case "$WORKTREE_DIR" in
            "$WORKTREE_PARENT"/*)
                # cwd-equality guard (P1 getcwd family): never rm -rf the
                # directory the caller still stands in — pulling the cwd out from
                # under a live process turns teardown into a getcwd(ENOENT) crash.
                # The confinement-to-$WORKTREE_PARENT case above is not enough:
                # a human (or agent) running this from inside the target is in it.
                _CALLER_CWD="$(pwd -P 2>/dev/null || true)"
                _TARGET_REAL="$(cd "$WORKTREE_DIR" 2>/dev/null && pwd -P || echo "$WORKTREE_DIR")"
                if [[ -n "$_CALLER_CWD" && ( "$_CALLER_CWD" == "$_TARGET_REAL" || "$_CALLER_CWD" == "$_TARGET_REAL"/* ) ]]; then
                    log_error "Refusing rm -rf $WORKTREE_DIR: caller cwd is inside it (would self-purge)"
                    log_error "cd out of the worktree and retry, or let the tmuxctld post-death teardown own it"
                    exit 1
                fi
                rm -rf "$WORKTREE_DIR"
                git --git-dir="$BARE_REPO" worktree prune 2>/dev/null || true
                log_success "Removed orphaned worktree dir (registration was already gone): $WORKTREE_DIR"
                ;;
            *)
                log_error "git worktree remove failed and $WORKTREE_DIR is outside $WORKTREE_PARENT — refusing to rm -rf"
                exit 1
                ;;
        esac
    fi
else
    log_info "Pruning stale worktree references..."
    git --git-dir="$BARE_REPO" worktree prune
    log_success "Pruned worktree references"
fi

# Delete branch if requested
if [[ "$DELETE_BRANCH" == "true" ]]; then
    if git --git-dir="$BARE_REPO" branch --list "$BRANCH_NAME" | grep -q .; then
        # Merged-guard: refuse to force-delete a branch whose commits are not
        # reachable from the default branch (squash-merged or genuinely unmerged
        # work) unless --force. Protects at-scale cleanup sweeps from data loss.
        DEFAULT_BRANCH="$(git --git-dir="$BARE_REPO" symbolic-ref --short HEAD 2>/dev/null || echo main)"
        if ! git --git-dir="$BARE_REPO" merge-base --is-ancestor "$BRANCH_NAME" "$DEFAULT_BRANCH" 2>/dev/null \
            && [[ "$FORCE" != "true" ]]; then
            log_error "Branch '$BRANCH_NAME' is not merged into '$DEFAULT_BRANCH' — refusing to delete it"
            log_error "If the work is preserved elsewhere (squash-merge, salvage), pass --force"
            exit 65
        fi
        log_info "Deleting local branch..."
        git --git-dir="$BARE_REPO" branch -D "$BRANCH_NAME"
        log_success "Branch deleted: $BRANCH_NAME"
    else
        log_warn "Branch '$BRANCH_NAME' not found locally (may already be deleted)"
    fi
fi

# Delete the remote branch if requested (best-effort: a branch that only ever
# lived locally, or was already pruned on GitHub, must not fail the teardown).
if [[ "$DELETE_REMOTE" == "true" ]]; then
    if git --git-dir="$BARE_REPO" push origin --delete "$BRANCH_NAME" 2>/dev/null; then
        log_success "Remote branch deleted: origin/$BRANCH_NAME"
    else
        log_warn "Remote branch origin/$BRANCH_NAME not deleted (absent, or push failed)"
    fi
fi

# Remove cd quick alias. awk literal-prefix filter, not sed: a branch name
# containing `/` collides with sed's address delimiter (proven live on
# fix/token-os-env-runtime-derivation) and regex metachars could over-match.
if $HAS_ALIAS; then
    log_info "Removing cd alias..."
    _tmp_aliases=$(mktemp)
    awk -v p="${BRANCH_NAME}=" 'index($0, p) != 1' "$CD_QUICK_ALIASES_FILE" > "$_tmp_aliases" \
        && mv "$_tmp_aliases" "$CD_QUICK_ALIASES_FILE"
    log_success "CD alias removed: $BRANCH_NAME"
fi

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo -e " ${GREEN}Worktree cleaned up!${NC}"
echo "═══════════════════════════════════════════════════════════════"
echo ""
