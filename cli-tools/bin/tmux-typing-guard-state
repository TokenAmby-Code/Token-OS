#!/usr/bin/env python3
# tmux-typing-guard-state — canonical pane typing-guard state transitions
from __future__ import annotations

import os
import sys
from pathlib import Path

_ROOT = Path(os.environ.get("TOKEN_OS") or Path(__file__).resolve().parents[2])
_LIB = Path(os.environ.get("TMUXCTLD_LIB") or (_ROOT / "tmuxctld" / "lib"))
_CLI_LIB = _ROOT / "cli-tools" / "lib"
for _path in (_CLI_LIB, _LIB):
    if str(_path) not in sys.path:
        sys.path.insert(0, str(_path))

try:
    from tmuxctl.typing_guard_state import main
except ImportError as exc:  # only the expected missing-module case fails open
    # A syntax/runtime error inside the helper is NOT swallowed — it propagates
    # so the state machine fails loudly instead of silently no-op'ing every pane
    # transition. Only a genuinely absent module degrades to a harmless exit 0.
    sys.stderr.write(f"tmux-typing-guard-state: state helper unavailable: {exc}\n")

    def main() -> int:
        return 0


raise SystemExit(main())
