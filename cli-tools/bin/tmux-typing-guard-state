#!/usr/bin/env python3
# tmux-typing-guard-state — canonical pane typing-guard state transitions
from __future__ import annotations

import sys
from pathlib import Path

_LIB = Path(__file__).resolve().parents[1] / "lib"
if str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

try:
    from tmuxctl.typing_guard_state import main
except Exception:  # pragma: no cover - import failure must fail-open, never break typing

    def main() -> int:
        return 0


raise SystemExit(main())
