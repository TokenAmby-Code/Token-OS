#!/usr/bin/env bash
# test - run the same checks CI runs, locally
# TAGS: workflow, ci
# AUDIENCE: human, agent
#
# Single source of truth: .github/workflows/pr.yml. Whatever the PR gate
# runs, this runs — no divergence between "passes locally" and "passes CI".
#
# Usage: test [target] [options]
#
# Targets:
#   (none) | all         All projects, all checks (format/lint/types/tests)
#   cli-tools            Only the cli-tools project
#   token-api            Only the token-api project
#   format               Format check only (all projects)
#   lint                 Lint only
#   types                Typecheck only
#   unit                 Pytest only
#
# Options:
#   --fix                Auto-format + auto-fix lint for selected project(s)
#                        (does NOT run tests)
#   -h, --help           Show this help
#
# Examples:
#   test                 Run the full local PR gate
#   test format          Check formatting only
#   test --fix           Format + lint-fix all Python projects
#   test cli-tools --fix Format + lint-fix cli-tools only
#
# (The old Node-based Teams payload tester moved to: test-teams)

set -uo pipefail

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'; NC=$'\033[0m'

log()  { printf '%s→%s %s\n' "$BLUE" "$NC" "$1"; }
ok()   { printf '%s✓%s %s\n' "$GREEN" "$NC" "$1"; }
warn() { printf '%s!%s %s\n' "$YELLOW" "$NC" "$1"; }
err()  { printf '%s✗%s %s\n' "$RED" "$NC" "$1" >&2; }

usage() { sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'; exit 0; }

TARGET="all"
FIX=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage ;;
        --fix) FIX=true; shift ;;
        all|cli-tools|token-api|format|lint|types|unit)
            TARGET="$1"; shift ;;
        *) err "Unknown argument: $1"; exit 2 ;;
    esac
done

# Walk up to repo root.
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$REPO_ROOT"

PROJECTS=()
case "$TARGET" in
    cli-tools) PROJECTS=(cli-tools) ;;
    token-api) PROJECTS=(token-api) ;;
    *)
        [[ -d cli-tools ]] && PROJECTS+=(cli-tools)
        [[ -d token-api ]] && PROJECTS+=(token-api)
        ;;
esac

EXIT=0
run_step() {
    local label="$1"; shift
    local proj="$1"; shift
    log "[$proj] $label"
    if (cd "$proj" && "$@"); then
        ok "[$proj] $label"
    else
        err "[$proj] $label failed"
        EXIT=1
    fi
}

for proj in "${PROJECTS[@]}"; do
    [[ -f "$proj/pyproject.toml" ]] || { warn "Skipping $proj (no pyproject.toml)"; continue; }

    if [[ "$FIX" == "true" ]]; then
        run_step "ruff format (write)" "$proj" uv run --group dev ruff format .
        run_step "ruff check --fix"     "$proj" uv run --group dev ruff check --fix .
        continue
    fi

    case "$TARGET" in
        format)
            run_step "ruff format --check" "$proj" uv run --group dev ruff format --check .
            ;;
        lint)
            run_step "ruff check" "$proj" uv run --group dev ruff check .
            ;;
        types)
            run_step "mypy" "$proj" uv run --group dev mypy --ignore-missing-imports .
            ;;
        unit)
            [[ -d "$proj/tests" ]] && run_step "pytest" "$proj" uv run --group dev pytest --tb=short
            ;;
        all|cli-tools|token-api)
            run_step "ruff format --check" "$proj" uv run --group dev ruff format --check .
            run_step "ruff check"          "$proj" uv run --group dev ruff check .
            run_step "mypy"                "$proj" uv run --group dev mypy --ignore-missing-imports .
            [[ -d "$proj/tests" ]] && run_step "pytest" "$proj" uv run --group dev pytest --tb=short
            ;;
    esac
done

echo ""
if [[ $EXIT -eq 0 ]]; then
    ok "All checks passed."
else
    err "One or more checks failed."
fi
exit "$EXIT"
