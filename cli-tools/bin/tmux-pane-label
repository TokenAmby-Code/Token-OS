#!/usr/bin/env python3
# tmux-pane-label - One-shot @PANE_LABEL backfill for live tmux panes
# TAGS: tmux, token-api
# AUDIENCE: human, agent
#
# RETIRED FROM THE HOT PATH (Phase 1 Part A). The pane border no longer shells out
# to this script every status-interval; it reads the in-memory @PANE_LABEL pushed by
# Token-API (SessionStart hydration + trg_tab_name_pane_state → pane_state_worker).
#
# This survives only as a deploy-time backfill: seed @PANE_LABEL on panes that were
# already alive before Phase 1 shipped (they never got a SessionStart hydration and
# won't until they rename). Run once after reloading the tmux config:
#
#     tmux-pane-label --backfill

from __future__ import annotations
# 410 GONE tombstone: tmux CLI exterminatus 2026-06-30.
import sys as _tmux_410_sys
_tmux_410_sys.stderr.write('410 GONE: cli-tools/bin/tmux-pane-label (tmux-pane-label) is tombstoned by the 2026-06-30 tmux CLI exterminatus.\\nThis cold tmux feature surface must not be used as an active runtime/control path.\\nDaemon-native replacement: daemon-pushed pane labels via tmuxctld/Token-API; route TBD.\\nOriginal body is retained below this early-return as the emergency restore lever; lift only this tombstone block to prove an active blocker, build/cut over the daemon-native replacement, then restore the 410.\\n')
raise SystemExit(410)

# --- ORIGINAL BODY BELOW: emergency restore lever, intentionally dead under the 410. ---

import os
import sqlite3
import subprocess
import sys

AGENTS_DB = os.environ.get("AGENTS_DB", os.path.expanduser("~/.claude/agents.db"))


def _live_labels() -> list[tuple[str, str]]:
    """Return (tmux_pane, tab_name) for every non-stopped instance with both set.

    Best-effort seed: uses the stored tmux_pane (what the trigger also stamps). The
    pane_state_worker keeps @PANE_LABEL fresh after this; this only covers panes that
    pre-date the push path.
    """
    try:
        conn = sqlite3.connect(f"file:{AGENTS_DB}?mode=ro", uri=True, timeout=1.0)
        try:
            rows = conn.execute(
                """
                SELECT tmux_pane, name AS tab_name
                FROM instances
                WHERE status != 'stopped'
                  AND tmux_pane IS NOT NULL AND tmux_pane != ''
                  AND name IS NOT NULL AND name != ''
                """
            ).fetchall()
        finally:
            conn.close()
    except Exception as exc:
        print(f"tmux-pane-label: DB read failed: {exc}", file=sys.stderr)
        return []
    return [(str(p), str(n)) for p, n in rows]


def _backfill() -> int:
    pairs = _live_labels()
    if not pairs:
        print("tmux-pane-label: no live panes to backfill")
        return 0
    applied = 0
    failed = 0
    for pane, name in pairs:
        try:
            proc = subprocess.run(
                ("tmux", "set-option", "-p", "-t", pane, "@PANE_LABEL", name),
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=5,
            )
            if proc.returncode == 0:
                applied += 1
            else:
                failed += 1
        except Exception:
            failed += 1
    summary = f"tmux-pane-label: backfilled @PANE_LABEL on {applied} pane(s)"
    if failed:
        summary += f", {failed} failed"
    print(summary)
    return 0


def main(argv: list[str]) -> int:
    if "--backfill" in argv:
        return _backfill()
    # The pane border no longer invokes this script; --backfill is the only mode.
    # Reject anything else loudly so a stray positional call surfaces instead of
    # silently no-op'ing.
    print("usage: tmux-pane-label --backfill", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
