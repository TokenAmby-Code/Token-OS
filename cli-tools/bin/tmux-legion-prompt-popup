#!/usr/bin/env bash
# tmux-legion-prompt-popup — Large Ctrl-Space prompt UI for legion dispatch
# TAGS: tmux, legion, launcher, prompt
# AUDIENCE: human

set -euo pipefail

PROMPT_TEXT=""
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DISPATCH_BIN="${SCRIPT_DIR}/dispatch"
LOG_FILE="${TMUX_LEGION_PROMPT_LOG:-$HOME/.claude/tmux-legion-prompt-popup.log}"
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
log_debug() { printf '%s %s\n' "$(date -Iseconds 2>/dev/null || date)" "$*" >>"$LOG_FILE" 2>/dev/null || true; }
soft_cancel() {
    log_debug "cancelled"
    exit 130
}
trap soft_cancel INT TERM

log_debug "popup start tty=$(tty 2>/dev/null || echo none) cwd=$PWD"
printf '\033[2J\033[H'

# Use bash readline so Left/Right/Home/End and normal line editing work inside
# the large popup. Raw-mode read was unreliable under display-popup; plain read
# ate arrow escape sequences.
if ! IFS= read -e -r -p 'dispatch> ' PROMPT_TEXT; then
    log_debug "readline failed/EOF"
    exit 130
fi

log_debug "read complete chars=${#PROMPT_TEXT}"
if ! printf '%s\n' "$PROMPT_TEXT" | grep -vE '^[[:space:]]*$' >/dev/null; then
    log_debug "empty prompt; cancelling"
    exit 130
fi

# Run dispatch/fzf in this popup before allocating any legion pane. Prefix+Space
# is the direct worker launcher, not aspirant intake; the selector must choose
# the actual launch harness before any worker pane is opened.
# If the user Ctrl-C's out of any selector, dispatch exits 130 and this popup
# closes without opening a worker pane or continuing down a launch path.
log_debug "starting dispatch selector chars=${#PROMPT_TEXT}"
TOKEN_API_DISPATCH_ORIGIN=d "$DISPATCH_BIN" --direct --target mechanicus:new --prompt "$PROMPT_TEXT"
log_debug "dispatch selector exited rc=0"
