#!/usr/bin/env bash
# CodeRabbit Sync - copy vault template into target repo's .coderabbit.yaml
# TAGS: ci, coderabbit
# AUDIENCE: human, agent
#
# Usage: coderabbit-sync <target-repo-path> [options]
#
# Reads the canonical template from
#   $IMPERIUM/Imperium-ENV/Terra/Meta/coderabbit-template.yaml
# and writes/overwrites <target>/.coderabbit.yaml.
#
# Idempotent — re-running with no template changes is a no-op (diff-free).
#
# Options:
#   -n, --dry-run       Show diff against existing .coderabbit.yaml, write nothing
#   --account NAME      Annotate sync with account context (personal|work). Selects
#                       which CODERABBIT_API_KEY secret name CI should reference.
#   -h, --help          Show this help

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

TEMPLATE="${IMPERIUM:-/Volumes/Imperium}/Imperium-ENV/Terra/Meta/coderabbit-template.yaml"

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'; NC=$'\033[0m'

log()    { printf '%s→%s %s\n' "$BLUE" "$NC" "$1"; }
ok()     { printf '%s✓%s %s\n' "$GREEN" "$NC" "$1"; }
warn()   { printf '%s!%s %s\n' "$YELLOW" "$NC" "$1"; }
err()    { printf '%s✗%s %s\n' "$RED" "$NC" "$1" >&2; }

usage() {
    sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
}

DRY_RUN=false
ACCOUNT=""
TARGET=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage ;;
        -n|--dry-run) DRY_RUN=true; shift ;;
        --account)
            [[ $# -lt 2 ]] && { err "--account requires a value"; exit 1; }
            ACCOUNT="$2"; shift 2
            ;;
        -*)
            err "Unknown option: $1"; exit 1 ;;
        *)
            [[ -n "$TARGET" ]] && { err "Too many arguments"; exit 1; }
            TARGET="$1"; shift
            ;;
    esac
done

if [[ -z "$TARGET" ]]; then
    err "Target repo path required"
    echo "Usage: coderabbit-sync <target-repo-path> [--dry-run] [--account personal|work]"
    exit 1
fi

if [[ ! -f "$TEMPLATE" ]]; then
    err "Template not found: $TEMPLATE"
    exit 1
fi

if [[ ! -d "$TARGET" ]]; then
    err "Target directory not found: $TARGET"
    exit 1
fi

if [[ ! -d "$TARGET/.git" ]] && ! git -C "$TARGET" rev-parse --git-dir &>/dev/null; then
    warn "Target is not a git repo: $TARGET (continuing anyway)"
fi

DEST="$TARGET/.coderabbit.yaml"

log "Template:  $TEMPLATE"
log "Target:    $DEST"
[[ -n "$ACCOUNT" ]] && log "Account:   $ACCOUNT"

if [[ -f "$DEST" ]]; then
    if cmp -s "$TEMPLATE" "$DEST"; then
        ok "Already in sync — no changes needed."
        exit 0
    fi
    log "Existing config differs. Diff (template → current):"
    diff -u "$DEST" "$TEMPLATE" || true
fi

if [[ "$DRY_RUN" == "true" ]]; then
    warn "Dry run — not writing."
    exit 0
fi

# cat-redirect avoids extended-attribute copy errors on SMB/NAS mounts.
cat "$TEMPLATE" > "$DEST"
ok "Wrote $DEST"

if [[ -n "$ACCOUNT" ]]; then
    case "$ACCOUNT" in
        personal|work) ok "Account: $ACCOUNT — CI should reference CODERABBIT_API_KEY secret for this account." ;;
        *) warn "Unknown account '$ACCOUNT' (expected: personal|work)" ;;
    esac
fi

echo ""
echo "Next:"
echo "  - Commit .coderabbit.yaml in $TARGET"
echo "  - Verify CodeRabbit GitHub App is installed for the repo"
echo "  - Set CODERABBIT_API_KEY in repo Actions secrets if push-side cr CLI is wired"
