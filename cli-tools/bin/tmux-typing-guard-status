#!/usr/bin/env python3
# tmux-typing-guard-status - recent-keystroke indicator for tmux status bar
# TAGS: tmux, guard, status
# AUDIENCE: human, agent
"""Show a compact tmux status segment while recent user typing is active.

Thin reader of the ONE canonical typing-guard predicate
(`tmuxctl.send_gate.typing_guard_active`), which reads tmux's #{client_activity}
timestamp and stays active for TMUX_TYPING_GUARD_WINDOW seconds after the last
keystroke. Keeping the client_activity logic in a single place means the status
segment, tmux-guard.sh, and the universal send gate can never disagree. Silent
outside tmux or on failure.
"""

from __future__ import annotations

import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parents[1] / "lib"))

try:
    from tmuxctl.send_gate import typing_guard_active
except Exception:  # fail-open: render nothing if the predicate can't be imported

    def typing_guard_active(**_kwargs) -> bool:
        return False


def main() -> int:
    plain = "--plain" in sys.argv[1:]
    if not typing_guard_active():
        return 0
    if plain:
        print("TYPE", end="")
    else:
        print("#[fg=colour214,bold]⌨#[default] ", end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
