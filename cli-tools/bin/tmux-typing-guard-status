#!/usr/bin/env python3
# tmux-typing-guard-status - typing-guard diagnostic / expiry projection helper
# TAGS: tmux, guard, status
# AUDIENCE: human, agent
"""Render or project the canonical per-pane typing guard.

Live tmux config must not invoke this from status-right or pane-border-format.
Those surfaces are pure reads of pushed tmux options. This command remains as a
manual diagnostic and as a one-shot expiry clearer scheduled when tmux's root key
binding arms a pane-local ``@TYPING_LOCK_UNTIL`` lock.

Modes:
  * default      — print a status segment for the current pane only.
  * ``--plain``  — print ``TYPE`` instead of a styled tmux segment.
  * ``--publish -t PANE --active|--inactive`` — set/clear ``@GUARD`` for one pane.
  * ``--clear-expired -t PANE`` — sleep until that pane's lock expiry, then clear
                   ``@GUARD`` iff the canonical predicate is no longer active.

There is intentionally no all-pane scan mode. Marker updates are event-driven by
the key binding, Enter clear, and this one-shot expiry clearer.
"""

from __future__ import annotations

import argparse
import subprocess
import sys
import time
from pathlib import Path

_LIB = Path(__file__).resolve().parents[1] / "lib"
if str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

SEGMENT_STYLED = "#[fg=colour214]#[bold]⌨ GUARD#[default] "
SEGMENT_PLAIN = "TYPE"
BORDER_MARKER = "#[fg=colour214]#[bold]⌨#[default]"


def _imports() -> tuple:
    try:
        from tmuxctl.send_gate import (
            publish_typing_guard_marker,
            typing_guard_active,
            typing_guard_deadline,
        )
        from tmuxctl.tmux_adapter import tmux_binary

        return typing_guard_active, typing_guard_deadline, publish_typing_guard_marker, tmux_binary
    except Exception:
        return None, None, None, None


def _tmux(binary: str, *args: str) -> str | None:
    try:
        proc = subprocess.run(
            [binary, *args],
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=0.5,
        )
    except Exception:
        return None
    if proc.returncode != 0:
        return None
    return proc.stdout


def _current_pane(binary: str) -> str:
    out = _tmux(binary, "display-message", "-p", "#{pane_id}")
    return (out or "").strip()


def _parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(add_help=True)
    parser.add_argument("--plain", action="store_true")
    parser.add_argument("--publish", action="store_true")
    state = parser.add_mutually_exclusive_group()
    state.add_argument("--active", action="store_true")
    state.add_argument("--inactive", action="store_true")
    parser.add_argument("--clear-expired", action="store_true")
    parser.add_argument("-t", "--target")
    args = parser.parse_args(argv)
    if args.publish and not (args.active or args.inactive):
        parser.error("--publish requires exactly one of --active or --inactive")
    return args


def main() -> int:
    args = _parse_args(sys.argv[1:])
    typing_guard_active, typing_guard_deadline, publish_marker, tmux_binary = _imports()
    if typing_guard_active is None or tmux_binary is None or publish_marker is None:
        return 0

    if args.publish:
        if not args.target:
            return 2
        publish_marker(args.target, bool(args.active) and not args.inactive)
        return 0

    if args.clear_expired:
        if not args.target or typing_guard_deadline is None:
            return 2
        while True:
            deadline = typing_guard_deadline(target=args.target)
            if deadline is None:
                break
            sleep_for = max(0.0, deadline - time.time() + 0.1)
            # Bound pathological clock/config values; the shipped lock is 300s.
            time.sleep(min(sleep_for, 3600.0))
            try:
                if not typing_guard_active(target=args.target):
                    break
            except Exception:
                break
        publish_marker(args.target, False)
        return 0

    try:
        binary = tmux_binary()
    except Exception:
        return 0
    pane = args.target or _current_pane(binary)
    if not pane:
        return 0

    try:
        active = bool(typing_guard_active(target=pane))
    except Exception:
        active = False

    if active:
        sys.stdout.write(SEGMENT_PLAIN if args.plain else SEGMENT_STYLED)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
