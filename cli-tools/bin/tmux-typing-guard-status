#!/usr/bin/env python3
# tmux-typing-guard-status - per-pane typing-guard stamp indicator
# TAGS: tmux, guard, status
# AUDIENCE: human, agent
"""Show a compact tmux status segment while the inbound send-keys guard is active.

This is intentionally separate from the outbound/OOB send gate. It mirrors the
shell guard's per-pane stamp-once model without importing tmuxctl on tmux's hot
path:

* stamp the current pane once when pending prompt input is observed;
* do not refresh the stamp on subsequent keystrokes;
* clear when the prompt is empty/submitted;
* hard-expire after TMUX_GUARD_TTL seconds (default 300).
"""

from __future__ import annotations

import os
import re
import subprocess
import sys
import time
from pathlib import Path


def _run_tmux(*args: str) -> str | None:
    try:
        proc = subprocess.run(
            ["tmux", *args],
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=0.3,
        )
    except Exception:
        return None
    if proc.returncode != 0:
        return None
    return proc.stdout


def _ttl() -> int:
    try:
        value = int(os.environ.get("TMUX_GUARD_TTL", "300"))
    except (TypeError, ValueError):
        value = 300
    return value if value > 0 else 300


def _now() -> int:
    raw = os.environ.get("TMUX_GUARD_NOW")
    if raw:
        try:
            return int(float(raw))
        except ValueError:
            pass
    return int(time.time())


def _state_dir() -> Path:
    default = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / f"tmux-typing-guard-{os.getuid()}"
    path = Path(os.environ.get("TMUX_GUARD_STATE_DIR", str(default)))
    path.mkdir(parents=True, exist_ok=True)
    return path


def _pane_key(pane: str) -> str:
    return re.sub(r"[^A-Za-z0-9_.:%-]", "_", pane)


def _stamp_file(pane: str) -> Path:
    return _state_dir() / f"{_pane_key(pane)}.stamp"


def _read_stamp(path: Path) -> tuple[int | None, str]:
    started: int | None = None
    state = ""
    try:
        for line in path.read_text(encoding="utf-8").splitlines():
            key, _, value = line.partition("=")
            if key == "started_at":
                try:
                    started = int(float(value))
                except ValueError:
                    started = None
            elif key == "state":
                state = value.strip()
    except OSError:
        pass
    return started, state


def _write_stamp(path: Path, started_at: int, state: str) -> None:
    tmp = path.with_suffix(path.suffix + f".{os.getpid()}")
    try:
        tmp.write_text(f"started_at={started_at}\nstate={state}\n", encoding="utf-8")
        tmp.replace(path)
    except OSError:
        try:
            tmp.unlink()
        except OSError:
            pass


def _clear_stamp(path: Path) -> None:
    try:
        path.unlink()
    except FileNotFoundError:
        pass
    except OSError:
        pass


def _pane_has_input(pane: str) -> bool:
    out = _run_tmux("capture-pane", "-t", pane, "-p")
    if out is None:
        return False
    lines = []
    for line in out.splitlines():
        if not line.strip():
            continue
        if re.match(r"^\s*[0-9]+%\s+[0-9]", line):
            continue
        if re.match(r"^\s*⏵", line):
            continue
        if re.match(r"^\s*esc again", line):
            continue
        lines.append(line)
    if not lines:
        return False
    last = lines[-1]
    if re.match(r"^[\s│░▒▓]*>\s*$", last):
        return False
    if re.search(r"[$%#>❯]\s*$", last):
        return False
    if not re.search(r"[$%#>❯]", last):
        return False
    return True


def guard_active_for_current_pane() -> bool:
    pane_out = _run_tmux("display-message", "-p", "#{pane_id}")
    pane = (pane_out or "").strip()
    if not pane:
        return False
    path = _stamp_file(pane)
    now = _now()
    ttl = _ttl()

    if not _pane_has_input(pane):
        _clear_stamp(path)
        return False

    started, state = _read_stamp(path)
    if state == "expired":
        return False
    if started is None:
        started = now
        _write_stamp(path, started, "active")
    if now - started >= ttl:
        _write_stamp(path, started, "expired")
        return False
    return True


def main() -> int:
    plain = "--plain" in sys.argv[1:]
    if not guard_active_for_current_pane():
        return 0
    if plain:
        print("TYPE", end="")
    else:
        print("#[fg=colour214,bold]⌨ GUARD#[default] ", end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
