#!/usr/bin/env python3
# tmux-typing-guard-status - per-pane typing-guard diagnostic
# TAGS: tmux, guard, status
# AUDIENCE: human, agent
"""Render the typing_guard state for a pane — the visible diagnostic.

This is the statusline/pane-border diagnostic for the inbound typing guard. Its
ONE job is to answer honestly: *would the universal send gate hold an automated
write to this pane right now?* So it consults the single canonical predicate,
``tmuxctl.send_gate.typing_guard_active(target=pane)`` — the same predicate that
gates the Python clobber path (state-hooks, enforcement, dispatch via
``TmuxAdapter.run``). It deliberately does NOT read the legacy 300s shell
``*.stamp`` files: those over-report (they light long after a keystroke and
across unattended agent panes), so a stamp-driven light could not tell "the
guard never engaged" from "the guard was pierced." This reads the real gate.

Modes:
  * default      — print the status-right segment for the *current* (active)
                   pane and publish its ``@GUARD`` pane option so the pane
                   border renders the same state with zero fork per redraw.
  * ``--plain``  — same decision, plain ``TYPE`` text (for tests / dumb bars).
  * ``--scan``   — refresh every live pane's ``@GUARD`` option in a single fork.
                   This is the per-pane border updater; it is intentionally kept
                   OUT of the per-render path so it never reintroduces the
                   N-shell-out status-bar lag (see cli-tools/tmux/tmux-base.conf).
  * ``--expire-pane <pane>`` — one-shot expiry helper used by the tmux key
                   bindings. It clears ``@GUARD`` only after both the ON lock and
                   the PENDING hold have expired; it does not scan panes.

Fail-open everywhere: any tmux/predicate error renders dark and never raises, so
a transient fault can neither brick the status bar nor fake a guard light.
"""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path

_LIB = Path(__file__).resolve().parents[1] / "lib"
if str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))

# Styled status-right segment (matches the bar's colour theme) and the compact
# colour-by-state markers pushed into the per-pane @GUARD border var.
SEGMENT_STYLED = "#[fg=colour214,bold]⌨ GUARD#[default] "
SEGMENT_PLAIN = "TYPE"
BORDER_MARKER_ON = "#[fg=colour214,bold]⌨#[default]"
BORDER_MARKER_PENDING = "#[fg=red,bold]⌨#[default]"
_TYPING_LOCK_OPTION = "@TYPING_LOCK_UNTIL"
_TYPING_PENDING_OPTION = "@TYPING_PENDING_UNTIL"


def _imports() -> tuple:
    """Import the canonical predicate + real-tmux resolver, or (None, None)."""
    try:
        from tmuxctl.send_gate import typing_guard_active
        from tmuxctl.tmux_adapter import tmux_binary

        return typing_guard_active, tmux_binary
    except Exception:
        return None, None


def _tmux(binary: str, *args: str) -> str | None:
    try:
        proc = subprocess.run(
            [binary, *args],
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=0.5,
        )
    except Exception:
        return None
    if proc.returncode != 0:
        return None
    return proc.stdout


def _current_pane(binary: str) -> str:
    out = _tmux(binary, "display-message", "-p", "#{pane_id}")
    return (out or "").strip()


def _live_panes(binary: str) -> list[str]:
    out = _tmux(binary, "list-panes", "-a", "-F", "#{pane_id}")
    if out is None:
        return []
    return [line.strip() for line in out.splitlines() if line.strip()]


def _pending_active(binary: str, pane: str) -> bool:
    """True iff the pane is inside its short pending hold."""
    import time

    pending_until = _pane_option_epoch(binary, pane, _TYPING_PENDING_OPTION)
    return pending_until is not None and time.time() < pending_until


def _publish(binary: str, pane: str, active: bool) -> None:
    """Push the pane-scoped @GUARD border var (zero-fork to render later).

    ON renders as yellow keyboard; pending renders as red keyboard. No literal
    text is included in @GUARD, so pane borders/statusline stay compact.
    """
    if not active:
        value = ""
    elif _pending_active(binary, pane):
        value = BORDER_MARKER_PENDING
    else:
        value = BORDER_MARKER_ON
    # Best-effort: a failed option write must never break the segment render.
    _tmux(binary, "set-option", "-p", "-t", pane, "@GUARD", value)


def _pane_option_epoch(binary: str, pane: str, option: str) -> int | None:
    out = _tmux(binary, "show-options", "-pqv", "-t", pane, option)
    raw = (out or "").strip()
    if not raw:
        return None
    try:
        return int(raw)
    except ValueError:
        return None


def _expire_pane(binary: str, pane: str) -> None:
    """Clear stale guard projection for one pane, without scanning all panes."""
    import time

    now = time.time()
    lock_until = _pane_option_epoch(binary, pane, _TYPING_LOCK_OPTION)
    pending_until = _pane_option_epoch(binary, pane, _TYPING_PENDING_OPTION)
    if (lock_until is not None and now < lock_until) or (
        pending_until is not None and now < pending_until
    ):
        return
    _tmux(binary, "set-option", "-pu", "-t", pane, _TYPING_LOCK_OPTION)
    _tmux(binary, "set-option", "-pu", "-t", pane, _TYPING_PENDING_OPTION)
    _publish(binary, pane, False)


def main() -> int:
    argv = sys.argv[1:]
    plain = "--plain" in argv
    scan = "--scan" in argv

    typing_guard_active, tmux_binary = _imports()
    if typing_guard_active is None or tmux_binary is None:
        return 0  # fail-open: no predicate available → render dark

    try:
        binary = tmux_binary()
    except Exception:
        return 0

    if "--expire-pane" in argv:
        try:
            pane = argv[argv.index("--expire-pane") + 1]
        except (ValueError, IndexError):
            return 0
        _expire_pane(binary, pane)
        return 0

    if scan:
        for pane in _live_panes(binary):
            try:
                active = bool(typing_guard_active(target=pane))
            except Exception:
                active = False
            _publish(binary, pane, active)
        return 0

    pane = _current_pane(binary)
    if not pane:
        return 0

    try:
        active = bool(typing_guard_active(target=pane))
    except Exception:
        active = False

    _publish(binary, pane, active)

    if active:
        sys.stdout.write(SEGMENT_PLAIN if plain else SEGMENT_STYLED)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
