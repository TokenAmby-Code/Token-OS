#!/usr/bin/env bash
# codex-dispatch — Launch Codex with Token-API session tracking and dispatch metadata

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib"

if [[ -f "$LIB_DIR/nas-path.sh" ]]; then
  source "$LIB_DIR/nas-path.sh"
elif [[ -n "${IMPERIUM:-}" && -f "$IMPERIUM/Token-OS/cli-tools/lib/nas-path.sh" ]]; then
  source "$IMPERIUM/Token-OS/cli-tools/lib/nas-path.sh"
fi

API_URL="${TOKEN_API_URL:-http://100.95.109.23:7777}"

SESSION_DOC=""
DISPATCH_TARGET=""
DISPATCH_WINDOW=""
DISPATCH_MODE=""
DISPATCH_SLOT=""
RESOLVED_TMUX_PANE=""
LAUNCH_MODE="direct_target"
TRANSPLANT_EXPECTED="false"
LAUNCHER="codex-dispatch"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session-doc) SESSION_DOC="$2"; shift 2 ;;
    --dispatch-target) DISPATCH_TARGET="$2"; shift 2 ;;
    --dispatch-window) DISPATCH_WINDOW="$2"; shift 2 ;;
    --dispatch-mode) DISPATCH_MODE="$2"; shift 2 ;;
    --dispatch-slot) DISPATCH_SLOT="$2"; shift 2 ;;
    --resolved-tmux-pane) RESOLVED_TMUX_PANE="$2"; shift 2 ;;
    --launch-mode) LAUNCH_MODE="$2"; shift 2 ;;
    --transplant-expected) TRANSPLANT_EXPECTED="$2"; shift 2 ;;
    --launcher) LAUNCHER="$2"; shift 2 ;;
    --) shift; break ;;
    -*) echo "Unknown option: $1" >&2; exit 64 ;;
    *) break ;;
  esac
done

if [[ $# -lt 2 ]]; then
  echo "Usage: codex-dispatch [dispatch-options] <working-dir> <prompt>" >&2
  exit 64
fi

WORKING_DIR="$1"
shift
PROMPT="$*"

if [[ ! -d "$WORKING_DIR" ]]; then
  echo "Error: working directory does not exist: $WORKING_DIR" >&2
  exit 65
fi

if ! command -v codex >/dev/null 2>&1; then
  echo "Error: codex not found in PATH" >&2
  exit 66
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq not found in PATH" >&2
  exit 67
fi

SESSION_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
BRIDGE_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
BRIDGE_DIR="${HOME}/.codex/session-bridges"
mkdir -p "$BRIDGE_DIR"
rm -f "${BRIDGE_DIR}/${BRIDGE_ID}.session_id"

post_hook() {
  local action_type="$1"
  local payload="$2"
  curl -s --connect-timeout 2 --max-time 5 \
    -X POST "${API_URL}/api/hooks/${action_type}" \
    -H "Content-Type: application/json" \
    -d "$payload" >/dev/null 2>&1 || true
}

build_env_object() {
  local env_obj="{}"
  [[ -n "${SSH_CLIENT:-}" ]]          && env_obj=$(echo "$env_obj" | jq -c --arg v "$SSH_CLIENT" '. + {SSH_CLIENT: $v}')
  [[ -n "${TMUX:-}" ]]               && env_obj=$(echo "$env_obj" | jq -c --arg v "$TMUX" '. + {TMUX: $v}')
  [[ -n "${TMUX_PANE:-}" ]]          && env_obj=$(echo "$env_obj" | jq -c --arg v "$TMUX_PANE" '. + {TMUX_PANE: $v}')
  [[ -n "${TOKEN_API_PRIMARCH:-}" ]] && env_obj=$(echo "$env_obj" | jq -c --arg v "$TOKEN_API_PRIMARCH" '. + {TOKEN_API_PRIMARCH: $v}')
  echo "$env_obj"
}

ENV_OBJ=$(build_env_object)
WRAPPER_START_PAYLOAD=$(jq -nc \
  --arg wrapper_launch_id "$BRIDGE_ID" \
  --arg launcher "$LAUNCHER" \
  --arg engine "codex" \
  --arg wd "$WORKING_DIR" \
  --arg tmux_pane "$RESOLVED_TMUX_PANE" \
  --argjson pid "$$" \
  --argjson env "$ENV_OBJ" \
  '{
    wrapper_launch_id: $wrapper_launch_id,
    launcher: $launcher,
    engine: $engine,
    cwd: $wd,
    tmux_pane: $tmux_pane,
    pid: $pid,
    env: $env
  }')
post_hook "WrapperStart" "$WRAPPER_START_PAYLOAD"

cleanup() {
  local exit_code=$?
  local codex_session_id="$SESSION_ID"
  local end_payload
  local wrapper_end_payload
  if [[ -s "${BRIDGE_DIR}/${BRIDGE_ID}.session_id" ]]; then
    codex_session_id="$(cat "${BRIDGE_DIR}/${BRIDGE_ID}.session_id" 2>/dev/null || printf '%s' "$SESSION_ID")"
  fi
  rm -f "${BRIDGE_DIR}/${BRIDGE_ID}.session_id"
  wrapper_end_payload=$(jq -nc \
    --arg wrapper_launch_id "$BRIDGE_ID" \
    --arg launcher "$LAUNCHER" \
    --arg engine "codex" \
    --arg wd "$WORKING_DIR" \
    --arg tmux_pane "$RESOLVED_TMUX_PANE" \
    --argjson pid "$$" \
    --argjson code "$exit_code" \
    --argjson env "$ENV_OBJ" \
    '{
      wrapper_launch_id: $wrapper_launch_id,
      launcher: $launcher,
      engine: $engine,
      cwd: $wd,
      tmux_pane: $tmux_pane,
      pid: $pid,
      exit_code: $code,
      env: $env
    }')
  post_hook "WrapperEnd" "$wrapper_end_payload"
  end_payload=$(jq -nc \
    --arg sid "$codex_session_id" \
    --arg wrapper_launch_id "$BRIDGE_ID" \
    --arg wd "$WORKING_DIR" \
    --arg launcher "$LAUNCHER" \
    --arg engine "codex" \
    --arg tmux_pane "$RESOLVED_TMUX_PANE" \
    --argjson code "$exit_code" \
    '{
      session_id: $sid,
      wrapper_launch_id: $wrapper_launch_id,
      cwd: $wd,
      launcher: $launcher,
      engine: $engine,
      tmux_pane: $tmux_pane,
      exit_code: $code
    }')
  post_hook "SessionEnd" "$end_payload"
}
trap cleanup EXIT INT TERM HUP

BYPASS_FLAG=""
if [[ "${CODEX_DANGEROUS_BYPASS:-1}" == "1" ]]; then
  BYPASS_FLAG="--dangerously-bypass-approvals-and-sandbox"
else
  BYPASS_FLAG="--full-auto"
fi

CODEX_ENV=(
  "TOKEN_API_SESSION_ID=${SESSION_ID}"
  "TOKEN_API_CODEX_BRIDGE_ID=${BRIDGE_ID}"
  "TOKEN_API_WRAPPER_LAUNCH_ID=${BRIDGE_ID}"
  "TOKEN_API_LAUNCHER=${LAUNCHER}"
  "TOKEN_API_ENGINE=codex"
  "TOKEN_API_DISPATCH_TARGET=${DISPATCH_TARGET}"
  "TOKEN_API_DISPATCH_WINDOW=${DISPATCH_WINDOW}"
  "TOKEN_API_DISPATCH_MODE=${DISPATCH_MODE}"
  "TOKEN_API_DISPATCH_SLOT=${DISPATCH_SLOT}"
  "TOKEN_API_DISPATCH_SESSION_DOC_PATH=${SESSION_DOC}"
  "TOKEN_API_TARGET_WORKING_DIR=${WORKING_DIR}"
  "TOKEN_API_LAUNCH_MODE=${LAUNCH_MODE}"
  "TOKEN_API_TRANSPLANT_EXPECTED=${TRANSPLANT_EXPECTED}"
  "TOKEN_API_DISPATCH_RESOLVED_PANE=${RESOLVED_TMUX_PANE}"
)

if [[ "${CODEX_HEADLESS:-0}" == "1" ]]; then
  OUTPUT_FILE="/tmp/codex-${SESSION_ID}.md"
  env "${CODEX_ENV[@]}" codex exec "$PROMPT" -C "$WORKING_DIR" $BYPASS_FLAG --json -o "$OUTPUT_FILE"
else
  env "${CODEX_ENV[@]}" codex "$PROMPT" -C "$WORKING_DIR" $BYPASS_FLAG
fi
