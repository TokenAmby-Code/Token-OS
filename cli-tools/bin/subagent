#!/usr/bin/env bash
# subagent - retired launcher alias
# TAGS: deprecated
# AUDIENCE: deprecated
set -euo pipefail
case "subagent" in
  inquisitor) replacement='dispatch --persona inquisition --prompt <task>' ;;
  subagent) replacement='dispatch --prompt <task>' ;;
esac
echo "subagent has been retired. Use: $replacement" >&2
exit 64
