#!/usr/bin/env bash
# 410 GONE tombstone: tmux CLI exterminatus 2026-06-30.
{
    cat >&2 <<'__TMUX_410_TOMBSTONE__'
410 GONE: cli-tools/bin/tmux-tombstone (tmux-tombstone) is tombstoned by the 2026-06-30 tmux CLI exterminatus.
This cold tmux feature surface must not be used as an active runtime/control path.
Daemon-native replacement: tmuxctld POST /tombstone/install or POST /tombstone/jump.
Original body is retained below this early-return as the emergency restore lever; lift only this tombstone block to prove an active blocker, build/cut over the daemon-native replacement, then restore the 410.
__TMUX_410_TOMBSTONE__
}
return 410 2>/dev/null || exit 410

# --- ORIGINAL BODY BELOW: emergency restore lever, intentionally dead under the 410. ---
# tmux-tombstone - Placeholder process for relocated managed tmux panes.
# TAGS: tmux, audience
# AUDIENCE: human

set -euo pipefail

SOURCE="${1:-${TOMBSTONE_SOURCE:-unknown}}"
TARGET="${2:-${TOMBSTONE_TARGET:-unknown}}"

pane_label() {
    local target="$1" label=""
    if [[ -n "$target" && "$target" != "unknown" ]]; then
        label=$(tmux show-options -pv -t "$target" @PANE_ID 2>/dev/null || true)
    fi
    label="${label#audience:}"
    printf '%s\n' "${label:-$target}"
}

if [[ -n "${TMUX_PANE:-}" ]]; then
    tmux set-option -p -t "$TMUX_PANE" @PANE_TYPE "tombstone" 2>/dev/null || true
    tmux set-option -p -t "$TMUX_PANE" @TOMBSTONE_SOURCE "$SOURCE" 2>/dev/null || true
    tmux set-option -p -t "$TMUX_PANE" @TOMBSTONE_TARGET "$TARGET" 2>/dev/null || true
fi

while true; do
    DISPLAY_SOURCE="$(pane_label "$SOURCE")"
    DISPLAY_TARGET="$(pane_label "$TARGET")"
    clear
    cat <<EOF
TOMBSTONE

slot:   ${DISPLAY_SOURCE}
target: ${DISPLAY_TARGET}

prefix + d jumps to the live pane.
prefix + e only native-zooms this tombstone pane.
EOF
    sleep 3600 &
    wait $! || true
done
