#!/usr/bin/env bash
# tmux-tombstone - Placeholder process for relocated managed tmux panes.
# TAGS: tmux, audience
# AUDIENCE: human

set -euo pipefail

SOURCE="${1:-${TOMBSTONE_SOURCE:-unknown}}"
TARGET="${2:-${TOMBSTONE_TARGET:-unknown}}"

pane_label() {
    local target="$1" label=""
    if [[ -n "$target" && "$target" != "unknown" ]]; then
        label=$(tmux show-options -pv -t "$target" @PANE_ID 2>/dev/null || true)
    fi
    label="${label#audience:}"
    printf '%s\n' "${label:-$target}"
}

if [[ -n "${TMUX_PANE:-}" ]]; then
    tmux set-option -p -t "$TMUX_PANE" @PANE_TYPE "tombstone" 2>/dev/null || true
    tmux set-option -p -t "$TMUX_PANE" @TOMBSTONE_SOURCE "$SOURCE" 2>/dev/null || true
    tmux set-option -p -t "$TMUX_PANE" @TOMBSTONE_TARGET "$TARGET" 2>/dev/null || true
fi

while true; do
    DISPLAY_SOURCE="$(pane_label "$SOURCE")"
    DISPLAY_TARGET="$(pane_label "$TARGET")"
    clear
    cat <<EOF
TOMBSTONE

slot:   ${DISPLAY_SOURCE}
target: ${DISPLAY_TARGET}

prefix + d jumps to the live pane.
prefix + e only native-zooms this tombstone pane.
EOF
    sleep 3600 &
    wait $! || true
done
