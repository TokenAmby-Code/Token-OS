#!/usr/bin/env bash
# 410 GONE tombstone: tmux CLI exterminatus 2026-06-30.
{
    cat >&2 <<'__TMUX_410_TOMBSTONE__'
410 GONE: cli-tools/bin/tmux-pane-rename (tmux-pane-rename) is tombstoned by the 2026-06-30 tmux CLI exterminatus.
This cold tmux feature surface must not be used as an active runtime/control path.
Daemon-native replacement: Token-API instance rename plus tmuxctld pane metadata route TBD.
Original body is retained below this early-return as the emergency restore lever; lift only this tombstone block to prove an active blocker, build/cut over the daemon-native replacement, then restore the 410.
__TMUX_410_TOMBSTONE__
}
return 410 2>/dev/null || exit 410

# --- ORIGINAL BODY BELOW: emergency restore lever, intentionally dead under the 410. ---
# tmux-pane-rename - Rename the Token-API instance bound to a tmux pane
# TAGS: tmux, instance
# AUDIENCE: human

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

API_URL="${TOKEN_API_URL:-http://localhost:7777}"
PANE="${1:-}"
NAME="${2:-}"

# Pane is always required; an empty NAME is valid and triggers the interview.
if [[ -z "$PANE" ]]; then
    tmux display-message "rename: pane required" 2>/dev/null || true
    exit 1
fi

INSTANCES=$(curl -s --connect-timeout 2 "$API_URL/api/instances" 2>/dev/null || true)
INSTANCE_ID=$(printf '%s' "$INSTANCES" | jq -r --arg pane "$PANE" \
    '.[] | select(.tmux_pane == $pane and (.status != "stopped")) | .id' 2>/dev/null | head -1)

if [[ -z "$INSTANCE_ID" || "$INSTANCE_ID" == "null" ]]; then
    tmux display-message "rename: no active instance for $PANE" 2>/dev/null || true
    exit 1
fi

# Empty input → interview: ask the agent to name itself (no synthesis here).
if [[ -z "$NAME" ]]; then
    PAYLOAD=$(jq -n --arg id "$INSTANCE_ID" '{instance_id: $id}')
    HTTP_CODE=$(curl -s -o /dev/null -w '%{http_code}' --connect-timeout 2 \
        -X POST "$API_URL/api/orchestrator/naming_nudge" \
        -H "Content-Type: application/json" -d "$PAYLOAD" 2>/dev/null || true)
    if [[ "$HTTP_CODE" == 2* ]]; then
        tmux display-message "interview: asked $INSTANCE_ID to name itself" 2>/dev/null || true
    else
        tmux display-message "interview: request failed (HTTP ${HTTP_CODE:-?})" 2>/dev/null || true
    fi
    exit 0
fi

if RESPONSE=$(instance-name "$NAME" --id "$INSTANCE_ID" --no-ui 2>&1); then
    INSTANCE_DATA=$(curl -s --connect-timeout 2 "$API_URL/api/instances/$INSTANCE_ID" 2>/dev/null || true)
    TAB_NAME=$(printf '%s' "$INSTANCE_DATA" | jq -r '.tab_name // empty' 2>/dev/null || true)
    if [[ -n "$TAB_NAME" ]]; then
        claude-cmd --instance "$INSTANCE_ID" "/rename $TAB_NAME" >/dev/null 2>&1 || true
    fi
    tmux display-message "${RESPONSE}; sent /rename ${TAB_NAME:-$NAME}" 2>/dev/null || true
else
    tmux display-message "rename failed: $RESPONSE" 2>/dev/null || true
    exit 1
fi
