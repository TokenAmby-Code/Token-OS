#!/usr/bin/env bash
# tmux-pane-rename - Rename the Token-API instance bound to a tmux pane
# TAGS: tmux, instance
# AUDIENCE: human

set -euo pipefail

_BIN_DIR="$(dirname "$(readlink -f "$0")")"
_LIB_DIR="${_BIN_DIR}/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

API_URL="${TOKEN_API_URL:-http://localhost:7777}"
PANE="${1:-}"
NAME="${2:-}"

if [[ -z "$PANE" ]]; then
    tmux display-message "rename: pane required" 2>/dev/null || true
    exit 1
fi

INSTANCE_ID=$(tmux show-options -pv -t "$PANE" @INSTANCE_ID 2>/dev/null | head -1 || true)
if [[ -z "$INSTANCE_ID" ]]; then
    tmux display-message "rename: no @INSTANCE_ID on $PANE" 2>/dev/null || true
    exit 1
fi

if [[ -z "$NAME" ]]; then
    PAYLOAD=$(jq -n --arg id "$INSTANCE_ID" '{instance_id: $id}')
    HTTP_CODE=$(curl -s -o /dev/null -w '%{http_code}' --connect-timeout 2 \
        -X POST "$API_URL/api/orchestrator/naming_nudge" \
        -H "Content-Type: application/json" -d "$PAYLOAD" 2>/dev/null || true)
    if [[ "$HTTP_CODE" == 2* ]]; then
        tmux display-message "interview: asked $INSTANCE_ID to name itself" 2>/dev/null || true
    else
        tmux display-message "interview: request failed (HTTP ${HTTP_CODE:-?})" 2>/dev/null || true
    fi
    exit 0
fi

RESPONSE=$(jq -n --arg tab_name "$NAME" '{tab_name: $tab_name}' \
    | curl -s -X PATCH "$API_URL/api/instances/$INSTANCE_ID/rename" \
        -H "Content-Type: application/json" \
        --data-binary @- 2>/dev/null || true)

if echo "$RESPONSE" | jq -e '.status == "renamed"' >/dev/null 2>&1; then
    TAB_NAME=$(printf '%s' "$RESPONSE" | jq -r '.tab_name // empty' 2>/dev/null || true)
    TAB_NAME="${TAB_NAME:-$NAME}"
    "${_BIN_DIR}/agent-cmd" --pane "$PANE" "/rename $TAB_NAME" >/dev/null 2>&1 || true
    tmux display-message "Renamed to: $TAB_NAME; sent /rename $TAB_NAME" 2>/dev/null || true
else
    DETAIL=$(echo "$RESPONSE" | jq -r '.detail // "rename failed"' 2>/dev/null || echo "rename failed")
    tmux display-message "rename failed: $DETAIL" 2>/dev/null || true
    exit 1
fi
