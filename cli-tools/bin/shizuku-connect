#!/bin/bash
# shizuku-connect - Manage persistent ADB connection to phone for Shizuku
# TAGS: mobile, shizuku, adb
# AUDIENCE: human, agent
#
# Connects to phone over Tailscale ADB (port 5555) so Shizuku can use
# "Connected to a computer" mode, which is far more stable than wireless debugging.
#
# Usage:
#   shizuku-connect              # Connect (or reconnect) to phone
#   shizuku-connect status       # Check connection status
#   shizuku-connect bootstrap    # One-time setup: pair + enable TCP mode
#   shizuku-connect disconnect   # Disconnect ADB from phone

set -e

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

PHONE_TAILSCALE_IP="$(imperium_cfg tailscale_ip phone)"
ADB_PORT=5555
PHONE_TARGET="${PHONE_TAILSCALE_IP}:${ADB_PORT}"
LOG_FILE="$HOME/.claude/shizuku-connect.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
    echo "$*"
}

is_connected() {
    adb devices 2>/dev/null | grep -q "${PHONE_TARGET}.*device$"
}

cmd_status() {
    if is_connected; then
        log "Connected to ${PHONE_TARGET}"
        adb -s "$PHONE_TARGET" shell "dumpsys package moe.shizuku.privileged.api 2>/dev/null | grep -A2 'MAIN'" 2>/dev/null || true
        return 0
    else
        log "Not connected to ${PHONE_TARGET}"
        adb devices 2>/dev/null
        return 1
    fi
}

cmd_connect() {
    if is_connected; then
        echo "Already connected to ${PHONE_TARGET}"
        return 0
    fi

    log "Connecting to ${PHONE_TARGET}..."

    # Kill any stale ADB server state
    adb disconnect "$PHONE_TARGET" 2>/dev/null || true

    # Connect over Tailscale
    output=$(adb connect "$PHONE_TARGET" 2>&1)
    log "adb connect: $output"

    # Verify
    sleep 1
    if is_connected; then
        log "Successfully connected to phone"

        # Notify phone via MacroDroid
        curl -sf "http://${PHONE_TAILSCALE_IP}:7777/notify?title=ADB+Connected&text=Shizuku+ADB+restored+from+Mac" \
            --connect-timeout 3 2>/dev/null || true

        return 0
    else
        log "Failed to connect — phone may need adb tcpip 5555 (run: shizuku-connect bootstrap)"
        return 1
    fi
}

cmd_disconnect() {
    log "Disconnecting from ${PHONE_TARGET}..."
    adb disconnect "$PHONE_TARGET" 2>&1
    log "Disconnected"
}

cmd_bootstrap() {
    cat << 'EOF'
=== Shizuku ADB Bootstrap (one-time setup) ===

This sets up persistent ADB over TCP so Shizuku can use "Connected to a computer" mode.

Steps:
1. On phone: Settings > Developer Options > Wireless Debugging > ON
2. Tap "Pair device with pairing code" — note the IP:PORT and CODE

EOF
    read -rp "Enter pairing address (e.g., 192.168.0.89:37123): " pair_addr
    read -rp "Enter pairing code (e.g., 482916): " pair_code

    echo ""
    log "Pairing with ${pair_addr}..."
    adb pair "$pair_addr" "$pair_code"

    echo ""
    # The wireless debugging port is different from the pairing port
    read -rp "Enter wireless debugging port (shown under 'Wireless debugging' header, e.g., 43567): " debug_port
    local_ip=$(echo "$pair_addr" | cut -d: -f1)
    connect_addr="${local_ip}:${debug_port}"

    log "Connecting to ${connect_addr}..."
    adb connect "$connect_addr"

    sleep 1

    # Disconnect mDNS auto-discovered device to avoid "more than one device" error
    for dev in $(adb devices 2>/dev/null | grep '_adb-tls' | awk '{print $1}'); do
        log "Disconnecting mDNS device: $dev"
        adb disconnect "$dev" 2>/dev/null || true
    done

    log "Setting ADB to TCP mode on port ${ADB_PORT}..."
    adb -s "$connect_addr" tcpip "$ADB_PORT"

    sleep 2

    log "Disconnecting local WiFi connection..."
    adb disconnect "$connect_addr" 2>/dev/null || true

    log "Connecting over Tailscale to ${PHONE_TARGET}..."
    adb connect "$PHONE_TARGET"

    sleep 1

    if is_connected; then
        log "Bootstrap complete! Phone ADB is now accessible over Tailscale."
        echo ""
        echo "Next steps:"
        echo "  1. Open Shizuku on phone"
        echo "  2. Select 'Start via connecting to a computer'"
        echo "  3. Shizuku should detect the ADB connection automatically"
        echo ""
        echo "You can now disable Wireless Debugging — the TCP connection persists."
        echo "Note: A phone reboot will require re-running 'shizuku-connect bootstrap'."
    else
        log "Bootstrap failed — could not connect over Tailscale"
        echo "Check that Tailscale is active on both devices."
        return 1
    fi
}

cmd_start_shizuku() {
    if ! is_connected; then
        log "Cannot start Shizuku — ADB not connected"
        return 1
    fi

    log "Starting Shizuku server via ADB..."
    adb -s "$PHONE_TARGET" shell sh /sdcard/Android/data/moe.shizuku.privileged.api/start.sh 2>&1
    sleep 1

    if adb -s "$PHONE_TARGET" shell "ps -ef" 2>/dev/null | grep -q "shizuku_server"; then
        log "Shizuku server is running"
        return 0
    else
        log "Shizuku server failed to start"
        return 1
    fi
}

is_shizuku_running() {
    adb -s "$PHONE_TARGET" shell "ps -ef" 2>/dev/null | grep -q "shizuku_server"
}

# Cron/LaunchAgent mode: silent reconnect + ensure Shizuku is running
cmd_keepalive() {
    # Ensure ADB connection
    if is_connected; then
        # Verify the connection actually works (not stale)
        if ! adb -s "$PHONE_TARGET" shell "echo ok" 2>/dev/null | grep -q "ok"; then
            log "Connection stale, reconnecting..."
            adb disconnect "$PHONE_TARGET" 2>/dev/null || true
            adb connect "$PHONE_TARGET" >/dev/null 2>&1
            sleep 1
            if ! is_connected; then
                log "Keepalive: failed to reconnect"
                exit 1
            fi
            log "Keepalive: reconnected to phone"
        fi
    else
        adb connect "$PHONE_TARGET" >/dev/null 2>&1
        sleep 1
        if is_connected; then
            log "Keepalive: reconnected to phone"
            curl -sf "${TOKEN_API_URL:-http://localhost:7777}/phone/event" \
                -X POST \
                -H "Content-Type: application/json" \
                -d '{"event": "shizuku_adb_reconnected", "source": "mac_keepalive"}' \
                --connect-timeout 3 2>/dev/null || true
        else
            log "Keepalive: failed to connect to phone"
            exit 1
        fi
    fi

    # Ensure Shizuku server is running
    if ! is_shizuku_running; then
        log "Keepalive: Shizuku not running, restarting..."
        cmd_start_shizuku
    fi
}

case "${1:-connect}" in
    status)     cmd_status ;;
    connect)    cmd_connect ;;
    disconnect) cmd_disconnect ;;
    bootstrap)  cmd_bootstrap ;;
    keepalive)  cmd_keepalive ;;
    start)      cmd_start_shizuku ;;
    *)
        echo "Usage: shizuku-connect [status|connect|disconnect|bootstrap|start|keepalive]"
        exit 1
        ;;
esac
