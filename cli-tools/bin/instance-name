#!/usr/bin/env bash
# Instance Name - Rename current session in Token-API registry
# TAGS: instance
# AUDIENCE: agent
#
# Usage: instance-name <name> [--id <instance-id>] [--session [title]] [--session-id N] [--path dir]
#
# Examples:
#   instance-name "auth-refactor"
#   instance-name "fix-bug" --id abc123

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

API_URL="${TOKEN_API_URL:-http://localhost:7777}"

# Help
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    cat << 'EOF'
Instance Name - Rename current session in Token-API registry

Usage: instance-name <name> [--id <instance-id>] [--session [title]] [--session-id N] [--path dir]

Sets the display name for this Claude Code session in the Token-API
registry dashboard. The name helps identify what you're working on.

Options:
  --id <id>          Explicit instance ID (for ambiguous cases)
  --no-ui            Skip Claude Code /rename (for headless/cron)
  --session          Create a session doc named after the instance and assign it
  --session <title>  Find existing session doc by title (fuzzy) and assign it
  --session-id <N>   Assign to existing session doc by ID
  --path <dir>       Override sessions directory (for --session create)

Instance Resolution (in order):
  1. --id flag if provided
  2. PID-based lookup via ~/.claude/session-pids/<claude-pid>
  3. PID field match in API instances list
  4. CWD match (processing instances preferred over idle)

Examples:
  instance-name "auth-refactor"
  instance-name "fix-bug-123"
  instance-name "feature/payments" --id abc123-def456
  instance-name "my-feature" --session                   # Create + assign session doc
  instance-name "my-feature" --session "existing-doc"    # Fuzzy match + assign
  instance-name "my-feature" --session-id 3              # Assign by ID
EOF
    exit 0
fi

# Parse arguments
NAME=""
EXPLICIT_ID=""
SESSION_FLAG=""
SESSION_ID=""
SESSION_PATH=""
NO_UI="${NO_UI:-0}"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --id)
            EXPLICIT_ID="$2"
            shift 2
            ;;
        --no-ui)
            NO_UI=1
            shift
            ;;
        --session)
            if [[ "${2:-}" =~ ^[0-9]+$ ]] || [[ "${2:-}" == --* ]] || [[ -z "${2:-}" ]]; then
                SESSION_FLAG="create"
                shift
            else
                SESSION_FLAG="assign-fuzzy"
                SESSION_ID="$2"
                shift 2
            fi
            ;;
        --session-id)
            SESSION_FLAG="assign-id"
            SESSION_ID="$2"
            shift 2
            ;;
        --path)
            SESSION_PATH="$2"
            shift 2
            ;;
        *)
            NAME="$1"
            shift
            ;;
    esac
done

# Require and validate name. Agents invoke this as `instance-name '<slug>'`.
if [[ -z "$NAME" ]]; then
    echo "Usage: instance-name <name> [--id <instance-id>] [--session [title]] [--session-id N] [--path dir]" >&2
    exit 2
fi

RAW_NAME="$NAME"
RAW_NAME="${RAW_NAME#✳ }"
RAW_NAME="${RAW_NAME#✳}"
RAW_NAME="$(printf '%s' "$RAW_NAME" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
if [[ -z "$RAW_NAME" ]]; then
    echo "Error: name cannot be empty" >&2
    exit 2
fi
if [[ ${#RAW_NAME} -gt 40 ]]; then
    echo "Error: name must be 40 characters or fewer" >&2
    exit 2
fi
if [[ "$RAW_NAME" =~ ^Claude[[:space:]][0-9]{2}:[0-9]{2}$ ]]; then
    echo "Error: name cannot be a placeholder like 'Claude HH:MM'" >&2
    exit 2
fi

# Preserve historical kebab-case behavior for the display slug.
NAME=$(echo "$RAW_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9 -]//g' | tr -s ' ' '-' | sed 's/^-//;s/-$//')
NAME=$(echo "$NAME" | cut -d- -f1-4)
if [[ -z "$NAME" ]]; then
    echo "Error: name cannot be empty after normalization" >&2
    exit 2
fi
if [[ ${#NAME} -gt 40 ]]; then
    echo "Error: normalized name must be 40 characters or fewer" >&2
    exit 2
fi

# Find parent claude process PID by walking up the process tree
_find_claude_pid() {
    local current="$PPID"
    local comm
    for _ in 1 2 3 4 5; do
        [[ -z "$current" || "$current" == "1" ]] && break
        comm=$(basename "$(ps -o comm= -p "$current" 2>/dev/null)" 2>/dev/null || true)
        if [[ "$comm" == "claude" ]]; then
            echo "$current"
            return 0
        fi
        current=$(ps -o ppid= -p "$current" 2>/dev/null | tr -d ' ' || true)
    done
    return 1
}

# Resolve and rename. The default path reads this pane's live @INSTANCE_ID
# stamp from tmux and uses the instance-id API; tmux is the runtime authority.
if [[ -n "$EXPLICIT_ID" ]]; then
    INSTANCE_ID="$EXPLICIT_ID"
else
    TMUX_PANE_ID="${TMUX_PANE:-}"
    if [[ -z "$TMUX_PANE_ID" ]]; then
        echo "Error: TMUX_PANE is not set; run this inside an active tmux pane" >&2
        exit 2
    fi
    INSTANCE_ID=$(tmux show-options -pv -t "$TMUX_PANE_ID" @INSTANCE_ID 2>/dev/null | head -1 || true)
    if [[ -z "$INSTANCE_ID" ]]; then
        echo "Error: pane $TMUX_PANE_ID has no @INSTANCE_ID" >&2
        exit 1
    fi
fi

RESPONSE=$(jq -n --arg tab_name "$NAME" '{tab_name: $tab_name}'     | curl -s -X PATCH "$API_URL/api/instances/$INSTANCE_ID/rename"         -H "Content-Type: application/json"         --data-binary @- 2>/dev/null || true)

if echo "$RESPONSE" | jq -e '.status == "renamed"' >/dev/null 2>&1; then
    echo "Renamed to: $NAME"

    # Queue /rename for next UserPromptSubmit (avoids collision with user typing).
    # pending-ui-flush tags the entry with this session's epoch + a timestamp so a
    # recycled pane never inherits it, it expires if never drained, and the drain
    # holds while the pane is being typed in — see cli-tools/bin/pending-ui-flush.
    if [[ "$NO_UI" != "1" ]]; then
        PANE=$(agent-cmd --self --resolve-only 2>/dev/null || true)

        if [[ -n "$PANE" ]]; then
            _BIN_DIR="$(dirname "$(readlink -f "$0")")"
            AGENT_PID=$(_find_claude_pid || true)
            AGENT_EPOCH=""
            if [[ -n "$AGENT_PID" && -f "${HOME}/.claude/session-pids/${AGENT_PID}" ]]; then
                AGENT_EPOCH=$(cat "${HOME}/.claude/session-pids/${AGENT_PID}" 2>/dev/null || true)
            fi

            if [[ -n "$AGENT_EPOCH" && "$AGENT_EPOCH" != "-" ]]; then
                ENQ_ARGS=(enqueue --pane "$PANE" --session "$AGENT_EPOCH" --rename "$NAME")
                "${_BIN_DIR}/pending-ui-flush" "${ENQ_ARGS[@]}" >/dev/null 2>&1 || true
                echo "Queued: /rename $NAME (fires on next prompt submit)"
            else
                echo "Skipped UI queue: no agent session epoch for $PANE" >&2
            fi
        fi
    fi

    # Handle session document if requested
    if [[ -n "$SESSION_FLAG" ]]; then
        case "$SESSION_FLAG" in
            create)
                CREATE_BODY="{\"title\": \"$NAME\"}"
                if [[ -n "$SESSION_PATH" ]]; then
                    FULL_PATH="${SESSION_PATH%/}/${NAME}.md"
                    CREATE_BODY="{\"title\": \"$NAME\", \"file_path\": \"$FULL_PATH\"}"
                fi
                SESSION_RESP=$(curl -s -X POST "$API_URL/api/instances/$INSTANCE_ID/create-doc" \
                    -H "Content-Type: application/json" \
                    -d "$CREATE_BODY" 2>/dev/null || true)
                if echo "$SESSION_RESP" | jq -e '.id' >/dev/null 2>&1; then
                    DOC_PATH=$(echo "$SESSION_RESP" | jq -r '.file_path')
                    echo "Session doc: $DOC_PATH"
                else
                    echo "Warning: session doc creation failed" >&2
                fi
                ;;
            assign-id)
                ASSIGN_RESP=$(curl -s -X POST "$API_URL/api/instances/$INSTANCE_ID/assign-doc?doc_id=$SESSION_ID" 2>/dev/null || true)
                if echo "$ASSIGN_RESP" | jq -e '.assigned == true' >/dev/null 2>&1; then
                    DOC_ID=$(echo "$ASSIGN_RESP" | jq -r '.doc_id')
                    echo "Assigned to session doc: $DOC_ID"
                else
                    echo "Warning: session doc assignment failed" >&2
                fi
                ;;
            assign-fuzzy)
                DOCS=$(curl -s "$API_URL/api/session-docs?status=active" 2>/dev/null || true)
                DOC_ID=$(echo "$DOCS" | jq -r --arg t "$SESSION_ID" \
                    '[.[] | select(.title | ascii_downcase | contains($t | ascii_downcase))] | .[0].id // ""' 2>/dev/null || true)
                if [[ -n "$DOC_ID" && "$DOC_ID" != "null" ]]; then
                    ASSIGN_RESP=$(curl -s -X POST "$API_URL/api/instances/$INSTANCE_ID/assign-doc?doc_id=$DOC_ID" 2>/dev/null || true)
                    DOC_PATH=$(echo "$ASSIGN_RESP" | jq -r '.file_path // "unknown"')
                    echo "Assigned to session: $DOC_PATH"
                else
                    echo "Warning: no session doc matching '$SESSION_ID' found" >&2
                fi
                ;;
        esac
    fi
else
    echo "Error: $(echo "$RESPONSE" | jq -r '.detail // "rename failed"' 2>/dev/null || echo "rename failed")" >&2
    exit 1
fi
