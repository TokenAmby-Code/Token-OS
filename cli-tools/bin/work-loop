#!/usr/bin/env bash
# work-loop — Full vault-to-worktree-to-vault work cycle orchestration
# TAGS: workflow, dispatch, worktree, orchestration
# AUDIENCE: human, agent, voice
#
# The work loop: vault context → worktree → implement → PR → merge → cleanup
#
# Usage:
#   work-loop dispatch <session-doc> [options]    # Launch autonomous work cycle
#   work-loop complete [options]                   # Wrap up: merge, cleanup, exit
#   work-loop status                               # Show active work-loop panes
#
# Dispatch creates a backrooms pane, launches Claude in the vault, and briefs it
# to create a worktree, transplant, and work autonomously. Callable from any
# instance, voice injection, or directly.
#
# Complete is called BY the dispatched instance when work is done. It merges the
# PR, updates the session doc, and exits — returning the pane to a bare shell.
#
# Examples:
#   work-loop dispatch Mars/Sessions/2026-04-04-auth-fix.md
#   work-loop dispatch Mars/Sessions/2026-04-04-auth-fix.md --branch auth-fix
#   work-loop dispatch Mars/Sessions/2026-04-04-auth-fix.md --primarch vulkan
#   work-loop dispatch Mars/Sessions/2026-04-04-auth-fix.md --pane %12
#   work-loop dispatch Mars/Sessions/2026-04-04-auth-fix.md --dry-run
#   work-loop complete
#   work-loop complete --session-doc Mars/Sessions/2026-04-04-auth-fix.md
#   work-loop complete --no-merge
#   work-loop status

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true
source "${_LIB_DIR}/pane-id.sh" 2>/dev/null || true

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}>${NC} $1"; }
log_success() { echo -e "${GREEN}+${NC} $1"; }
log_warn()    { echo -e "${YELLOW}!${NC} $1"; }
log_error()   { echo -e "${RED}x${NC} $1"; }
log_dry()     { echo -e "${CYAN}~${NC} $1"; }

# --- Vault path ---
VAULT_DIR="${IMPERIUM}/Imperium-ENV"

# --- Backrooms pane management ---
# Split a new pane in the backrooms window. Returns the new pane ID.
split_backrooms_pane() {
    local session="${1:-main}"

    # Check if backrooms window exists
    if ! tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null | grep -q '^backrooms$'; then
        log_error "No backrooms window in session '$session'"
        echo "  Create one with: tmux-workspace"
        return 1
    fi

    # Get the first pane in backrooms to split from
    local base_pane
    base_pane=$(tmux list-panes -t "${session}:backrooms" -F '#{pane_id}' 2>/dev/null | head -1)

    if [[ -z "$base_pane" ]]; then
        log_error "No panes in backrooms window"
        return 1
    fi

    # Split horizontally (side-by-side) from the base pane
    # -d: don't switch focus, -P: print new pane info, -F: format
    local new_pane
    new_pane=$(tmux split-window -h -t "$base_pane" -d -P -F '#{pane_id}' -c "$HOME" 2>/dev/null)

    if [[ -z "$new_pane" ]]; then
        # Horizontal split failed (too narrow), try vertical
        new_pane=$(tmux split-window -v -t "$base_pane" -d -P -F '#{pane_id}' -c "$HOME" 2>/dev/null)
    fi

    if [[ -z "$new_pane" ]]; then
        log_error "Could not split backrooms pane (window too small?)"
        return 1
    fi

    # Tag it as a work-loop pane
    tmux set-option -p -t "$new_pane" @PANE_TYPE "work-loop" 2>/dev/null || true

    echo "$new_pane"
}

# List work-loop panes in backrooms
list_workloop_panes() {
    local session="${1:-main}"
    local panes=()

    while IFS=$'\t' read -r pane_id pane_type cmd window_name; do
        [[ "$window_name" == "backrooms" ]] || continue
        [[ "$pane_type" == "work-loop" ]] || continue
        panes+=("$pane_id")
    done < <(tmux list-panes -a -F "#{pane_id}	#{@PANE_TYPE}	#{pane_current_command}	#{window_name}" 2>/dev/null)

    printf '%s\n' "${panes[@]+"${panes[@]}"}"
}

# --- Branch name generation ---
# Derive a branch name from a session doc path
# Mars/Sessions/2026-04-04-auth-fix.md → auth-fix
derive_branch_name() {
    local session_doc="$1"
    local basename
    basename=$(basename "$session_doc" .md)
    # Strip date prefix (YYYY-MM-DD-)
    echo "$basename" | sed 's/^[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}-//'
}

# --- Project detection ---
# Detect project from vault context (same logic as worktree-setup)
detect_project() {
    echo "Token-OS"
}

# --- Dispatch prompt builder ---
build_dispatch_prompt() {
    local session_doc="$1"
    local branch_name="$2"
    local project="$3"
    local primarch_name="${4:-}"
    local extra_context="${5:-}"
    local zealotry="${6:-3}"

    cat << PROMPT
You are dispatched into the work loop. Your mission:

1. READ your session doc: ${session_doc}
   - Follow wikilinks to related session docs, task notes, and architecture references
   - Understand what needs to be done and what's already been done

2. CREATE a worktree and transplant:
   worktree-setup ${branch_name} --project ${project}
   (worktree-setup will auto-transplant you into the new worktree)

3. IMPLEMENT the task described in your session doc:
   - Act autonomously on clear tasks
   - Make judgment calls — don't stall on missing input
   - Update your session doc work log as you go
   - Escalate ambiguity via discord send if needed

4. CREATE a PR when implementation is complete:
   pr-create --title "<concise title>" --body "<summary>"
   - Wait for review comments and address them

5. WHEN PR IS APPROVED AND MERGED, wrap up:
   work-loop complete --session-doc ${session_doc}
   This will clean up the worktree and update your session doc.

IMPORTANT:
- Do NOT use TTS
- Do NOT block on AskUserQuestion — make judgment calls instead
- You are running in a backrooms pane — this is autonomous background work
- Your zealotry level is ${zealotry} (1=minimal follow-up, 5=aggressive)
PROMPT

    if [[ -n "$primarch_name" ]]; then
        echo "- You are operating as primarch: ${primarch_name}"
    fi

    if [[ -n "$extra_context" ]]; then
        echo ""
        echo "Additional context: ${extra_context}"
    fi
}

# ═══════════════════════════════════════════════════════════════
# DISPATCH subcommand
# ═══════════════════════════════════════════════════════════════
do_dispatch() {
    local session_doc=""
    local branch_name=""
    local project=""
    local target_pane=""
    local primarch_name=""
    local zealotry=3
    local extra_context=""
    local dry_run=false
    local no_backrooms=false

    # Parse dispatch-specific args
    while [[ $# -gt 0 ]]; do
        case $1 in
            --branch)     branch_name="$2"; shift 2 ;;
            --project)    project="$2"; shift 2 ;;
            --pane)       target_pane="$2"; no_backrooms=true; shift 2 ;;
            --primarch)   primarch_name="$2"; shift 2 ;;
            --zealotry)   zealotry="$2"; shift 2 ;;
            --context)    extra_context="$2"; shift 2 ;;
            --dry-run)    dry_run=true; shift ;;
            -*)           log_error "Unknown option: $1"; exit 1 ;;
            *)
                if [[ -z "$session_doc" ]]; then
                    session_doc="$1"
                else
                    log_error "Too many arguments"; exit 1
                fi
                shift ;;
        esac
    done

    # --- Validate ---
    if [[ -z "$session_doc" ]]; then
        log_error "Session doc required"
        echo "Usage: work-loop dispatch <session-doc> [options]"
        exit 1
    fi

    # Resolve full path
    if [[ ! -f "${VAULT_DIR}/${session_doc}" ]]; then
        log_error "Session doc not found: ${VAULT_DIR}/${session_doc}"
        exit 1
    fi

    # Auto-derive branch name
    if [[ -z "$branch_name" ]]; then
        branch_name=$(derive_branch_name "$session_doc")
    fi

    # Auto-detect project
    if [[ -z "$project" ]]; then
        project=$(detect_project)
    fi

    # --- Check tmux ---
    if ! tmux display-message -p '#{session_name}' &>/dev/null; then
        log_error "Not in tmux — work-loop requires tmux"
        exit 1
    fi

    local tmux_session
    tmux_session=$(tmux display-message -p '#{session_name}' 2>/dev/null || echo "main")

    # --- Resolve pane ---
    if [[ -z "$target_pane" ]]; then
        target_pane=$(split_backrooms_pane "$tmux_session")
        if [[ -z "$target_pane" ]]; then
            log_error "Could not create backrooms pane"
            exit 1
        fi
        log_success "Split backrooms pane: $target_pane"
    else
        if ! tmux display-message -t "$target_pane" -p '#{pane_id}' &>/dev/null; then
            log_error "Pane not found: $target_pane"
            exit 1
        fi
        log_success "Using specified pane: $target_pane"
    fi

    # --- Build dispatch prompt ---
    local dispatch_prompt
    dispatch_prompt=$(build_dispatch_prompt "$session_doc" "$branch_name" "$project" "$primarch_name" "$extra_context" "$zealotry")

    # --- Resolve claude binary ---
    local claude_bin
    claude_bin=$(command -v claude 2>/dev/null || echo "\$HOME/.local/bin/claude")

    # --- Store metadata on the pane for status/tracking ---
    tmux set-option -p -t "$target_pane" @WORKLOOP_SESSION_DOC "$session_doc" 2>/dev/null || true
    tmux set-option -p -t "$target_pane" @WORKLOOP_BRANCH "$branch_name" 2>/dev/null || true
    tmux set-option -p -t "$target_pane" @WORKLOOP_PROJECT "$project" 2>/dev/null || true
    tmux set-option -p -t "$target_pane" @WORKLOOP_DISPATCHED "$(date -Iseconds)" 2>/dev/null || true

    # --- Display summary ---
    echo ""
    echo -e "${BOLD}=========================================${NC}"
    echo -e "${BOLD} Work Loop — Dispatch${NC}"
    echo -e "${BOLD}=========================================${NC}"
    echo ""
    echo -e "  ${DIM}Session doc:${NC}  $session_doc"
    echo -e "  ${DIM}Branch:${NC}       $branch_name"
    echo -e "  ${DIM}Project:${NC}      $project"
    echo -e "  ${DIM}Pane:${NC}         $target_pane"
    [[ -n "$primarch_name" ]] && echo -e "  ${DIM}Primarch:${NC}    $primarch_name"
    echo -e "  ${DIM}Zealotry:${NC}    $zealotry"
    echo ""

    # --- Dry run ---
    if $dry_run; then
        log_dry "DRY RUN — no changes will be made"
        echo ""
        log_dry "Claude binary: ${claude_bin}"
        [[ -n "$primarch_name" ]] && log_dry "Via primarch: ${primarch_name}"
        log_dry "Working dir: ${VAULT_DIR}"
        echo ""
        log_dry "Dispatch prompt:"
        echo -e "${DIM}"
        echo "$dispatch_prompt" | sed 's/^/  /'
        echo -e "${NC}"
        # Kill the pane we split (if we created one)
        if [[ "$no_backrooms" != "true" ]]; then
            tmux kill-pane -t "$target_pane" 2>/dev/null || true
        fi
        exit 0
    fi

    # --- Execute dispatch ---
    log_info "Dispatching to pane $target_pane..."

    # Write prompt to temp file (multi-line prompts can't survive tmux send-keys)
    local prompt_file="/tmp/work-loop-prompt-$$.txt"
    echo "$dispatch_prompt" > "$prompt_file"

    # Clear the pane
    tmux send-keys -t "$target_pane" "clear" Enter
    sleep 0.3

    # Build and send the launch command — reads prompt from temp file, then cleans up
    if [[ -n "$primarch_name" ]]; then
        tmux send-keys -t "$target_pane" "cd '${VAULT_DIR}' && primarch ${primarch_name} \"\$(cat ${prompt_file})\" ; rm -f ${prompt_file}" Enter
    else
        tmux send-keys -t "$target_pane" "cd '${VAULT_DIR}' && ${claude_bin} --dangerously-skip-permissions \"\$(cat ${prompt_file})\" ; rm -f ${prompt_file}" Enter
    fi

    log_success "Claude launched in vault"

    # --- Background: set zealotry after instance registers ---
    (
        sleep 8
        if command -v curl &>/dev/null && command -v jq &>/dev/null; then
            local api_url="${TOKEN_API_URL:-http://localhost:7777}"
            local instance_id
            instance_id=$(curl -s "${api_url}/api/instances" 2>/dev/null | \
                jq -r --arg pane "$target_pane" \
                '.[] | select(.tmux_pane == $pane and (.stopped_at == null)) | .id' 2>/dev/null | head -1)

            if [[ -n "$instance_id" ]]; then
                curl -s -X PATCH "${api_url}/api/instances/${instance_id}" \
                    -H "Content-Type: application/json" \
                    -d "{\"zealotry\": $zealotry}" >/dev/null 2>&1 || true
            fi
        fi
    ) &
    disown

    echo ""
    log_success "Dispatch complete"
    echo ""
    echo -e "  ${DIM}The instance will:${NC}"
    echo -e "  ${DIM}1. Read session doc at ${session_doc}${NC}"
    echo -e "  ${DIM}2. Create worktree: ${branch_name} (${project})${NC}"
    echo -e "  ${DIM}3. Transplant and begin autonomous work${NC}"
    echo -e "  ${DIM}4. PR → review → merge → cleanup${NC}"
    echo ""
}

# ═══════════════════════════════════════════════════════════════
# COMPLETE subcommand
# ═══════════════════════════════════════════════════════════════
do_complete() {
    local session_doc=""
    local no_merge=false
    local no_exit=false
    local dry_run=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --session-doc) session_doc="$2"; shift 2 ;;
            --no-merge)    no_merge=true; shift ;;
            --no-exit)     no_exit=true; shift ;;
            --dry-run)     dry_run=true; shift ;;
            -*)            log_error "Unknown option: $1"; exit 1 ;;
            *)             log_error "Unexpected argument: $1"; exit 1 ;;
        esac
    done

    echo ""
    echo -e "${BOLD}=========================================${NC}"
    echo -e "${BOLD} Work Loop — Complete${NC}"
    echo -e "${BOLD}=========================================${NC}"
    echo ""

    # --- Step 1: Merge PR ---
    if ! $no_merge; then
        log_info "Merging PR..."
        if $dry_run; then
            log_dry "Would run: pr-merge --yes"
        else
            if command -v pr-merge &>/dev/null; then
                pr-merge --yes || {
                    log_warn "pr-merge failed or no PR to merge — continuing cleanup"
                }
            else
                log_warn "pr-merge not found — skipping merge step"
            fi
        fi
    else
        log_info "Skipping merge (--no-merge)"
    fi

    # --- Step 2: Update session doc ---
    if [[ -n "$session_doc" ]]; then
        local doc_path="${VAULT_DIR}/${session_doc}"
        if [[ -f "$doc_path" ]]; then
            log_info "Updating session doc: $session_doc"
            if ! $dry_run; then
                # Update status to completed in frontmatter
                if grep -q '^status: active' "$doc_path"; then
                    if [[ "$IMPERIUM_MACHINE" == "mac" ]]; then
                        sed -i '' 's/^status: active/status: completed/' "$doc_path"
                    else
                        sed -i 's/^status: active/status: completed/' "$doc_path"
                    fi
                    log_success "Session doc status → completed"
                fi

                # Append completion timestamp
                echo "" >> "$doc_path"
                echo "## Work Loop Completion" >> "$doc_path"
                echo "" >> "$doc_path"
                echo "Completed at: $(date -Iseconds)" >> "$doc_path"
                echo "Completed by: work-loop" >> "$doc_path"
                log_success "Completion timestamp appended"
            else
                log_dry "Would update status to completed in $doc_path"
            fi
        else
            log_warn "Session doc not found: $doc_path"
        fi
    else
        log_info "No session doc specified — skipping doc update"
    fi

    # --- Step 3: Clean up worktree (if pr-merge didn't already) ---
    # pr-merge handles worktree removal, but if --no-merge was used,
    # the caller is responsible for cleanup.

    # --- Step 4: Exit ---
    if ! $no_exit; then
        echo ""
        log_success "Work loop complete. Exiting."
        echo ""
        if ! $dry_run; then
            # Send /exit to self via claude-cmd
            # This gracefully exits the Claude instance
            if command -v claude-cmd &>/dev/null; then
                claude-cmd --self --detach "/exit"
            fi
        else
            log_dry "Would send /exit to self"
        fi
    else
        echo ""
        log_success "Work loop complete (staying alive due to --no-exit)."
        echo ""
    fi
}

# ═══════════════════════════════════════════════════════════════
# STATUS subcommand
# ═══════════════════════════════════════════════════════════════
do_status() {
    echo ""
    echo -e "${BOLD}=========================================${NC}"
    echo -e "${BOLD} Work Loop — Status${NC}"
    echo -e "${BOLD}=========================================${NC}"
    echo ""

    local found=false

    # Check all backrooms panes for work-loop metadata
    while IFS=$'\t' read -r pane_id pane_type cmd window_name; do
        [[ "$window_name" == "backrooms" ]] || continue

        local session_doc branch project dispatched
        session_doc=$(tmux show-options -p -t "$pane_id" -v @WORKLOOP_SESSION_DOC 2>/dev/null || true)
        branch=$(tmux show-options -p -t "$pane_id" -v @WORKLOOP_BRANCH 2>/dev/null || true)
        project=$(tmux show-options -p -t "$pane_id" -v @WORKLOOP_PROJECT 2>/dev/null || true)
        dispatched=$(tmux show-options -p -t "$pane_id" -v @WORKLOOP_DISPATCHED 2>/dev/null || true)

        # Skip panes without work-loop metadata (original backrooms pane)
        [[ -z "$session_doc" ]] && continue

        found=true

        # Detect state: is Claude still running?
        local state="${GREEN}running${NC}"
        local pane_pid
        pane_pid=$(tmux list-panes -a -F "#{pane_id} #{pane_pid}" 2>/dev/null | awk -v p="$pane_id" '$1 == p {print $2}')
        if [[ -n "$pane_pid" ]]; then
            if ! pgrep -P "$pane_pid" -f "claude" &>/dev/null 2>&1; then
                state="${DIM}idle (no claude)${NC}"
            fi
        fi

        echo -e "  ${CYAN}${pane_id}${NC}  ${state}"
        echo -e "    ${DIM}doc:${NC}      $session_doc"
        echo -e "    ${DIM}branch:${NC}   $branch"
        echo -e "    ${DIM}project:${NC}  $project"
        echo -e "    ${DIM}since:${NC}    $dispatched"
        echo ""
    done < <(tmux list-panes -a -F "#{pane_id}	#{@PANE_TYPE}	#{pane_current_command}	#{window_name}" 2>/dev/null)

    if [[ "$found" != "true" ]]; then
        echo -e "  ${DIM}No active work-loop panes${NC}"
        echo ""
    fi
}

# ═══════════════════════════════════════════════════════════════
# MAIN — Route subcommand
# ═══════════════════════════════════════════════════════════════
usage() {
    cat << 'EOF'
work-loop — Full vault-to-worktree-to-vault work cycle orchestration

Usage:
  work-loop dispatch <session-doc> [options]    Launch autonomous work cycle
  work-loop complete [options]                   Wrap up: merge, cleanup, exit
  work-loop status                               Show active work-loop panes

Dispatch Options:
  --branch <name>       Branch name (default: derived from session doc filename)
  --project <name>      Project config (default: auto-detected from vault)
  --pane <id>           Use specific tmux pane instead of splitting backrooms
  --primarch <name>     Launch as a primarch persona
  --zealotry <1-5>      Golden Throne follow-up aggressiveness (default: 3)
  --context <text>      Extra context for the dispatch prompt
  --dry-run             Show what would happen without executing

Complete Options:
  --session-doc <path>  Session doc to update (relative to vault root)
  --no-merge            Skip PR merge (just update docs and exit)
  --no-exit             Stay alive after completion (don't /exit)
  --dry-run             Show what would happen without executing

Examples:
  work-loop dispatch Mars/Sessions/2026-04-04-auth-fix.md
  work-loop dispatch Mars/Sessions/2026-04-04-auth-fix.md --branch auth-fix --zealotry 4
  work-loop complete --session-doc Mars/Sessions/2026-04-04-auth-fix.md
  work-loop status
EOF
    exit 0
}

SUBCOMMAND=""
ARGS=()

# Extract subcommand, pass rest to handler
if [[ $# -eq 0 ]]; then
    usage
fi

case "$1" in
    dispatch|complete|status)
        SUBCOMMAND="$1"
        shift
        ;;
    -h|--help)
        usage
        ;;
    *)
        log_error "Unknown subcommand: $1"
        echo "Usage: work-loop <dispatch|complete|status> [options]"
        exit 1
        ;;
esac

case "$SUBCOMMAND" in
    dispatch)  do_dispatch "$@" ;;
    complete)  do_complete "$@" ;;
    status)    do_status ;;
esac
