#!/usr/bin/env python3
# macrodroid-read - Inspect MacroDroid .mdr exports and extract official .macro JSON
# TAGS: mobile, macrodroid
# AUDIENCE: human, agent

import argparse
import copy
import json
import os
import subprocess
import sys
import time
from pathlib import Path
from urllib.error import URLError
from urllib.request import urlopen

PHONE_HTTP_PORT = 7777
PHONE_TAILSCALE_IP = os.environ.get('PHONE_TAILSCALE_IP', '100.102.92.24')
PHONE_LOCAL_IP = os.environ.get('PHONE_LOCAL_IP', '192.168.0.89')
EXPORT_ENDPOINT = 'list-exports'
DEFAULT_EXPORT_PATH = '~/macros/EXPORT.mdr'


def trigger_phone_export(timeout=5):
    for ip in [PHONE_TAILSCALE_IP, PHONE_LOCAL_IP]:
        try:
            with urlopen(f'http://{ip}:{PHONE_HTTP_PORT}/{EXPORT_ENDPOINT}', timeout=timeout) as response:
                response.read()
                if response.status == 200:
                    return True
        except (URLError, TimeoutError, OSError):
            pass
    return False


def pull_export_from_phone(dest_path):
    attempts = [
        ['scp', '-q', '-o', 'ConnectTimeout=5', f'phone:{DEFAULT_EXPORT_PATH}', str(dest_path)],
        ['scp', '-q', '-P', '8022', '-o', 'ConnectTimeout=5', f'{PHONE_TAILSCALE_IP}:{DEFAULT_EXPORT_PATH}', str(dest_path)],
    ]
    for cmd in attempts:
        try:
            if subprocess.run(cmd, capture_output=True, timeout=20).returncode == 0:
                return True
        except (subprocess.TimeoutExpired, FileNotFoundError):
            pass

    # Wake sshd once through MacroDroid, then retry direct Tailscale SCP.
    try:
        with urlopen(f'http://{PHONE_TAILSCALE_IP}:{PHONE_HTTP_PORT}/sshd', timeout=5) as resp:
            resp.read()
        time.sleep(2)
        cmd = ['scp', '-q', '-P', '8022', '-o', 'ConnectTimeout=5', f'{PHONE_TAILSCALE_IP}:{DEFAULT_EXPORT_PATH}', str(dest_path)]
        return subprocess.run(cmd, capture_output=True, timeout=20).returncode == 0
    except (URLError, TimeoutError, OSError, subprocess.TimeoutExpired, FileNotFoundError):
        return False


def refresh_export():
    dest = Path.cwd() / 'EXPORT.mdr'
    print('Triggering MacroDroid export...', file=sys.stderr)
    trigger_phone_export()
    time.sleep(2)
    print(f'Pulling export to {dest}...', file=sys.stderr)
    if not pull_export_from_phone(dest):
        print('Error: could not pull EXPORT.mdr from phone', file=sys.stderr)
        return None
    return dest


def load_mdr(path):
    with open(path, 'r', encoding='utf-8') as f:
        data = json.load(f)
    if not isinstance(data, dict) or not isinstance(data.get('macroList'), list):
        raise ValueError('not a MacroDroid .mdr JSON export: missing macroList array')
    return data


def macro_name(m):
    return m.get('m_name') or m.get('name') or 'Unnamed'


def find_macro(macros, name):
    needle = name.lower()
    matches = [m for m in macros if macro_name(m).lower() == needle]
    if matches:
        return matches[0]
    partial = [m for m in macros if needle in macro_name(m).lower()]
    if len(partial) == 1:
        return partial[0]
    return None


def print_macro_summary(m, verbose=False):
    status = '✓' if m.get('m_enabled', False) else '✗'
    triggers = m.get('m_triggerList', []) or []
    actions = m.get('m_actionList', []) or []
    constraints = m.get('m_constraintList', []) or []
    print(f'{status} {macro_name(m)}')
    print(f'  Category: {m.get("m_category", "Uncategorized")}')
    print(f'  Triggers: {len(triggers)} | Actions: {len(actions)} | Constraints: {len(constraints)}')
    desc = m.get('m_description')
    if desc:
        print(f'  Description: {desc}')
    if verbose:
        if triggers:
            print('  Trigger classes:')
            for t in triggers:
                print(f'    - {t.get("m_classType", "Unknown")}')
        if actions:
            print('  Action classes:')
            for a in actions:
                print(f'    - {a.get("m_classType", "Unknown")}')
        if constraints:
            print('  Constraint classes:')
            for c in constraints:
                print(f'    - {c.get("m_classType", "Unknown")}')


def importable_wrapper(raw_macro, global_variables, user_icons):
    macro = copy.deepcopy(raw_macro)
    macro['m_GUID'] = 0
    macro['m_completed'] = True
    macro['aiGenerated'] = 1
    macro.setdefault('m_enabled', True)
    macro.setdefault('m_description', macro_name(macro))
    macro.setdefault('m_triggerList', [{'m_classType': 'EmptyTrigger', 'm_SIGUID': 0}])
    macro.setdefault('m_actionList', [])
    macro.setdefault('m_constraintList', [])
    return {
        'macroExportVersion': 1,
        'macro': macro,
        'globalVariables': global_variables if isinstance(global_variables, list) else [],
        'userIcons': user_icons if user_icons is not None else None,
        'aiFeedback': 'Extracted from MacroDroid .mdr export as official importable .macro JSON. Macro GUID reset to 0.',
    }


def main():
    parser = argparse.ArgumentParser(description='Inspect MacroDroid .mdr exports; extract official .macro JSON wrappers')
    parser.add_argument('mdr_file', nargs='?', help='MacroDroid .mdr JSON export; defaults to ./EXPORT.mdr')
    parser.add_argument('--refresh', '-r', action='store_true', help='trigger phone export and pull EXPORT.mdr first')
    parser.add_argument('--list', '-l', action='store_true', help='list macro names only')
    parser.add_argument('--detail', '-d', action='store_true', help='show macro class details')
    parser.add_argument('--json', '-j', action='store_true', help='output raw .mdr JSON, or raw macro JSON with --macro')
    parser.add_argument('--macro', '-m', help='select macro by exact name; unique partial match also accepted')
    parser.add_argument('--export-macro', action='store_true', help='with --macro, output official importable .macro wrapper JSON')
    parser.add_argument('--variables', '-v', action='store_true', help='show global variables')
    parser.add_argument('--geofences', '-g', action='store_true', help='show geofences')
    parser.add_argument('--http-config', action='store_true', help='show MacroDroid HTTP server config')
    args = parser.parse_args()

    if args.refresh:
        path = refresh_export()
        if path is None:
            return 1
    else:
        path = Path(args.mdr_file) if args.mdr_file else Path.cwd() / 'EXPORT.mdr'

    if not path.exists():
        print(f'Error: file not found: {path}', file=sys.stderr)
        return 1

    try:
        data = load_mdr(path)
    except Exception as e:
        print(f'Error: {e}', file=sys.stderr)
        return 1

    macros = data.get('macroList', [])

    if args.variables:
        variables = data.get('variables', []) or []
        names = ['bool', 'int', 'string', 'decimal', 'dict', 'array']
        print(f'Global Variables ({len(variables)}):')
        for v in variables:
            t = v.get('m_type', 2)
            print(f'  {v.get("m_name", "")} ({names[t] if isinstance(t, int) and t < len(names) else t})')
        return 0

    if args.geofences:
        gd = data.get('geofenceData', {}) or {}
        geofences = list(gd.get('geofenceMap', {}).values()) if isinstance(gd.get('geofenceMap'), dict) else gd.get('m_geofenceData', []) or []
        print(f'Geofences ({len(geofences)}):')
        for g in geofences:
            print(f'  {g.get("name", g.get("m_name", ""))}: ({g.get("latitude", g.get("m_latitude", 0)):.5f}, {g.get("longitude", g.get("m_longitude", 0)):.5f}) r={g.get("radius", g.get("m_radius", 0))}m')
        return 0

    if args.http_config:
        cfg = data.get('httpServerConfig', {}) or {}
        print('HTTP Server Config:')
        print(f'  Port: {cfg.get("port", 8080)}')
        print(f'  Enabled: {cfg.get("enabled", False)}')
        print(f'  Auth required: {cfg.get("authRequired", False)}')
        return 0

    if args.macro:
        found = find_macro(macros, args.macro)
        if not found:
            print(f'Macro not found or ambiguous: {args.macro}', file=sys.stderr)
            print('Available macros:', file=sys.stderr)
            for m in macros:
                print(f'  - {macro_name(m)}', file=sys.stderr)
            return 1
        if args.export_macro:
            print(json.dumps(importable_wrapper(found, data.get('variables', []), data.get('userIcons')), indent=2))
        elif args.json:
            print(json.dumps(found, indent=2))
        else:
            print_macro_summary(found, verbose=True)
        return 0

    if args.export_macro:
        print('Error: --export-macro requires --macro NAME', file=sys.stderr)
        return 1

    if args.list:
        print(f'Macros ({len(macros)}):')
        for m in macros:
            print(f'  {"✓" if m.get("m_enabled", False) else "✗"} {macro_name(m)}')
        return 0

    if args.json:
        print(json.dumps(data, indent=2))
        return 0

    print(f'MacroDroid Backup: {path.name}')
    print(f'Export version: {data.get("exportAppVersion", "Unknown")}')
    print(f'Total macros: {len(macros)}')
    print('=' * 50)
    for m in macros:
        print_macro_summary(m, verbose=args.detail)
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
