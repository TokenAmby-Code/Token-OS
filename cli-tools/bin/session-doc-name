#!/usr/bin/env bash
# Rename the current pane's session document.
# Usage: session-doc-name "Descriptive Session Title"

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

API_URL="${TOKEN_API_URL:-http://localhost:7777}"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
  cat >&2 <<'EOF_HELP'
Usage: session-doc-name "Descriptive Session Title"

Names the session document attached to the current tmux pane. Use a descriptive
3-6 word title. Do not use dates, timestamps, UUIDs, pane IDs, model names, or
generic project roots.
EOF_HELP
  exit $([[ $# -lt 1 ]] && echo 2 || echo 0)
fi

TITLE="$*"
TITLE="$(printf '%s' "$TITLE" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
if [[ -z "$TITLE" ]]; then
  echo "Error: title cannot be empty" >&2
  exit 2
fi
if [[ "$TITLE" =~ [0-9]{4}-[0-9]{2}-[0-9]{2} || "$TITLE" =~ [0-9]{2}:[0-9]{2} ]]; then
  echo "Error: title must not contain dates or timestamps" >&2
  exit 2
fi

PANE_TARGET="${TMUX_PANE:-current}"
if [[ "$PANE_TARGET" == %* ]]; then
  PANE_TARGET=$("$(dirname "$0")/tmuxctl" resolve-pane --format id "$PANE_TARGET" 2>/dev/null || true)
fi
[[ -n "$PANE_TARGET" ]] || PANE_TARGET="current"

TMUXCTL_ERR=$(mktemp)
DOC=$("$(dirname "$0")/tmuxctl" session-doc --pane "$PANE_TARGET" --format json 2>"$TMUXCTL_ERR" || true)
TMUXCTL_STATUS=$?
ERR_TEXT=$(cat "$TMUXCTL_ERR" 2>/dev/null || true)
rm -f "$TMUXCTL_ERR"
DOC_ID=$(echo "$DOC" | jq -r '.id // .doc_id // empty' 2>/dev/null || true)
if [[ -z "$DOC_ID" ]]; then
  if grep -q 'no_doc_bound' <<<"$ERR_TEXT"; then
    echo "No session doc is bound to this pane yet; nothing renamed. If this is a brand-new worker, submit the first prompt and retry." >&2
    exit 0
  fi
  if grep -q 'pane_mismatch\|no live instance\|no active instance\|no live instance stamp' <<<"$ERR_TEXT"; then
    echo "Error: pane mismatch: this pane does not currently resolve to a live instance (${PANE_TARGET})." >&2
    exit 1
  fi
  if grep -q 'failed to fetch' <<<"$ERR_TEXT"; then
    echo "Error: Token-API is unreachable or returned invalid data while resolving the session doc." >&2
    exit 1
  fi
  echo "Error: could not resolve session doc for pane ${PANE_TARGET}${ERR_TEXT:+: $ERR_TEXT}" >&2
  exit 1
fi

RESP=$(jq -n --arg title "$TITLE" '{title: $title}' \
  | curl -s -X PATCH "$API_URL/api/session-docs/$DOC_ID" \
      -H "Content-Type: application/json" \
      --data-binary @- 2>/dev/null || true)

if echo "$RESP" | jq -e '.updated == true' >/dev/null 2>&1; then
  # Explicit session-doc-name is an official naming-interview response. Rename
  # the current instance through the sanctioned instance-name boundary as well;
  # no server-side session-doc slug mirroring is allowed.
  if ! "$(dirname "$0")/instance-name" "$TITLE" --no-ui >/dev/null 2>&1; then
    echo "Error: session doc renamed, but instance rename failed" >&2
    exit 1
  fi
  echo "Session doc named: $TITLE"
else
  echo "Error: $(echo "$RESP" | jq -r '.detail // "session doc rename failed"' 2>/dev/null || echo "session doc rename failed")" >&2
  exit 1
fi
