#!/usr/bin/env bash
# Run the hooked Imperial Guard routing regression. If the assertion pops,
# notify/resume the registered asserter instance.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CHECKS="${SCRIPT_DIR}/../guardsman-checks/discord-routing.guardsman"
ASSERTER_ID="${TOKEN_API_ROUTING_ASSERT_INSTANCE_ID:-${1:-}}"
if [[ -z "$ASSERTER_ID" ]]; then
  echo "imperial-guard-routing-regression: set TOKEN_API_ROUTING_ASSERT_INSTANCE_ID or pass instance id" >&2
  exit 64
fi
while IFS= read -r check || [[ -n "$check" ]]; do
  [[ -z "$check" || "$check" =~ ^# ]] && continue
  "${SCRIPT_DIR}/guardsman" --assert-instance "$ASSERTER_ID" "$check"
done < "$CHECKS"
