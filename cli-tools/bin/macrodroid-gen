#!/usr/bin/env python3
# macrodroid-gen - Generate/normalize official MacroDroid .macro JSON
# TAGS: mobile, macrodroid
# AUDIENCE: human, agent
"""
macrodroid-gen - official-schema-only MacroDroid .macro generator

No YAML DSL. No legacy compiler. The source of truth is:
  /Volumes/Imperium/Token-OS/mobile/macrodroid-llm-schema.yaml

Usage:
  macrodroid-gen official.macro --pretty --validate
  macrodroid-gen bare-macro.json --wrap --pretty > importable.macro
  macrodroid-gen --empty "Manual Macro" > manual.macro
  macrodroid-gen --http-endpoint heartbeat --name Heartbeat --response-text OK > heartbeat.macro
"""

import argparse
import json
import subprocess
import sys
from pathlib import Path


def base_macro(name, description='', category='Uncategorized', triggers=None, actions=None, constraints=None):
    return {
        'm_name': name,
        'm_enabled': True,
        'm_completed': True,
        'm_GUID': 0,
        'm_category': category,
        'aiGenerated': 1,
        'm_description': description or name,
        'm_triggerList': triggers if triggers is not None else [{'m_classType': 'EmptyTrigger', 'm_SIGUID': 0}],
        'm_actionList': actions if actions is not None else [],
        'm_constraintList': constraints if constraints is not None else [],
    }


def wrapper(macro, feedback='Generated as official MacroDroid .macro JSON.'):
    return {
        'macroExportVersion': 1,
        'macro': macro,
        'globalVariables': [],
        'userIcons': None,
        'aiFeedback': feedback,
    }


def load_json(path):
    with open(path, 'r', encoding='utf-8') as f:
        return json.load(f)


def normalize_loaded(obj, force_wrap=False):
    if isinstance(obj, dict) and obj.get('macroExportVersion') == 1 and 'macro' in obj and not force_wrap:
        out = dict(obj)
        out.setdefault('globalVariables', [])
        out.setdefault('userIcons', None)
        out.setdefault('aiFeedback', 'Normalized as official MacroDroid .macro JSON.')
        if isinstance(out.get('macro'), dict):
            out['macro'].setdefault('m_completed', True)
            out['macro'].setdefault('aiGenerated', 1)
            out['macro'].setdefault('m_GUID', 0)
            out['macro'].setdefault('m_constraintList', [])
        return out
    if not isinstance(obj, dict):
        raise SystemExit('Input must be a JSON object')
    # Bare macro object -> official wrapper.
    obj.setdefault('m_completed', True)
    obj.setdefault('aiGenerated', 1)
    obj.setdefault('m_GUID', 0)
    obj.setdefault('m_enabled', True)
    obj.setdefault('m_description', obj.get('m_name', 'Macro'))
    obj.setdefault('m_triggerList', [{'m_classType': 'EmptyTrigger', 'm_SIGUID': 0}])
    obj.setdefault('m_actionList', [])
    obj.setdefault('m_constraintList', [])
    return wrapper(obj, 'Wrapped bare macro object as official MacroDroid .macro JSON.')


def main():
    ap = argparse.ArgumentParser(description='Generate or normalize official MacroDroid .macro JSON. Legacy YAML is not supported.')
    ap.add_argument('input', nargs='?', help='official .macro JSON wrapper or bare macro JSON object')
    ap.add_argument('--wrap', action='store_true', help='treat input as bare macro JSON and wrap it')
    ap.add_argument('--empty', metavar='NAME', help='generate an EmptyTrigger macro skeleton')
    ap.add_argument('--http-endpoint', metavar='IDENTIFIER', help='generate simple HttpServerTrigger + HttpServerResponseAction macro')
    ap.add_argument('--name', help='macro name for generated templates')
    ap.add_argument('--description', default='', help='macro description for generated templates')
    ap.add_argument('--category', default='Uncategorized', help='macro category for generated templates')
    ap.add_argument('--response-text', default='OK', help='HTTP response text for --http-endpoint')
    ap.add_argument('--response-code', type=int, default=200, help='HTTP response status code for --http-endpoint')
    ap.add_argument('--pretty', action='store_true', help='pretty-print JSON')
    ap.add_argument('--validate', action='store_true', help='run macrodroid-validate before printing')
    args = ap.parse_args()

    modes = sum(bool(x) for x in [args.input, args.empty, args.http_endpoint])
    if modes != 1:
        ap.error('choose exactly one: input file, --empty, or --http-endpoint')

    if args.empty:
        out = wrapper(base_macro(args.empty, args.description, args.category), 'Generated EmptyTrigger official MacroDroid macro skeleton.')
    elif args.http_endpoint:
        name = args.name or args.http_endpoint
        macro = base_macro(
            name=name,
            description=args.description or f'HTTP endpoint /{args.http_endpoint}',
            category=args.category,
            triggers=[{
                'm_classType': 'HttpServerTrigger',
                'm_SIGUID': 0,
                'identifier': args.http_endpoint,
                'sendResponse': True,
                'responseText': args.response_text,
                'responseCode': args.response_code,
            }],
            actions=[{
                'm_classType': 'HttpServerResponseAction',
                'm_SIGUID': 0,
                'option': 0,
                'text': args.response_text,
                'responseCode': args.response_code,
            }],
        )
        out = wrapper(macro, 'Generated HTTP endpoint macro from official MacroDroid schema fields.')
    else:
        p = Path(args.input)
        if p.suffix.lower() in ('.yaml', '.yml'):
            raise SystemExit('YAML DSL input is removed. Generate official .macro JSON from macrodroid-llm-schema.yaml.')
        out = normalize_loaded(load_json(p), force_wrap=args.wrap)

    rendered = json.dumps(out, indent=2 if args.pretty else None, separators=None if args.pretty else (',', ':'))

    if args.validate:
        proc = subprocess.run(['macrodroid-validate', '--quiet', '-'], input=rendered, text=True)
        if proc.returncode != 0:
            return proc.returncode

    print(rendered)
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
