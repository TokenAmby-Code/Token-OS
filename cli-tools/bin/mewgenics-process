#!/usr/bin/env python3
"""mewgenics-process - Filter, crop, and prepare game screenshots for extraction.

Pipeline:
  1. Filter out non-game frames (terminal screenshots, taskbar, etc.)
  2. Crop to the stat panel region (top-left quadrant)
  3. Output filtered/cropped frames ready for batch vision processing

Usage:
    mewgenics-process <input-dir> [options]

Options:
    --output <dir>      Output directory (default: <input-dir>/processed/)
    --dark-threshold     Max percentage of dark pixels for a game frame (default: 40)
    --crop               Crop to stat panel region (default: full frame)
    --crop-region L,T,R,B  Custom crop region as percentages (default: 0,0,45,75)
    --dry-run            Show classification without copying
    --list               Just list game frames to stdout
    -h, --help           Show this help
"""

import sys
import os
import shutil
import argparse
import json
from pathlib import Path

from PIL import Image
import numpy as np


def log(msg):
    print(f"\033[0;36m[mewgenics-process]\033[0m {msg}", file=sys.stderr)

def ok(msg):
    print(f"\033[0;32m[mewgenics-process]\033[0m {msg}", file=sys.stderr)

def warn(msg):
    print(f"\033[1;33m[mewgenics-process]\033[0m {msg}", file=sys.stderr)


def is_game_frame(path, dark_threshold=40):
    """Detect if a frame is from the game vs terminal/desktop.

    Game frames have a lighter, varied palette (browns, greys, paper textures).
    Terminal frames are overwhelmingly dark with sparse bright text.
    """
    img = Image.open(path).convert("L")  # grayscale
    pixels = np.array(img)

    # What percentage of pixels are very dark (< 30 brightness)?
    dark_pct = (pixels < 30).sum() / pixels.size * 100

    return dark_pct < dark_threshold, dark_pct


def crop_stat_panel(img, region=(0, 0, 45, 75)):
    """Crop to stat panel region (percentages of image dimensions)."""
    w, h = img.size
    left = int(w * region[0] / 100)
    top = int(h * region[1] / 100)
    right = int(w * region[2] / 100)
    bottom = int(h * region[3] / 100)
    return img.crop((left, top, right, bottom))


def main():
    parser = argparse.ArgumentParser(description="Filter and crop Mewgenics screenshots")
    parser.add_argument("input_dir", help="Directory with screenshots to process")
    parser.add_argument("--output", help="Output directory")
    parser.add_argument("--dark-threshold", type=float, default=40,
                        help="Max dark pixel %% for game frames (default: 40)")
    parser.add_argument("--crop", action="store_true", help="Crop to stat panel")
    parser.add_argument("--crop-region", default="0,0,45,75",
                        help="Crop region as L,T,R,B percentages (default: 0,0,45,75)")
    parser.add_argument("--dry-run", action="store_true", help="Classify only")
    parser.add_argument("--list", action="store_true", help="List game frame paths to stdout")
    args = parser.parse_args()

    input_dir = Path(args.input_dir)
    frames = sorted(input_dir.glob("*.png"))

    if not frames:
        warn(f"No PNG files in {input_dir}")
        sys.exit(1)

    crop_region = tuple(int(x) for x in args.crop_region.split(","))

    log(f"Processing {len(frames)} frames from {input_dir}")

    game_frames = []
    non_game = []

    for f in frames:
        is_game, dark_pct = is_game_frame(f, args.dark_threshold)
        if is_game:
            game_frames.append(f)
            label = f"  GAME  {f.name} (dark={dark_pct:.0f}%)"
        else:
            non_game.append(f)
            label = f"  SKIP  {f.name} (dark={dark_pct:.0f}%)"
        print(label, file=sys.stderr)

    ok(f"{len(game_frames)}/{len(frames)} game frames detected")

    if args.list:
        for f in game_frames:
            print(f)
        return

    if args.dry_run:
        return

    # Output processed frames
    out_dir = Path(args.output) if args.output else input_dir / "processed"
    out_dir.mkdir(parents=True, exist_ok=True)

    for i, f in enumerate(game_frames, 1):
        img = Image.open(f)
        if args.crop:
            img = crop_stat_panel(img, crop_region)

        dest = out_dir / f"{i:03d}_{f.name}"
        img.save(dest, "PNG")

    ok(f"Processed frames → {out_dir}")

    # Print output dir
    print(out_dir)


if __name__ == "__main__":
    main()
