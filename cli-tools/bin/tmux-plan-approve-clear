#!/usr/bin/env bash
# 410 GONE tombstone: tmux CLI exterminatus 2026-06-30.
{
    cat >&2 <<'__TMUX_410_TOMBSTONE__'
410 GONE: cli-tools/bin/tmux-plan-approve-clear (tmux-plan-approve-clear) is tombstoned by the 2026-06-30 tmux CLI exterminatus.
This cold tmux feature surface must not be used as an active runtime/control path.
Daemon-native replacement: tmuxctld hook/user-prompt-submit clear-context route TBD.
Original body is retained below this early-return as the emergency restore lever; lift only this tombstone block to prove an active blocker, build/cut over the daemon-native replacement, then restore the 410.
__TMUX_410_TOMBSTONE__
}
return 410 2>/dev/null || exit 410

# --- ORIGINAL BODY BELOW: emergency restore lever, intentionally dead under the 410. ---
# tmux-plan-approve-clear — approve only clear-context plan approval modals
# TAGS: tmux, plan, approval
# AUDIENCE: system
#
# One-shot, time-limited screen watcher. It only sends keys when captured pane
# text contains a clear-context approval modal. Claude gets Enter (option 1).
# Codex gets Down, Enter (option 2). Event hooks launch this watcher; screen
# polling is only the fallback for the TUI modal itself, and it runs only while
# Token-API says planning_state is planning/approving.

set -euo pipefail

PANE=""
INSTANCE_ID=""
CONTROL_PANE=""
AGENT="auto"
TIMEOUT=10
INTERVAL="0.25"
CAPTURE_FILE=""
DRY_RUN=false
UPDATE_STATE=true
REAL_TMUX="${TOKEN_API_TMUX_BIN:-/opt/homebrew/bin/tmux}"
[[ -x "$REAL_TMUX" ]] || REAL_TMUX="/usr/bin/tmux"
[[ -x "$REAL_TMUX" ]] || REAL_TMUX="$(command -v tmux || true)"
if [[ -z "$REAL_TMUX" || ! -x "$REAL_TMUX" ]]; then
    echo "tmux-plan-approve-clear: real tmux binary not found" >&2
    exit 2
fi

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${_script_dir}/../lib/nas-path.sh" >/dev/null 2>&1 || true

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pane) PANE="$2"; shift 2 ;;
        --instance-id) INSTANCE_ID="$2"; shift 2 ;;
        --agent) AGENT="$2"; shift 2 ;;
        --timeout) TIMEOUT="$2"; shift 2 ;;
        --interval) INTERVAL="$2"; shift 2 ;;
        --capture-file) CAPTURE_FILE="$2"; shift 2 ;;
        --dry-run) DRY_RUN=true; shift ;;
        --no-state) UPDATE_STATE=false; shift ;;
        -h|--help) sed -n '2,/^$/s/^# //p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
done

if [[ -z "$PANE" && -z "$INSTANCE_ID" && -z "$CAPTURE_FILE" ]]; then
    PANE="${TMUX_PANE:-}"
fi
if [[ -z "$PANE" && -z "$INSTANCE_ID" && -z "$CAPTURE_FILE" ]]; then
    echo "tmux-plan-approve-clear: --pane, --instance-id, or --capture-file required" >&2
    exit 2
fi


find_tmuxctl() {
    local candidate root
    candidate="$(command -v tmuxctl 2>/dev/null || true)"
    if [[ -n "$candidate" && -x "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    candidate="${TOKEN_OS:-}/cli-tools/bin/tmuxctl"
    if [[ -n "${TOKEN_OS:-}" && -x "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    root="${IMPERIUM:-}"
    candidate="${root%/}/runtimes/token-os/live/cli-tools/bin/tmuxctl"
    if tmux_plan_approve_mount_live "$root" && [[ -x "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    return 1
}

tmux_plan_approve_mount_live() {
    local root="$1"
    [[ -n "$root" && -d "$root" ]] || return 1
    ls "$root" >/dev/null 2>&1
}

resolve_control_pane() {
    local target="$PANE" tmuxctl resolved
    [[ -z "$CAPTURE_FILE" ]] || return 0
    if [[ -n "$INSTANCE_ID" ]]; then
        tmuxctl="$(find_tmuxctl 2>/dev/null || true)"
        if [[ -n "$tmuxctl" ]]; then
            resolved="$("$tmuxctl" resolve-instance --format physical "$INSTANCE_ID" 2>/dev/null || true)"
            if [[ "$resolved" == %* ]]; then
                CONTROL_PANE="$resolved"
                return 0
            fi
        fi
    fi
    [[ -n "$target" ]] || return 1
    resolved="$("$REAL_TMUX" display-message -p -t "$target" '#{pane_id}' 2>/dev/null || true)"
    if [[ "$resolved" == %* ]]; then
        CONTROL_PANE="$resolved"
        return 0
    fi
    tmuxctl="$(find_tmuxctl 2>/dev/null || true)"
    if [[ -n "$tmuxctl" ]]; then
        resolved="$("$tmuxctl" resolve-pane --format physical "$target" 2>/dev/null || true)"
        if [[ "$resolved" == %* ]]; then
            CONTROL_PANE="$resolved"
            return 0
        fi
    fi
    [[ "$target" == %* ]] || return 1
    CONTROL_PANE="$target"
}

json_escape() {
    python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"
}

set_planning_state() {
    local state="$1"
    if ! $UPDATE_STATE || $DRY_RUN || [[ -n "$CAPTURE_FILE" || -z "${TOKEN_API_URL:-}" ]]; then
        return 0
    fi
    if [[ -z "$INSTANCE_ID" && -z "$PANE" ]]; then
        return 0
    fi
    local body target_field
    if [[ -n "$INSTANCE_ID" ]]; then
        target_field="\"instance_id\":$(json_escape "$INSTANCE_ID")"
    else
        target_field="\"tmux_pane\":$(json_escape "$PANE")"
    fi
    body="{$target_field,\"state\":$(json_escape "$state"),\"source\":\"tmux-plan-approve-clear\"}"
    curl -sf --max-time 1 -X POST "${TOKEN_API_URL}/api/planning/state" \
        -H 'Content-Type: application/json' \
        -d "$body" >/dev/null || true
}



get_planning_state() {
    # Read-only GET: dry-run must NOT bypass here (dry-run gates writes only).
    # Reading real state in dry-run is what makes the `state-not-planning` /
    # `state-left-planning` no-op branches below reachable and testable.
    if ! $UPDATE_STATE || [[ -n "$CAPTURE_FILE" || -z "${TOKEN_API_URL:-}" ]]; then
        echo "bypass"
        return 0
    fi
    if [[ -n "$INSTANCE_ID" ]]; then
        curl -fsS -G --connect-timeout 1 --max-time 2 \
            --data-urlencode "instance_id=${INSTANCE_ID}" \
            "${TOKEN_API_URL}/api/planning/state" 2>/dev/null \
            | python3 -c 'import json,sys; print((json.load(sys.stdin).get("planning_state") or ""))' 2>/dev/null \
            || true
        return 0
    fi
    if [[ -z "$PANE" ]]; then
        echo "bypass"
        return 0
    fi
    curl -fsS -G --connect-timeout 1 --max-time 2 \
        --data-urlencode "tmux_pane=${PANE}" \
        "${TOKEN_API_URL}/api/planning/state" 2>/dev/null \
        | python3 -c 'import json,sys; print((json.load(sys.stdin).get("planning_state") or ""))' 2>/dev/null \
        || true
}

planning_state_allows_poll() {
    local state
    state="$(get_planning_state)"
    case "$state" in
        planning|approving|bypass) return 0 ;;
        *) return 1 ;;
    esac
}

capture() {
    if [[ -n "$CAPTURE_FILE" ]]; then
        cat "$CAPTURE_FILE" 2>/dev/null || true
    else
        "$REAL_TMUX" capture-pane -p -t "$CONTROL_PANE" -S -80 2>/dev/null || true
    fi
}

log_result() {
    local result="$1" extra="${2:-}"
    local pane_label="$PANE"
    [[ -z "$CAPTURE_FILE" ]] || pane_label="capture-file"
    printf '[%s] tmux-plan-approve-clear result=%s pane=%s instance_id=%s control_pane=%s agent=%s%s\n' \
        "$(date '+%Y-%m-%d %H:%M:%S')" "$result" "$pane_label" "$INSTANCE_ID" "$CONTROL_PANE" "$AGENT" "${extra:+ $extra}" >&2
}

safe_pane_name() {
    printf '%s' "$1" | tr -c 'A-Za-z0-9_.:-' '_'
}

runtime_root() {
    local uid root mode
    uid="${UID:-$(id -u 2>/dev/null || printf 'unknown')}"
    root="${TMPDIR:-/tmp}/tmux-plan-approve-clear-${uid}"
    ( umask 077 && mkdir -p "$root" ) 2>/dev/null || return 1
    [[ -d "$root" && -O "$root" && ! -L "$root" ]] || return 1
    mode="$(stat -c %a "$root" 2>/dev/null || stat -f %Lp "$root" 2>/dev/null || true)"
    [[ "$mode" =~ ^[0-7]+$ ]] || return 1
    (( (8#$mode & 077) == 0 )) || return 1
    printf '%s\n' "$root"
}

lease_path() {
    local safe root
    [[ -z "$CAPTURE_FILE" ]] || return 1
    [[ -n "$INSTANCE_ID" || -n "$PANE" ]] || return 1
    safe="$(safe_pane_name "${INSTANCE_ID:-$PANE}")"
    root="$(runtime_root)" || return 1
    printf '%s/%s.deadline\n' "$root" "$safe"
}

current_deadline() {
    local lease value fallback
    fallback=$(( start + TIMEOUT ))
    lease="$(lease_path 2>/dev/null || true)"
    if [[ -n "$lease" && -r "$lease" ]]; then
        value="$(cat "$lease" 2>/dev/null || true)"
        if [[ "$value" =~ ^[0-9]+$ && "$value" -gt "$fallback" ]]; then
            printf '%s\n' "$value"
            return 0
        fi
    fi
    printf '%s\n' "$fallback"
}

save_timeout_snippet() {
    local content="$1" dir file
    [[ "$AGENT" == "codex" ]] || return 0
    [[ "${PLAN_APPROVER_SAVE_TIMEOUT_SNIPPET:-}" == "1" ]] || return 0
    dir="${PLAN_APPROVER_LOG_FILE:+$(dirname "$PLAN_APPROVER_LOG_FILE")}"
    [[ -n "$dir" ]] || dir="${HOME}/.codex/log"
    ( umask 077 && mkdir -p "$dir" ) 2>/dev/null || true
    local target_name="${INSTANCE_ID:-$PANE}"
    file="$dir/plan-approver-timeout-${target_name//[^A-Za-z0-9_.:-]/_}-$(date +%Y%m%d-%H%M%S).txt"
    ( umask 077 && printf '%s' "$content" | tail -c 4000 > "$file" ) 2>/dev/null || true
    printf '%s\n' "$file"
}

LOCK_FD_OPEN=false
LOCK_DIR=""

_release_single_flight() {
    if [[ -n "${LOCK_DIR:-}" ]]; then
        rm -rf "$LOCK_DIR" 2>/dev/null || true
    fi
}

acquire_single_flight() {
    [[ -z "$CAPTURE_FILE" ]] || return 0
    [[ -n "$CONTROL_PANE" || -n "$INSTANCE_ID" || -n "$PANE" ]] || return 0
    local safe root lockfile
    safe="$(safe_pane_name "${CONTROL_PANE:-${INSTANCE_ID:-$PANE}}")"
    root="$(runtime_root)" || return 1
    lockfile="$root/${safe}.lock"
    if command -v flock >/dev/null 2>&1; then
        exec 9>"$lockfile" || return 1
        flock -n 9 || return 1
        LOCK_FD_OPEN=true
        return 0
    fi
    LOCK_DIR="$root/${safe}.lockd"
    if ! mkdir "$LOCK_DIR" 2>/dev/null; then
        return 1
    fi
    printf '%s\n' "$$" > "$LOCK_DIR/pid" 2>/dev/null || true
    trap _release_single_flight EXIT INT TERM
    return 0
}

classify() {
    # Detection is wrap- AND resize-invariant: lowercase the capture, strip ALL
    # whitespace, then test short atomic tokens. The pane hard-wraps (~36 col) and
    # the Emperor resizes/shunts panes constantly, so any long prose phrase shatters
    # across lines and a substring test silently misses (the modal then "sticks").
    # CC 2.1.185 also dropped the old "implement this plan?" header, which is why
    # the prose match regressed — atomic tokens cover the current + legacy copy.
    #
    # Cursor safety: Claude only presses Enter when the current cursor option is
    # clear-context. Codex only presses Down,Enter when the option one Down from
    # the current cursor is the clear-context option. Otherwise return "none" and
    # leave the modal for the human; never guess a Down-count.
    #
    # Scrollback shadowing: capture() reads -S -80, so the capture can contain a
    # STALE cursor-marked modal frozen in scrollback above the live one (e.g. an
    # "❯ 1. Exit anyway / 2. Stay" prompt left by a prior session in the pane
    # before it was relaunched). The active TUI modal is always rendered at the
    # BOTTOM of the pane; any cursor markers above it are dead scrollback. So we
    # anchor `current` on the LAST cursor option (bottom-most = live), not the
    # first — anchoring on the first lets a stale top modal shadow the real one,
    # classify returns "none", the approver times out, and the modal sticks
    # (forcing manual approval — the exact regression this guards against).
    python3 -c 'import re,sys
agent=sys.argv[1]
text=sys.stdin.read()
flat=re.sub(r"\s+","",text.lower())
# Anchor on the rare clear-context option, then require ONE short corroborating
# atom — a plan-execute header OR an approval-option phrase. All tokens survive
# whitespace-strip, so wrap/resize cannot blank the match, and a plan body that
# merely mentions "clear context" in prose lacks the corroborating atom.
clear = any(t in flat for t in ("clearcontext", "clearconte", "freshthread"))
corrob = any(t in flat for t in (
    "readytoexecute","writtenupaplan","implementthisplan","liketoproceed","wishtoproceed",
    "acceptedits","approveedits","manuallyapprove","manualapproval","bypasspermissions", "freshthread"))
if not (clear and corrob):
    print("none")
    raise SystemExit
if agent == "auto":
    # NEVER text-sniff scrollback for the harness: a Claude pane that merely
    # mentions "codex" (every fleet session does) used to flip to the Codex key
    # sequence (Down,Enter), moving the cursor off the clear-context option ->
    # plan mode never cleanly exits and the agent retries (spurious re-entry).
    # The gatekeeper resolves the real harness (tmuxctl resolve-agent) and passes
    # --agent claude|codex explicitly, yielding entirely if it cannot; auto is a
    # defensive fallback to claude, still gated by the cursor-safety below.
    agent = "claude"

opt_re=re.compile(r"^\s*([❯›>])?\s*(\d+)[.)]\s*(.*)$")
options=[]
current=None
lines=text.splitlines()
i=0
while i < len(lines):
    m=opt_re.match(lines[i])
    if not m:
        i += 1
        continue
    cursor=bool(m.group(1))
    num=int(m.group(2))
    chunk=[m.group(3)]
    j=i+1
    while j < len(lines):
        if opt_re.match(lines[j]) or not lines[j].strip():
            break
        chunk.append(lines[j])
        j += 1
    opt_flat=re.sub(r"\s+",""," ".join(chunk).lower())
    item={"num":num,"cursor":cursor,"flat":opt_flat,"index":len(options)}
    options.append(item)
    if cursor:
        # Last cursor wins: the live modal is the bottom-most one; earlier cursor
        # markers are stale scrollback (see "Scrollback shadowing" above).
        current=item
    i=j

if agent == "claude":
    if current is None or not any(t in current["flat"] for t in ("clearcontext", "clearconte", "freshthread")):
        print("none")
        raise SystemExit
elif agent == "codex":
    if current is None:
        print("none")
        raise SystemExit
    target=None
    for opt in options[current["index"]+1:]:
        target=opt
        break
    if target is None or target["num"] != current["num"] + 1 or not any(t in target["flat"] for t in ("clearcontext", "clearconte", "freshthread")):
        print("none")
        raise SystemExit
print(agent)' "$AGENT"
}
send_action() {
    local detected="$1"
    if $DRY_RUN || [[ -n "$CAPTURE_FILE" ]]; then
        if [[ "$detected" == "codex" ]]; then
            echo "action=codex option-2 Down Enter"
        else
            echo "action=claude option-1 Enter"
        fi
        return 0
    fi
    if [[ "$detected" == "codex" ]]; then
        "$REAL_TMUX" send-keys -t "$CONTROL_PANE" Down Enter
    else
        "$REAL_TMUX" send-keys -t "$CONTROL_PANE" Enter
    fi
}

if [[ -z "$CAPTURE_FILE" ]]; then
    if ! resolve_control_pane; then
        log_result "target-unresolved"
        $DRY_RUN && echo "action=none target-unresolved"
        exit 0
    fi
fi

if ! acquire_single_flight; then
    log_result "locked"
    $DRY_RUN && echo "action=none locked"
    exit 0
fi

if ! planning_state_allows_poll; then
    log_result "state-not-planning"
    $DRY_RUN && echo "action=none state-not-planning"
    exit 0
fi
set_planning_state approving

start=$(date +%s)
classifier_none_plan_tokens_logged=false
while true; do
    if ! planning_state_allows_poll; then
        log_result "state-left-planning"
        $DRY_RUN && echo "action=none state-left-planning"
        exit 0
    fi
    content="$(capture)"
    detected="$(classify "$AGENT" <<<"$content")"
    if [[ "$detected" != "none" ]]; then
        send_action "$detected"
        log_result "clicked" "detected=$detected"
        # Do not mark planning complete here.  A successful clear-context
        # approval causes the harness to re-fire SessionStart/supplant; that
        # canonical row transition owns planning_state=none.
        exit 0
    fi
    now=$(date +%s)
    deadline="$(current_deadline)"
    if ! $classifier_none_plan_tokens_logged && [[ "$detected" == "none" ]] && grep -qiE '(<proposed_plan>|implement this plan|clear context|fresh thread)' <<<"$content"; then
        log_result "classifier-none-with-plan-tokens"
        classifier_none_plan_tokens_logged=true
    fi
    if (( now >= deadline )); then
        snippet=""
        # Leave planning_state at `approving` (set at launch) — the accurate
        # "approval requested, outcome unobserved" state. The post-approval
        # Write/Edit (PostToolUse auto-clear) or the next SessionStart resolves it
        # to `none`. This watcher is no longer the authority for that transition;
        # it stays only as the auto-clicker for the clear-context modal.
        if $DRY_RUN; then
            echo "action=none timeout"
        else
            snippet="$(save_timeout_snippet "$content" 2>/dev/null || true)"
        fi
        $DRY_RUN || log_result "timeout" "${snippet:+snippet=$snippet}"
        exit 0
    fi
    sleep "$INTERVAL"
done
