#!/usr/bin/env bash
# tmux-refresh-layout - Python-backed canonical layout reset
# TAGS: tmux, layout, reset
# AUDIENCE: script
#
# Compatibility shim for the tmuxctl normalize path.


# 410-on-touch shim: this cold CLI/keybind path is retired.  The dead body
# below is intentionally retained for the separately-gated atomic wipe.
echo "tmux-refresh-layout: HTTP 410 Gone — layout normalize live path is tmuxctld-ping POST /normalize." >&2
exit 154  # 410 modulo POSIX shell's 8-bit exit status

set -euo pipefail

_BIN_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
_REPO_ROOT="${TOKEN_OS:-$(cd "${_BIN_DIR}/../.." && pwd)}"
_LIB_DIR="${TMUXCTLD_LIB:-${_REPO_ROOT}/tmuxctld/lib}"
_CLI_LIB_DIR="${_REPO_ROOT}/cli-tools/lib"

target="${1:-current}"
if [[ "$target" != "current" && "$target" != --* ]]; then
    exec env PYTHONPATH="${_LIB_DIR}:${_CLI_LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" \
        python3 -m tmuxctl.cli normalize --window "$target"
fi

exec env PYTHONPATH="${_LIB_DIR}:${_CLI_LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" \
    python3 -m tmuxctl.cli normalize --window current
