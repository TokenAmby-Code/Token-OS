#!/usr/bin/env bash
# tmux-refresh-layout - Python-backed canonical layout reset
# TAGS: tmux, layout, reset
# AUDIENCE: script
#
# Compatibility shim for the tmuxctl normalize path.

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"

target="${1:-current}"
if [[ "$target" != "current" && "$target" != --* ]]; then
    exec env PYTHONPATH="${_LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" \
        python3 -m tmuxctl.cli normalize --window "$target"
fi

exec env PYTHONPATH="${_LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" \
    python3 -m tmuxctl.cli normalize --window current
