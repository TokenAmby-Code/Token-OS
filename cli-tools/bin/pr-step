#!/usr/bin/env bash
# PR Step
# TAGS: git, pr, workflow
# AUDIENCE: agent
#
# Canonical PR lifecycle command. Handles commit, PR create/update,
# CodeRabbit review readback, and merge when green. Worktree teardown is
# deferred to tmuxctld WrapperEnd.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$SCRIPT_PATH")")" && pwd)"
source "$SCRIPT_DIR/../lib/git-remote.sh"
source "$SCRIPT_DIR/../lib/nas-path.sh" >/dev/null 2>&1 || true
source "$SCRIPT_DIR/../lib/worktree-park.sh" 2>/dev/null || true
source "$SCRIPT_DIR/../lib/worktree-resolve.sh" 2>/dev/null || true

PUSH_WRAPPER="$SCRIPT_DIR/push"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'
log() { echo -e "${BLUE}[pr-step]${NC} $1" >&2; }
info() { echo -e "${CYAN}   $1${NC}" >&2; }
warn() { echo -e "${YELLOW}[pr-step]${NC} $1" >&2; }
error() { echo -e "${RED}[pr-step]${NC} $1" >&2; }
success() { echo -e "${GREEN}[pr-step]${NC} $1" >&2; }

MESSAGE=""
TITLE=""
BODY=""
AUTO_MERGE=true
TIMEOUT_MINS=""
SHOW_RAW_REVIEW=false
FORCE_MODE=""
FORCE_ARGS=()

is_denied_worktree_env_path() {
    local path="${1#./}" base
    base="${path##*/}"
    case "$path" in
        .worktree.env|*/.worktree.env|.worktree.env.*|*/.worktree.env.*)
            return 0
            ;;
    esac
    case "$base" in
        .worktree.env|.worktree.env.*|*.worktree.env|*.worktree.env.*|worktree.env|worktree-*.env|*.worktree-env|*.worktree-env.*)
            return 0
            ;;
    esac
    return 1
}

unstage_denied_worktree_env_files() {
    local path
    local -a denied=()
    while IFS= read -r -d '' path; do
        if is_denied_worktree_env_path "$path"; then
            denied+=("$path")
        fi
    done < <(git diff --cached --name-only -z --diff-filter=ACMRD)

    [[ ${#denied[@]} -gt 0 ]] || return 0

    warn "Refusing to commit generated worktree env file(s): ${denied[*]}"
    if ! git restore --staged -- "${denied[@]}" 2>/dev/null; then
        git reset -q HEAD -- "${denied[@]}" 2>/dev/null || true
    fi
}

default_commit_message_from_staged() {
    local count first status verb
    count="$(git diff --cached --name-only --ignore-submodules -- | sed '/^$/d' | wc -l | tr -d ' ')"
    if [[ "$count" == "1" ]]; then
        first="$(git diff --cached --name-only --ignore-submodules -- | sed -n '1p')"
        status="$(git diff --cached --name-status --ignore-submodules -- | awk 'NR == 1 {print $1}')"
        case "$status" in
            A*) verb="add" ;;
            D*) verb="remove" ;;
            R*) verb="rename" ;;
            *) verb="update" ;;
        esac
        echo "chore: ${verb} ${first}"
    elif [[ "$count" =~ ^[0-9]+$ && "$count" -gt 1 ]]; then
        echo "chore: update ${count} files"
    else
        echo "chore: update working tree"
    fi
}

emit_coderabbit_heartbeat() {
    local message="$1"
    [[ "${PR_STEP_OPAQUE_WAIT:-false}" == "true" ]] && return 0
    if [[ -n "${PR_STEP_HEARTBEAT_FILE:-}" ]]; then
        printf '%s\n' "$message" >>"$PR_STEP_HEARTBEAT_FILE" 2>/dev/null || true
    else
        log "$message"
    fi
}

normalize_timeout_mins() {
    local value="${1:-}"
    case "$value" in
        ""|0|none|never|unbounded)
            return 0
            ;;
    esac
    [[ "$value" =~ ^[0-9]+$ ]] && (( value > 0 )) || return 1
    printf '%s' "$value"
}

timeout_mins_to_seconds() {
    local mins="${1:-}"
    [[ -n "$mins" ]] || { echo 0; return 0; }
    echo $((mins * 60))
}

wait_is_bounded() {
    local max_wait="${1:-0}"
    [[ "$max_wait" =~ ^[0-9]+$ ]] && (( max_wait > 0 ))
}

wait_timed_out() {
    local elapsed="${1:-0}" max_wait="${2:-0}"
    wait_is_bounded "$max_wait" && (( elapsed >= max_wait ))
}

usage() {
    cat <<'USAGE'
PR Step

Usage:
  pr-step [options]
  pr-step --force create [create-options]
  pr-step --force review [review-options]
  pr-step --force merge [merge-options]

Normal options:
  --message MSG          Commit/re-review message. Default derives from staged diff.
  --title TITLE          PR title for first create. Default uses latest commit subject.
  --body BODY            PR body for first create. Default is generated.
  --timeout MINS         Explicit CodeRabbit wait cap; default is no timeout
  --no-merge             Do not auto-merge even if checks are green.
  --show-raw-review      Print full CodeRabbit/GitHub review output.
  -h, --help             Show this help.

Force escape hatches:
  --force create         Create PR path, equivalent to the old pr-create behavior.
  --force review         Review/read path, equivalent to the old pr-review-loop behavior.
  --force merge          Merge path, equivalent to the old pr-merge entrypoint.

Behavior:
  No PR: commit pending changes, push, create PR, summarize review/check state.
  PR:    commit pending changes, push, skip re-review if current head is already green;
         otherwise request CodeRabbit re-review and summarize actionable findings.
  Green: auto-merge unless --no-merge is set; worktree cleanup is deferred to WrapperEnd.
USAGE
}

usage_force_create() {
    cat <<'USAGE'
PR Step --force create

Usage: pr-step --force create [gh pr create options] [--wait] [--timeout MINS]

Explicit escape hatch for jammed create states. Prefer plain `pr-step`.
Common options: --title/-t, --body/-b, --base/-B, --head/-H, --draft, --wait,
--no-wait, --timeout MINS (explicit emergency cap; default unbounded).
USAGE
}

usage_force_review() {
    cat <<'USAGE'
PR Step --force review

Usage: pr-step --force review [PR_NUMBER] [options]

Explicit escape hatch for jammed review states. Prefer plain `pr-step`.
Options: --message MSG, --no-push, --read, --timeout MINS (explicit emergency cap; default unbounded).
USAGE
}

usage_force_merge() {
    cat <<'USAGE'
PR Step --force merge

Usage: pr-step --force merge [PR_NUMBER] [options]

Explicit escape hatch for jammed merge states. Prefer plain `pr-step`.
Options: --squash, --merge, --rebase, --no-cleanup, -y/--yes, --dry-run.
USAGE
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --message|--title|--body|--timeout)
                [[ $# -ge 2 ]] || { error "Missing value for $1"; usage >&2; exit 2; }
                case "$1" in
                    --message) MESSAGE="$2" ;;
                    --title) TITLE="$2" ;;
                    --body) BODY="$2" ;;
                    --timeout)
                        TIMEOUT_MINS="$(normalize_timeout_mins "$2")" || {
                            error "Invalid --timeout value: $2 (use positive minutes, 0, none, never, or unbounded)"
                            exit 2
                        }
                        ;;
                esac
                shift 2
                ;;
            --no-merge) AUTO_MERGE=false; shift ;;
            --show-raw-review) SHOW_RAW_REVIEW=true; shift ;;
            --force)
                [[ $# -ge 2 ]] || { error "--force requires create, review, or merge"; usage >&2; exit 2; }
                case "$2" in
                    create|review|merge) FORCE_MODE="$2"; shift 2; FORCE_ARGS=("$@"); return 0 ;;
                    *) error "Unknown --force mode: $2"; usage >&2; exit 2 ;;
                esac
                ;;
            -h|--help) usage; exit 0 ;;
            *) error "Unknown argument: $1"; usage >&2; exit 2 ;;
        esac
    done
}

json_escape() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"; }

pr_step_ledger_resolve_field() {
    local query_key="$1" query_value="$2" field="$3" base url json
    [[ -n "$query_key" && -n "$query_value" && -n "$field" ]] || return 0
    base="${TMUXCTLD_URL:-http://127.0.0.1:7778}"
    url="$(QUERY_KEY="$query_key" QUERY_VALUE="$query_value" BASE="$base" python3 - <<'PYURL'
import os, urllib.parse
base = os.environ.get("BASE", "http://127.0.0.1:7778").rstrip("/")
print(f"{base}/ledger/resolve?{urllib.parse.urlencode({os.environ.get('QUERY_KEY', ''): os.environ.get('QUERY_VALUE', '')})}")
PYURL
)"
    json="$(curl -fsS -m 1 "$url" 2>/dev/null || true)"
    [[ -n "$json" ]] || return 0
    LEDGER_JSON="$json" LEDGER_FIELD="$field" python3 - <<'PYLEDGER'
import json, os, sys
try:
    data = json.loads(os.environ.get("LEDGER_JSON", ""))
except Exception:
    sys.exit(0)
if not isinstance(data, dict):
    sys.exit(0)
# tmuxctld returns {ok:true,result:{found:true,row:{...}}}; tolerate older
# direct shapes only while still consuming the canonical /ledger/resolve surface.
result = data.get("result") if isinstance(data.get("result"), dict) else data
if not isinstance(result, dict) or not result.get("found"):
    sys.exit(0)
row = result.get("row") if isinstance(result.get("row"), dict) else {}
field = os.environ.get("LEDGER_FIELD", "")
value = row.get(field) or result.get(field) or ""
if value:
    print(str(value), end="")
PYLEDGER
}

pr_step_wrapper_id() {
    printf '%s' "${TOKEN_API_WRAPPER_ID:-${TOKEN_API_WRAPPER_LAUNCH_ID:-}}"
}

pr_step_resolve_instance_id() {
    local wrapper pane value env_iid
    wrapper="$(pr_step_wrapper_id)"
    value="$(pr_step_ledger_resolve_field wrapper_id "$wrapper" instance_id || true)"
    [[ -n "$value" ]] && { printf '%s' "$value"; return 0; }

    # Non-Token-OS repos and some revival/wave workers may not have a tmuxctld
    # wrapper row available to this shell, but the harness still exports the
    # originating instance id. Prefer that explicit identity before falling back
    # to pane lookup: pane variables are easier to inherit stale across nested
    # shells and caused PR flags to land on the wrong row.
    env_iid="${TOKEN_API_INSTANCE_ID:-}"
    [[ -n "$env_iid" ]] && { printf '%s' "$env_iid"; return 0; }

    pane="${TMUX_PANE:-${TOKEN_API_DISPATCH_RESOLVED_PANE:-}}"
    value="$(pr_step_ledger_resolve_field pane_id "$pane" instance_id || true)"
    [[ -n "$value" ]] && { printf '%s' "$value"; return 0; }
    return 0
}

pr_step_resolve_pane() {
    local wrapper pane value
    wrapper="$(pr_step_wrapper_id)"
    value="$(pr_step_ledger_resolve_field wrapper_id "$wrapper" pane_positional_id || true)"
    [[ -n "$value" ]] && { printf '%s' "$value"; return 0; }
    pane="${TMUX_PANE:-${TOKEN_API_DISPATCH_RESOLVED_PANE:-}}"
    value="$(pr_step_ledger_resolve_field pane_id "$pane" pane_positional_id || true)"
    [[ -n "$value" ]] && { printf '%s' "$value"; return 0; }
    [[ -n "$pane" ]] && printf '%s' "$pane"
}

mark_instance_status() {
    local status="$1" api iid body
    iid="$(pr_step_resolve_instance_id)"
    [[ -n "$iid" ]] || return 0
    api="${TOKEN_API_URL:-http://localhost:7777}"
    case "$status" in
        reviewing)
            body="{\"status\":$(json_escape "$status"),\"workflow_state\":\"review_mode\",\"next_required_action\":\"review\",\"next_action_owner\":\"human\"}"
            ;;
        victorious)
            body="{\"status\":$(json_escape "$status"),\"workflow_state\":\"complete\",\"next_required_action\":null,\"next_action_owner\":null}"
            ;;
        *)
            body="{\"status\":$(json_escape "$status")}" ;;
    esac
    curl -fsS -m 5 -X PATCH -H 'Content-Type: application/json' -d "$body" \
        "${api%/}/api/instances/${iid}/status" >/dev/null 2>&1 || true
}

mark_pr_flag() {
    local pr_url="$1" pr_state="${2:-open}" api iid body
    iid="$(pr_step_resolve_instance_id)"
    [[ -n "$iid" ]] || return 0
    api="${TOKEN_API_URL:-http://localhost:7777}"
    body="{\"pr_url\":$(json_escape "$pr_url"),\"pr_state\":$(json_escape "$pr_state") }"
    curl -fsS -m 5 -X PATCH -H 'Content-Type: application/json' -d "$body" \
        "${api%/}/api/instances/${iid}/pr" >/dev/null 2>&1 || true
}

pr_plan_followup_context() {
    local pr="$1" head short cr review changes findings checks
    head="$(pr_head_sha "$pr" 2>/dev/null || true)"
    short="${head:0:7}"
    cr="$(coderabbit_state_for_head "$head" 2>/dev/null || true)"
    review="$(latest_coderabbit_review_state "$pr" 2>/dev/null || true)"
    changes="$(changes_requested_count "$pr" 2>/dev/null || true)"
    checks="$(checks_summary "$pr" 2>/dev/null || true)"
    findings="$(summarize_actionable_findings "$pr" "$head" 2>/dev/null || true)"

    printf 'CodeRabbit verdict: commit=%s; review=%s; changes_requested=%s; head=%s\n' "${cr:-none}" "${review:-none}" "${changes:-unknown}" "${short:-unknown}"
    printf 'Checks:\n'
    if [[ -n "$checks" ]]; then printf '%s\n' "$checks"; else printf '  - none reported\n'; fi
    printf 'Actionable CodeRabbit findings:\n'
    if [[ -n "$findings" ]]; then printf '%s\n' "$findings"; else printf '  - none found on current head\n'; fi
}

arm_pr_plan_followup() {
    local stage="$1" pr="$2" url="${3:-}" summary="${4:-}" pane iid api prompt body context
    pane="$(pr_step_resolve_pane)"
    [[ -n "$pane" ]] || return 0
    iid="$(pr_step_resolve_instance_id || true)"

    case "$stage" in
        review)
            [[ -n "$summary" ]] || summary="plan fixes or next review action."
            prompt="/plan PR #${pr} review returned"
            [[ -n "$url" ]] && prompt+=" (${url})"
            context="$(pr_plan_followup_context "$pr" 2>/dev/null || true)"
            prompt+="; ${summary}"
            [[ -n "$context" ]] && prompt+=$'\n\n'"${context}"
            ;;
        merge)
            [[ -n "$summary" ]] || summary="summarize closure and update context."
            prompt="/plan PR #${pr} merged"
            [[ -n "$url" ]] && prompt+=" (${url})"
            prompt+="; ${summary}"
            ;;
        *)
            return 0
            ;;
    esac

    api="${TOKEN_API_URL:-http://localhost:7777}"
    if [[ -n "$iid" ]]; then
        body="{\"target_instance_id\":$(json_escape "$iid"),\"target_pane\":$(json_escape "$pane"),\"subscriber_instance_id\":$(json_escape "$iid"),\"subscriber_pane\":$(json_escape "$pane"),\"event\":\"stop\",\"delivery\":\"prompt\",\"purpose\":\"pr_step_plan\",\"payload\":$(json_escape "$prompt"),\"oneshot\":true}"
    else
        body="{\"target_pane\":$(json_escape "$pane"),\"subscriber_pane\":$(json_escape "$pane"),\"event\":\"stop\",\"delivery\":\"prompt\",\"purpose\":\"pr_step_plan\",\"payload\":$(json_escape "$prompt"),\"oneshot\":true}"
    fi
    curl -fsS -m 3 -X POST -H 'Content-Type: application/json' -d "$body" \
        "${api%/}/api/hooks/subscribe" >/dev/null 2>&1 || true
}


disarm_pr_plan_followup() {
    local pane iid api body
    pane="$(pr_step_resolve_pane)"
    iid="$(pr_step_resolve_instance_id || true)"
    [[ -n "$pane" || -n "$iid" ]] || return 0
    api="${TOKEN_API_URL:-http://localhost:7777}"
    if [[ -n "$iid" && -n "$pane" ]]; then
        body="{\"target_instance_id\":$(json_escape "$iid"),\"target_pane\":$(json_escape "$pane"),\"subscriber_instance_id\":$(json_escape "$iid"),\"subscriber_pane\":$(json_escape "$pane"),\"event\":\"stop\",\"purpose\":\"pr_step_plan\"}"
    elif [[ -n "$iid" ]]; then
        body="{\"target_instance_id\":$(json_escape "$iid"),\"subscriber_instance_id\":$(json_escape "$iid"),\"event\":\"stop\",\"purpose\":\"pr_step_plan\"}"
    else
        body="{\"target_pane\":$(json_escape "$pane"),\"subscriber_pane\":$(json_escape "$pane"),\"event\":\"stop\",\"purpose\":\"pr_step_plan\"}"
    fi
    curl -fsS -m 3 -X POST -H 'Content-Type: application/json' -d "$body" \
        "${api%/}/api/hooks/unsubscribe" >/dev/null 2>&1 || true
}

assert_pr_capable_remote() {
    local top origin
    top="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    origin="$(git remote get-url origin 2>/dev/null || true)"
    if [[ "$top" == *"/Token-OS/"* || "$top" == *"/Token-OS" ]]; then
        if ! token_os_github_remote "$origin"; then
            error "worktree is not PR-capable; expected TokenAmby-Code/Token-OS GitHub remote"
            error "origin remote: ${origin:-<missing>}"
            exit 64
        fi
        return 0
    fi
    if dead_or_quarantined_remote "$origin"; then
        error "worktree is not PR-capable; origin remote is missing, dead, or quarantined: ${origin:-<missing>}"
        exit 64
    fi
}

assert_repo() {
    git rev-parse --show-toplevel >/dev/null 2>&1 || { error "Must be run in a git repository"; exit 1; }
    local branch
    branch="$(git branch --show-current)"
    [[ -n "$branch" ]] || { error "Detached HEAD; cannot manage PR"; exit 1; }
    case "$branch" in main|master|prod) error "Refusing to run pr-step on protected branch: $branch"; exit 64 ;; esac
    assert_pr_capable_remote
}

commit_if_needed() {
    local msg="$1"
    if git diff --quiet --ignore-submodules -- && git diff --cached --quiet --ignore-submodules -- && [[ -z "$(git ls-files --others --exclude-standard)" ]]; then
        log "Commit: no local changes."
        return 1
    fi
    git add -A
    unstage_denied_worktree_env_files
    if git diff --cached --quiet --ignore-submodules --; then
        log "Commit: no staged changes after git add -A."
        return 1
    fi
    if [[ -z "$msg" ]]; then
        msg="$(default_commit_message_from_staged)"
    fi
    local out rc
    out="$(mktemp -t pr-step-commit.XXXXXX)"
    if git commit -m "$msg" >"$out" 2>&1; then
        success "Commit: $(git rev-parse --short HEAD) — $(git log -1 --pretty=%s)"
        rm -f "$out"
        return 0
    fi
    rc=$?
    cat "$out" >&2
    rm -f "$out"
    return "$rc"
}

push_branch() {
    local branch out rc
    branch="$(git branch --show-current)"
    out="$(mktemp -t pr-step-push.XXXXXX)"
    if git rev-parse --abbrev-ref '@{upstream}' >/dev/null 2>&1; then
        "$PUSH_WRAPPER" "$GIT_GITHUB_REMOTE" "$branch" >"$out" 2>&1 || rc=$?
    else
        "$PUSH_WRAPPER" -u "$GIT_GITHUB_REMOTE" "$branch" >"$out" 2>&1 || rc=$?
    fi
    if [[ -n "${rc:-}" ]]; then
        cat "$out" >&2
        rm -f "$out"
        return "$rc"
    fi
    success "Push: ${branch} -> ${GIT_GITHUB_REMOTE}/${branch}"
    rm -f "$out"
}

current_pr_number() {
    gh pr view --json number -q '.number' 2>/dev/null || true
}

current_pr_url() {
    local pr="$1"
    gh pr view "$pr" --json url -q '.url' 2>/dev/null || true
}

current_pr_state() {
    local pr="$1"
    gh pr view "$pr" --json state -q '.state' 2>/dev/null || true
}

default_body() {
    local subject="$1"
    cat <<BODY
## Summary
- ${subject}

## Test plan
- [ ] Review automated checks
- [ ] CodeRabbit review

Generated by pr-step.
BODY
}

repo_slug() { gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null || true; }

pr_head_sha() {
    local pr="$1" repo
    repo="$(repo_slug)"
    [[ -n "$repo" ]] || return 1
    gh api "repos/${repo}/pulls/${pr}" --jq '.head.sha' 2>/dev/null || true
}

coderabbit_state_for_head() {
    local head="$1" repo state check
    repo="$(repo_slug)"
    [[ -n "$repo" && -n "$head" ]] || return 1
    state="$(gh api --paginate "repos/${repo}/commits/${head}/statuses" 2>/dev/null | jq -s -r 'add | [.[] | select(.context | ascii_downcase | startswith("coderabbit"))] | sort_by(.updated_at) | .[-1].state // ""' 2>/dev/null || true)"
    if [[ -n "$state" ]]; then
        printf '%s\n' "$state"
        return 0
    fi
    check="$(gh api --paginate "repos/${repo}/commits/${head}/check-runs" 2>/dev/null | jq -s -r '
        [.[].check_runs[]? | select(
            (((.name // "") | ascii_downcase) | startswith("coderabbit"))
            or (((.app.slug // "") | ascii_downcase) == "coderabbitai")
        )]
        | sort_by(.completed_at // .started_at // .created_at // "")
        | .[-1] // empty
        | if . == null then "" elif (.status // "") != "completed" then (.status // "") else (.conclusion // "") end
    ' 2>/dev/null || true)"
    case "$check" in
        success|neutral) printf 'success\n' ;;
        failure|cancelled|timed_out|action_required) printf 'failure\n' ;;
        *) printf '%s\n' "$check" ;;
    esac
}

latest_coderabbit_review_state() {
    local pr="$1" repo
    repo="$(repo_slug)"
    [[ -n "$repo" ]] || return 1
    gh api "repos/${repo}/pulls/${pr}/reviews" 2>/dev/null | jq -r '
        [.[] | select((.user.login // "" | ascii_downcase) as $u | $u == "coderabbitai[bot]" or $u == "coderabbitai" or $u == "coderabbit")]
        | sort_by(.submitted_at)
        | .[-1].state // ""
    ' 2>/dev/null || true
}

# --- Rate-limit / CodeRabbit shelved-review handling -------------------------
# When CodeRabbit hits its own usage/rate limit it does NOT run a review: it
# posts a "review skipped / rate limit exceeded" deferral and never comes back
# on its own. That deferral must never be mistaken for a completed review — the
# gate is only satisfied by a genuine review. pr-step detects the deferral,
# re-requests deliberately, and keeps waiting (reusing the unbounded wait) until
# a real review lands.
CR_RATELIMIT_REGEX='rate limit exceeded|rate limited|review limit reached|exceeded the (rate )?limit|before requesting another review|review skipped|reached (your|the) [^.]*limit|usage limits?|next review (will be )?available|please wait [0-9]|retry-after|x-ratelimit-reset|x-rate-limit-reset|ratelimit-reset|rate-limit-reset'

rate_limit_reset_epoch_from_text() {
    local now="${1:-}"
    local text
    text="$(cat)"
    RATE_LIMIT_NOW="$now" RATE_LIMIT_TEXT="$text" python3 - <<'PY'
from __future__ import annotations

from datetime import datetime, timezone
from email.utils import parsedate_to_datetime
import os
import re

try:
    now = int(float(os.environ.get("RATE_LIMIT_NOW", "")))
except Exception:
    now = int(datetime.now(timezone.utc).timestamp())

text = os.environ.get("RATE_LIMIT_TEXT", "")
plain = re.sub(r"(?i)<br\s*/?>", "\n", text)
plain = re.sub(r"[*_`]", "", plain)


def emit(epoch: int | None) -> None:
    if epoch is not None:
        print(epoch)
        raise SystemExit(0)


def parse_http_or_iso(value: str) -> int | None:
    value = value.strip()
    if not value:
        return None
    try:
        parsed = parsedate_to_datetime(value)
        if parsed.tzinfo is None:
            parsed = parsed.replace(tzinfo=timezone.utc)
        return int(parsed.timestamp())
    except Exception:
        pass
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
        if parsed.tzinfo is None:
            parsed = parsed.replace(tzinfo=timezone.utc)
        return int(parsed.timestamp())
    except Exception:
        return None


# RFC-ish headers and common CLI/debug spellings. Prefer Retry-After because it
# is the explicit "try again after this" signal; then accept reset-epoch headers.
# CodeRabbit may surface the reset as prose/comment text rather than raw headers.
# Header-form captures whole HTTP-date lines; inline comment-form only accepts
# numeric deltas so punctuation around prose cannot become a bogus date string.
retry = re.search(r"(?im)^\s*retry-after\s*:\s*([^\r\n]+)", text)
if not retry:
    retry = re.search(r"(?i)\bretry-after\s*:\s*(\d+)\b", text)
if retry:
    value = retry.group(1).strip().rstrip(".")
    if re.fullmatch(r"\d+", value):
        emit(now + int(value))
    emit(parse_http_or_iso(value))

reset = re.search(
    r"(?im)^\s*(?:x-?ratelimit-reset|x-?rate-limit-reset|ratelimit-reset|rate-limit-reset)\s*:\s*([^\r\n]+)",
    text,
)
if not reset:
    reset = re.search(
        r"(?i)\b(?:x-?ratelimit-reset|x-?rate-limit-reset|ratelimit-reset|rate-limit-reset)\s*:\s*(\d+)\b",
        text,
    )
if reset:
    value = reset.group(1).strip().rstrip(".")
    if re.fullmatch(r"\d+", value):
        number = int(value)
        # GitHub's x-ratelimit-reset is epoch seconds. Some RateLimit-Reset
        # variants are delta seconds; tolerate both without inventing a delay.
        emit(number if number > 1_000_000_000 else now + number)
    emit(parse_http_or_iso(value))

# CodeRabbit comment bodies sometimes express the documented window in prose.
duration = re.search(
    r"(?:retry after|please wait|wait|next review (?:will be )?available in|review available in|available in:?)\s+"
    r"(?:(\d+)\s*(?:hours?|hrs?|h)\s*)?"
    r"(?:and\s*)?"
    r"(?:(\d+)\s*(?:minutes?|mins?|m)\s*)?"
    r"(?:and\s*)?"
    r"(?:(\d+)\s*(?:seconds?|secs?|s))?",
    plain,
    re.I,
)
if duration and any(duration.groups()):
    hours = int(duration.group(1) or 0)
    minutes = int(duration.group(2) or 0)
    seconds = int(duration.group(3) or 0)
    emit(now + hours * 3600 + minutes * 60 + seconds)

at = re.search(r"(?:resets?|try again)\s+(?:at|after)\s+([^\r\n.]+)", plain, re.I)
if at:
    emit(parse_http_or_iso(at.group(1).strip()))
PY
}

rate_limit_reset_reached() {
    local reset_epoch="$1" now
    [[ "$reset_epoch" =~ ^[0-9]+$ ]] || return 1
    now="$(date +%s)"
    [[ "$now" =~ ^[0-9]+$ ]] || return 1
    (( now >= reset_epoch ))
}

sleep_until_rate_limit_reset() {
    local reset_epoch="$1" label="${2:-rate limit}" now wait_for
    [[ "$reset_epoch" =~ ^[0-9]+$ ]] || return 1
    while true; do
        now="$(date +%s)"
        [[ "$now" =~ ^[0-9]+$ ]] || return 1
        (( now >= reset_epoch )) && return 0
        wait_for=$(( reset_epoch - now ))
        sleep "$wait_for"
    done
}

rate_limit_reset_epoch_with_review_padding() {
    local reset_epoch="$1"
    [[ "$reset_epoch" =~ ^[0-9]+$ ]] || return 1
    echo $(( reset_epoch + 60 ))
}

# Pure predicate (testable): is this CodeRabbit comment body a rate-limit/shelved
# deferral rather than a genuine review? A real summary is never a deferral.
coderabbit_body_is_ratelimit() {
    local body="$1"
    [[ -n "$body" ]] || return 1
    grep -qiE '^[[:space:]]*#{1,3}[[:space:]]*Summary by CodeRabbit' <<<"$body" && return 1
    grep -qiE 'Full review finished|No actionable comments were generated' <<<"$body" && return 1
    grep -qiE 'Result:[[:space:]]*Skipped[[:space:]]*-[[:space:]]*Already reviewed|Skipped[[:space:]]*-[[:space:]]*Already reviewed' <<<"$body" && return 1
    grep -qiE "$CR_RATELIMIT_REGEX" <<<"$body"
}

# Pure parser (testable): seconds CodeRabbit asked us to wait before re-review.
# Reads Retry-After/reset/prose hints; echoes 0 when absent.
coderabbit_ratelimit_wait_seconds() {
    local body="$1" now reset
    now="$(date +%s)"
    reset="$(rate_limit_reset_epoch_from_text "$now" <<<"$body" || true)"
    if [[ "$reset" =~ ^[0-9]+$ ]] && (( reset > now )); then
        echo $(( reset - now ))
    else
        echo 0
    fi
}

coderabbit_ratelimit_reset_epoch() {
    local body="$1" now
    now="$(date +%s)"
    rate_limit_reset_epoch_from_text "$now" <<<"$body" || true
}

iso_timestamp_epoch() {
    local stamp="$1"
    [[ -n "$stamp" ]] || return 1
    TIMESTAMP_TEXT="$stamp" python3 - <<'PY_EPOCH'
from __future__ import annotations

from datetime import datetime, timezone
import os

stamp = os.environ.get("TIMESTAMP_TEXT", "").strip()
try:
    parsed = datetime.fromisoformat(stamp.replace("Z", "+00:00"))
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=timezone.utc)
    print(int(parsed.timestamp()))
except Exception:
    raise SystemExit(1)
PY_EPOCH
}

coderabbit_ratelimit_reset_epoch_at() {
    local body="$1" stamp="${2:-}" base
    base="$(iso_timestamp_epoch "$stamp" 2>/dev/null || true)"
    [[ "$base" =~ ^[0-9]+$ ]] || base="$(date +%s)"
    rate_limit_reset_epoch_from_text "$base" <<<"$body" || true
}

coderabbit_latest_issue_comment_json() {
    local pr="$1" repo
    repo="$(repo_slug)"
    [[ -n "$repo" ]] || return 1
    gh api --paginate "repos/${repo}/issues/${pr}/comments" 2>/dev/null | jq -s -r '
        [ .[] | .[] | select((.user.login // "" | ascii_downcase) as $u
            | $u == "coderabbitai[bot]" or $u == "coderabbitai" or $u == "coderabbit")]
        | sort_by(.updated_at // .created_at // "") | .[-1] // empty' 2>/dev/null || true
}

# Fetch the body of CodeRabbit's most recent issue (general) comment on a PR.
coderabbit_latest_issue_comment_body() {
    local pr="$1"
    coderabbit_latest_issue_comment_json "$pr" | jq -r '.body // ""' 2>/dev/null || true
}

coderabbit_latest_issue_comment_timestamp() {
    local pr="$1"
    coderabbit_latest_issue_comment_json "$pr" | jq -r '.updated_at // .created_at // ""' 2>/dev/null || true
}

# True when CodeRabbit's most recent activity on the PR is a rate-limit/shelved
# deferral (i.e. no genuine review has landed for the current request).
coderabbit_review_is_deferred() {
    local pr="$1" body
    body="$(coderabbit_latest_issue_comment_body "$pr")"
    coderabbit_body_is_ratelimit "$body"
}

# Compute how long to wait before re-requesting a CodeRabbit review from the
# reset signal CodeRabbit explicitly stated. No signal means no invented sleep.
coderabbit_backoff_seconds() {
    local pr="$1" asked
    asked="$(coderabbit_ratelimit_wait_seconds "$(coderabbit_latest_issue_comment_body "$pr")")"
    [[ "$asked" =~ ^[0-9]+$ ]] && (( asked > 0 )) || return 1
    echo "$asked"
}

# Deliberately re-request a full CodeRabbit review (used to escape a rate-limit
# deferral). Posts the canonical trigger command as a PR comment.
coderabbit_rerequest_review() {
    local pr="$1"
    local reason="${2:-CodeRabbit review was rate-limited/shelved; re-requesting a full review.}"
    gh pr comment "$pr" --body "$reason

@coderabbitai full review" >/dev/null 2>&1
}

coderabbit_maybe_rerequest_on_timeout() {
    local pr="$1" done_var="$2" max="${3:-${PR_STEP_CR_TIMEOUT_REREQUESTS:-2}}" done
    [[ "$max" =~ ^[0-9]+$ ]] || return 1
    done="${!done_var:-0}"
    [[ "$done" =~ ^[0-9]+$ ]] || done=0
    (( done < max )) || return 1
    done=$((done + 1))
    coderabbit_rerequest_review "$pr" "CodeRabbit review timed out with no fresh verdict; re-requesting the full review (attempt ${done}/${max})." || return 2
    printf -v "$done_var" '%s' "$done"
    return 0
}

coderabbit_maybe_wait_rate_limit_on_timeout() {
    local pr="$1" done_var="${2:-}" max="${3:-${PR_STEP_CR_TIMEOUT_REREQUESTS:-2}}" latest body stamp
    latest="$(coderabbit_latest_issue_comment_json "$pr")"
    body="$(printf '%s' "$latest" | jq -r '.body // ""' 2>/dev/null || true)"
    coderabbit_body_is_ratelimit "$body" || return 1
    stamp="$(printf '%s' "$latest" | jq -r '.updated_at // .created_at // ""' 2>/dev/null || true)"
    coderabbit_handle_ratelimit_comment "$pr" "$body" "$stamp" "$done_var" "$max"
}

coderabbit_handle_ratelimit_comment() {
    local pr="$1" body="${2:-}" stamp="${3:-}" done_var="${4:-}" max="${5:-${PR_STEP_CR_TIMEOUT_REREQUESTS:-2}}" signature reset padded_reset done
    coderabbit_body_is_ratelimit "$body" || return 1
    signature="$(printf '%s' "${stamp}:${body}" | cksum | awk '{print $1 ":" $2}')"
    [[ "$signature" != "${LAST_RATELIMIT_SIGNATURE:-}" ]] || return 1
    LAST_RATELIMIT_SIGNATURE="$signature"

    reset="$(coderabbit_ratelimit_reset_epoch_at "$body" "$stamp")"
    if [[ "$reset" =~ ^[0-9]+$ ]]; then
        padded_reset="$(rate_limit_reset_epoch_with_review_padding "$reset")"
        if [[ -n "$done_var" ]]; then
            [[ "$max" =~ ^[0-9]+$ ]] || return 1
            done="${!done_var:-0}"
            [[ "$done" =~ ^[0-9]+$ ]] || done=0
            (( done < max )) || return 1
        fi
        sleep_until_rate_limit_reset "$padded_reset" "CodeRabbit rate limit"
        if rate_limit_reset_reached "$padded_reset"; then
            if [[ -n "$done_var" ]]; then
                done=$((done + 1))
                printf -v "$done_var" '%s' "$done"
            fi
            coderabbit_rerequest_review "$pr" "CodeRabbit rate limit reset + 60s reached; re-requesting the full review." || {
                error "Failed to re-request CodeRabbit review after rate-limit reset"
                exit 1
            }
            return 0
        fi
    else
        :
    fi
    return 1
}

changes_requested_count() {
    local pr="$1" repo
    repo="$(repo_slug)"
    [[ -n "$repo" ]] || { echo 1; return 0; }
    gh api "repos/${repo}/pulls/${pr}/reviews" 2>/dev/null | jq -r '
        sort_by(.user.login, .submitted_at)
        | group_by(.user.login)
        | map(max_by(.submitted_at))
        | [.[] | select(.state == "CHANGES_REQUESTED")]
        | length
    ' 2>/dev/null || echo 1
}

checks_summary() {
    local pr="$1" out rc
    out="$(mktemp -t pr-step-checks.XXXXXX)"
    if gh pr checks "$pr" --watch=false --fail-fast=false >"$out" 2>&1; then
        if [[ -s "$out" ]]; then
            awk 'NF {print "  - " $0}' "$out" | head -20
        else
            echo "  - no checks reported"
        fi
        rm -f "$out"
        return 0
    fi
    rc=$?
    if grep -qi "no checks" "$out" 2>/dev/null; then
        echo "  - no checks reported"
        rm -f "$out"
        return 0
    fi
    awk 'NF {print "  - " $0}' "$out" | head -20
    rm -f "$out"
    return "$rc"
}

checks_green() {
    local pr="$1" head cr_state changes mergeable state checks_tmp
    head="$(pr_head_sha "$pr")"
    [[ -n "$head" ]] || return 1
    state="$(gh pr view "$pr" --json state -q '.state' 2>/dev/null || true)"
    [[ "$state" == "OPEN" ]] || return 1
    mergeable="$(gh pr view "$pr" --json mergeable -q '.mergeable' 2>/dev/null || true)"
    [[ "$mergeable" != "CONFLICTING" ]] || return 1
    cr_state="$(coderabbit_state_for_head "$head")"
    [[ "$cr_state" == "success" ]] || return 1
    # A rate-limit/shelved deferral is not a completed review even if the commit
    # status flipped to success. Never let a skipped review satisfy the gate —
    # this is the path that otherwise voids the Golden Throne victory condition.
    if coderabbit_review_is_deferred "$pr"; then
        return 1
    fi
    changes="$(changes_requested_count "$pr")"
    [[ "$changes" == "0" ]] || return 1
    checks_tmp="$(mktemp -t pr-step-checks.XXXXXX)"
    if gh pr checks "$pr" --watch=false --fail-fast=false >"$checks_tmp" 2>/dev/null; then
        rm -f "$checks_tmp"
        return 0
    fi
    if grep -qi "no checks" "$checks_tmp" 2>/dev/null; then
        rm -f "$checks_tmp"
        return 0
    fi
    rm -f "$checks_tmp"
    return 1
}

summarize_actionable_findings() {
    local pr="$1" head="${2:-}" repo short
    repo="$(repo_slug)"
    [[ -n "$repo" ]] || return 0
    short="${head:0:7}"
    gh api "repos/${repo}/pulls/${pr}/comments" 2>/dev/null | jq -r --arg head "$head" --arg short "$short" '
        def is_coderabbit:
            (.user.login // "" | ascii_downcase) as $u
            | $u == "coderabbitai[bot]" or $u == "coderabbitai" or $u == "coderabbit";
        def has_live_line:
            ((.position // .line // .original_line // null) != null);
        def first_line:
            (.body // ""
            | gsub("\\r\\n"; "\\n")
            | split("\\n")
            | map(select(length > 0 and (startswith("<!--") | not)))
            | .[0] // "");
        def format_finding:
            "  - \(.path // "General"):\(.line // .original_line // "?") — \(first_line | .[0:220])";

        [.[] | select(is_coderabbit)] as $all
        | ($all
            | map(select(($head != "") and ((.commit_id // "") == $head) and has_live_line))
            | sort_by(.updated_at)
            | reverse) as $current
        | ($all
            | map(select((($head == "") or ((.commit_id // "") != $head) or (has_live_line | not))))
            | length) as $historical
        | if ($current | length) > 0 then
            (($current[:8][] | format_finding),
             (if $historical > 0 then
                "  - historical/resolved CodeRabbit findings omitted: \($historical) (not on current head \($short))"
              else empty end))
          elif ($all | length) > 0 then
            "  - none on current head \($short); historical/resolved CodeRabbit findings omitted: \(($all | length))"
          else
            empty
          end
    ' 2>/dev/null || true
}

latest_coderabbit_overview_body() {
    local pr="$1" repo
    repo="$(repo_slug)"
    [[ -n "$repo" ]] || return 0
    gh api "repos/${repo}/issues/${pr}/comments" 2>/dev/null | jq -r '
        def is_coderabbit:
            (.user.login // "" | ascii_downcase) as $u
            | $u == "coderabbitai[bot]" or $u == "coderabbitai" or $u == "coderabbit";
        [.[] | select(is_coderabbit)]
        | sort_by(.updated_at // .created_at // "")
        | .[-1].body // ""
    ' 2>/dev/null || true
}

latest_coderabbit_review_body() {
    local pr="$1" repo
    repo="$(repo_slug)"
    [[ -n "$repo" ]] || return 0
    gh api "repos/${repo}/pulls/${pr}/reviews" 2>/dev/null | jq -r '
        def is_coderabbit:
            (.user.login // "" | ascii_downcase) as $u
            | $u == "coderabbitai[bot]" or $u == "coderabbitai" or $u == "coderabbit";
        [.[] | select(is_coderabbit)]
        | sort_by(.submitted_at // "")
        | .[-1]
        | if . == null then "" else
            "State: \(.state // "unknown")\n\((.body // "") | gsub("\r\n"; "\n"))"
          end
    ' 2>/dev/null || true
}

coderabbit_inline_findings_full() {
    local pr="$1" head="${2:-}" repo
    repo="$(repo_slug)"
    [[ -n "$repo" ]] || return 0
    gh api "repos/${repo}/pulls/${pr}/comments" 2>/dev/null | jq -r --arg head "$head" '
        def is_coderabbit:
            (.user.login // "" | ascii_downcase) as $u
            | $u == "coderabbitai[bot]" or $u == "coderabbitai" or $u == "coderabbit";
        def has_live_line:
            ((.position // .line // .original_line // null) != null);
        [.[] | select(is_coderabbit and (($head == "") or ((.commit_id // "") == $head)) and has_live_line)]
        | sort_by(.path // "", .line // .original_line // 0, .updated_at // "")
        | .[]
        | "### \(.path // "General"):\(.line // .original_line // "N/A")\n\((.body // "") | gsub("\r\n"; "\n"))\n"
    ' 2>/dev/null || true
}

print_failing_check_details() {
    local pr="$1" checks_json failed_count run_ids
    checks_json="$(gh pr checks "$pr" --json name,workflow,state,bucket,link,description 2>/dev/null || true)"
    if [[ -z "$checks_json" ]]; then
        return 0
    fi
    failed_count="$(printf '%s' "$checks_json" | jq -r '
        if type != "array" then 0 else
        [ .[] | select(
            ((.bucket // "") | ascii_downcase) as $b
            | ((.state // "") | ascii_downcase) as $s
            | ($b | test("fail|cancel|error|action_required|timed_out"))
              or ($s | test("fail|cancel|error|action_required|timed_out"))
        ) ] | length end
    ' 2>/dev/null || echo 0)"
    [[ "$failed_count" =~ ^[0-9]+$ ]] || failed_count=0
    (( failed_count > 0 )) || return 0

    echo "  Failing check detail:"
    printf '%s' "$checks_json" | jq -r '
        if type != "array" then empty else
        .[] | select(
            ((.bucket // "") | ascii_downcase) as $b
            | ((.state // "") | ascii_downcase) as $s
            | ($b | test("fail|cancel|error|action_required|timed_out"))
              or ($s | test("fail|cancel|error|action_required|timed_out"))
        )
        | "  - \(.workflow // "workflow") / \(.name // "check"): \(.state // .bucket // "failed")"
          + (if (.description // "") != "" then " — \(.description)" else "" end)
          + (if (.link // "") != "" then "\n    \(.link)" else "" end)
        end
    ' 2>/dev/null || true

    run_ids="$(printf '%s' "$checks_json" | jq -r '
        if type != "array" then empty else
        .[] | select(
            ((.bucket // "") | ascii_downcase) as $b
            | ((.state // "") | ascii_downcase) as $s
            | ($b | test("fail|cancel|error|action_required|timed_out"))
              or ($s | test("fail|cancel|error|action_required|timed_out"))
        )
        | (.link // "")
        | try capture("/actions/runs/(?<run>[0-9]+)").run catch empty
        end
    ' 2>/dev/null | awk '!seen[$0]++' | head -3)"
    [[ -n "$run_ids" ]] || return 0
    while IFS= read -r run_id; do
        [[ -n "$run_id" ]] || continue
        echo "    Failed log excerpt for run ${run_id}:"
        gh run view "$run_id" --log-failed 2>/dev/null | tail -120 | sed 's/^/      /' || true
    done <<<"$run_ids"
}

print_coderabbit_full_verdict() {
    local pr="$1" head="${2:-}" overview review inline
    overview="$(latest_coderabbit_overview_body "$pr")"
    review="$(latest_coderabbit_review_body "$pr")"
    inline="$(coderabbit_inline_findings_full "$pr" "$head")"

    echo "  CodeRabbit verdict:"
    if [[ -n "$overview" ]] && ! coderabbit_body_is_ratelimit "$overview"; then
        echo "  --- latest overview ---"
        printf '%s\n' "$overview" | sed 's/^/  /'
    elif [[ -n "$review" ]]; then
        :
    else
        echo "  - no CodeRabbit review body found; using commit status/check state above"
    fi
    if [[ -n "$review" ]]; then
        echo "  --- latest review ---"
        printf '%s\n' "$review" | sed 's/^/  /'
    fi
    if [[ -n "$inline" ]]; then
        echo "  --- inline findings ---"
        printf '%s\n' "$inline" | sed 's/^/  /'
    fi
    print_failing_check_details "$pr"
}

summarize_pr() {
    local pr="$1" url state title branch head short cr review changes mergeable
    url="$(current_pr_url "$pr")"
    state="$(gh pr view "$pr" --json state -q '.state' 2>/dev/null || true)"
    title="$(gh pr view "$pr" --json title -q '.title' 2>/dev/null || true)"
    branch="$(gh pr view "$pr" --json headRefName -q '.headRefName' 2>/dev/null || true)"
    mergeable="$(gh pr view "$pr" --json mergeable -q '.mergeable' 2>/dev/null || true)"
    head="$(pr_head_sha "$pr")"
    short="${head:0:7}"
    cr="$(coderabbit_state_for_head "$head")"
    review="$(latest_coderabbit_review_state "$pr")"
    changes="$(changes_requested_count "$pr")"

    echo ""
    echo "PR summary"
    echo "  PR:          #${pr}${title:+ — ${title}}"
    [[ -n "$url" ]] && echo "  URL:         $url"
    echo "  State:       ${state:-unknown}; mergeable: ${mergeable:-unknown}"
    echo "  Branch:      ${branch:-unknown}; head: ${short:-unknown}"
    echo "  CodeRabbit:  commit=${cr:-none}; review=${review:-none}; changes_requested=${changes:-unknown}"
    echo "  Checks:"
    checks_summary "$pr" || true
    echo "  Actionable CodeRabbit findings:"
    local findings
    findings="$(summarize_actionable_findings "$pr" "$head")"
    if [[ -n "$findings" ]]; then
        printf '%s\n' "$findings"
    else
        echo "  - none found on current head"
    fi
    print_coderabbit_full_verdict "$pr" "$head"
    echo ""
}

run_internal_capture() {
    local label="$1" print_on_failure="$2"; shift 2
    local out heartbeat rc=0 pid last_line="" line
    out="$(mktemp -t "pr-step-${label}.XXXXXX")"
    heartbeat="$(mktemp -t "pr-step-${label}-heartbeat.XXXXXX")"
    PR_STEP_HEARTBEAT_FILE="$heartbeat" "$@" >"$out" 2>&1 &
    pid=$!
    while kill -0 "$pid" 2>/dev/null; do
        if [[ -s "$heartbeat" ]]; then
            line="$(tail -n 1 "$heartbeat" 2>/dev/null || true)"
            if [[ -n "$line" && "$line" != "$last_line" ]]; then
                log "$line"
                last_line="$line"
            fi
        fi
        sleep 1
    done
    if wait "$pid"; then
        rc=0
    else
        rc=$?
    fi
    if [[ -s "$heartbeat" ]]; then
        line="$(tail -n 1 "$heartbeat" 2>/dev/null || true)"
        if [[ -n "$line" && "$line" != "$last_line" ]]; then
            log "$line"
        fi
    fi
    if [[ "$SHOW_RAW_REVIEW" == "true" || "${PR_STEP_PRINT_CAPTURED_OUTPUT:-false}" == "true" || ( "$print_on_failure" == "true" && $rc -ne 0 ) ]]; then
        cat "$out"
    fi
    rm -f "$out" "$heartbeat"
    return "$rc"
}


pr_create_main() (
# PR Create
# TAGS: git, pr, workflow
# AUDIENCE: human, agent
#
# Creates a pull request and prints the PR URL. Use pr-review-loop --read when
# you want the agent-readable CodeRabbit review.
#
# Usage: pr-create [gh pr create options]
#
# Examples:
#   pr-create --title "feat: add login" --body "## Summary\n- Added login"
#   pr-create -t "fix: bug" -b "Fixed the thing"
#
# The tool will create the PR, start GitHub checks, and return promptly unless
# --wait is explicitly provided.

set -euo pipefail

# Source shared libs
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]:-$0}")")" && pwd)"
source "$SCRIPT_DIR/../lib/git-remote.sh"
source "$SCRIPT_DIR/../lib/nas-path.sh" >/dev/null 2>&1 || true

json_escape() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"; }

pr_set_instance_status() {
    local status="$1" api iid body
    iid="$(pr_step_resolve_instance_id)"
    [[ -n "$iid" ]] || return 0
    api="${TOKEN_API_URL:-http://localhost:7777}"
    case "$status" in
        reviewing)
            body="{\"status\":$(json_escape "$status"),\"workflow_state\":\"review_mode\",\"next_required_action\":\"review\",\"next_action_owner\":\"human\"}"
            ;;
        victorious)
            body="{\"status\":$(json_escape "$status"),\"workflow_state\":\"complete\",\"next_required_action\":null,\"next_action_owner\":null}"
            ;;
        *)
            body="{\"status\":$(json_escape "$status")}"
            ;;
    esac
    curl -fsS -m 5 -X PATCH -H 'Content-Type: application/json' -d "$body" \
        "${api%/}/api/instances/${iid}/status" >/dev/null 2>&1 || true
}

pr_set_instance_pr_state() {
    local url="$1" state="$2" api iid body
    iid="$(pr_step_resolve_instance_id)"
    [[ -n "$iid" ]] || return 0
    api="${TOKEN_API_URL:-http://localhost:7777}"
    body="{\"pr_url\":$(json_escape "$url"),\"pr_state\":$(json_escape "$state")}"
    curl -fsS -m 5 -X PATCH -H 'Content-Type: application/json' -d "$body" \
        "${api%/}/api/instances/${iid}/pr" >/dev/null 2>&1 || true
}

POLL_INTERVAL=30        # seconds between checks
MAX_WAIT_TIME=0         # 0 means unbounded; CodeRabbit may legitimately take a long time
REVIEWERS=("coderabbitai[bot]" "coderabbitai" "coderabbit")
PUSH_WRAPPER="$SCRIPT_DIR/push"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log() { echo -e "${BLUE}[pr-create]${NC} $1" >&2; }
warn() { echo -e "${YELLOW}[pr-create]${NC} $1" >&2; }
error() { echo -e "${RED}[pr-create]${NC} $1" >&2; }
success() { echo -e "${GREEN}[pr-create]${NC} $1" >&2; }

assert_pr_capable_remote() {
    local top origin
    top="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    origin="$(git remote get-url origin 2>/dev/null || true)"
    if [[ "$top" == *"/Token-OS/"* || "$top" == *"/Token-OS" ]]; then
        if ! token_os_github_remote "$origin"; then
            error "worktree is not PR-capable; expected TokenAmby-Code/Token-OS GitHub remote"
            error "origin remote: ${origin:-<missing>}"
            exit 64
        fi
        return 0
    fi
    if dead_or_quarantined_remote "$origin"; then
        error "worktree is not PR-capable; origin remote is missing, dead, or quarantined: ${origin:-<missing>}"
        exit 64
    fi
}

merge_comments_json() {
    local inline_json="$1"
    local issue_json="$2"

    jq -s '
        def ensure_array:
            if . == null then []
            elif type == "array" then .
            else [] end;
        def annotate($kind):
            map(if type == "object" then . + {comment_type: $kind} else . end);
        (.[0] | ensure_array | annotate("inline"))
        +
        (.[1] | ensure_array | annotate("issue"))
    ' \
        <(printf "%s" "$inline_json") \
        <(printf "%s" "$issue_json")
}

# Show help
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    cat << 'EOF'
PR Create

Creates a pull request and prints the PR URL. Long CodeRabbit review retrieval
is handled by pr-review-loop --read unless --wait is provided. When waiting,
CodeRabbit polling is unbounded by default.

Usage: pr-create [gh pr create options]

Options (passed to gh pr create):
  -t, --title         PR title (required)
  -b, --body          PR body/description
  -B, --base          Base branch (default: main)
  -H, --head          Head branch (default: current branch)
  --draft             Create as draft PR

Additional options:
  --wait              Wait for initial CodeRabbit signal
  --no-wait           Compatibility no-op; default behavior
  --timeout <mins>    Explicit max wait in minutes (default: no timeout)
  --merge             Merge current branch into base via worktree-safe squash
  --base <branch>     Base branch for --merge (default: auto-detect or main)
  -h, --help          Show this help

Examples:
  pr-create --title "feat: add auth" --body "Added OAuth support"
  pr-create -t "fix: login bug" -b "Fixed null check"
  pr-create -t "refactor: cleanup" -b "Code cleanup" --wait --timeout 10
  pr-create --merge                  # Merge current branch after PR review
  pr-create --merge --base develop   # Merge into specific base branch

Output:
  Prints the PR URL. For review details, run: pr-review-loop --read
EOF
    exit 0
fi

# Parse our custom options
NO_WAIT=true
MERGE_MODE=false
TIMEOUT_MINS=""
BASE_BRANCH=""
GH_ARGS=()

gh_args_have_head() {
    local arg
    for arg in "$@"; do
        case "$arg" in
            --head|-H|--head=*)
                return 0
                ;;
        esac
    done
    return 1
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --no-wait)
            NO_WAIT=true
            shift
            ;;
        --wait)
            NO_WAIT=false
            shift
            ;;
        --timeout)
            TIMEOUT_MINS="$(normalize_timeout_mins "$2")" || {
                error "Invalid --timeout value: $2 (use positive minutes, 0, none, never, or unbounded)"
                exit 2
            }
            MAX_WAIT_TIME="$(timeout_mins_to_seconds "$TIMEOUT_MINS")"
            shift 2
            ;;
        --merge)
            MERGE_MODE=true
            shift
            ;;
        --base)
            BASE_BRANCH="$2"
            shift 2
            ;;
        *)
            GH_ARGS+=("$1")
            shift
            ;;
    esac
done

# Worktree-safe merge; worktree cleanup is deferred to WrapperEnd
do_merge() {
    local branch
    branch=$(git branch --show-current)
    if [[ -z "$branch" ]]; then
        error "Cannot determine current branch (detached HEAD?)"
        exit 1
    fi

    # Determine base branch
    local base="$BASE_BRANCH"
    if [[ -z "$base" ]]; then
        # Try to detect from PR
        local repo_slug
        repo_slug=$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null || true)
        if [[ -n "$repo_slug" ]]; then
            base=$(gh pr view "$branch" --repo "$repo_slug" --json baseRefName -q '.baseRefName' 2>/dev/null || true)
        fi
        if [[ -z "$base" ]]; then
            # Fall back to default branch
            base=$(git remote show "$GIT_GITHUB_REMOTE" 2>/dev/null | sed -n 's/.*HEAD branch: //p')
            base="${base:-main}"
        fi
    fi

    log "Merging '$branch' into '$base'..."

    # Detect if running from a worktree
    local git_common_dir
    git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null)
    local git_dir
    git_dir=$(git rev-parse --git-dir 2>/dev/null)

    local main_worktree=""
    local is_worktree=false

    if [[ "$git_common_dir" != "$git_dir" ]]; then
        is_worktree=true
        # Main worktree is the parent of .git common dir
        main_worktree=$(git worktree list --porcelain | awk 'found == 0 && /^worktree / { sub(/^worktree /, ""); print; found = 1 }')
        log "Detected worktree. Main worktree: $main_worktree"
    else
        main_worktree=$(git rev-parse --show-toplevel)
    fi

    # Fetch latest from remote
    git -C "$main_worktree" fetch "$GIT_GITHUB_REMOTE" "$base" || {
        error "Failed to fetch $GIT_GITHUB_REMOTE/$base"
        exit 1
    }

    # Get PR title for commit message
    local pr_title=""
    local repo_slug
    repo_slug=$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null || true)
    if [[ -n "$repo_slug" ]]; then
        pr_title=$(gh pr view "$branch" --repo "$repo_slug" --json title -q '.title' 2>/dev/null || true)
    fi
    if [[ -z "$pr_title" ]]; then
        pr_title="Merge branch '$branch'"
    fi

    # Switch to base branch in main worktree and squash-merge
    log "Switching to '$base' in main worktree..."
    git -C "$main_worktree" checkout "$base" || {
        error "Failed to checkout '$base' in main worktree"
        exit 1
    }

    git -C "$main_worktree" pull --ff-only "$GIT_GITHUB_REMOTE" "$base" || {
        error "Failed to pull latest '$base'"
        exit 1
    }

    log "Squash-merging '$branch'..."
    git -C "$main_worktree" merge --squash "$branch" || {
        error "Squash merge failed. Resolve conflicts in: $main_worktree"
        exit 1
    }

    git -C "$main_worktree" commit -m "$pr_title" || {
        error "Commit failed"
        exit 1
    }

    log "Pushing '$base' to $GIT_GITHUB_REMOTE..."
    (cd "$main_worktree" && "$PUSH_WRAPPER" "$GIT_GITHUB_REMOTE" "$base") || {
        error "Failed to push '$base' to $GIT_GITHUB_REMOTE"
        exit 1
    }

    success "Merged and pushed '$base'"

    # Durable merge marker so WrapperEnd can prove the (squash) merge without
    # git ancestry — a squash rewrites the SHA, so pr_state=merged is the only
    # ground truth for deferred worktree teardown. Best-effort like the other
    # merge paths; mark_pr_flag stamps pr_url+pr_state together, so a missing
    # 'open' flag doesn't block it.
    local merged_pr_url=""
    if [[ -n "$repo_slug" ]]; then
        merged_pr_url=$(gh pr view "$branch" --repo "$repo_slug" --json url -q '.url' 2>/dev/null || true)
    fi
    [[ -n "$merged_pr_url" ]] && mark_pr_flag "$merged_pr_url" merged

    echo ""
    success "Done! Merge complete. Worktree teardown is deferred to tmuxctld WrapperEnd."
    echo ""
}

# Verify we're in a git repo
if ! git rev-parse --show-toplevel &>/dev/null; then
    error "Must be run from within a git repository"
    exit 1
fi
assert_pr_capable_remote

# Handle --merge mode
if [[ "$MERGE_MODE" == "true" ]]; then
    do_merge
    pr_set_instance_status victorious
    exit 0
fi

pr_set_instance_status reviewing

# Get repo info
REPO=$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null) || {
    error "Could not determine repository. Make sure you're in a GitHub repo."
    exit 1
}

log "Creating PR in $REPO..."

# Auto-push if branch has no remote tracking branch
if ! git rev-parse --abbrev-ref '@{upstream}' &>/dev/null; then
    CURRENT_BRANCH=$(git branch --show-current)
    log "Pushing branch to $GIT_GITHUB_REMOTE..."
    "$PUSH_WRAPPER" -u "$GIT_GITHUB_REMOTE" "$CURRENT_BRANCH" || {
        error "Failed to push branch '$CURRENT_BRANCH' to $GIT_GITHUB_REMOTE"
        exit 1
    }
    success "Pushed '$CURRENT_BRANCH' to $GIT_GITHUB_REMOTE"
fi

CURRENT_BRANCH=$(git branch --show-current)
if [[ -z "$CURRENT_BRANCH" ]]; then
    error "Cannot determine current branch (detached HEAD?)"
    exit 1
fi
if ! gh_args_have_head "${GH_ARGS[@]}"; then
    GH_ARGS+=(--head "$CURRENT_BRANCH")
fi

# Create the PR and capture URL
PR_URL=$(gh pr create "${GH_ARGS[@]}" 2>&1) || {
    error "Failed to create PR: $PR_URL"
    exit 1
}

# Extract PR number from URL
PR_NUMBER=$(echo "$PR_URL" | grep -oE '[0-9]+$')

if [[ -z "$PR_NUMBER" ]]; then
    error "Could not extract PR number from: $PR_URL"
    exit 1
fi

success "Created PR #$PR_NUMBER: $PR_URL"

# Session-doc rubric: record PR open + URL on the linked session doc.
# Best-effort; rubric-flip exits silently when no doc is linked.
if [[ -x "$SCRIPT_DIR/rubric-flip" ]]; then
    "$SCRIPT_DIR/rubric-flip" --quiet --extra "pr_url=$PR_URL" pr_opened true || true
fi

# Instance DB flag: mark the originating instance as "has PR open" so /ui/ops can
# badge it. Identity is resolved through tmuxctld's wrapper ledger oracle, not
# TOKEN_API_INSTANCE_ID, so this survives plan-mode/env strip-downs.
pr_set_instance_pr_state "$PR_URL" open
pr_set_instance_status reviewing

if [[ "$NO_WAIT" == "true" ]]; then
    printf '%s\n' "$PR_URL"
    log "Review wait skipped. Run: pr-review-loop $PR_NUMBER --read"
    exit 0
fi

log "Waiting for automated reviews (CodeRabbit)..."
if wait_is_bounded "$MAX_WAIT_TIME"; then
    log "Polling every ${POLL_INTERVAL}s for up to ${TIMEOUT_MINS} minutes..."
else
    log "Polling every ${POLL_INTERVAL}s until CodeRabbit responds (no timeout)."
fi

# Poll for reviews
START_TIME=$(date +%s)
FOUND_REVIEWS=false
HEAD_SHA=""
CR_STATE=""

while true; do
    ELAPSED=$(($(date +%s) - START_TIME))

    if wait_timed_out "$ELAPSED" "$MAX_WAIT_TIME"; then
        warn "Explicit timeout reached (${TIMEOUT_MINS} minutes). Fetching any available comments..."
        break
    fi

    # Fetch PR comments (inline) and issue comments (general)
    COMMENTS=$(gh api "repos/${REPO}/pulls/${PR_NUMBER}/comments" 2>/dev/null || echo "[]")
    ISSUE_COMMENTS=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null || echo "[]")
    ALL_COMMENTS=$(merge_comments_json "$COMMENTS" "$ISSUE_COMMENTS")

    # Check for bot/reviewer comments across all endpoints
    REVIEWERS_JSON=$(printf '%s\n' "${REVIEWERS[@]}" | jq -R . | jq -sc .)

    COMMENT_COUNT=$(printf "%s" "$ALL_COMMENTS" | jq -r --argjson reviewers "$REVIEWERS_JSON" '
        if type != "array" then 0
        else
            [ .[] | select(
                try ((.user.login | ascii_downcase) as $login |
                    any($reviewers[]; . as $r | $login == ($r | ascii_downcase))) catch false
            ) ] | length
        end
    ')

    # Also check reviews (not just comments)
    REVIEWS=$(gh api "repos/${REPO}/pulls/${PR_NUMBER}/reviews" 2>/dev/null || echo "[]")
    REVIEW_API_COUNT=$(printf "%s" "$REVIEWS" | jq -r --argjson reviewers "$REVIEWERS_JSON" '
        if type != "array" then 0
        else
            [ .[] | select(
                try ((.user.login | ascii_downcase) as $login |
                    any($reviewers[]; . as $r | $login == ($r | ascii_downcase))) catch false
            ) ] | length
        end
    ')
    REVIEW_COUNT=$((COMMENT_COUNT + REVIEW_API_COUNT))

    CURRENT_OVERVIEW_TIMESTAMP=$(printf "%s" "$ISSUE_COMMENTS" | jq --argjson reviewers "$REVIEWERS_JSON" -r '
        if type != "array" then "" else
            [.[] | select(
                try ((.user.login | ascii_downcase) as $login |
                    any($reviewers[]; . as $r | $login == ($r | ascii_downcase))) catch false
            )] | sort_by(.updated_at // .created_at // "") | .[-1].updated_at // .[-1].created_at // ""
        end
    ' 2>/dev/null || true)
    LATEST_ISSUE_COMMENT=$(printf "%s" "$ISSUE_COMMENTS" | jq --argjson reviewers "$REVIEWERS_JSON" -r '
        if type != "array" then "" else
            [.[] | select(
                try ((.user.login | ascii_downcase) as $login |
                    any($reviewers[]; . as $r | $login == ($r | ascii_downcase))) catch false
            )] | sort_by(.updated_at // .created_at // "") | .[-1].body // ""
        end
    ' 2>/dev/null || true)
    if coderabbit_body_is_ratelimit "$LATEST_ISSUE_COMMENT"; then
        if coderabbit_handle_ratelimit_comment "$PR_NUMBER" "$LATEST_ISSUE_COMMENT" "$CURRENT_OVERVIEW_TIMESTAMP"; then
            START_TIME=$(date +%s)
            continue
        fi
        log "Latest CodeRabbit activity is a rate-limit deferral; keeping the review gate open."
    elif echo "$LATEST_ISSUE_COMMENT" | grep -qE '^[[:space:]]*#{1,3}[[:space:]]*Summary by CodeRabbit'; then
        FOUND_REVIEWS=true
        log "Found CodeRabbit summary comment."
        break
    fi

    LATEST_REVIEW_STATE=$(printf "%s" "$REVIEWS" | jq -r --argjson reviewers "$REVIEWERS_JSON" '
        if type != "array" then "" else
            [.[] | select(
                try ((.user.login | ascii_downcase) as $login |
                    any($reviewers[]; . as $r | $login == ($r | ascii_downcase))) catch false
            )] | sort_by(.submitted_at // "") | .[-1].state // ""
        end
    ' 2>/dev/null || true)
    if [[ "$LATEST_REVIEW_STATE" == "APPROVED" || "$LATEST_REVIEW_STATE" == "CHANGES_REQUESTED" ]]; then
        FOUND_REVIEWS=true
        log "Found CodeRabbit review verdict: $LATEST_REVIEW_STATE"
        break
    fi

    if [[ $REVIEW_COUNT -gt 0 ]]; then
        # Do not return early for arbitrary CodeRabbit activity. Inline findings
        # and rate-limit deferrals can precede the actual verdict; pr-step is the
        # poll, so keep blocking until summary/review/status is terminal.
        log "Found $REVIEW_COUNT CodeRabbit item(s), waiting for verdict."
    fi

    # CodeRabbit can complete cleanly without leaving review comments. Treat its
    # terminal commit status as a stop signal; otherwise unbounded create waits
    # would keep waiting after a comment-free success.
    HEAD_SHA=$(gh api "repos/${REPO}/pulls/${PR_NUMBER}" --jq '.head.sha' 2>/dev/null || echo "")
    if [[ -n "$HEAD_SHA" ]]; then
        CR_STATE="$(coderabbit_state_for_head "$HEAD_SHA")"
        if [[ "$CR_STATE" == "success" || "$CR_STATE" == "failure" ]]; then
            if coderabbit_body_is_ratelimit "$LATEST_ISSUE_COMMENT"; then
                log "CodeRabbit commit status is terminal ($CR_STATE), but latest CodeRabbit comment is a rate-limit deferral; keeping the review gate open."
            else
                FOUND_REVIEWS=true
                log "CodeRabbit commit status reached terminal state: $CR_STATE"
                break
            fi
        fi
    fi

    if wait_is_bounded "$MAX_WAIT_TIME"; then
        REMAINING=$(( (MAX_WAIT_TIME - ELAPSED) / 60 ))
        emit_coderabbit_heartbeat "CodeRabbit poll: waiting (${REMAINING}m remaining, ${REVIEW_COUNT} comments found, status=${CR_STATE:-none})"
    else
        emit_coderabbit_heartbeat "CodeRabbit poll: waiting (${ELAPSED}s elapsed, no timeout, ${REVIEW_COUNT} comments found, status=${CR_STATE:-none})"
    fi
    sleep "$POLL_INTERVAL"
done

# Fetch final comments
log "Fetching review comments..."

COMMENTS=$(gh api "repos/${REPO}/pulls/${PR_NUMBER}/comments" 2>/dev/null || echo "[]")
ISSUE_COMMENTS=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null || echo "[]")
ALL_COMMENTS=$(merge_comments_json "$COMMENTS" "$ISSUE_COMMENTS")
REVIEWS=$(gh api "repos/${REPO}/pulls/${PR_NUMBER}/reviews" 2>/dev/null || echo "[]")

# Output the reviews in a readable format
echo ""
echo "=============================================="
echo "PR #${PR_NUMBER} Automated Review Comments"
echo "=============================================="
echo ""

OUTPUT_COUNT=0
REVIEWERS_JSON=$(printf '%s\n' "${REVIEWERS[@]}" | jq -R . | jq -sc .)

# Process PR and issue comments together (bot users + known reviewers)
REVIEWER_COMMENTS=$(printf "%s" "$ALL_COMMENTS" | jq -r --argjson reviewers "$REVIEWERS_JSON" '
    if type != "array" then empty
    else
        def is_coderabbit:
            try ((.user.login | ascii_downcase) as $login |
                any($reviewers[]; . as $r | $login == ($r | ascii_downcase))) catch false;
        def format_comment:
            if (.comment_type // "") == "inline" then
                "### \(.user.login) - \(.path // "General"):\(.line // .original_line // "N/A")\n\((.body // "") | gsub("\r\n"; "\n"))\n"
            else
                "### \(.user.login) (General Comment)\n\((.body // "") | gsub("\r\n"; "\n"))\n"
            end;
        .[] | select(is_coderabbit) | format_comment
    end
')

if [[ -n "$REVIEWER_COMMENTS" ]]; then
    echo "$REVIEWER_COMMENTS"
    OUTPUT_COUNT=$((OUTPUT_COUNT + 1))
fi

# Process reviews (bot users + known reviewers)
REVIEWER_REVIEWS=$(printf "%s" "$REVIEWS" | jq -r --argjson reviewers "$REVIEWERS_JSON" '
    if type != "array" then empty
    else
        .[]
        | select(
            try ((.user.login | ascii_downcase) as $login |
                any($reviewers[]; . as $r | $login == ($r | ascii_downcase))) catch false)
        | select(.body != null and .body != "")
        | "### \(.user.login) - Review (\(.state))\n\((.body // "") | gsub("\r\n"; "\n"))\n"
    end
')

if [[ -n "$REVIEWER_REVIEWS" ]]; then
    echo "$REVIEWER_REVIEWS"
    OUTPUT_COUNT=$((OUTPUT_COUNT + 1))
fi

if [[ $OUTPUT_COUNT -eq 0 && -n "${CR_STATE:-}" ]]; then
    warn "No automated review comments found. CodeRabbit commit status: ${CR_STATE}."
elif [[ $OUTPUT_COUNT -eq 0 ]]; then
    warn "No automated review comments found."
    echo ""
    echo "This could mean:"
    echo "  - Reviews are still processing"
    echo "  - No issues were found"
    echo "  - Reviewers are not configured for this repo"
    echo ""
    echo "You can manually check: $PR_URL"
fi

echo ""
echo "=============================================="
echo "PR URL: $PR_URL"
echo "=============================================="
)


pr_review_main() (
# PR Review Loop
# TAGS: git, pr
# AUDIENCE: agent
#
# Automates the "push, request re-review, wait for results" cycle after
# fixing PR review comments. Companion to pr-create.
#
# Usage: pr-review-loop [PR_NUMBER] [OPTIONS]
#
# Examples:
#   pr-review-loop                    # Auto-detect PR from current branch
#   pr-review-loop 42                 # Specific PR number
#   pr-review-loop --message "Fixed auth bug and added tests"
#   pr-review-loop --no-push          # Skip git push (already pushed)
#   pr-review-loop --read             # Just poll for existing review results
#   pr-review-loop --timeout 10       # Wait max 10 minutes
#
# The tool will:
#   1. Push current branch to remote (unless --no-push)
#   2. Post a PR comment requesting re-review
#   3. Poll for new CodeRabbit review comments, summary, and commit status
#   4. Output review results in an agent-readable form

set -euo pipefail

# Source shared libs
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]:-$0}")")" && pwd)"
source "$SCRIPT_DIR/../lib/git-remote.sh"

POLL_INTERVAL=30        # seconds between checks
MAX_WAIT_TIME=0         # 0 means unbounded; CodeRabbit/rate limits may take a long time
REVIEWER_BOT="coderabbitai[bot]"
REVIEWER_USER="coderabbitai"
SUMMARY_MARKER="^## Summary by CodeRabbit"
COMMIT_STATUS_CONTEXT="coderabbit"
PUSH_WRAPPER="$SCRIPT_DIR/push"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log() { echo -e "${BLUE}[pr-review-loop]${NC} $1" >&2; }
warn() { echo -e "${YELLOW}[pr-review-loop]${NC} $1" >&2; }
error() { echo -e "${RED}[pr-review-loop]${NC} $1" >&2; }
success() { echo -e "${GREEN}[pr-review-loop]${NC} $1" >&2; }

# gh_api wrapper: on GitHub rate-limit failures, wait for the real reset signal
# (Retry-After / rate-limit reset header / rate_limit reset) before reissuing.
# No reset signal means no invented debounce: return the original failure.
gh_api() {
    local err out rc reset now
    while true; do
        err="$(mktemp -t pr-review-gh-api.XXXXXX)"
        if out=$(gh api "$@" 2>"$err"); then
            rm -f "$err"
            printf '%s
' "$out"
            return 0
        fi
        rc=$?
        if ! grep -qiE 'rate limit|API rate limit|secondary rate|retry-after|x-ratelimit-reset|x-rate-limit-reset|ratelimit-reset|rate-limit-reset' "$err"; then
            cat "$err" >&2
            rm -f "$err"
            return "$rc"
        fi

        now="$(date +%s)"
        reset="$(rate_limit_reset_epoch_from_text "$now" <"$err" || true)"
        if [[ -z "$reset" ]]; then
            reset="$(gh api rate_limit --jq '.resources.core.reset' 2>/dev/null || true)"
        fi
        if ! [[ "$reset" =~ ^[0-9]+$ ]] || (( reset <= now )); then
            cat "$err" >&2
            rm -f "$err"
            return "$rc"
        fi
        rm -f "$err"
        sleep_until_rate_limit_reset "$reset" "GitHub API rate limit"
        rate_limit_reset_reached "$reset" || return "$rc"
    done
}

sleep_for_coderabbit_command_cooldown() {
    local latest_body reset
    latest_body=$(gh_api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null | jq -r '''
        [.[] | select((.body // "") | test("@coderabbitai"; "i"))] | sort_by(.created_at) | .[-1].body // ""
    ''' 2>/dev/null || true)
    [[ -n "$latest_body" ]] || return 0
    reset="$(coderabbit_ratelimit_reset_epoch "$latest_body")"
    [[ "$reset" =~ ^[0-9]+$ ]] || return 0
    sleep_until_rate_limit_reset "$reset" "CodeRabbit command cooldown"
    return 0
}

# Show help
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    cat << 'EOF'
PR Review Loop

Automates the "push, request re-review, wait for results" cycle after
fixing PR review comments.

Usage: pr-review-loop [PR_NUMBER] [OPTIONS]

Arguments:
  PR_NUMBER           PR number (optional, auto-detected from current branch)

Options:
  --message MSG       Description of fixes applied (included in PR comment)
  --no-push           Skip git push step (if already pushed)
  --read              Read-only: skip push and comment, just poll for results
  --timeout MINS      Explicit max wait in minutes (default: no timeout)
  -h, --help          Show this help

Examples:
  pr-review-loop
  pr-review-loop 42
  pr-review-loop --message "Fixed auth bug and added tests"
  pr-review-loop --no-push --timeout 10
  pr-review-loop --read              # Just wait for existing review

Workflow:
  1. Push current branch to remote (unless --no-push)
  2. Post PR comment requesting re-review from @coderabbitai
  3. Poll for new CodeRabbit summary or commit status (every 30s)
  4. Output new comments and current review state
  5. Exit 0 if review approved + no CHANGES_REQUESTED, exit 1 otherwise
EOF
    exit 0
fi

# Parse arguments
PR_NUMBER=""
MESSAGE=""
NO_PUSH=false
READ_ONLY=false
TIMEOUT_MINS=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --message)
            MESSAGE="$2"
            shift 2
            ;;
        --no-push)
            NO_PUSH=true
            shift
            ;;
        --read)
            READ_ONLY=true
            NO_PUSH=true
            shift
            ;;
        --timeout)
            TIMEOUT_MINS="$(normalize_timeout_mins "$2")" || {
                error "Invalid --timeout value: $2 (use positive minutes, 0, none, never, or unbounded)"
                exit 2
            }
            MAX_WAIT_TIME="$(timeout_mins_to_seconds "$TIMEOUT_MINS")"
            shift 2
            ;;
        -h|--help)
            # Already handled above
            shift
            ;;
        *)
            # Assume it's the PR number
            if [[ -z "$PR_NUMBER" ]]; then
                PR_NUMBER="$1"
            else
                error "Unknown argument: $1"
                exit 1
            fi
            shift
            ;;
    esac
done

# Verify we're in a git repo
if ! git rev-parse --show-toplevel &>/dev/null; then
    error "Must be run from within a git repository"
    exit 1
fi

# Get repo info
REPO=$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null) || {
    error "Could not determine repository. Make sure you're in a GitHub repo."
    exit 1
}

# Auto-detect PR number if not provided
if [[ -z "$PR_NUMBER" ]]; then
    log "Detecting PR from current branch..."
    PR_NUMBER=$(gh pr view --json number -q '.number' 2>/dev/null) || {
        error "Could not auto-detect PR number. Please specify PR number as argument."
        exit 1
    }
    success "Detected PR #$PR_NUMBER"
fi

# Step 1: Push to remote (unless --no-push)
if [[ "$NO_PUSH" == "false" ]]; then
    log "🔄 Pushing to $GIT_GITHUB_REMOTE..."
    CURRENT_BRANCH=$(git branch --show-current)
    "$PUSH_WRAPPER" "$GIT_GITHUB_REMOTE" "$CURRENT_BRANCH" || {
        error "Failed to push to $GIT_GITHUB_REMOTE"
        exit 1
    }
    success "Pushed to $GIT_GITHUB_REMOTE"
else
    log "Skipping push (--no-push specified)"
fi

# Get baseline comment counts and timestamps before posting
BASELINE_REVIEW_COMMENTS=$(gh_api "repos/${REPO}/pulls/${PR_NUMBER}/comments" 2>/dev/null | \
    jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" '[.[] | select(.user.login == $bot or .user.login == $user)] | length')
BASELINE_ISSUE_COMMENTS=$(gh_api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null | \
    jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" '[.[] | select(.user.login == $bot or .user.login == $user)] | length')

# Get the updated_at timestamp of the latest CodeRabbit summary comment (if any)
BASELINE_OVERVIEW_TIMESTAMP=$(gh_api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null | \
    jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r '[.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.updated_at) | .[-1].updated_at // ""')
BASELINE_REVIEW_TIMESTAMP=$(gh_api "repos/${REPO}/pulls/${PR_NUMBER}/reviews" 2>/dev/null | \
    jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r '[.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.submitted_at) | .[-1].submitted_at // ""')
CURRENT_REVIEW_COMMENTS="$BASELINE_REVIEW_COMMENTS"
CURRENT_ISSUE_COMMENTS="$BASELINE_ISSUE_COMMENTS"
CURRENT_OVERVIEW_TIMESTAMP="$BASELINE_OVERVIEW_TIMESTAMP"
CURRENT_REVIEW_TIMESTAMP="$BASELINE_REVIEW_TIMESTAMP"

# Capture the head SHA so we can check the coderabbit commit status against it.
HEAD_SHA=$(gh_api "repos/${REPO}/pulls/${PR_NUMBER}" --jq '.head.sha' 2>/dev/null || echo "")

# Step 2: Post re-review request comment (skip in --read mode)
if [[ "$READ_ONLY" == "false" ]]; then
    log "📝 Posting re-review request on PR #$PR_NUMBER..."
    sleep_for_coderabbit_command_cooldown

    # Build comment body
    COMMENT_BODY="## Fixes Applied"
    if [[ -n "$MESSAGE" ]]; then
        COMMENT_BODY="${COMMENT_BODY}\n\n${MESSAGE}"
    else
        COMMENT_BODY="${COMMENT_BODY}\n\nAddressed review feedback."
    fi
    COMMENT_BODY="${COMMENT_BODY}\n\n@coderabbitai full review"

    gh pr comment "$PR_NUMBER" --body "$(echo -e "$COMMENT_BODY")" || {
        error "Failed to post PR comment"
        exit 1
    }
    success "Posted re-review request"
else
    log "👀 Read-only mode: polling for existing review on PR #$PR_NUMBER..."
fi

# Step 3: Poll for new review comments
if wait_is_bounded "$MAX_WAIT_TIME"; then
    log "⏳ Waiting for CodeRabbit re-review (timeout: ${TIMEOUT_MINS}m)..."
else
    log "⏳ Waiting for CodeRabbit re-review (no timeout)..."
fi

START_TIME=$(date +%s)
NEW_INLINE_COUNT=0
NEW_OVERVIEW_COUNT=0
FOUND_OVERVIEW=false
OVERVIEW_UPDATED=false
REVIEW_VERDICT_FOUND=false
LAST_RATELIMIT_SIGNATURE=""
TIMEOUT_REREQUESTS_DONE=0
TIMEOUT_REREQUESTS_MAX="${PR_STEP_CR_TIMEOUT_REREQUESTS:-2}"

while true; do
    ELAPSED=$(($(date +%s) - START_TIME))

    if wait_timed_out "$ELAPSED" "$MAX_WAIT_TIME"; then
        if [[ "$READ_ONLY" == "false" ]] && coderabbit_maybe_wait_rate_limit_on_timeout "$PR_NUMBER" TIMEOUT_REREQUESTS_DONE "$TIMEOUT_REREQUESTS_MAX"; then
            START_TIME=$(date +%s)
            BASELINE_REVIEW_COMMENTS="$CURRENT_REVIEW_COMMENTS"
            BASELINE_ISSUE_COMMENTS="$CURRENT_ISSUE_COMMENTS"
            BASELINE_OVERVIEW_TIMESTAMP="$CURRENT_OVERVIEW_TIMESTAMP"
            BASELINE_REVIEW_TIMESTAMP="$CURRENT_REVIEW_TIMESTAMP"
            continue
        fi
        if [[ "$READ_ONLY" == "false" ]] && coderabbit_maybe_rerequest_on_timeout "$PR_NUMBER" TIMEOUT_REREQUESTS_DONE "$TIMEOUT_REREQUESTS_MAX"; then
            START_TIME=$(date +%s)
            BASELINE_REVIEW_COMMENTS="$CURRENT_REVIEW_COMMENTS"
            BASELINE_ISSUE_COMMENTS="$CURRENT_ISSUE_COMMENTS"
            BASELINE_OVERVIEW_TIMESTAMP="$CURRENT_OVERVIEW_TIMESTAMP"
            BASELINE_REVIEW_TIMESTAMP="$CURRENT_REVIEW_TIMESTAMP"
            continue
        fi
        warn "cr_wait_exceeded: CodeRabbit review timed out after ${TIMEOUT_MINS} minutes and bounded re-request attempts were exhausted."
        break
    fi

    # Fetch current comments
    CURRENT_REVIEW_COMMENTS=$(gh_api "repos/${REPO}/pulls/${PR_NUMBER}/comments" 2>/dev/null | \
        jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" '[.[] | select(.user.login == $bot or .user.login == $user)] | length')
    CURRENT_ISSUE_COMMENTS=$(gh_api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null | \
        jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" '[.[] | select(.user.login == $bot or .user.login == $user)] | length')

    NEW_INLINE_COUNT=$((CURRENT_REVIEW_COMMENTS - BASELINE_REVIEW_COMMENTS))
    NEW_OVERVIEW_COUNT=$((CURRENT_ISSUE_COMMENTS - BASELINE_ISSUE_COMMENTS))

    # Check for new summary comment OR updated existing one
    CURRENT_OVERVIEW_TIMESTAMP=$(gh_api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null | \
        jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r '[.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.updated_at) | .[-1].updated_at // ""')
    LATEST_ISSUE_COMMENT=$(gh_api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null | \
        jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r '[.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.updated_at) | .[-1].body // ""')

    if coderabbit_body_is_ratelimit "$LATEST_ISSUE_COMMENT"; then
        if [[ "$READ_ONLY" == "false" ]] && coderabbit_handle_ratelimit_comment "$PR_NUMBER" "$LATEST_ISSUE_COMMENT" "$CURRENT_OVERVIEW_TIMESTAMP" TIMEOUT_REREQUESTS_DONE "$TIMEOUT_REREQUESTS_MAX"; then
            START_TIME=$(date +%s)
            continue
        fi
        log "Latest CodeRabbit activity is a rate-limit deferral; keeping the review gate open."
    fi

    CURRENT_REVIEW_TIMESTAMP=$(gh_api "repos/${REPO}/pulls/${PR_NUMBER}/reviews" 2>/dev/null | \
        jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r '[.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.submitted_at) | .[-1].submitted_at // ""')
    LATEST_REVIEW_STATE_LOOP=$(gh_api "repos/${REPO}/pulls/${PR_NUMBER}/reviews" 2>/dev/null | \
        jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r '[.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.submitted_at) | .[-1].state // ""')
    if [[ "$LATEST_REVIEW_STATE_LOOP" == "APPROVED" || "$LATEST_REVIEW_STATE_LOOP" == "CHANGES_REQUESTED" ]] && \
       { [[ "$READ_ONLY" == "true" ]] || [[ -z "$BASELINE_REVIEW_TIMESTAMP" ]] || [[ "$CURRENT_REVIEW_TIMESTAMP" != "$BASELINE_REVIEW_TIMESTAMP" ]]; }; then
        REVIEW_VERDICT_FOUND=true
        log "Found CodeRabbit review verdict: $LATEST_REVIEW_STATE_LOOP"
        break
    fi

    if [[ $NEW_OVERVIEW_COUNT -gt 0 ]]; then
        LATEST_ISSUE_COMMENT=$(gh_api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null | \
            jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r '.[] | select(.user.login == $bot or .user.login == $user) | .body' | tail -1)

        if [[ "$READ_ONLY" == "false" ]] && coderabbit_handle_ratelimit_comment "$PR_NUMBER" "$LATEST_ISSUE_COMMENT" "$CURRENT_OVERVIEW_TIMESTAMP" TIMEOUT_REREQUESTS_DONE "$TIMEOUT_REREQUESTS_MAX"; then
            START_TIME=$(date +%s)
            continue
        fi

        if echo "$LATEST_ISSUE_COMMENT" | grep -qE "$SUMMARY_MARKER"; then
            FOUND_OVERVIEW=true
            log "Found new CodeRabbit summary comment."
            break
        fi
    elif [[ -n "$BASELINE_OVERVIEW_TIMESTAMP" ]] && [[ -n "$CURRENT_OVERVIEW_TIMESTAMP" ]] && \
         [[ "$CURRENT_OVERVIEW_TIMESTAMP" != "$BASELINE_OVERVIEW_TIMESTAMP" ]]; then
        LATEST_ISSUE_COMMENT=$(gh_api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null | \
            jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r '[.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.updated_at) | .[-1].body')

        if [[ "$READ_ONLY" == "false" ]] && coderabbit_handle_ratelimit_comment "$PR_NUMBER" "$LATEST_ISSUE_COMMENT" "$CURRENT_OVERVIEW_TIMESTAMP" TIMEOUT_REREQUESTS_DONE "$TIMEOUT_REREQUESTS_MAX"; then
            START_TIME=$(date +%s)
            continue
        fi

        if echo "$LATEST_ISSUE_COMMENT" | grep -qE "$SUMMARY_MARKER"; then
            FOUND_OVERVIEW=true
            OVERVIEW_UPDATED=true
            log "Existing CodeRabbit summary was updated."
            break
        fi
    fi

    # Also accept terminal coderabbit commit status (success/failure) as a stop signal.
    if [[ -n "$HEAD_SHA" ]]; then
        CR_STATE="$(coderabbit_state_for_head "$HEAD_SHA")"
        if [[ "$CR_STATE" == "success" || "$CR_STATE" == "failure" || "$CR_STATE" == "error" ]]; then
            if coderabbit_review_is_deferred "$PR_NUMBER"; then
                LATEST_ISSUE_COMMENT="$(coderabbit_latest_issue_comment_body "$PR_NUMBER")"
                if [[ "$READ_ONLY" == "false" ]] && coderabbit_handle_ratelimit_comment "$PR_NUMBER" "$LATEST_ISSUE_COMMENT" "$CURRENT_OVERVIEW_TIMESTAMP" TIMEOUT_REREQUESTS_DONE "$TIMEOUT_REREQUESTS_MAX"; then
                    START_TIME=$(date +%s)
                    continue
                fi
                log "CodeRabbit commit status is terminal ($CR_STATE), but latest CodeRabbit comment is a rate-limit deferral; keeping the review gate open."
            else
                FOUND_OVERVIEW=true
                log "CodeRabbit commit status reached terminal state: $CR_STATE"
                break
            fi
        fi
    fi

    ELAPSED_SECS=$ELAPSED
    STATUS=""
    if [[ "$OVERVIEW_UPDATED" == "true" ]]; then
        STATUS=" (updated)"
    fi
    if wait_is_bounded "$MAX_WAIT_TIME"; then
        REMAINING=$(( (MAX_WAIT_TIME - ELAPSED) / 60 ))
        emit_coderabbit_heartbeat "CodeRabbit poll: ${ELAPSED_SECS}s elapsed, ${REMAINING}m remaining, ${NEW_INLINE_COUNT} new inline, ${NEW_OVERVIEW_COUNT} new summary${STATUS}, head=${HEAD_SHA:0:7}"
    else
        emit_coderabbit_heartbeat "CodeRabbit poll: ${ELAPSED_SECS}s elapsed, no timeout, ${NEW_INLINE_COUNT} new inline, ${NEW_OVERVIEW_COUNT} new summary${STATUS}, head=${HEAD_SHA:0:7}"
    fi
    sleep "$POLL_INTERVAL"
done

# Step 4: Fetch and output the results
if [[ "$FOUND_OVERVIEW" == "false" ]] && [[ "$REVIEW_VERDICT_FOUND" == "false" ]] && \
   [[ $NEW_INLINE_COUNT -eq 0 ]] && [[ $NEW_OVERVIEW_COUNT -eq 0 ]]; then
    warn "cr_wait_exceeded: no fresh CodeRabbit verdict or review comments after bounded wait/re-request policy; PR=https://github.com/${REPO}/pull/${PR_NUMBER}"
    exit 1
fi

log "Fetching review results..."

# Fetch all comments
ALL_REVIEW_COMMENTS=$(gh_api "repos/${REPO}/pulls/${PR_NUMBER}/comments" 2>/dev/null || echo "[]")
ALL_ISSUE_COMMENTS=$(gh_api "repos/${REPO}/issues/${PR_NUMBER}/comments" 2>/dev/null || echo "[]")

# Get new inline comments (after baseline)
NEW_INLINE_COMMENTS=$(echo "$ALL_REVIEW_COMMENTS" | jq --arg bot "$REVIEWER_BOT" \
    --arg user "$REVIEWER_USER" \
    --argjson baseline "$BASELINE_REVIEW_COMMENTS" '
    [.[] | select(.user.login == $bot or .user.login == $user)] |
    if length > ($baseline | tonumber) then .[$baseline:] else [] end
')

# Get new summary comments (after baseline) OR the updated one
if [[ "$OVERVIEW_UPDATED" == "true" ]]; then
    NEW_OVERVIEW_COMMENTS=$(echo "$ALL_ISSUE_COMMENTS" | jq --arg bot "$REVIEWER_BOT" \
        --arg user "$REVIEWER_USER" \
        '[.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.updated_at) | [.[-1]]')
else
    NEW_OVERVIEW_COMMENTS=$(echo "$ALL_ISSUE_COMMENTS" | jq --arg bot "$REVIEWER_BOT" \
        --arg user "$REVIEWER_USER" \
        --argjson baseline "$BASELINE_ISSUE_COMMENTS" '
        [.[] | select(.user.login == $bot or .user.login == $user)] |
        if length > ($baseline | tonumber) then .[$baseline:] else [] end
    ')
fi

# Determine review state from PR reviews + commit status.
REVIEW_STATE=""
REVIEW_STATUS_ICON=""
LATEST_REVIEW_STATE=$(gh_api "repos/${REPO}/pulls/${PR_NUMBER}/reviews" 2>/dev/null | \
    jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r \
    '[.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.submitted_at) | .[-1].state // ""')
CR_COMMIT_STATE=""
if [[ -n "$HEAD_SHA" ]]; then
    CR_COMMIT_STATE=$(gh_api "repos/${REPO}/commits/${HEAD_SHA}/statuses" 2>/dev/null | \
        jq --arg ctx "$COMMIT_STATUS_CONTEXT" -r \
        '[.[] | select(.context | ascii_downcase | startswith($ctx))] | sort_by(.updated_at) | .[-1].state // ""')
fi

if [[ "$LATEST_REVIEW_STATE" == "CHANGES_REQUESTED" ]]; then
    REVIEW_STATE="CHANGES_REQUESTED"
    REVIEW_STATUS_ICON="❌"
elif [[ "$LATEST_REVIEW_STATE" == "APPROVED" ]] || [[ "$CR_COMMIT_STATE" == "success" ]]; then
    REVIEW_STATE="APPROVED"
    REVIEW_STATUS_ICON="✅"
elif [[ "$CR_COMMIT_STATE" == "failure" || "$CR_COMMIT_STATE" == "error" ]]; then
    REVIEW_STATE="FAILURE"
    REVIEW_STATUS_ICON="❌"
elif [[ -n "$LATEST_REVIEW_STATE" ]]; then
    REVIEW_STATE="$LATEST_REVIEW_STATE"
fi

# Output formatted results
echo ""
echo "=============================================="
echo "PR #${PR_NUMBER} Re-Review Results"
echo "=============================================="
echo ""

if [[ -n "$REVIEW_STATE" ]]; then
    echo "Review State:    ${REVIEW_STATE} ${REVIEW_STATUS_ICON}"
fi
if [[ -n "$CR_COMMIT_STATE" ]]; then
    echo "CodeRabbit CI:   ${CR_COMMIT_STATE}"
fi
echo ""

if [[ $NEW_INLINE_COUNT -gt 0 ]]; then
    echo "### New Inline Comments (${NEW_INLINE_COUNT}):"
    echo ""

    echo "$NEW_INLINE_COMMENTS" | jq -r '
        .[] |
        "### \(.user.login) - \(.path):\(.line // .original_line // "N/A")\n\(.body)\n"
    '
fi

if [[ $NEW_OVERVIEW_COUNT -gt 0 ]] || [[ "$OVERVIEW_UPDATED" == "true" ]]; then
    OVERVIEW_LABEL="### Overview:"
    if [[ "$OVERVIEW_UPDATED" == "true" ]]; then
        OVERVIEW_LABEL="### Overview (Updated):"
    fi
    echo "$OVERVIEW_LABEL"
    echo ""
    echo "$NEW_OVERVIEW_COMMENTS" | jq -r '.[] | .body'
    echo ""
fi

LATEST_REVIEW_BODY=$(echo "$(gh_api "repos/${REPO}/pulls/${PR_NUMBER}/reviews" 2>/dev/null || echo "[]")" | \
    jq --arg bot "$REVIEWER_BOT" --arg user "$REVIEWER_USER" -r '
    [.[] | select(.user.login == $bot or .user.login == $user)] | sort_by(.submitted_at) | .[-1]
    | if . == null then "" else "### Review Body (\(.state // "unknown"))\n\((.body // "") | gsub("\r\n"; "\n"))" end
')
if [[ -n "$LATEST_REVIEW_BODY" ]]; then
    echo "$LATEST_REVIEW_BODY"
    echo ""
fi

echo "### Failing Check Detail:"
if ! print_failing_check_details "$PR_NUMBER"; then
    true
fi
echo ""

echo "=============================================="
echo "PR URL: https://github.com/${REPO}/pull/${PR_NUMBER}"
echo "=============================================="
echo ""

# Exit based on review state.
case "$REVIEW_STATE" in
    APPROVED)
        success "CodeRabbit approved (or commit status success)."
        exit 0
        ;;
    CHANGES_REQUESTED)
        warn "CodeRabbit requested changes — fix and re-run."
        exit 1
        ;;
    FAILURE)
        warn "CodeRabbit commit status: failure — review needed."
        exit 1
        ;;
    *)
        warn "Inconclusive review state: '${REVIEW_STATE:-(none)}'. Inspect manually."
        exit 1
        ;;
esac
)


pr_merge_main() (
# PR Merge (worktree cleanup deferred to WrapperEnd)
# TAGS: git, pr
# AUDIENCE: human, agent
#
# Merges a PR. Worktree teardown is a WrapperEnd lifecycle event,
# never a side effect of the merge command.
#
# Usage: pr-merge [PR_NUMBER] [options]
#
# Examples:
#   pr-merge                          # Auto-detect PR from current branch
#   pr-merge 42                       # Merge PR #42
#   pr-merge --squash                 # Squash merge (default)
#   pr-merge --merge                  # Create merge commit
#   pr-merge --no-cleanup             # Merge only, skip cleanup
#   pr-merge --dry-run                # Preview what would happen

set -euo pipefail

# Source shared libs
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]:-$0}")")" && pwd)"
source "$SCRIPT_DIR/../lib/git-remote.sh"
source "$SCRIPT_DIR/../lib/worktree-park.sh" 2>/dev/null || true
source "$SCRIPT_DIR/../lib/worktree-resolve.sh"
source "$SCRIPT_DIR/../lib/nas-path.sh" >/dev/null 2>&1 || true

json_escape() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"; }

pr_set_instance_status() {
    local status="$1" api iid body
    iid="$(pr_step_resolve_instance_id)"
    [[ -n "$iid" ]] || return 0
    api="${TOKEN_API_URL:-http://localhost:7777}"
    case "$status" in
        reviewing)
            body="{\"status\":$(json_escape "$status"),\"workflow_state\":\"review_mode\",\"next_required_action\":\"review\",\"next_action_owner\":\"human\"}"
            ;;
        victorious)
            body="{\"status\":$(json_escape "$status"),\"workflow_state\":\"complete\",\"next_required_action\":null,\"next_action_owner\":null}"
            ;;
        *)
            body="{\"status\":$(json_escape "$status")}"
            ;;
    esac
    curl -fsS -m 5 -X PATCH -H 'Content-Type: application/json' -d "$body" \
        "${api%/}/api/instances/${iid}/status" >/dev/null 2>&1 || true
}

pr_set_instance_pr_state() {
    local url="$1" state="$2" api iid body
    iid="$(pr_step_resolve_instance_id)"
    [[ -n "$iid" ]] || return 0
    api="${TOKEN_API_URL:-http://localhost:7777}"
    body="{\"pr_url\":$(json_escape "$url"),\"pr_state\":$(json_escape "$state")}"
    curl -fsS -m 5 -X PATCH -H 'Content-Type: application/json' -d "$body" \
        "${api%/}/api/instances/${iid}/pr" >/dev/null 2>&1 || true
}

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Icons
SEARCH="🔍"
MERGE="🔀"
CLEANUP="🧹"
PULL="📥"
SUCCESS="✅"
ERROR="❌"
WARNING="⚠️"

log() { echo -e "${BLUE}[pr-merge]${NC} $1" >&2; }
info() { echo -e "${CYAN}   $1${NC}" >&2; }
warn() { echo -e "${YELLOW}[pr-merge]${NC} $1" >&2; }
error() { echo -e "${RED}[pr-merge]${NC} $1" >&2; }
success() { echo -e "${GREEN}[pr-merge]${NC} $1" >&2; }

# Defaults
MERGE_METHOD="squash"
NO_CLEANUP=false
SKIP_CONFIRM=false
DRY_RUN=false
PR_NUMBER=""

usage() {
    cat << 'EOF'
PR Merge

Merges a PR. Worktree teardown is deferred to tmuxctld WrapperEnd.

Usage: pr-merge [PR_NUMBER] [options]

Arguments:
  PR_NUMBER           PR number to merge (auto-detected if not provided)

Options:
  --squash            Squash and merge (default)
  --merge             Create a merge commit
  --rebase            Rebase and merge
  --no-cleanup        Accepted for compatibility; cleanup is always deferred
  -y, --yes           Skip confirmation prompt
  --dry-run           Show what would happen without doing anything
  -h, --help          Show this help

Examples:
  pr-merge                    # Auto-detect and merge current branch's PR
  pr-merge 42                 # Merge PR #42
  pr-merge --merge            # Use merge commit instead of squash
  pr-merge --no-cleanup       # Compatibility no-op; just merge
  pr-merge --dry-run          # Preview the actions

Description:
  1. Detects PR number from current branch if not provided
  2. Shows PR info and asks for confirmation
  3. Merges the PR (squash by default)
  4. Stops. Worktree teardown happens later in tmuxctld WrapperEnd

EOF
    exit 0
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            usage
            ;;
        --squash)
            MERGE_METHOD="squash"
            shift
            ;;
        --merge)
            MERGE_METHOD="merge"
            shift
            ;;
        --rebase)
            MERGE_METHOD="rebase"
            shift
            ;;
        --no-cleanup)
            NO_CLEANUP=true
            shift
            ;;
        -y|--yes)
            SKIP_CONFIRM=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        [0-9]*)
            if [[ -z "$PR_NUMBER" ]]; then
                PR_NUMBER="$1"
            else
                error "Multiple PR numbers provided"
                exit 1
            fi
            shift
            ;;
        *)
            error "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
    esac
done

# Verify we're in a git repo
if ! git rev-parse --show-toplevel &>/dev/null; then
    error "Must be run from within a git repository"
    exit 1
fi

# Get repo info
REPO=$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null) || {
    error "Could not determine repository. Make sure you're in a GitHub repo."
    exit 1
}

# Get repo root
REPO_ROOT=$(git rev-parse --show-toplevel)

# Detect PR number if not provided
if [[ -z "$PR_NUMBER" ]]; then
    log "Detecting PR from current branch..."
    PR_NUMBER=$(gh pr view --json number -q '.number' 2>/dev/null) || {
        error "Could not detect PR from current branch. Provide PR number as argument."
        exit 1
    }
fi

# Get PR info
PR_INFO=$(gh pr view "$PR_NUMBER" --json title,headRefName,state,mergeable 2>/dev/null) || {
    error "Could not fetch PR #${PR_NUMBER}. Does it exist?"
    exit 1
}

PR_TITLE=$(echo "$PR_INFO" | jq -r '.title')
BRANCH_NAME=$(echo "$PR_INFO" | jq -r '.headRefName')
PR_STATE=$(echo "$PR_INFO" | jq -r '.state')
PR_MERGEABLE=$(echo "$PR_INFO" | jq -r '.mergeable')

# Check if PR is open
if [[ "$PR_STATE" != "OPEN" ]]; then
    error "PR #${PR_NUMBER} is not open (state: ${PR_STATE})"
    exit 1
fi

# Check if PR is mergeable
if [[ "$PR_MERGEABLE" == "CONFLICTING" ]]; then
    error "PR #${PR_NUMBER} has conflicts and cannot be merged"
    exit 1
fi

# Resolve the PR head worktree for display only. Worktree teardown is deferred
# to tmuxctld WrapperEnd so merge commands never remove their own cwd.
IN_WORKTREE=false
WORKTREE_PATH=""
PR_WORKTREE_PATH="$(resolve_worktree_for_branch "$BRANCH_NAME")"
MAIN_WORKTREE_PATH=$(git worktree list --porcelain | awk 'found == 0 && /^worktree / { sub(/^worktree /, ""); print; found = 1 }')

if [[ -n "$PR_WORKTREE_PATH" && -f "$PR_WORKTREE_PATH/.git" ]]; then
    # The PR's head branch is checked out in a linked worktree. Display it,
    # but do not clean it up here.
    IN_WORKTREE=true
    WORKTREE_PATH="$PR_WORKTREE_PATH"
fi

# Show plan
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo " PR Merge Plan"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "  Repository:    $REPO"
echo "  PR:            #${PR_NUMBER} - ${PR_TITLE}"
echo "  Branch:        ${BRANCH_NAME}"
echo "  Merge method:  ${MERGE_METHOD}"
echo ""

if [[ "$IN_WORKTREE" == "true" ]]; then
    echo "  Context:       Worktree at ${WORKTREE_PATH}"
    echo "  Main repo:     ${MAIN_WORKTREE_PATH}"
else
    echo "  Context:       Regular checkout (not a worktree)"
fi

echo ""

echo "  Actions:"
echo "    1. Merge PR #${PR_NUMBER} (${MERGE_METHOD})"
echo "    2. Stop; worktree teardown is deferred to tmuxctld WrapperEnd"
if [[ "$NO_CLEANUP" == "true" ]]; then
    echo "    (--no-cleanup is accepted for compatibility; cleanup is always deferred)"
fi

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo ""

if [[ "$DRY_RUN" == "true" ]]; then
    warn "Dry run - no changes made"
    exit 0
fi

# Confirmation
if [[ "$SKIP_CONFIRM" == "false" ]]; then
    read -p "Proceed with merge? (y/N) " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        warn "Aborted by user"
        exit 0
    fi
fi

# Merge the PR
echo ""
log "${MERGE} Merging PR #${PR_NUMBER} (${MERGE_METHOD})..."

# Merge only. Branch/worktree teardown is a WrapperEnd lifecycle concern; doing
# it from pr-step/pr-merge can delete the cwd of the still-running agent.
MERGE_OUTPUT=$(gh pr merge "$PR_NUMBER" "--${MERGE_METHOD}" 2>&1) || {
    error "Failed to merge PR: $MERGE_OUTPUT"
    exit 1
}

success "${SUCCESS} PR merged successfully"
echo ""
PR_URL_AFTER_MERGE=$(gh pr view "$PR_NUMBER" --json url -q '.url' 2>/dev/null || echo "")
if [[ -n "$PR_URL_AFTER_MERGE" ]]; then
    pr_set_instance_pr_state "$PR_URL_AFTER_MERGE" merged
fi
pr_set_instance_status victorious

success "Done! Merge complete. Worktree teardown is deferred to tmuxctld WrapperEnd."
exit 0


)


create_pr_normal() {
    local subject body pr_url pr_num
    local -a wait_args
    subject="${TITLE:-$(git log -1 --pretty=%s)}"
    body="${BODY:-$(default_body "$subject")}"
    wait_args=(--wait)
    [[ -n "$TIMEOUT_MINS" ]] && wait_args+=(--timeout "$TIMEOUT_MINS")
    log "Creating PR..."
    if [[ "$SHOW_RAW_REVIEW" == "true" ]]; then
        pr_create_main --title "$subject" --body "$body" "${wait_args[@]}"
    else
        PR_STEP_OPAQUE_WAIT=true PR_STEP_PRINT_CAPTURED_OUTPUT=true run_internal_capture create true pr_create_main --title "$subject" --body "$body" "${wait_args[@]}"
    fi
    pr_num="$(current_pr_number)"
    [[ -n "$pr_num" ]] || { error "Could not determine created PR number"; exit 1; }
    pr_url="$(current_pr_url "$pr_num")"
    [[ -n "$pr_url" ]] && mark_pr_flag "$pr_url" open
    success "PR: #${pr_num}${pr_url:+ — ${pr_url}}"
    printf '%s\n' "$pr_num"
}

review_pr_normal() {
    local pr="$1" mode_msg="$2" rc=0
    local -a review_args
    review_args=("$pr" --message "$mode_msg")
    [[ -n "$TIMEOUT_MINS" ]] && review_args+=(--timeout "$TIMEOUT_MINS")
    log "Requesting CodeRabbit review for PR #${pr}..."
    if [[ "$SHOW_RAW_REVIEW" == "true" ]]; then
        pr_review_main "${review_args[@]}" || rc=$?
    else
        PR_STEP_OPAQUE_WAIT=true PR_STEP_PRINT_CAPTURED_OUTPUT=false run_internal_capture review false pr_review_main "${review_args[@]}" || rc=$?
    fi
    return "$rc"
}

read_review_normal() {
    local pr="$1" rc=0
    local -a review_args
    review_args=("$pr" --read)
    [[ -n "$TIMEOUT_MINS" ]] && review_args+=(--timeout "$TIMEOUT_MINS")
    if [[ "$SHOW_RAW_REVIEW" == "true" ]]; then
        pr_review_main "${review_args[@]}" || rc=$?
    else
        PR_STEP_OPAQUE_WAIT=true PR_STEP_PRINT_CAPTURED_OUTPUT=false run_internal_capture review-read false pr_review_main "${review_args[@]}" || rc=$?
    fi
    return "$rc"
}

merge_pr_normal() {
    local pr="$1"
    log "Merging PR #$pr..."
    pr_merge_main "$pr" -y
}

run_force_mode() {
    case "$FORCE_MODE" in
        create)
            if [[ "${FORCE_ARGS[0]:-}" == "--help" || "${FORCE_ARGS[0]:-}" == "-h" ]]; then usage_force_create; exit 0; fi
            warn "Compatibility path: prefer plain 'pr-step'. Running forced create."
            pr_create_main ${FORCE_ARGS[@]+"${FORCE_ARGS[@]}"}
            ;;
        review)
            if [[ "${FORCE_ARGS[0]:-}" == "--help" || "${FORCE_ARGS[0]:-}" == "-h" ]]; then usage_force_review; exit 0; fi
            warn "Compatibility path: prefer plain 'pr-step'. Running forced review."
            pr_review_main ${FORCE_ARGS[@]+"${FORCE_ARGS[@]}"}
            ;;
        merge)
            if [[ "${FORCE_ARGS[0]:-}" == "--help" || "${FORCE_ARGS[0]:-}" == "-h" ]]; then usage_force_merge; exit 0; fi
            warn "Compatibility path: prefer plain 'pr-step'. Running forced merge."
            pr_merge_main ${FORCE_ARGS[@]+"${FORCE_ARGS[@]}"}
            ;;
    esac
}

main() {
    parse_args "$@"
    if [[ -n "$FORCE_MODE" ]]; then
        run_force_mode
        return $?
    fi

    assert_repo
    mark_instance_status reviewing

    local pr msg pr_url pr_state committed=false arm_review_followup=false
    pr="$(current_pr_number)"
    msg="${MESSAGE:-}"

    if [[ -z "$pr" ]]; then
        log "No PR found for current branch."
        if commit_if_needed "$msg"; then committed=true; fi
        push_branch
        local create_out create_rc
        create_out="$(create_pr_normal)" || {
            create_rc=$?
            [[ -n "$create_out" ]] && printf '%s\n' "$create_out" >&2
            return "$create_rc"
        }
        pr="$(printf '%s\n' "$create_out" | tail -n 1)"
        read_review_normal "$pr" || true
        pr_url="$(current_pr_url "$pr")"
        arm_review_followup=true
    else
        pr_url="$(current_pr_url "$pr")"
        pr_state="$(current_pr_state "$pr")"
        if [[ "$pr_state" == "MERGED" ]]; then
            [[ -n "$pr_url" ]] && mark_pr_flag "$pr_url" merged
            mark_instance_status victorious
            disarm_pr_plan_followup
            log "PR #$pr is already merged; terminal state, no plan re-arm."
            summarize_pr "$pr"
            return 0
        fi
        [[ -n "$pr_url" ]] && mark_pr_flag "$pr_url" open
        log "PR #$pr found."
        if commit_if_needed "$msg"; then committed=true; fi
        push_branch
        if checks_green "$pr"; then
            success "Current PR head is already green; skipping re-review request."
        else
            review_pr_normal "$pr" "${msg:-Updated branch; request deterministic full review of latest head.}" || true
            pr_url="$(current_pr_url "$pr")"
            arm_review_followup=true
        fi
    fi

    summarize_pr "$pr"

    if [[ "$AUTO_MERGE" == "true" ]] && checks_green "$pr"; then
        success "PR #$pr is green; auto-merging."
        merge_pr_normal "$pr"
        pr_url="$(current_pr_url "$pr")"
        [[ -n "$pr_url" ]] && mark_pr_flag "$pr_url" merged
        mark_instance_status victorious
        disarm_pr_plan_followup
    else
        if [[ "$AUTO_MERGE" != "true" ]]; then
            log "Auto-merge disabled (--no-merge); leaving PR #$pr open."
        else
            log "PR #$pr is not green yet; leaving it open."
        fi
        if [[ "$arm_review_followup" == "true" ]]; then
            pr_url="$(current_pr_url "$pr")"
            arm_pr_plan_followup review "$pr" "$pr_url" "plan fixes or next review action."
        fi
    fi
}

if [[ "${PR_STEP_SOURCE_ONLY:-}" != "1" ]]; then
    main "$@"
fi
