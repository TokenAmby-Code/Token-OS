#!/usr/bin/env bash
# tmux-shuttle — Context-aware pane promotion/demotion
# TAGS: tmux, pane-management
# AUDIENCE: human (keybind: prefix + d)
#
# Window-aware behavior:
#   palace/somnium      → demote current pane to legion (fresh shell replaces it)
#   legion/mechanicus   → popup selector to promote (swap) into a palace or somnium slot
#
# Selector layout:
#   1-4  Palace slots  (W N S E)
#   5-9  Somnium slots (W N NE S SE)
#
# Dirty panes (Claude processing) are dimmed in the selector.

set -euo pipefail
export IMPERIUM_ALLOW_TMUX_FOCUS="${IMPERIUM_ALLOW_TMUX_FOCUS:-1}"
export IMPERIUM_ALLOW_MECHANICUS_FOCUS="${IMPERIUM_ALLOW_MECHANICUS_FOCUS:-1}"

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
# shellcheck source=../lib/nas-path.sh
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true
# shellcheck source=../lib/pane-id.sh
source "${_LIB_DIR}/pane-id.sh"

SESSION="main"
API_URL="${TOKEN_API_URL:-http://localhost:7777}"
CLIENT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --client)
            CLIENT="${2:-}"
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

# Resolve a base window name to its actual tmux name (may have instance count suffix)
# e.g. "legion" → "legion(2)" if renamed by instance count system
resolve_window() {
    local base="$1"
    tmux list-windows -t "$SESSION" -F '#{window_name}' | grep -m1 "^${base}" || echo "$base"
}

# Update pane_label in Token-API DB so orchestration knows the new location
relocate_pane() {
    local pane_id="$1" label="$2"
    if curl -fsS -X PATCH "${API_URL}/api/pane/relocate" \
        -H "Content-Type: application/json" \
        -d "{\"tmux_pane\": \"${pane_id}\", \"pane_label\": \"${label}\"}" \
        >/dev/null 2>&1; then
        return 0
    fi

    local db_path="${TOKEN_API_DB:-$HOME/.claude/agents.db}"
    command -v sqlite3 >/dev/null 2>&1 || return 0
    [[ -f "$db_path" ]] || return 0
    pane_id="${pane_id//\'/\'\'}"
    label="${label//\'/\'\'}"
    sqlite3 "$db_path" \
        "UPDATE instances SET pane_label='${label}' WHERE tmux_pane='${pane_id}' AND stopped_at IS NULL;" \
        >/dev/null 2>&1 || true
}

# --- Internal: swap + retag (called by display-menu) ---
if [[ "${1:-}" == "--do-swap" ]]; then
    # Args: --do-swap <source_pane> <target_pane> <target_tag>
    src="$2"
    dst="$3"
    dst_tag="$4"

    # Get source pane's current tag before swap
    src_tag=$(pane_id_of "$src") || true
    src_window="${src_tag%%:*}"
    src_window="${src_window:-legion}"
    tombstone_source=""
    case "$src_tag" in
        legion:custodes|mechanicus:fabricator-general|mechanicus:anchor)
            tombstone_source="$src_tag"
            ;;
    esac

    tmux swap-pane -s "$src" -t "$dst" || { echo "swap-pane failed"; exit 1; }

    # After swap: src content is at dst's position, dst content is at src's position.
    # Pane IDs (%N) follow content, so:
    #   $src (now in somnium position) gets the somnium tag
    #   $dst (now in legion/mechanicus position) gets demoted tag
    pane_tag "$src" "$dst_tag" || true
    if [[ -n "$tombstone_source" ]]; then
        pane_tag "$dst" "$tombstone_source" || true
        tmux set-option -p -t "$dst" @PANE_TYPE "tombstone" 2>/dev/null || true
        tmux set-option -p -t "$dst" @TOMBSTONE_SOURCE "$tombstone_source" 2>/dev/null || true
        tmux set-option -p -t "$dst" @TOMBSTONE_TARGET "$src" 2>/dev/null || true
        tmux send-keys -t "$dst" "exec tmux-tombstone '$tombstone_source' '$src'" Enter
    else
        pane_tag "$dst" "${src_window}:bumped" || true
        tmux set-option -p -t "$dst" @PANE_TYPE "$src_window" 2>/dev/null || true
    fi

    # Update Token-API DB so orchestration sees the new locations
    relocate_pane "$src" "$dst_tag"
    if [[ -z "$tombstone_source" ]]; then
        relocate_pane "$dst" "${src_window}:bumped"
    fi

    # Trigger workspace audit (backburner cleanup, etc.) — fire and forget
    tmux-audit --force &

    exit 0
fi

# --- Get context ---
current_window=$(tmux display-message -p '#{window_name}')
current_window="${current_window%%(*}"  # Strip instance count suffix
current_pane=$(tmux display-message -p '#{pane_id}')
current_tag=$(pane_id_of "$current_pane")
current_type=$(tmux show-options -pv -t "$current_pane" @PANE_TYPE 2>/dev/null || true)

if [[ "$current_type" == "tombstone" ]]; then
    # Tombstone jump remains a shuttle operation. Expand (`prefix + e`) is now
    # native zoom in all cases and must not perform audience/tombstone routing.
    args=(tombstone jump --pane "$current_pane")
    if [[ -n "$CLIENT" ]]; then
        args+=(--client "$CLIENT")
    fi
    PYTHONPATH="${_LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m tmuxctl.cli "${args[@]}"
fi

# --- DEMOTE: palace/somnium → legion stack ---
demote() {
    # Remember the slot identity + working directory before the pane moves.
    local slot_tag="$current_tag"
    local wdir src_window src_target
    wdir=$(tmux display-message -t "$current_pane" -p '#{pane_current_path}')
    # Resolve the live source window so we can refill the vacated slot after the
    # pane is joined out into the legion stack. window_id (@N) is stable across
    # the join; session:index is what normalize --window expects.
    src_window=$(tmux display-message -t "$current_pane" -p '#{window_id}')
    src_target=$(tmux display-message -t "$current_pane" -p '#{session_name}:#{window_index}')

    # Adopt the LIVE pane into the legion stack through the unified allocator —
    # the same path every other worker takes. `stack adopt` join-panes the pane
    # in (preserving its pane id + running claude process), ensures the legion
    # window + Custodes orchestrator exist, tags it as a stack worker, assigns
    # the lowest free ordinal, and runs enforce. No bespoke stack surgery here.
    PYTHONPATH="${_LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" \
        python3 -m tmuxctl.cli stack adopt legion \
            --pane "$current_pane" \
            --session "$SESSION" \
            --cwd "${wdir:-$HOME}" \
            --no-focus \
        || { tmux display-message "Shuttle: failed to adopt pane into legion stack"; return 1; }

    # Refill the vacated palace/somnium slot with a fresh shell so the source
    # grid never collapses to zero panes. `pane_tag` restores the slot identity
    # and derives the correct @GRID_STATE (side for W/E, small for the center
    # grid incl. N/S/NE/SE) so normalize._rebalance_grid replaces it cleanly.
    local replacement
    replacement=$(tmux split-window -t "$src_window" -d -P -F '#{pane_id}' -c "${wdir:-$HOME}")
    if [[ -n "$replacement" ]]; then
        pane_tag "$replacement" "$slot_tag" || true
        tmux set-option -p -t "$replacement" @GRID_RESERVED "false" 2>/dev/null || true
        tmux set-option -pu -t "$replacement" @STACK_PENDING 2>/dev/null || true
    fi

    # Read the ordinal the allocator assigned (legion:N, lowest free) back off
    # the live pane and tell Token-API where the agent now lives.
    local stack_tag
    stack_tag=$(pane_id_of "$current_pane") || true
    [[ -n "$stack_tag" ]] || stack_tag="legion:worker"
    relocate_pane "$current_pane" "$stack_tag"

    # Normalize the source grid, then keep the camera on the replacement.
    tmux-refresh-layout "$src_target" 2>/dev/null || true
    [[ -n "$replacement" ]] && tmux select-pane -t "$replacement" 2>/dev/null || true

    tmux display-message "Shipped to legion stack"
}

# --- PROMOTE: legion/mechanicus → somnium (selector) ---
promote() {
    # Collect pane data into flat parallel arrays (no associative arrays — compat)
    local pd_tags="" pd_pids="" pd_cmds="" pd_states=""

    collect_panes() {
        local window="$1"
        while IFS=$'\t' read -r pid tag cmd state; do
            [[ -z "$tag" || "$tag" == "(null)" ]] && continue
            pd_tags="${pd_tags}${tag}"$'\n'
            pd_pids="${pd_pids}${pid}"$'\n'
            pd_cmds="${pd_cmds}${cmd}"$'\n'
            pd_states="${pd_states}${state}"$'\n'
        done < <(tmux list-panes -t "${SESSION}:${window}" \
            -F '#{pane_id}	#{@PANE_ID}	#{pane_current_command}	#{@CC_STATE}' 2>/dev/null || true)
    }
    collect_panes palace
    collect_panes somnium

    # Lookup helper: find pid/cmd/state for a given tag
    lookup_tag() {
        local want="$1"
        local i=1
        while true; do
            local t
            t=$(echo "$pd_tags" | sed -n "${i}p")
            [[ -z "$t" ]] && return 1
            if [[ "$t" == "$want" ]]; then
                _pid=$(echo "$pd_pids" | sed -n "${i}p")
                _cmd=$(echo "$pd_cmds" | sed -n "${i}p")
                _state=$(echo "$pd_states" | sed -n "${i}p")
                return 0
            fi
            ((i++))
        done
    }

    # Build display-menu arguments in order
    local menu_args=()

    add_slot() {
        local key="$1" tag="$2" label="$3"
        local _pid="" _cmd="" _state=""
        if lookup_tag "$tag"; then
            local prefix=""
            if [[ "$_cmd" == "claude" && "$_state" == "processing" ]]; then
                prefix="#[dim]"
            fi
            menu_args+=("${prefix}${key}  ${label}" "$key" \
                "run-shell \"tmux-run tmux-shuttle --do-swap '${current_pane}' '${_pid}' '${tag}'\"")
        fi
    }

    # Palace slots (1-4)
    add_slot 1 "palace:W" "Palace W"
    add_slot 2 "palace:N" "Palace N"
    add_slot 3 "palace:S" "Palace S"
    add_slot 4 "palace:E" "Palace E"

    # Somnium slots (5-9)
    add_slot 5 "somnium:W" "Somnium W"
    add_slot 6 "somnium:N" "Somnium N"
    add_slot 7 "somnium:NE" "Somnium NE"
    add_slot 8 "somnium:S" "Somnium S"
    add_slot 9 "somnium:SE" "Somnium SE"

    if [[ ${#menu_args[@]} -eq 0 ]]; then
        tmux display-message "No target panes found"
        return 1
    fi

    tmux display-menu -T " Promote to " -x C -y C "${menu_args[@]}"
}

# --- Route based on current window ---
case "$current_window" in
    palace|somnium)
        demote
        ;;
    legion|mechanicus|mars|kreig)
        promote
        ;;
    *)
        tmux display-message "Shuttle: only works on palace/somnium/legion/mechanicus"
        ;;
esac
