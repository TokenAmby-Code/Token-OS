#!/usr/bin/env bash
# victory - Cron-job victory marker (legacy session-victory mode redirects to victory-ack)
# TAGS: golden-throne, cron
# AUDIENCE: human, agent
#
# Usage:
#     victory --cron <job_id> "reason"                # Cron job victory (canonical mode)
#     victory --cron <job_id> --run <run_id> "reason"
#
# Session-doc victory: use `victory-ack` (rubric-validated). For backward
# compat, `victory "reason"` (no --cron) prints a deprecation hint and
# forwards through victory-ack so existing callers do not break.

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

TOKEN_API="${TOKEN_API_URL:-http://localhost:7777}"

# Parse flags
MODE="instance"
CRON_JOB_ID=""
CRON_RUN_ID=""
REASON=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --cron)
            MODE="cron"
            CRON_JOB_ID="${2:?--cron requires a job_id}"
            shift 2
            ;;
        --run)
            CRON_RUN_ID="${2:?--run requires a run_id}"
            shift 2
            ;;
        *)
            REASON="$1"
            shift
            ;;
    esac
done

if [[ -z "$REASON" ]]; then
    echo "Usage: victory --cron <job_id> \"reason\"" >&2
    echo "       (for session victory, use: victory-ack \"reason\")" >&2
    exit 1
fi

# ── Cron job victory (canonical) ─────────────────────────────
if [[ "$MODE" == "cron" ]]; then
    BODY="{\"reason\": $(echo "$REASON" | jq -Rs .)}"
    [[ -n "$CRON_RUN_ID" ]] && BODY="{\"reason\": $(echo "$REASON" | jq -Rs .), \"run_id\": $CRON_RUN_ID}"

    RESPONSE=$(curl -sf -X POST "${TOKEN_API}/api/cron/jobs/${CRON_JOB_ID}/victory" \
        -H "Content-Type: application/json" \
        -d "$BODY" 2>/dev/null) || {
        echo "Error: Cron victory API call failed" >&2
        exit 1
    }

    JOB_NAME=$(echo "$RESPONSE" | jq -r '.job_name // "unknown"')
    echo "⚔️ IMPERIUM VICTORIOUS — [${JOB_NAME}] $REASON"
    exit 0
fi

# ── Legacy instance-mode shim → victory-ack ─────────────────
echo "victory: instance mode is deprecated; forwarding through victory-ack" >&2
exec "$(dirname "$(readlink -f "$0")")/victory-ack" "$REASON"
