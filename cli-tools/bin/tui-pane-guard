#!/usr/bin/env bash
# tui-pane-guard — Lifecycle wrapper for TUI/browser monitor panes
# TAGS: tmux, tui, browser, lifecycle
# AUDIENCE: script (called by tmuxctl/tx-managed panes, not directly by user)
#
# Wraps the monitor command with lifecycle hooks:
#   - Traps Ctrl+C (SIGINT) → sets @TUI_DIRTY, then exits (no auto-restart)
#   - Normal/crash exit → leaves no dirty bit (auto-restart kicks in)
#
# Default surface:
#   auto           — use a terminal HTML browser inside tmux when available,
#                    otherwise open Token-API's Somnium display in a GUI browser
#
# Surface overrides:
#   terminal-html  — render local Somnium HTML snapshot inside tmux via w3m
#   browser        — open the JavaScript dashboard in Safari/configured browser
#   terminal       — run the legacy token-api-tui.py Rich TUI
#
# Overrides:
#   TOKEN_API_TUI_SURFACE=auto|terminal-html|browser|terminal
#   TOKEN_API_TUI_URL=http://localhost:7777/ui/somnium
#   TOKEN_API_TUI_TERMINAL_URL=http://localhost:7777/ui/somnium/terminal
#   TOKEN_API_TUI_BROWSER_CMD='open -a "Safari"'
#
# The pane must have remain-on-exit enabled and a pane-died hook that
# checks @TUI_DIRTY before deciding whether to respawn.

set -euo pipefail

PANE_ID="${TMUX_PANE:-}"

if [[ -z "$PANE_ID" ]]; then
    echo "tui-pane-guard: must run inside a tmux pane" >&2
    exit 1
fi

# Clear any stale dirty bit from a previous run
tmux set-option -p -t "$PANE_ID" @TUI_DIRTY "false" 2>/dev/null || true

CHILD_PID=""

_mark_dirty_and_exit() {
    tmux set-option -p -t "$PANE_ID" @TUI_DIRTY "true" 2>/dev/null || true
    if [[ -n "$CHILD_PID" ]]; then
        kill "$CHILD_PID" 2>/dev/null || true
    fi
    exit 0
}

# On intentional close (Ctrl+C), mark dirty so auto-restart skips this pane
trap _mark_dirty_and_exit INT TERM

# Source machine identity for paths
_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
# shellcheck source=../lib/nas-path.sh
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

TOKEN_API_DIR="${TOKEN_OS}/token-api"
cd "$TOKEN_API_DIR"

REQUESTED_SURFACE="${TOKEN_API_TUI_SURFACE:-auto}"
SOMNIUM_URL="${TOKEN_API_TUI_URL:-${TOKEN_API_URL:-http://localhost:7777}/ui/somnium}"
SOMNIUM_TERMINAL_URL="${TOKEN_API_TUI_TERMINAL_URL:-${TOKEN_API_URL:-http://localhost:7777}/ui/somnium/terminal}"

if [[ "$REQUESTED_SURFACE" == "auto" ]]; then
    if command -v w3m >/dev/null 2>&1; then
        SURFACE="terminal-html"
    else
        SURFACE="browser"
    fi
else
    SURFACE="$REQUESTED_SURFACE"
fi

tmux set-option -p -t "$PANE_ID" @TUI_SURFACE "$SURFACE" 2>/dev/null || true
tmux set-option -p -t "$PANE_ID" @TUI_URL "$SOMNIUM_URL" 2>/dev/null || true
tmux set-option -p -t "$PANE_ID" @TUI_TERMINAL_URL "$SOMNIUM_TERMINAL_URL" 2>/dev/null || true

_open_browser() {
    local url="$1"

    if [[ -n "${TOKEN_API_TUI_BROWSER_CMD:-}" ]]; then
        # shellcheck disable=SC2086
        ${TOKEN_API_TUI_BROWSER_CMD} "$url"
        return $?
    fi

    if command -v osascript >/dev/null 2>&1; then
        # Reuse an existing Somnium Safari tab when possible.  The previous
        # default used `open -n`, which creates a fresh Safari application
        # instance every time this guard is respawned; tmux/UI churn then
        # spams the Dock with Safari icons.
        osascript - "$url" <<'APPLESCRIPT'
on run argv
    set targetUrl to item 1 of argv
    tell application "Safari"
        set foundTab to missing value
        set foundWindow to missing value
        repeat with w in windows
            repeat with t in tabs of w
                try
                    if (URL of t) starts with targetUrl then
                        set foundTab to t
                        set foundWindow to w
                        exit repeat
                    end if
                end try
            end repeat
            if foundTab is not missing value then exit repeat
        end repeat
        if foundTab is not missing value then
            set current tab of foundWindow to foundTab
        else
            open location targetUrl
        end if
    end tell
end run
APPLESCRIPT
        return $?
    fi

    if command -v open >/dev/null 2>&1; then
        # Reuse the existing browser application; never use `-n` here.
        open -a "Safari" "$url"
        return $?
    fi

    if command -v termux-open-url >/dev/null 2>&1; then
        termux-open-url "$url"
        return $?
    fi

    if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url"
        return $?
    fi

    return 127
}

if [[ "$SURFACE" == "terminal" ]]; then
    # Legacy fallback. Run it as a child so the dirty-bit trap still fires.
    UV_PROJECT_ENVIRONMENT=~/.local/venvs/token-api uv run python token-api-tui.py &
    CHILD_PID=$!
    wait "$CHILD_PID" 2>/dev/null || true
    exit 0
fi

if [[ "$SURFACE" == "terminal-html" ]]; then
    if ! command -v w3m >/dev/null 2>&1; then
        echo "tui-pane-guard: w3m not found; falling back to GUI browser" >&2
        SURFACE="browser"
        tmux set-option -p -t "$PANE_ID" @TUI_SURFACE "$SURFACE" 2>/dev/null || true
    elif ! command -v somnium-terminal-html >/dev/null 2>&1; then
        echo "tui-pane-guard: somnium-terminal-html not found; falling back to GUI browser" >&2
        SURFACE="browser"
        tmux set-option -p -t "$PANE_ID" @TUI_SURFACE "$SURFACE" 2>/dev/null || true
    else
        SNAPSHOT="/tmp/somnium-terminal-${PANE_ID#%}.html"
        clear
        echo "Somnium terminal HTML display"
        echo
        echo "File:     ${SNAPSHOT}"
        echo "Surface:  terminal-html (w3m)"
        echo "Pane:     ${PANE_ID}"
        echo
        echo "w3m controls: q=quit, R=reload, arrow/jk navigation."
        echo "Ctrl+C marks this pane dirty and disables automatic TUI respawn."
        echo
        (
            while true; do
                somnium-terminal-html >"${SNAPSHOT}.tmp" 2>/dev/null && mv "${SNAPSHOT}.tmp" "$SNAPSHOT"
                sleep 5
            done
        ) &
        SNAPSHOT_PID=$!
        sleep 0.5
        w3m "$SNAPSHOT" &
        CHILD_PID=$!
        wait "$CHILD_PID" 2>/dev/null || true
        kill "$SNAPSHOT_PID" 2>/dev/null || true
        exit 0
    fi
fi

if ! _open_browser "$SOMNIUM_URL"; then
    echo "tui-pane-guard: no browser opener found; falling back to terminal TUI" >&2
    UV_PROJECT_ENVIRONMENT=~/.local/venvs/token-api uv run python token-api-tui.py &
    CHILD_PID=$!
    wait "$CHILD_PID" 2>/dev/null || true
    exit 0
fi

clear
cat <<EOF
Somnium browser display launched

URL:      ${SOMNIUM_URL}
Surface:  browser
Pane:     ${PANE_ID}

The JavaScript HTML display renders in Safari/the configured browser, not inside
this tmux pane. If w3m is installed and TOKEN_API_TUI_SURFACE is auto, this
guard renders /ui/somnium/terminal directly in the pane instead.

If the browser is not visible, open the URL above. Respawns reuse the
existing Somnium tab and must not create additional Safari app instances.

Ctrl+C marks this pane dirty and disables automatic TUI respawn.
Set TOKEN_API_TUI_SURFACE=terminal before launch to run token-api-tui.py.
EOF

while true; do
    sleep 3600 &
    CHILD_PID=$!
    wait "$CHILD_PID" 2>/dev/null || true
done
