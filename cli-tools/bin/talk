#!/usr/bin/env python3
# talk - Two-way inter-persona conversation primitive.
# TAGS: trinity, ipc, talk
# AUDIENCE: agent
"""Two-way talk between two tmux panes via Token-API.

Usage:
    talk --pane <id> "prompt"            # block until response or stop
    talk --pane <id> --no-wait "prompt"  # send-only; return talk_id immediately
    talk --pane <id> --timeout 600 "..." # override wait timeout (seconds)
    talk --pane <id> --json "..."        # emit machine-readable JSON
    talk --pane <id> --caller palace:N "..."  # override caller-pane detection

Pane addressing accepts:
    somnium:SE           position id (window:position)
    main:2:SE            full triple (session:window:position)

Raw tmux %NNN ids are internal-only and are never printed back.

See Mars/Tasks/trinity-chunk-1-talk-cli.md and
Terra/Ultramar/Inter-Persona Communication.md for the canon spec.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
import urllib.error
import urllib.request
import urllib.parse

_LIB_DIR = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "lib"))
if _LIB_DIR not in sys.path:
    sys.path.insert(0, _LIB_DIR)
from tmuxctld_timeouts import SEND_CLIENT_TIMEOUT_SECONDS, SEND_HOLD_CEILING_SECONDS

DEFAULT_TIMEOUT_TOTAL = 600.0
DEFAULT_SERVER_POLL = 30.0

TOKEN_API_URL = os.environ.get("TOKEN_API_URL", "http://localhost:7777")
TMUXCTLD_URL = os.environ.get("TMUXCTLD_URL", "http://127.0.0.1:8765")


def _err(msg: str) -> None:
    print(f"talk: {msg}", file=sys.stderr)


def _post(path: str, body: dict, timeout: float = SEND_CLIENT_TIMEOUT_SECONDS) -> dict:
    url = f"{TOKEN_API_URL}{path}"
    data = json.dumps(body).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read().decode("utf-8"))


def _ledger_get(path: str, timeout: float = 2.0) -> dict:
    url = f"{TMUXCTLD_URL}{path}"
    req = urllib.request.Request(url, method="GET")
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read().decode("utf-8"))


def _get(path: str, timeout: float = SEND_CLIENT_TIMEOUT_SECONDS) -> dict:
    url = f"{TOKEN_API_URL}{path}"
    req = urllib.request.Request(url, method="GET")
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read().decode("utf-8"))



def _await_failure_record(last_record: dict, send: dict, *, error: str) -> dict:
    """Build a structured await-failure record without losing send delivery state.

    A failure while polling /api/talk/await is not the same as a send failure.
    Preserve the original send receipt (including delivery) so callers can tell
    whether a retry risks a duplicate.
    """
    base = dict(last_record or {})
    base.update(
        {
            "status": "await_failed",
            "await_error": error,
            "error": error,
            "send_status": (send or {}).get("status"),
            "talk_id": base.get("talk_id") or (send or {}).get("talk_id"),
            "send": send or {},
        }
    )
    if "delivery" not in base and isinstance(send, dict) and "delivery" in send:
        base["delivery"] = send.get("delivery")
    return base

def _resolve_caller(explicit: str | None) -> str:
    if explicit:
        return explicit
    wrapper_id = os.environ.get("TOKEN_API_WRAPPER_ID") or os.environ.get("TOKEN_API_WRAPPER_LAUNCH_ID")
    if wrapper_id:
        try:
            data = _ledger_get(f"/ledger/resolve?wrapper_id={urllib.parse.quote(wrapper_id)}")
            pane = data.get("pane_id") or data.get("pane") or data.get("pane_label")
            if data.get("found") and pane:
                return str(pane)
        except Exception:
            pass
    env_pane = os.environ.get("TMUX_PANE")
    if env_pane:
        try:
            data = _ledger_get(f"/ledger/resolve?pane={urllib.parse.quote(env_pane)}")
            pane = data.get("pane_id") or data.get("pane") or data.get("pane_label")
            if data.get("found") and pane:
                return str(pane)
        except Exception:
            pass
        return env_pane
    _err(
        "could not detect caller pane (no --caller and $TMUX_PANE unset). "
        "Pass --caller <page:id> explicitly."
    )
    sys.exit(64)


def _render_response(record: dict, *, json_out: bool) -> None:
    if json_out:
        print(json.dumps(record, indent=2, sort_keys=True))
        return
    status = record.get("status")
    text = (record.get("result_text") or "").strip()
    kind = record.get("result_kind") or ""
    returned_by = record.get("returned_by_pane") or ""
    if status == "returned":
        header = f"[talk:{kind}"
        if returned_by:
            header += f" from {returned_by}"
        header += "]"
        print(header)
        if text:
            print(text)
    elif status in {"cancelled", "expired"}:
        print(f"[talk:{status}] {record.get('result_kind') or ''}".rstrip())
    elif status == "open":
        print(f"[talk:pending] talk_id={record.get('talk_id')}")
    else:
        print(json.dumps(record, indent=2, sort_keys=True))


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        prog="talk",
        description="Two-way inter-persona conversation between tmux panes.",
        add_help=True,
    )
    parser.add_argument("--pane", required=True, help="Target pane (public {page}:{id} id)")
    parser.add_argument(
        "--caller",
        default=None,
        help="Caller pane id (defaults to $TMUX_PANE)",
    )
    parser.add_argument(
        "--no-wait",
        action="store_true",
        help="Return talk_id immediately, do not block for response",
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=DEFAULT_TIMEOUT_TOTAL,
        help=f"Total wait timeout in seconds (default {int(DEFAULT_TIMEOUT_TOTAL)})",
    )
    parser.add_argument(
        "--json",
        dest="json_out",
        action="store_true",
        help="Emit JSON result instead of human text",
    )
    parser.add_argument("prompt", help="The message to send")
    args = parser.parse_args(argv)

    caller = _resolve_caller(args.caller)
    body = {
        "caller_pane": caller,
        "target_pane": args.pane,
        "payload": args.prompt,
    }
    try:
        send = _post("/api/talk/send", body, timeout=SEND_CLIENT_TIMEOUT_SECONDS)
    except urllib.error.HTTPError as exc:
        try:
            detail = json.loads(exc.read().decode("utf-8")).get("detail", str(exc))
        except Exception:
            detail = str(exc)
        _err(f"send failed: {detail}")
        return 1
    except urllib.error.URLError as exc:
        _err(f"Token-API unreachable at {TOKEN_API_URL}: {exc.reason}")
        return 1

    status = send.get("status")
    talk_id = send.get("talk_id")
    if status == "returned":
        # Caller hit the explicit-return shortcut — we ARE the return. The
        # server still attempts to inject the payload into the original caller's
        # pane; that delivery can fail independently of the pair-return.
        delivery = send.get("delivery") or {}
        delivered_ok = delivery.get("status") != "failed"
        if args.json_out:
            print(json.dumps(send, indent=2, sort_keys=True))
        elif delivered_ok:
            print(f"[talk:returned] delivered to {args.pane}")
        else:
            _err(
                f"[talk:returned] delivery failed to {args.pane}: "
                f"{delivery.get('error') or delivery.get('status')}"
            )
        return 0 if delivered_ok else 1
    if args.no_wait:
        if args.json_out:
            print(json.dumps(send, indent=2, sort_keys=True))
        else:
            print(f"[talk:open] talk_id={talk_id} target={args.pane}")
        return 0
    if status != "open" or not talk_id:
        _err(f"unexpected send status: {status}")
        return 2

    deadline = time.monotonic() + args.timeout
    poll_url = f"/api/talk/await/{talk_id}?timeout={DEFAULT_SERVER_POLL}"
    last_record: dict = send
    try:
        while True:
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                if args.json_out:
                    print(json.dumps(last_record, indent=2, sort_keys=True))
                else:
                    print(f"[talk:timeout] talk_id={talk_id}")
                return 124
            wait = max(0.1, min(DEFAULT_SERVER_POLL, remaining))
            try:
                record = _get(
                    f"/api/talk/await/{talk_id}?timeout={wait}",
                    timeout=wait + 15.0,
                )
            except urllib.error.HTTPError as exc:
                failure = _await_failure_record(
                    last_record, send, error=f"HTTP Error {exc.code}: {exc.reason}"
                )
                if args.json_out:
                    print(json.dumps(failure, indent=2, sort_keys=True))
                else:
                    _err(
                        f"await failed after send status={send.get('status')} "
                        f"talk_id={talk_id}: HTTP Error {exc.code}: {exc.reason}"
                    )
                return 1
            except urllib.error.URLError as exc:
                failure = _await_failure_record(
                    last_record, send, error=f"connection error: {exc.reason}"
                )
                if args.json_out:
                    print(json.dumps(failure, indent=2, sort_keys=True))
                else:
                    _err(
                        f"await connection error after send status={send.get('status')} "
                        f"talk_id={talk_id}: {exc.reason}"
                    )
                return 1
            last_record = record
            if record.get("status") and record["status"] != "open":
                _render_response(record, json_out=args.json_out)
                return 0 if record["status"] == "returned" else 3
            # Still open — loop and re-poll.
    except KeyboardInterrupt:
        try:
            _post(f"/api/talk/cancel/{talk_id}", {}, timeout=10.0)
        except Exception:
            pass
        _err(f"interrupted; cancelled talk_id={talk_id}")
        return 130


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
