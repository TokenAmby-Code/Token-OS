#!/usr/bin/env bash
# inquisitor - retired launcher alias
# TAGS: deprecated
# AUDIENCE: deprecated
set -euo pipefail
case "inquisitor" in
  claude-dispatch) replacement='dispatch --engine claude' ;;
  vault-dispatch) replacement='dispatch --session-doc <path> --dir <path>' ;;
  claude-launcher) replacement='dispatch --interactive' ;;
  inquisitor) replacement='dispatch --persona inquisition --prompt <task>' ;;
  subagent) replacement='dispatch --prompt <task>' ;;
esac
echo "inquisitor has been retired. Use: $replacement" >&2
exit 64
