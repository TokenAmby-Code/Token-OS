#!/usr/bin/env bash
# inquisitor - retired launcher alias
# TAGS: deprecated
# AUDIENCE: deprecated
set -euo pipefail
case "inquisitor" in
  inquisitor) replacement='dispatch --persona inquisition --prompt <task>' ;;
  subagent) replacement='dispatch --prompt <task>' ;;
esac
echo "inquisitor has been retired. Use: $replacement" >&2
exit 64
