#!/usr/bin/env bash
# Worktree Setup - create git worktrees from NAS bare repos
# TAGS: git, worktree, nas
# AUDIENCE: human, agent
#
# Usage: worktree-setup <branch-name> [options]
#
# Creates a worktree on local disk from a NAS-hosted bare repo, copies
# env files from the NAS secrets dir, and syncs dependencies.
#
# Config: ~/.config/worktrees/<project>.conf
#
# Examples:
#   worktree-setup feature-auth                    # New branch, default project (askCivic)
#   worktree-setup fix-bug --existing              # Use existing branch
#   worktree-setup my-feature --project Scripts    # Different project
#   worktree-setup my-feature --dry-run            # Preview what would happen

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
_HOOKS_DIR="$(dirname "$(readlink -f "$0")")/../git-hooks"
_CALLER_IMPERIUM="${IMPERIUM:-}"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true
[[ -n "$_CALLER_IMPERIUM" ]] && export IMPERIUM="$_CALLER_IMPERIUM"
source "${_LIB_DIR}/git-remote.sh" 2>/dev/null || true
source "${_LIB_DIR}/worktree-ports.sh" 2>/dev/null || true

# Ensure Homebrew is on PATH (Apple Silicon Macs, non-interactive shells)
[[ -d /opt/homebrew/bin ]] && export PATH="/opt/homebrew/bin:$PATH"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Detect default project from PWD (vault → project mapping)
detect_default_project() {
    case "$PWD" in
        */Imperium-ENV*) echo "Token-OS" ;;
        */Pax-ENV*)      echo "askCivic" ;;
        *)               echo "askCivic" ;;
    esac
}

# Defaults
DRY_RUN=false
USE_EXISTING_BRANCH=false
SKIP_SYNC=false
NO_TRANSPLANT=false
REQUIRE_FREE=false
FORCE=false
RESUME=false
ALLOW_PROTECTED_BRANCH=false
PROJECT="$(detect_default_project)"
INIT_MODE=false
SESSION_DOC_ID=""

usage() {
    cat << 'EOF'
Worktree Setup - create git worktrees from NAS bare repos

Usage: worktree-setup <branch-name> [options]
       worktree-setup --init [project-name]

Arguments:
  branch-name         Name for the new branch and worktree directory

Options:
  -e, --existing        Use an existing branch instead of creating new one
  -p, --project NAME    Project config to use (default: askCivic)
  -n, --dry-run         Show what would happen without making changes
  -s, --skip-sync       Skip running uv sync / npm install
  --no-transplant       Skip session transplant (for subagents or non-interactive use)
  --require-free        Claim the branch atomically; refuse if a live worktree
                        already holds it (1 branch = 1 worktree = 1 PR)
  --resume              Finish an interrupted setup: if the worktree already
                        holds this branch, skip creation and re-run the
                        remaining (idempotent) steps
  --allow-protected-branch
                        Admin escape hatch: allow creating main/master worktrees.
                        Normal agents must not use main/master as work targets.
  -f, --force           Override an existing claim / reuse an existing branch
  --session-doc <id>    Register this worktree (active) in the session doc's
                        frontmatter worktrees: list. Supplied by the parent
                        launcher (worktree-setup runs before the child instance
                        exists). Best-effort; worktree still creates if absent.
  --init                Print template config for a new project
  -h, --help            Show this help message

Config:
  ~/.config/worktrees/<project>.conf defines:
    BARE_REPO         Path to bare git repo on NAS
    WORKTREE_PARENT   Local directory for worktrees
    SECRETS_DIR       NAS directory with env files and credentials
    PROTECTED_ROOT    Optional protected checkout/root agents must not edit
    RUNTIME_CHECKOUT  Optional deploy-owned runtime checkout (not a work target)
    LOCAL_BARE_MAIN_SYNC
                      true when local CD owns bare main synchronization

Examples:
  worktree-setup feature-auth              # New branch in askCivic
  worktree-setup fix-bug --existing        # Existing branch
  worktree-setup my-feature --project Scripts  # Different project
  worktree-setup --init myproject          # Print config template
EOF
    exit 0
}

log_info() {
    echo -e "${BLUE}→${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}✓${NC} $1" >&2
}

log_warn() {
    echo -e "${YELLOW}!${NC} $1" >&2
}

log_error() {
    echo -e "${RED}✗${NC} $1" >&2
}

validate_canonical_remote() {
    local project="$1" config="$2"
    CANONICAL_REMOTE="$(git --git-dir="$BARE_REPO" remote get-url origin 2>/dev/null || true)"
    if [[ -z "$CANONICAL_REMOTE" ]]; then
        log_error "Bare repo origin remote is empty: $BARE_REPO"
        log_error "Set origin in $config to the canonical GitHub remote before creating PR-capable worktrees."
        exit 64
    fi
    if dead_or_quarantined_remote "$CANONICAL_REMOTE"; then
        log_error "Refusing canonical remote with dead/quarantined provenance: $CANONICAL_REMOTE"
        log_error "Expected a live GitHub remote, not the old NAS/recycle Token-OS source."
        exit 64
    fi
    if [[ "$project" == "Token-OS" ]] && ! token_os_github_remote "$CANONICAL_REMOTE"; then
        log_error "Token-OS worktrees must use GitHub origin git@github.com:TokenAmby-Code/Token-OS.git"
        log_error "Configured bare origin is: $CANONICAL_REMOTE"
        exit 64
    fi
}

# ── Per-branch worktree claim lock (super-workflow Gap 1, D2 — LIVE guard) ──
# Serializes the (project, branch) create race so two concurrent worktree-setup
# runs cannot both create/claim the same branch. Prefers flock(1) where present
# (Linux/CI); falls back to an atomic mkdir lock on macOS, where flock is not
# installed and the worktree-ports precedent silently no-ops — this guard must
# stay live on the Mac too. Held until the process exits. Uses fd 8 to avoid
# clashing with the ports lib's fd 9.
CLAIM_LOCK_HELD=""
release_claim_lock() {
    if [[ -n "$CLAIM_LOCK_HELD" ]]; then
        rm -rf "$CLAIM_LOCK_HELD" 2>/dev/null || true
    fi
}
acquire_claim_lock() {
    local key="$1" timeout="${2:-10}"
    local state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/imperium/worktree-claims"
    mkdir -p "$state_dir"
    # Hash the full (project, branch) key so distinct refs never share a lock
    # file (e.g. `feature/foo` vs `feature-foo`). git hash-object is always present.
    local safe_key
    safe_key="$(printf '%s' "$key" | git hash-object --stdin 2>/dev/null)"
    [[ -n "$safe_key" ]] || safe_key="${key//[^a-zA-Z0-9]/_}"
    # WORKTREE_CLAIM_NO_FLOCK forces the portable mkdir path (used by tests to
    # exercise the macOS fallback deterministically on a flock-equipped CI).
    if [[ -z "${WORKTREE_CLAIM_NO_FLOCK:-}" ]] && command -v flock &>/dev/null; then
        exec 8>"$state_dir/${safe_key}.lock"
        flock -w "$timeout" 8 && return 0
        return 1
    fi
    # Portable fallback: atomic mkdir lock with bounded wait + stale-owner steal.
    local lockdir="$state_dir/${safe_key}.lockd"
    local waited=0 owner
    while ! mkdir "$lockdir" 2>/dev/null; do
        owner="$(cat "$lockdir/pid" 2>/dev/null || true)"
        if [[ -n "$owner" ]] && ! kill -0 "$owner" 2>/dev/null; then
            rm -rf "$lockdir" 2>/dev/null || true
            continue
        fi
        if (( waited >= timeout * 10 )); then
            return 1
        fi
        sleep 0.1
        waited=$(( waited + 1 ))
    done
    printf '%s' "$$" > "$lockdir/pid"
    CLAIM_LOCK_HELD="$lockdir"
    trap release_claim_lock EXIT
    return 0
}

load_config() {
    local project="${1:-askCivic}"
    local config="$HOME/.config/worktrees/${project}.conf"
    if [[ ! -f "$config" ]]; then
        log_error "Project config not found: $config"
        echo "  Create it with: worktree-setup --init $project" >&2
        exit 1
    fi
    # shellcheck disable=SC1090
    source "$config"
    for var in BARE_REPO WORKTREE_PARENT SECRETS_DIR; do
        if [[ -z "${!var:-}" ]]; then
            log_error "$var not set in $config"
            exit 1
        fi
    done
    # Optional: SYNC_SUBDIR — subdirectory containing pyproject.toml (for monorepos)
    SYNC_SUBDIR="${SYNC_SUBDIR:-}"
    # NAS mount check
    if [[ ! -d "$BARE_REPO" ]]; then
        log_error "Bare repo not found: $BARE_REPO (is NAS mounted?)"
        exit 1
    fi
    if [[ "$(git --git-dir="$BARE_REPO" rev-parse --is-bare-repository 2>/dev/null)" != "true" ]]; then
        log_error "$BARE_REPO is not a bare git repository"
        exit 1
    fi
    validate_canonical_remote "$project" "$config"
    # Quarantine guard (incident 2026-06-22): never cut a worktree from a bare in
    # a recycle bin or a dated legacy archive — its commondir would bind into a
    # purge target and the work is silently destroyed when the bin empties.
    if declare -f imperium_path_is_quarantined >/dev/null 2>&1 \
            && imperium_path_is_quarantined "$BARE_REPO"; then
        log_error "Refusing to use a quarantined bare repo (recycle bin / legacy archive): $BARE_REPO"
        log_error "Point BARE_REPO in $config at the canonical bare (e.g. \$HOME/runtimes/Token-OS/token-os.git)."
        exit 64
    fi
    if [[ ! -d "$SECRETS_DIR" ]]; then
        log_error "Secrets dir not found: $SECRETS_DIR (is NAS mounted?)"
        exit 1
    fi
    mkdir -p "$WORKTREE_PARENT"
}

print_init_template() {
    local project="${1:-myproject}"
    cat << EOF
# ${project} worktree configuration
# Save as: ~/.config/worktrees/${project}.conf

BARE_REPO=/mnt/civic/${project}.git
WORKTREE_PARENT=\$HOME/worktrees/${project}
SECRETS_DIR=/mnt/civic/${project}.secrets
PROTECTED_ROOT=
RUNTIME_CHECKOUT=
LOCAL_BARE_MAIN_SYNC=false

# Optional: subdirectory containing pyproject.toml (for monorepos)
# SYNC_SUBDIR=subdir
EOF
    exit 0
}

# Parse arguments
BRANCH_NAME=""
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            usage
            ;;
        --init)
            INIT_MODE=true
            shift
            # Next arg is optional project name
            if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
                PROJECT="$1"
                shift
            fi
            ;;
        -n|--dry-run)
            DRY_RUN=true
            shift
            ;;
        -e|--existing)
            USE_EXISTING_BRANCH=true
            shift
            ;;
        -s|--skip-sync)
            SKIP_SYNC=true
            shift
            ;;
        -p|--project)
            if [[ $# -lt 2 ]]; then
                log_error "--project requires a name"
                exit 1
            fi
            PROJECT="$2"
            shift 2
            ;;
        --no-transplant)
            NO_TRANSPLANT=true
            shift
            ;;
        --require-free)
            REQUIRE_FREE=true
            shift
            ;;
        --resume)
            RESUME=true
            shift
            ;;
        --allow-protected-branch|--allow-main-worktree|--admin-readonly-main)
            ALLOW_PROTECTED_BRANCH=true
            shift
            ;;
        --session-doc)
            if [[ $# -lt 2 ]]; then
                log_error "--session-doc requires a doc id"
                exit 1
            fi
            SESSION_DOC_ID="$2"
            shift 2
            ;;
        -f|--force)
            FORCE=true
            shift
            ;;
        -*)
            log_error "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
        *)
            if [[ -z "$BRANCH_NAME" ]]; then
                BRANCH_NAME="$1"
            else
                log_error "Too many arguments"
                exit 1
            fi
            shift
            ;;
    esac
done

# Handle --init mode
if [[ "$INIT_MODE" == "true" ]]; then
    print_init_template "$PROJECT"
fi

# Validate arguments
if [[ -z "$BRANCH_NAME" ]]; then
    log_error "Branch name required"
    echo "Usage: worktree-setup <branch-name> [options]"
    echo "Use --help for more information"
    exit 1
fi

# Load project config (validates NAS mounts, bare repo, etc.)
load_config "$PROJECT"

if [[ "$BRANCH_NAME" == "main" || "$BRANCH_NAME" == "master" ]]; then
    if [[ "$ALLOW_PROTECTED_BRANCH" != "true" ]]; then
        log_error "Refusing to create a '$BRANCH_NAME' worktree: main/master are protected skeleton branches, not agent work targets"
        log_error "Use a feature branch. Admin/read-only exception: --allow-protected-branch"
        exit 64
    fi
    log_warn "Admin exception: creating protected branch worktree '$BRANCH_NAME'"
fi

WORKTREE_DIR="$WORKTREE_PARENT/wt-$BRANCH_NAME"

# Resume: an interrupted setup (SIGKILL mid-sync, dropped SSH) leaves a real
# worktree with some later steps missing (secrets, port, hooks, venvs). With
# --resume, if the directory is already this branch's checkout, skip creation
# and re-run every remaining step — they are all idempotent. Resume is explicit
# (not automatic) because dispatch relies on the existing-dir refusal to keep
# 1 branch = 1 worktree = 1 PR: auto-resume would enter a live agent's worktree.
RESUME_MODE=false
if [[ -d "$WORKTREE_DIR" ]]; then
    _existing_branch="$(git -C "$WORKTREE_DIR" branch --show-current 2>/dev/null || true)"
    if [[ "$RESUME" == "true" && "$_existing_branch" == "$BRANCH_NAME" ]]; then
        RESUME_MODE=true
        log_warn "Worktree for '$BRANCH_NAME' already exists — resuming setup (interrupted run?)"
    elif [[ "$RESUME" == "true" ]]; then
        log_error "Cannot resume: $WORKTREE_DIR holds '${_existing_branch:-not a git worktree}', not '$BRANCH_NAME'"
        exit 1
    else
        log_error "Directory already exists: $WORKTREE_DIR"
        log_error "If a previous setup was interrupted, re-run with --resume to finish the remaining steps."
        exit 1
    fi
fi

# Per-branch claim (Gap 1, D1/D2): with --require-free, serialize the create
# race under a local-FS lock, then refuse a 2nd worktree on a branch already
# checked out in a live worktree (1 branch = 1 worktree = 1 PR) unless --force.
# The lock is held until exit, so it also covers the `git worktree add` below.
# A claim held by our own WORKTREE_DIR is the resume case, not a conflict.
if [[ "$REQUIRE_FREE" == "true" ]]; then
    if ! acquire_claim_lock "${PROJECT}-${BRANCH_NAME}" 10; then
        log_error "Could not acquire worktree claim lock for ${PROJECT}/${BRANCH_NAME} (another worktree-setup creating it?)"
        exit 75
    fi
    EXISTING_WT="$(git --git-dir="$BARE_REPO" worktree list --porcelain 2>/dev/null \
        | awk -v b="refs/heads/$BRANCH_NAME" '/^worktree /{p=substr($0,10)} /^branch /{if (substr($0,8)==b) print p}' \
        || true)"
    _own_resume_claim=false
    if [[ "$RESUME_MODE" == "true" && "$EXISTING_WT" == "$WORKTREE_DIR" ]]; then
        _own_resume_claim=true
    fi
    if [[ -n "$EXISTING_WT" && "$_own_resume_claim" != "true" && "$FORCE" != "true" ]]; then
        log_error "Branch '$BRANCH_NAME' is already claimed by a live worktree: $EXISTING_WT"
        log_error "1 branch = 1 worktree = 1 PR. Pass --force to override."
        exit 1
    fi
fi

# Check if branch exists (if --existing not specified). Skipped on resume:
# the branch necessarily exists and is checked out in WORKTREE_DIR.
if [[ "$RESUME_MODE" == "false" ]]; then
    BRANCH_EXISTS=$(git --git-dir="$BARE_REPO" branch --list "$BRANCH_NAME" | wc -l)
    REMOTE_EXISTS=$(git --git-dir="$BARE_REPO" branch -r --list "origin/$BRANCH_NAME" | wc -l)

    if [[ "$USE_EXISTING_BRANCH" == "false" ]]; then
        if [[ $BRANCH_EXISTS -gt 0 ]] || [[ $REMOTE_EXISTS -gt 0 ]]; then
            if [[ "$FORCE" == "true" ]]; then
                log_warn "Branch '$BRANCH_NAME' already exists; --force → reusing it"
                USE_EXISTING_BRANCH=true
            else
                log_error "Branch '$BRANCH_NAME' already exists. Use --existing to use it."
                exit 1
            fi
        fi
    else
        if [[ $BRANCH_EXISTS -eq 0 ]] && [[ $REMOTE_EXISTS -eq 0 ]]; then
            log_error "Branch '$BRANCH_NAME' does not exist"
            exit 1
        fi
    fi
fi

# Normalize: strip any trailing slash so the prefix strip below is reliable.
SECRETS_DIR="${SECRETS_DIR%/}"

# Identify files to copy from secrets dir: mirror every regular file at its
# relative path. SECRETS_DIR *is* the definition of what a worktree needs —
# pattern-matching specific layouts here silently skipped projects whose
# secrets live elsewhere (Token-OS: config.json + token-api/.env were never
# copied because only .env / widget/.env.* / deploy/*.json were recognized).
FILES_TO_COPY=()
while IFS= read -r -d '' _secret_file; do
    FILES_TO_COPY+=("${_secret_file#"$SECRETS_DIR/"}")
done < <(find "$SECRETS_DIR" -type f ! -name '.DS_Store' -print0 2>/dev/null)

# Show plan
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo " Worktree Setup Plan"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "  Project:       $PROJECT"
echo "  Bare repo:     $BARE_REPO"
echo "  Origin:        $CANONICAL_REMOTE"
echo "  Branch:        $BRANCH_NAME $(if [[ "$USE_EXISTING_BRANCH" == "true" ]]; then echo "(existing)"; else echo "(new)"; fi)"
echo "  Worktree:      $WORKTREE_DIR"
echo "  Secrets from:  $SECRETS_DIR"
echo ""

if [[ ${#FILES_TO_COPY[@]} -gt 0 ]]; then
    echo "  Files to copy:"
    for file in "${FILES_TO_COPY[@]}"; do
        echo "    - $file"
    done
else
    echo "  Files to copy: (none found)"
fi
echo ""

# Detect package manager (check bare repo for file existence)
# SYNC_SUBDIR: for monorepos, check the subdirectory that contains pyproject.toml
PKG_MANAGER=""
_PYPROJECT_PATH="${SYNC_SUBDIR:+$SYNC_SUBDIR/}pyproject.toml"
_UVLOCK_PATH="${SYNC_SUBDIR:+$SYNC_SUBDIR/}uv.lock"
_POETRYLOCK_PATH="${SYNC_SUBDIR:+$SYNC_SUBDIR/}poetry.lock"
if git --git-dir="$BARE_REPO" cat-file -e "HEAD:$_PYPROJECT_PATH" 2>/dev/null; then
    if git --git-dir="$BARE_REPO" cat-file -e "HEAD:$_UVLOCK_PATH" 2>/dev/null; then
        PKG_MANAGER="uv"
    elif git --git-dir="$BARE_REPO" cat-file -e "HEAD:$_POETRYLOCK_PATH" 2>/dev/null; then
        PKG_MANAGER="poetry"
    else
        PKG_MANAGER="pip"
    fi
fi

# Check for npm dependencies
HAS_NPM=false
if git --git-dir="$BARE_REPO" cat-file -e HEAD:package.json 2>/dev/null; then
    HAS_NPM=true
fi
for dir in widget frontend; do
    if git --git-dir="$BARE_REPO" cat-file -e "HEAD:$dir/package.json" 2>/dev/null; then
        HAS_NPM=true
        break
    fi
done
if [[ "$HAS_NPM" == "true" ]]; then
    if [[ -n "$PKG_MANAGER" ]]; then
        PKG_MANAGER="$PKG_MANAGER + npm"
    else
        PKG_MANAGER="npm"
    fi
fi

if [[ -n "$PKG_MANAGER" ]] && [[ "$SKIP_SYNC" == "false" ]]; then
    echo "  Package sync:  $PKG_MANAGER"
else
    echo "  Package sync:  (skipped)"
fi
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo ""

if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "Dry run - no changes made"
    exit 0
fi

# Execute
if [[ "$RESUME_MODE" == "true" ]]; then
    log_info "Worktree already present — skipping creation, re-running remaining steps..."
else
    log_info "Creating worktree..."
    # Explicit --force (Gap 1 claim override) maps through, and prunes any stale
    # worktree registration left by a removed-but-unpruned dir so the re-add succeeds.
    # main/master are refused above unless --allow-protected-branch is passed.
    FORCE_FLAG=""
    if [[ "$FORCE" == "true" ]]; then
        FORCE_FLAG="--force"
    fi
    if [[ "$FORCE" == "true" ]]; then
        git --git-dir="$BARE_REPO" worktree prune 2>/dev/null || true
    fi
    if [[ "$USE_EXISTING_BRANCH" == "true" ]]; then
        git --git-dir="$BARE_REPO" worktree add ${FORCE_FLAG:+"$FORCE_FLAG"} "$WORKTREE_DIR" "$BRANCH_NAME"
    else
        # Base new branches on the freshest origin default branch, not bare HEAD.
        # Local CD normally keeps bare main current, but if a deploy was missed
        # (machine asleep, webhook drop) bare HEAD is silently stale and every
        # branch cut from it starts behind — the classic rebase surprise.
        BASE_REF="HEAD"
        DEFAULT_BRANCH="$(git --git-dir="$BARE_REPO" symbolic-ref --short HEAD 2>/dev/null || echo main)"
        if git --git-dir="$BARE_REPO" fetch --quiet origin "refs/heads/$DEFAULT_BRANCH" 2>/dev/null; then
            BASE_REF="FETCH_HEAD"
            log_success "Fetched origin/$DEFAULT_BRANCH — basing new branch on it"
        else
            log_warn "Could not fetch origin/$DEFAULT_BRANCH — basing on local bare HEAD (may be stale)"
        fi
        git --git-dir="$BARE_REPO" worktree add ${FORCE_FLAG:+"$FORCE_FLAG"} -b "$BRANCH_NAME" "$WORKTREE_DIR" "$BASE_REF"
    fi
    log_success "Worktree created at $WORKTREE_DIR"
fi

# Remote provenance guard: worktrees inherit remote config from the common
# gitdir, so a worktree cut from a recycled/runtime checkout can silently keep a
# dead NAS origin. Force the checked-out worktree back to the bare repo's
# canonical origin before any PR-capable agent starts work.
git -C "$WORKTREE_DIR" remote set-url origin "$CANONICAL_REMOTE"
git -C "$WORKTREE_DIR" remote add github "$CANONICAL_REMOTE" 2>/dev/null || \
    git -C "$WORKTREE_DIR" remote set-url github "$CANONICAL_REMOTE"
if [[ "$PROJECT" == "Token-OS" ]] \
        && ! git -C "$WORKTREE_DIR" remote get-url origin | grep -Eq 'github\.com[:/]TokenAmby-Code/Token-OS(\.git)?$'; then
    log_error "Worktree is not PR-capable; expected TokenAmby-Code/Token-OS GitHub remote"
    exit 64
fi
log_success "Verified PR-capable remotes from canonical origin"

# Copy files from secrets dir
if [[ ${#FILES_TO_COPY[@]} -gt 0 ]]; then
    log_info "Copying environment files from secrets..."
    for file in "${FILES_TO_COPY[@]}"; do
        src="$SECRETS_DIR/$file"
        dst="$WORKTREE_DIR/$file"

        # Ensure destination directory exists
        mkdir -p "$(dirname "$dst")"

        if [[ -f "$src" ]]; then
            cp "$src" "$dst"
            log_success "Copied $file"
        else
            log_warn "Skipped $file (not found)"
        fi
    done
fi

# Create config directory (required by Dockerfile but git-ignored)
log_info "Creating config directory..."
mkdir -p "$WORKTREE_DIR/config"
log_success "Created config/ directory"

# Assign a local dev port from the pool and write .worktree.env.
if command -v assign_port &>/dev/null; then
    if ASSIGNED_PORT=$(assign_port "$WORKTREE_DIR"); then
        cat > "$WORKTREE_DIR/.worktree.env" <<EOF
# Auto-generated by worktree-setup. Do not commit.
PORT=$ASSIGNED_PORT
WORKTREE_BRANCH=$BRANCH_NAME
WORKTREE_PROJECT=$PROJECT
EOF
        # Persist the session-doc id so worktree-delete can archive the entry.
        if [[ -n "$SESSION_DOC_ID" ]]; then
            echo "SESSION_DOC_ID=$SESSION_DOC_ID" >> "$WORKTREE_DIR/.worktree.env"
        fi
        log_success "Assigned port $ASSIGNED_PORT (written to .worktree.env)"
    else
        log_warn "Port assignment failed — .worktree.env not written"
    fi
else
    log_warn "worktree-ports lib not found — skipping port assignment"
fi

# DB isolation (P0 2026-06-09): a worktree dev token-api must never write the live
# ~/.claude/agents.db. Seed the worktree with a consistent snapshot of the live DB
# (sqlite .backup — safe against a running writer) so agents develop and live-test
# against realistic data with zero risk to production, and point TOKEN_API_DB at it.
# Independent of port assignment: isolation must hold even if the port pool failed.
if [[ -d "$WORKTREE_DIR/token-api" ]]; then
    DEV_DB="$WORKTREE_DIR/token-api/.dev-agents.db"
    LIVE_DB="$HOME/.claude/agents.db"
    if [[ -f "$LIVE_DB" ]] && command -v sqlite3 &>/dev/null; then
        if sqlite3 "$LIVE_DB" ".backup '$DEV_DB'" 2>/dev/null; then
            log_success "Seeded dev DB from live snapshot: $DEV_DB"
        else
            rm -f "$DEV_DB"
            log_warn "Live DB snapshot failed — dev server will initialize an empty isolated DB at $DEV_DB"
        fi
    else
        log_warn "No live DB (or sqlite3 missing) — dev server will initialize an empty isolated DB at $DEV_DB"
    fi
    {
        echo "# Dev DB isolation: never point this at ~/.claude/agents.db (live)."
        echo "TOKEN_API_DB=$DEV_DB"
    } >> "$WORKTREE_DIR/.worktree.env"
    log_success "TOKEN_API_DB written to .worktree.env (isolated from live)"
fi

# Register this worktree as the session doc's active worktree (Phase 3 registry).
# Server-side holds the one-active invariant (demotes any prior active → archived).
# Best-effort: a missing/unreachable token-api never fails worktree creation.
if [[ -n "$SESSION_DOC_ID" ]]; then
    _claimed_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    _wt_api="${TOKEN_API_URL:-http://localhost:7777}"
    _wt_body=$(printf '{"action":"claim","path":"%s","branch":"%s","port":"%s","claimed_at":"%s"}' \
        "$WORKTREE_DIR" "$BRANCH_NAME" "${ASSIGNED_PORT:-}" "$_claimed_at")
    if curl -fsS -m 5 -X POST \
        -H "Content-Type: application/json" \
        -d "$_wt_body" \
        "$_wt_api/api/session-docs/$SESSION_DOC_ID/worktrees" >/dev/null 2>&1; then
        log_success "Registered worktree in session doc $SESSION_DOC_ID (active)"
    else
        log_warn "Could not register worktree in session doc $SESSION_DOC_ID (token-api unreachable?)"
    fi
fi

# Install local post-push hook (per-worktree dev server hot-restart).
if [[ -f "$_HOOKS_DIR/post-push" ]]; then
    HOOK_DIR=$(git -C "$WORKTREE_DIR" rev-parse --git-path hooks 2>/dev/null || echo "")
    if [[ -n "$HOOK_DIR" ]]; then
        mkdir -p "$HOOK_DIR"
        cat "$_HOOKS_DIR/post-push" > "$HOOK_DIR/post-push"
        chmod +x "$HOOK_DIR/post-push"
        log_success "Installed post-push hook at $HOOK_DIR/post-push"
    fi
fi

# Install native pre-commit hook (ruff belt-and-suspenders — keeps commits matching
# CI's lockfile-pinned ruff even if the PostToolUse format-on-save hook goes stale).
if [[ -f "$_HOOKS_DIR/pre-commit" ]]; then
    HOOK_DIR=$(git -C "$WORKTREE_DIR" rev-parse --git-path hooks 2>/dev/null || echo "")
    if [[ -n "$HOOK_DIR" ]]; then
        mkdir -p "$HOOK_DIR"
        cat "$_HOOKS_DIR/pre-commit" > "$HOOK_DIR/pre-commit"
        chmod +x "$HOOK_DIR/pre-commit"
        log_success "Installed pre-commit hook at $HOOK_DIR/pre-commit"
    fi
fi

# Sync dependencies
if [[ -n "$PKG_MANAGER" ]] && [[ "$SKIP_SYNC" == "false" ]]; then
    log_info "Syncing dependencies..."
    cd "$WORKTREE_DIR"

    if [[ "$PKG_MANAGER" == *"uv"* ]]; then
        if [[ -n "${SYNC_SUBDIR:-}" ]]; then
            uv sync --project "$SYNC_SUBDIR" && log_success "Python dependencies synced (uv)" || \
                log_warn "Python sync failed (uv) — continuing with remaining steps"
        else
            uv sync && log_success "Python dependencies synced (uv)" || \
                log_warn "Python sync failed (uv) — continuing with remaining steps"
        fi
    elif [[ "$PKG_MANAGER" == *"poetry"* ]]; then
        poetry install && log_success "Python dependencies synced (poetry)" || \
            log_warn "Python sync failed (poetry) — continuing with remaining steps"
    elif [[ "$PKG_MANAGER" == *"pip"* ]]; then
        pip install -r requirements.txt && log_success "Python dependencies synced (pip)" || \
            log_warn "Python sync failed (pip) — continuing with remaining steps"
    fi

    if [[ "$PKG_MANAGER" == *"npm"* ]]; then
        # Root package.json (e.g., puppeteer, dotenv for E2E tests)
        if [[ -f "$WORKTREE_DIR/package.json" ]]; then
            cd "$WORKTREE_DIR"
            npm install
            log_success "Node dependencies synced (root)"
        fi

        # Subdirectory package.json (widget, frontend)
        for dir in widget frontend; do
            if [[ -d "$WORKTREE_DIR/$dir" ]] && [[ -f "$WORKTREE_DIR/$dir/package.json" ]]; then
                cd "$WORKTREE_DIR/$dir"
                npm install
                log_success "Node dependencies synced ($dir)"
            fi
        done
    fi
fi

# Token-OS dual-project dev venv: the ruff hooks (post-tool-format.sh PostToolUse +
# the native pre-commit) run `uv run --group dev ruff`, which needs a synced dev
# venv. The generic sync above is a no-op when PKG_MANAGER is unset (Token-OS.conf
# defines none), so ensure each project's dev group is synced before the first
# edit/commit. Guarded to Token-OS's layout so other projects are unaffected.
if [[ "$SKIP_SYNC" == "false" ]] && command -v uv &>/dev/null; then
    for proj in token-api cli-tools; do
        if [[ -f "$WORKTREE_DIR/$proj/pyproject.toml" ]]; then
            log_info "Syncing $proj dev venv (uv sync --group dev)..."
            if (cd "$WORKTREE_DIR/$proj" && uv sync --python 3.11 --group dev); then
                log_success "$proj dev dependencies synced"
            else
                log_warn "$proj dev sync failed — ruff hooks may sync lazily on first run"
            fi
        fi
    done
fi

echo ""

# Register quick cd alias (branch name → worktree dir). Upsert via an awk
# literal-prefix filter + append — branch names may contain regex/sed
# metacharacters (`fix/…` broke the sed delimiter in worktree-delete).
CD_QUICK_ALIASES_FILE="$HOME/.cd_quick_aliases"
_tmp_aliases=$(mktemp)
awk -v p="${BRANCH_NAME}=" 'index($0, p) != 1' "$CD_QUICK_ALIASES_FILE" 2>/dev/null > "$_tmp_aliases" || true
echo "${BRANCH_NAME}=${WORKTREE_DIR}" >> "$_tmp_aliases"
mv "$_tmp_aliases" "$CD_QUICK_ALIASES_FILE"
log_success "CD alias registered: cd $BRANCH_NAME → $WORKTREE_DIR"

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo -e " ${GREEN}Worktree ready!${NC}"
echo "═══════════════════════════════════════════════════════════════"
echo ""

# ═══════════════════════════════════════════════════════════════
# Session Transplant: delegate to the transplant tool
# ═══════════════════════════════════════════════════════════════

if [[ "$NO_TRANSPLANT" == "true" ]]; then
    echo "  cd $WORKTREE_DIR"
elif command -v transplant &>/dev/null; then
    transplant "$WORKTREE_DIR" || echo "  cd $WORKTREE_DIR"
else
    log_warn "transplant tool not found — skipping session transplant"
    echo "  cd $WORKTREE_DIR"
fi
echo ""
