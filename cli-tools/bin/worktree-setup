#!/usr/bin/env bash
# Worktree Setup - create git worktrees from NAS bare repos
# TAGS: git, worktree, nas
# AUDIENCE: human, agent
#
# Usage: worktree-setup <branch-name> [options]
#
# Creates a worktree on local disk from a NAS-hosted bare repo, copies
# env files from the NAS secrets dir, and syncs dependencies.
#
# Config: ~/.config/worktrees/<project>.conf
#
# Examples:
#   worktree-setup feature-auth                    # New branch, default project (askCivic)
#   worktree-setup fix-bug --existing              # Use existing branch
#   worktree-setup my-feature --project Scripts    # Different project
#   worktree-setup my-feature --dry-run            # Preview what would happen

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

# Ensure Homebrew is on PATH (Apple Silicon Macs, non-interactive shells)
[[ -d /opt/homebrew/bin ]] && export PATH="/opt/homebrew/bin:$PATH"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Defaults
DRY_RUN=false
USE_EXISTING_BRANCH=false
SKIP_SYNC=false
NO_TRANSPLANT=false
PROJECT="askCivic"
INIT_MODE=false

usage() {
    cat << 'EOF'
Worktree Setup - create git worktrees from NAS bare repos

Usage: worktree-setup <branch-name> [options]
       worktree-setup --init [project-name]

Arguments:
  branch-name         Name for the new branch and worktree directory

Options:
  -e, --existing        Use an existing branch instead of creating new one
  -p, --project NAME    Project config to use (default: askCivic)
  -n, --dry-run         Show what would happen without making changes
  -s, --skip-sync       Skip running uv sync / npm install
  --no-transplant       Skip session transplant (for subagents or non-interactive use)
  --init                Print template config for a new project
  -h, --help            Show this help message

Config:
  ~/.config/worktrees/<project>.conf defines:
    BARE_REPO         Path to bare git repo on NAS
    WORKTREE_PARENT   Local directory for worktrees
    SECRETS_DIR       NAS directory with env files and credentials

Examples:
  worktree-setup feature-auth              # New branch in askCivic
  worktree-setup fix-bug --existing        # Existing branch
  worktree-setup my-feature --project Scripts  # Different project
  worktree-setup --init myproject          # Print config template
EOF
    exit 0
}

log_info() {
    echo -e "${BLUE}→${NC} $1"
}

log_success() {
    echo -e "${GREEN}✓${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}!${NC} $1"
}

log_error() {
    echo -e "${RED}✗${NC} $1"
}

load_config() {
    local project="${1:-askCivic}"
    local config="$HOME/.config/worktrees/${project}.conf"
    if [[ ! -f "$config" ]]; then
        log_error "Project config not found: $config"
        echo "  Create it with: worktree-setup --init $project"
        exit 1
    fi
    # shellcheck disable=SC1090
    source "$config"
    for var in BARE_REPO WORKTREE_PARENT SECRETS_DIR; do
        if [[ -z "${!var:-}" ]]; then
            log_error "$var not set in $config"
            exit 1
        fi
    done
    # Optional: SYNC_SUBDIR — subdirectory containing pyproject.toml (for monorepos)
    SYNC_SUBDIR="${SYNC_SUBDIR:-}"
    # NAS mount check
    if [[ ! -d "$BARE_REPO" ]]; then
        log_error "Bare repo not found: $BARE_REPO (is NAS mounted?)"
        exit 1
    fi
    if [[ "$(git --git-dir="$BARE_REPO" rev-parse --is-bare-repository 2>/dev/null)" != "true" ]]; then
        log_error "$BARE_REPO is not a bare git repository"
        exit 1
    fi
    if [[ ! -d "$SECRETS_DIR" ]]; then
        log_error "Secrets dir not found: $SECRETS_DIR (is NAS mounted?)"
        exit 1
    fi
    mkdir -p "$WORKTREE_PARENT"
}

print_init_template() {
    local project="${1:-myproject}"
    cat << EOF
# ${project} worktree configuration
# Save as: ~/.config/worktrees/${project}.conf

BARE_REPO=/mnt/civic/${project}.git
WORKTREE_PARENT=\$HOME/worktrees/${project}
SECRETS_DIR=/mnt/civic/${project}.secrets

# Optional: subdirectory containing pyproject.toml (for monorepos)
# SYNC_SUBDIR=subdir
EOF
    exit 0
}

# Parse arguments
BRANCH_NAME=""
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            usage
            ;;
        --init)
            INIT_MODE=true
            shift
            # Next arg is optional project name
            if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
                PROJECT="$1"
                shift
            fi
            ;;
        -n|--dry-run)
            DRY_RUN=true
            shift
            ;;
        -e|--existing)
            USE_EXISTING_BRANCH=true
            shift
            ;;
        -s|--skip-sync)
            SKIP_SYNC=true
            shift
            ;;
        -p|--project)
            if [[ $# -lt 2 ]]; then
                log_error "--project requires a name"
                exit 1
            fi
            PROJECT="$2"
            shift 2
            ;;
        --no-transplant)
            NO_TRANSPLANT=true
            shift
            ;;
        -*)
            log_error "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
        *)
            if [[ -z "$BRANCH_NAME" ]]; then
                BRANCH_NAME="$1"
            else
                log_error "Too many arguments"
                exit 1
            fi
            shift
            ;;
    esac
done

# Handle --init mode
if [[ "$INIT_MODE" == "true" ]]; then
    print_init_template "$PROJECT"
fi

# Validate arguments
if [[ -z "$BRANCH_NAME" ]]; then
    log_error "Branch name required"
    echo "Usage: worktree-setup <branch-name> [options]"
    echo "Use --help for more information"
    exit 1
fi

# Load project config (validates NAS mounts, bare repo, etc.)
load_config "$PROJECT"

WORKTREE_DIR="$WORKTREE_PARENT/wt-$BRANCH_NAME"

# Check if worktree already exists
if [[ -d "$WORKTREE_DIR" ]]; then
    log_error "Directory already exists: $WORKTREE_DIR"
    exit 1
fi

# Check if branch exists (if --existing not specified)
BRANCH_EXISTS=$(git --git-dir="$BARE_REPO" branch --list "$BRANCH_NAME" | wc -l)
REMOTE_EXISTS=$(git --git-dir="$BARE_REPO" branch -r --list "origin/$BRANCH_NAME" | wc -l)

if [[ "$USE_EXISTING_BRANCH" == "false" ]]; then
    if [[ $BRANCH_EXISTS -gt 0 ]] || [[ $REMOTE_EXISTS -gt 0 ]]; then
        log_error "Branch '$BRANCH_NAME' already exists. Use --existing to use it."
        exit 1
    fi
else
    if [[ $BRANCH_EXISTS -eq 0 ]] && [[ $REMOTE_EXISTS -eq 0 ]]; then
        log_error "Branch '$BRANCH_NAME' does not exist"
        exit 1
    fi
fi

# Identify files to copy from secrets dir
FILES_TO_COPY=()

# Root .env
if [[ -f "$SECRETS_DIR/.env" ]]; then
    FILES_TO_COPY+=(".env")
fi

# widget/.env.* files
if [[ -d "$SECRETS_DIR/widget" ]]; then
    for envfile in "$SECRETS_DIR"/widget/.env.*; do
        if [[ -f "$envfile" ]]; then
            FILES_TO_COPY+=("widget/$(basename "$envfile")")
        fi
    done
fi

# deploy/*.json files (service account credentials)
if [[ -d "$SECRETS_DIR/deploy" ]]; then
    for jsonfile in "$SECRETS_DIR"/deploy/*.json; do
        if [[ -f "$jsonfile" ]]; then
            FILES_TO_COPY+=("deploy/$(basename "$jsonfile")")
        fi
    done
fi

# Show plan
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo " Worktree Setup Plan"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "  Project:       $PROJECT"
echo "  Bare repo:     $BARE_REPO"
echo "  Branch:        $BRANCH_NAME $(if [[ "$USE_EXISTING_BRANCH" == "true" ]]; then echo "(existing)"; else echo "(new)"; fi)"
echo "  Worktree:      $WORKTREE_DIR"
echo "  Secrets from:  $SECRETS_DIR"
echo ""

if [[ ${#FILES_TO_COPY[@]} -gt 0 ]]; then
    echo "  Files to copy:"
    for file in "${FILES_TO_COPY[@]}"; do
        echo "    - $file"
    done
else
    echo "  Files to copy: (none found)"
fi
echo ""

# Detect package manager (check bare repo for file existence)
# SYNC_SUBDIR: for monorepos, check the subdirectory that contains pyproject.toml
PKG_MANAGER=""
_PYPROJECT_PATH="${SYNC_SUBDIR:+$SYNC_SUBDIR/}pyproject.toml"
_UVLOCK_PATH="${SYNC_SUBDIR:+$SYNC_SUBDIR/}uv.lock"
_POETRYLOCK_PATH="${SYNC_SUBDIR:+$SYNC_SUBDIR/}poetry.lock"
if git --git-dir="$BARE_REPO" cat-file -e "HEAD:$_PYPROJECT_PATH" 2>/dev/null; then
    if git --git-dir="$BARE_REPO" cat-file -e "HEAD:$_UVLOCK_PATH" 2>/dev/null; then
        PKG_MANAGER="uv"
    elif git --git-dir="$BARE_REPO" cat-file -e "HEAD:$_POETRYLOCK_PATH" 2>/dev/null; then
        PKG_MANAGER="poetry"
    else
        PKG_MANAGER="pip"
    fi
fi

# Check for npm dependencies
HAS_NPM=false
if git --git-dir="$BARE_REPO" cat-file -e HEAD:package.json 2>/dev/null; then
    HAS_NPM=true
fi
for dir in widget frontend; do
    if git --git-dir="$BARE_REPO" cat-file -e "HEAD:$dir/package.json" 2>/dev/null; then
        HAS_NPM=true
        break
    fi
done
if [[ "$HAS_NPM" == "true" ]]; then
    if [[ -n "$PKG_MANAGER" ]]; then
        PKG_MANAGER="$PKG_MANAGER + npm"
    else
        PKG_MANAGER="npm"
    fi
fi

if [[ -n "$PKG_MANAGER" ]] && [[ "$SKIP_SYNC" == "false" ]]; then
    echo "  Package sync:  $PKG_MANAGER"
else
    echo "  Package sync:  (skipped)"
fi
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo ""

if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "Dry run - no changes made"
    exit 0
fi

# Execute
log_info "Creating worktree..."
# --force for main/master: allows both WSL and Mac to have wt-main simultaneously
FORCE_FLAG=""
if [[ "$BRANCH_NAME" == "main" || "$BRANCH_NAME" == "master" ]]; then
    FORCE_FLAG="--force"
fi
if [[ "$USE_EXISTING_BRANCH" == "true" ]]; then
    git --git-dir="$BARE_REPO" worktree add $FORCE_FLAG "$WORKTREE_DIR" "$BRANCH_NAME"
else
    git --git-dir="$BARE_REPO" worktree add $FORCE_FLAG -b "$BRANCH_NAME" "$WORKTREE_DIR"
fi
log_success "Worktree created at $WORKTREE_DIR"

# Copy files from secrets dir
if [[ ${#FILES_TO_COPY[@]} -gt 0 ]]; then
    log_info "Copying environment files from secrets..."
    for file in "${FILES_TO_COPY[@]}"; do
        src="$SECRETS_DIR/$file"
        dst="$WORKTREE_DIR/$file"

        # Ensure destination directory exists
        mkdir -p "$(dirname "$dst")"

        if [[ -f "$src" ]]; then
            cp "$src" "$dst"
            log_success "Copied $file"
        else
            log_warn "Skipped $file (not found)"
        fi
    done
fi

# Create config directory (required by Dockerfile but git-ignored)
log_info "Creating config directory..."
mkdir -p "$WORKTREE_DIR/config"
log_success "Created config/ directory"

# Sync dependencies
if [[ -n "$PKG_MANAGER" ]] && [[ "$SKIP_SYNC" == "false" ]]; then
    log_info "Syncing dependencies..."
    cd "$WORKTREE_DIR"

    if [[ "$PKG_MANAGER" == *"uv"* ]]; then
        if [[ -n "${SYNC_SUBDIR:-}" ]]; then
            uv sync --project "$SYNC_SUBDIR" && log_success "Python dependencies synced (uv)" || \
                log_warn "Python sync failed (uv) — continuing with remaining steps"
        else
            uv sync && log_success "Python dependencies synced (uv)" || \
                log_warn "Python sync failed (uv) — continuing with remaining steps"
        fi
    elif [[ "$PKG_MANAGER" == *"poetry"* ]]; then
        poetry install && log_success "Python dependencies synced (poetry)" || \
            log_warn "Python sync failed (poetry) — continuing with remaining steps"
    elif [[ "$PKG_MANAGER" == *"pip"* ]]; then
        pip install -r requirements.txt && log_success "Python dependencies synced (pip)" || \
            log_warn "Python sync failed (pip) — continuing with remaining steps"
    fi

    if [[ "$PKG_MANAGER" == *"npm"* ]]; then
        # Root package.json (e.g., puppeteer, dotenv for E2E tests)
        if [[ -f "$WORKTREE_DIR/package.json" ]]; then
            cd "$WORKTREE_DIR"
            npm install
            log_success "Node dependencies synced (root)"
        fi

        # Subdirectory package.json (widget, frontend)
        for dir in widget frontend; do
            if [[ -d "$WORKTREE_DIR/$dir" ]] && [[ -f "$WORKTREE_DIR/$dir/package.json" ]]; then
                cd "$WORKTREE_DIR/$dir"
                npm install
                log_success "Node dependencies synced ($dir)"
            fi
        done
    fi
fi

echo ""

# Register quick cd alias (branch name → worktree dir)
CD_QUICK_ALIASES_FILE="$HOME/.cd_quick_aliases"
if grep -q "^${BRANCH_NAME}=" "$CD_QUICK_ALIASES_FILE" 2>/dev/null; then
    sed -i '' "s|^${BRANCH_NAME}=.*|${BRANCH_NAME}=${WORKTREE_DIR}|" "$CD_QUICK_ALIASES_FILE" 2>/dev/null || \
    sed -i "s|^${BRANCH_NAME}=.*|${BRANCH_NAME}=${WORKTREE_DIR}|" "$CD_QUICK_ALIASES_FILE"
else
    echo "${BRANCH_NAME}=${WORKTREE_DIR}" >> "$CD_QUICK_ALIASES_FILE"
fi
log_success "CD alias registered: cd $BRANCH_NAME → $WORKTREE_DIR"

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo -e " ${GREEN}Worktree ready!${NC}"
echo "═══════════════════════════════════════════════════════════════"
echo ""

# ═══════════════════════════════════════════════════════════════
# Session Transplant: delegate to the transplant tool
# ═══════════════════════════════════════════════════════════════

if [[ "$NO_TRANSPLANT" == "true" ]]; then
    echo "  cd $WORKTREE_DIR"
elif command -v transplant &>/dev/null; then
    transplant "$WORKTREE_DIR" || echo "  cd $WORKTREE_DIR"
else
    log_warn "transplant tool not found — skipping session transplant"
    echo "  cd $WORKTREE_DIR"
fi
echo ""
