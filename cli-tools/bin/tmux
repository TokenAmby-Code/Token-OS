#!/usr/bin/env bash
# tmux — Imperium tmux shim
# TAGS: tmux, resolver, wrapper
# AUDIENCE: system, agent, user
#
# For pane-scoped tmux commands, this shim accepts Imperium stable pane ids
# (1:N, palace:N, somnium:SE, council:custodes) anywhere a %pane target is accepted.
# It resolves them live via tmuxctl, then execs the real tmux binary.

set -euo pipefail

_THIS="$(readlink -f "$0")"
_BIN_DIR="$(dirname "$_THIS")"
_TX_BIN="${_BIN_DIR}/tx"

# Hard recursion fuse — belt-and-suspenders, independent of resolution
# correctness. If the shim ever re-enters itself (a poisoned
# IMPERIUM_TMUX_BIN/REAL_TMUX pointing back at this script, a PATH loop, a
# self-referencing wrapper), this bounds the blast radius so it can never
# again exhaust the process table and brick the machine. The counter is
# exported so it survives BOTH exec re-entry and $(...) child invocations.
# In correct operation the shim never re-enters itself (real tmux is the
# resolved system binary), so depth stays at 1; a bound of 3 leaves slack
# for any benign one-level nesting while killing an exponential fork bomb
# almost immediately.
_IMPERIUM_TMUX_SHIM_MAX_DEPTH=3
# Validate the INHERITED counter and trip the fuse BEFORE incrementing. Three
# ways a poisoned value could otherwise defeat the guard, all failed closed:
#   1. non-digit / negative (e.g. -100) — never a valid counter.
#   2. oversized literal (e.g. 9223372036854775807) — `+1` would wrap to a
#      negative intmax_t and silently slip past the `> max` check. We reject by
#      DIGIT COUNT before any arithmetic, so an overflowing value never reaches
#      the numeric comparison.
#   3. already at/above the bound — we are genuinely re-entering.
#   4. leading-zero literal (e.g. 08/09) — bash arithmetic would parse it as
#      OCTAL, and under `set -e` an invalid octal digit aborts the script with
#      a raw bash error (rc!=70) instead of cleanly tripping the fuse. Every
#      arithmetic use of the inherited value is therefore forced to base 10
#      with `10#` so a digit-only counter is always read as decimal.
# Comparing the inherited value against max (rather than max+1 after a bump) is
# equivalent to the old post-increment `> max` test, and guarantees the `+1`
# below only ever runs on a small in-range value (<= max-1), so it cannot
# overflow.
_inherited_tmux_depth="${IMPERIUM_TMUX_SHIM_DEPTH:-0}"
case "$_inherited_tmux_depth" in
    (''|*[!0-9]*) _inherited_tmux_depth="" ;;   # mark invalid
esac
if [[ -z "$_inherited_tmux_depth" || ${#_inherited_tmux_depth} -gt 3 ]] \
   || (( 10#$_inherited_tmux_depth >= _IMPERIUM_TMUX_SHIM_MAX_DEPTH )); then
    printf 'tmux: FATAL recursion fuse tripped or invalid IMPERIUM_TMUX_SHIM_DEPTH=%s (max depth %s) — real tmux likely misresolved to this shim. Refusing to recurse to prevent a fork bomb.\n' \
        "${IMPERIUM_TMUX_SHIM_DEPTH:-}" "$_IMPERIUM_TMUX_SHIM_MAX_DEPTH" >&2
    exit 70
fi
IMPERIUM_TMUX_SHIM_DEPTH=$(( 10#$_inherited_tmux_depth + 1 ))
export IMPERIUM_TMUX_SHIM_DEPTH
unset _inherited_tmux_depth

find_real_tmux() {
    # A self-pointing override (IMPERIUM_TMUX_BIN/REAL_TMUX resolving to THIS
    # shim) must be REJECTED so resolution falls through to a real binary —
    # otherwise _REAL_TMUX becomes the shim and every invocation re-execs the
    # shim (the self-fork-bomb). Mirror the PATH-scan self-reference guard.
    if [[ -n "${IMPERIUM_TMUX_BIN:-}" && -x "${IMPERIUM_TMUX_BIN}" \
          && "$(readlink -f "${IMPERIUM_TMUX_BIN}")" != "$_THIS" ]]; then
        echo "${IMPERIUM_TMUX_BIN}"
        return 0
    fi
    if [[ -n "${REAL_TMUX:-}" && -x "${REAL_TMUX}" \
          && "$(readlink -f "${REAL_TMUX}")" != "$_THIS" ]]; then
        echo "${REAL_TMUX}"
        return 0
    fi
    local candidate
    while IFS= read -r candidate; do
        [[ -n "$candidate" ]] || continue
        if [[ "$(readlink -f "$candidate")" != "$_THIS" ]]; then
            echo "$candidate"
            return 0
        fi
    done < <(type -aP tmux 2>/dev/null || true)
    for candidate in /opt/homebrew/bin/tmux /usr/local/bin/tmux /usr/bin/tmux /bin/tmux; do
        if [[ -x "$candidate" && "$(readlink -f "$candidate")" != "$_THIS" ]]; then
            echo "$candidate"
            return 0
        fi
    done
    echo "tmux: real tmux binary not found" >&2
    return 127
}

_REAL_TMUX="$(find_real_tmux)"
export IMPERIUM_TMUX_BIN="$_REAL_TMUX"

is_launch_command() {
    if [[ $# -eq 0 ]]; then
        return 0
    fi
    case "$1" in
        attach|attach-session|new|new-session)
            return 0 ;;
        *)
            return 1 ;;
    esac
}

is_pane_command() {
    case "$1" in
        break-pane|capture-pane|display-message|join-pane|kill-pane|move-pane|pipe-pane|respawn-pane|resize-pane|select-pane|send-keys|split-window|swap-pane)
            return 0 ;;
        set-option|set|show-options|show)
            local arg
            for arg in "$@"; do
                [[ "$arg" == -* && "$arg" == *p* ]] && return 0
            done
            return 1 ;;
        *) return 1 ;;
    esac
}

looks_custom_target() {
    local target="$1" slot
    [[ -n "$target" && "$target" != %* ]] || return 1
    case "$target" in current|!|'{last}'|'{next}'|'{previous}') return 1 ;; esac
    [[ "$target" == *:* ]] || return 1
    slot="${target##*:}"
    [[ -n "$slot" && ! "$slot" =~ ^[0-9]+$ && "$slot" =~ ^[A-Za-z][A-Za-z0-9_-]*$ ]]
    local left="${target%%:*}"
    [[ "$left" =~ ^[0-9]+$ || "$left" =~ ^(palace|somnium|legion|mechanicus|reservists|mars|kreig|tui)$ ]]
}

resolve_target() {
    local target="$1" resolved
    if ! looks_custom_target "$target"; then
        printf '%s\n' "$target"
        return 0
    fi
    if resolved=$("${_BIN_DIR}/tmux-resolve-pane" --format physical "$target" 2>/dev/null); then
        if [[ -n "$resolved" ]]; then
            printf '%s\n' "$resolved"
            return 0
        fi
    fi
    echo "tmux: pane target not found: $target" >&2
    return 1
}

# Universal send gate (shell entrypoint). This shim is the chokepoint every bare
# `tmux send-keys` in the repo resolves to via PATH, so gating here closes the
# shell escape hatch around TmuxAdapter.run()'s Python gate — together they make
# the sentinel inescapable across both languages. Only the mutating send verbs
# are gated (reads pass through). Sanctioned direct-input sends
# (TMUX_SEND_GATE_ALLOW set, optionally TMUX_SEND_GATE_POLICY=pierce) are still
# routed through the canonical predicate so the override is allowed AND audited
# (send_gate_override) — never silently bypassed. Typing-guarded automation
# delays by default; cancellation is explicit policy or quiet-hours default. Any
# check error fails open so a transient fault never bricks all pane writes.
# Returns 0 (true) only to CANCEL/SUPPRESS.
send_gate_suppresses() {
    case "${1:-}" in
        send-keys|send-key|send|paste-buffer) ;;
        *) return 1 ;;  # not a mutating send verb — never gated
    esac
    local lib_dir rc=0
    lib_dir="$(cd "${_BIN_DIR}/../lib" 2>/dev/null && pwd)" || return 1
    # TMUX_SEND_GATE_ALLOW (if set) is inherited by the child, which logs the
    # override and returns allow (rc 0); only rc 100 means suppress.
    PYTHONPATH="${lib_dir}${PYTHONPATH:+:$PYTHONPATH}" \
        python3 -m tmuxctl.send_gate check "$@" >/dev/null 2>&1 || rc=$?
    [[ "$rc" -eq 100 ]]
}

inbound_typing_guard_allows() {
    case "${1:-}" in
        send-keys|send-key|send) ;;
        *) return 0 ;;
    esac
    [[ "${TMUX_GUARD_SKIP:-}" == "1" ]] && return 0

    local target
    target="$(extract_target_flag -t "$@" 2>/dev/null || true)"
    if [[ -z "$target" ]]; then
        target="${TMUX_PANE:-}"
    fi
    [[ -n "$target" ]] || return 0

    local lib_dir
    lib_dir="$(cd "${_BIN_DIR}/../lib" 2>/dev/null && pwd)" || return 0
    # shellcheck disable=SC1091
    TMUX_GUARD_REAL_TMUX="$_REAL_TMUX" source "${lib_dir}/tmux-guard.sh" || return 0
    tmux_wait_for_clear "$target" "${TMUX_GUARD_TIMEOUT:-0}"
}

sanitize_pane_ids() {
    local lib_dir
    lib_dir="$(cd "${_BIN_DIR}/../lib" 2>/dev/null && pwd)" || {
        # Fail closed: if tmuxctl cannot be located, raw pane ids still must not
        # reach a human surface.
        perl -pe 's/%[0-9]+/unresolved/g'
        return 0
    }
    PYTHONPATH="${lib_dir}${PYTHONPATH:+:$PYTHONPATH}" \
        IMPERIUM_TMUX_BIN="$_REAL_TMUX" \
        python3 -m tmuxctl.cli translate-ids 2>/dev/null || \
        perl -pe 's/%[0-9]+/unresolved/g'
}

is_read_command_with_pane_ids() {
    [[ $# -gt 0 ]] || return 1
    case "$1" in
        capture-pane|capturep)
            # Captured agent transcripts are human-readable surfaces and may
            # include earlier leaked %pane ids; always sanitize them.
            return 0 ;;
        list-panes|lsp|list-windows|lsw|list-sessions|ls)
            # Default list-panes output includes raw tmux pane ids, and the
            # other listing commands are human id-printing surfaces. Always
            # pass them through the public-id sanitizer.
            return 0 ;;
        display-message|display)
            # `display-message` has two distinct uses, and only one is a leak
            # surface:
            #   * Human-facing — a status-line message (or a print) whose format
            #     embeds a %pane id inside descriptive text. Sanitize to public
            #     ids so raw %ids never reach a human.
            #   * Programmatic — `display-message -p '#{pane_id}'` (or #D /
            #     #{window_id} / #{session_id}) fetches a RAW machine id on
            #     stdout for immediate reuse as a `-t` target (e.g.
            #     tmux-grid-expand resolving its own pane). Rewriting that pure
            #     id to a public id yields an unresolvable target
            #     ("can't find session: council"), so it MUST pass through
            #     untranslated.
            # Parse just enough to isolate the format string and the print flag,
            # then exempt ONLY the pure-id print form: -p present, the format is
            # exactly one id token, nothing embedded.
            local arg fmt="" has_print=0 want=""
            for arg in "$@"; do
                if [[ -n "$want" ]]; then
                    [[ "$want" == -F ]] && fmt="$arg"
                    want=""
                    continue
                fi
                case "$arg" in
                    -c|-d|-t|-F) want="$arg" ;;          # consumes the next arg
                    -F?*) fmt="${arg#-F}" ;;             # -F<format> combined
                    -c?*|-d?*|-t?*) : ;;                 # opt+value combined
                    -p) has_print=1 ;;
                    -*p*) has_print=1 ;;                 # clustered flags w/ p
                    -*) : ;;                             # other flags (-a/-l/-v…)
                    *) fmt="$arg" ;;                     # positional = format
                esac
            done
            case "$fmt" in
                '#{pane_id}'|'#D'|'#{window_id}'|'#{session_id}')
                    # Pure id token: raw on stdout when printed (programmatic),
                    # otherwise a human status-line render.
                    (( has_print )) && return 1
                    return 0 ;;
                *'#{pane_id}'*|*'#D'*|*'#{window_id}'*|*'#{session_id}'*)
                    return 0 ;;                          # id embedded in text
            esac
            return 1 ;;
        *) return 1 ;;
    esac
}

extract_target_flag() {
    local flag="$1"; shift
    local arg
    while [[ $# -gt 0 ]]; do
        arg="$1"
        if [[ "$arg" == "$flag" && $# -gt 1 ]]; then
            printf '%s' "$2"
            return 0
        fi
        if [[ "$arg" == "$flag"* && "$arg" != "$flag" ]]; then
            printf '%s' "${arg#"$flag"}"
            return 0
        fi
        shift
    done
    return 1
}

runtime_invariant_preflight() {
    [[ $# -gt 0 ]] || return 0
    local command="$1" target="" opt="" arg
    case "$command" in
        respawn-pane)
            target="$(extract_target_flag -t "$@" 2>/dev/null || true)"
            [[ -n "$target" ]] || target="$TMUX_PANE"
            [[ -n "$target" ]] || return 0
            IMPERIUM_TMUX_AUTOMATION=1 "${_BIN_DIR}/tmuxctl" clear-runtime --pane "$target" >/dev/null 2>&1 || true
            ;;
        set-option|set)
            local pane_scope=0 unset_scope=0
            for arg in "$@"; do
                [[ "$arg" == -* && "$arg" == *p* ]] && pane_scope=1
                [[ "$arg" == -* && "$arg" == *u* ]] && unset_scope=1
            done
            [[ "$pane_scope" == 1 && "$unset_scope" == 1 ]] || return 0
            opt="${@: -1}"
            [[ "$opt" == "@INSTANCE_ID" ]] || return 0
            target="$(extract_target_flag -t "$@" 2>/dev/null || true)"
            [[ -n "$target" ]] || target="$TMUX_PANE"
            [[ -n "$target" ]] || return 0
            # clear-runtime clears pane tint/title before unsetting @INSTANCE_ID.
            IMPERIUM_TMUX_AUTOMATION=1 "${_BIN_DIR}/tmuxctl" clear-runtime --pane "$target" >/dev/null 2>&1 || true
            ;;
    esac
}

if [[ "${IMPERIUM_TMUX_RAW:-}" != "1" ]] && is_launch_command "$@"; then
    exec "$_TX_BIN" start
fi

if [[ $# -gt 0 && "${IMPERIUM_TMUX_RAW:-}" == "1" ]]; then
    if ! inbound_typing_guard_allows "$@"; then
        exit 1
    fi
fi

if [[ $# -gt 0 && "${IMPERIUM_TMUX_RAW:-}" != "1" ]] && is_pane_command "$@"; then
    args=("$@")
    i=1
    while (( i < ${#args[@]} )); do
        if [[ "${args[$i]}" == "-t" || "${args[$i]}" == "-s" ]]; then
            if (( i + 1 < ${#args[@]} )); then
                args[$((i+1))]="$(resolve_target "${args[$((i+1))]}")"
            fi
            i=$((i+2))
        elif [[ "${args[$i]}" == -t* && "${args[$i]}" != "-t" ]]; then
            args[$i]="-t$(resolve_target "${args[$i]#-t}")"
            i=$((i+1))
        elif [[ "${args[$i]}" == -s* && "${args[$i]}" != "-s" ]]; then
            args[$i]="-s$(resolve_target "${args[$i]#-s}")"
            i=$((i+1))
        else
            i=$((i+1))
        fi
    done
    if send_gate_suppresses "${args[@]}"; then
        exit 0  # cancel policy (e.g. quiet hours): no PTY write
    fi
    if is_read_command_with_pane_ids "${args[@]}"; then
        "$_REAL_TMUX" "${args[@]}" | sanitize_pane_ids
        exit "${PIPESTATUS[0]}"
    fi
    runtime_invariant_preflight "${args[@]}"
    exec "$_REAL_TMUX" "${args[@]}"
fi

if [[ "${IMPERIUM_TMUX_RAW:-}" != "1" ]] && is_read_command_with_pane_ids "$@"; then
    "$_REAL_TMUX" "$@" | sanitize_pane_ids
    exit "${PIPESTATUS[0]}"
fi

exec "$_REAL_TMUX" "$@"
