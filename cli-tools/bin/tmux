#!/usr/bin/env bash
# tmux — Imperium tmux shim
# TAGS: tmux, resolver, wrapper
# AUDIENCE: system, agent, user
#
# For pane-scoped tmux commands, this shim accepts Imperium stable pane ids
# (1:N, palace:N, somnium:SE, legion:custodes) anywhere a %pane target is accepted.
# It resolves them live via tmuxctl, then execs the real tmux binary.

set -euo pipefail

_THIS="$(readlink -f "$0")"
_BIN_DIR="$(dirname "$_THIS")"
_TX_BIN="${_BIN_DIR}/tx"
find_real_tmux() {
    if [[ -n "${IMPERIUM_TMUX_BIN:-}" && -x "${IMPERIUM_TMUX_BIN}" ]]; then
        echo "${IMPERIUM_TMUX_BIN}"
        return 0
    fi
    if [[ -n "${REAL_TMUX:-}" && -x "${REAL_TMUX}" ]]; then
        echo "${REAL_TMUX}"
        return 0
    fi
    local candidate
    while IFS= read -r candidate; do
        [[ -n "$candidate" ]] || continue
        if [[ "$(readlink -f "$candidate")" != "$_THIS" ]]; then
            echo "$candidate"
            return 0
        fi
    done < <(command -v -a tmux 2>/dev/null || true)
    for candidate in /opt/homebrew/bin/tmux /usr/local/bin/tmux /usr/bin/tmux /bin/tmux; do
        if [[ -x "$candidate" && "$(readlink -f "$candidate")" != "$_THIS" ]]; then
            echo "$candidate"
            return 0
        fi
    done
    echo "tmux: real tmux binary not found" >&2
    return 127
}

_REAL_TMUX="$(find_real_tmux)"
export IMPERIUM_TMUX_BIN="$_REAL_TMUX"

is_launch_command() {
    if [[ $# -eq 0 ]]; then
        return 0
    fi
    case "$1" in
        attach|attach-session|new|new-session)
            return 0 ;;
        *)
            return 1 ;;
    esac
}

is_pane_command() {
    case "$1" in
        break-pane|capture-pane|display-message|join-pane|kill-pane|move-pane|pipe-pane|respawn-pane|resize-pane|select-pane|send-keys|split-window|swap-pane)
            return 0 ;;
        set-option|set|show-options|show)
            local arg
            for arg in "$@"; do
                [[ "$arg" == -* && "$arg" == *p* ]] && return 0
            done
            return 1 ;;
        *) return 1 ;;
    esac
}

looks_custom_target() {
    local target="$1" slot
    [[ -n "$target" && "$target" != %* ]] || return 1
    case "$target" in current|!|'{last}'|'{next}'|'{previous}') return 1 ;; esac
    [[ "$target" == *:* ]] || return 1
    slot="${target##*:}"
    [[ -n "$slot" && ! "$slot" =~ ^[0-9]+$ && "$slot" =~ ^[A-Za-z][A-Za-z0-9_-]*$ ]]
    local left="${target%%:*}"
    [[ "$left" =~ ^[0-9]+$ || "$left" =~ ^(palace|somnium|legion|mechanicus|mars|kreig)$ ]]
}

resolve_target() {
    local target="$1" resolved
    if ! looks_custom_target "$target"; then
        printf '%s\n' "$target"
        return 0
    fi
    if resolved=$("${_BIN_DIR}/tmux-resolve-pane" --format id "$target" 2>/dev/null); then
        if [[ -n "$resolved" ]]; then
            printf '%s\n' "$resolved"
            return 0
        fi
    fi
    echo "tmux: pane target not found: $target" >&2
    return 1
}

# Universal send gate (shell entrypoint). This shim is the chokepoint every bare
# `tmux send-keys` in the repo resolves to via PATH, so gating here closes the
# shell escape hatch around TmuxAdapter.run()'s Python gate — together they make
# the sentinel inescapable across both languages. Only the mutating send verbs
# are gated (reads pass through). Sanctioned human-initiated sends
# (TMUX_SEND_GATE_ALLOW set) are still routed through the canonical predicate so
# the override is allowed AND audited (send_gate_override) — never silently
# bypassed. Any check error fails open so a transient fault never bricks all
# pane writes. Returns 0 (true) to SUPPRESS.
send_gate_suppresses() {
    case "${1:-}" in
        send-keys|send-key|send|paste-buffer) ;;
        *) return 1 ;;  # not a mutating send verb — never gated
    esac
    local lib_dir rc=0
    lib_dir="$(cd "${_BIN_DIR}/../lib" 2>/dev/null && pwd)" || return 1
    # TMUX_SEND_GATE_ALLOW (if set) is inherited by the child, which logs the
    # override and returns allow (rc 0); only rc 100 means suppress.
    PYTHONPATH="${lib_dir}${PYTHONPATH:+:$PYTHONPATH}" \
        python3 -m tmuxctl.send_gate check "$@" >/dev/null 2>&1 || rc=$?
    [[ "$rc" -eq 100 ]]
}

if [[ "${IMPERIUM_TMUX_RAW:-}" != "1" ]] && is_launch_command "$@"; then
    exec "$_TX_BIN" start
fi

if [[ $# -gt 0 && "${IMPERIUM_TMUX_RAW:-}" != "1" ]] && is_pane_command "$@"; then
    args=("$@")
    i=1
    while (( i < ${#args[@]} )); do
        if [[ "${args[$i]}" == "-t" || "${args[$i]}" == "-s" ]]; then
            if (( i + 1 < ${#args[@]} )); then
                args[$((i+1))]="$(resolve_target "${args[$((i+1))]}")"
            fi
            i=$((i+2))
        elif [[ "${args[$i]}" == -t* && "${args[$i]}" != "-t" ]]; then
            args[$i]="-t$(resolve_target "${args[$i]#-t}")"
            i=$((i+1))
        elif [[ "${args[$i]}" == -s* && "${args[$i]}" != "-s" ]]; then
            args[$i]="-s$(resolve_target "${args[$i]#-s}")"
            i=$((i+1))
        else
            i=$((i+1))
        fi
    done
    if send_gate_suppresses "${args[@]}"; then
        exit 0  # quiet hours OR typing guard active — silent no-op, no PTY write
    fi
    exec "$_REAL_TMUX" "${args[@]}"
fi

exec "$_REAL_TMUX" "$@"
