#!/usr/bin/env bash
# deploy-mac - Mac-native deploy (no WSL required)
# TAGS: deploy, mac
# AUDIENCE: human, agent
#
# Forks the WSL deploy workflow for Mac. Uses Homebrew gcloud/gsutil.
# Does NOT modify the Makefile or the WSL deploy path.
#
# Usage:
#   deploy-mac                    # Deploy backend to dev
#   deploy-mac backend            # Deploy backend to dev
#   deploy-mac backend prod       # Deploy backend to production
#   deploy-mac web                # Deploy widget to dev
#   deploy-mac web prod           # Deploy widget to production
#   deploy-mac widget-proxy       # Deploy widget proxy to dev
#   deploy-mac chat-proxy         # Deploy chat proxy to dev
#   deploy-mac proxies            # Deploy both proxies to dev
#   deploy-mac backend -p         # Skip docker build, push last image
#   deploy-mac backend -y         # Skip build + push, deploy last pushed
#
# Prerequisites:
#   brew install --cask google-cloud-sdk
#   gcloud auth activate-service-account --key-file=deploy/dev-service-account.json

set -euo pipefail

# ── Mac gcloud/gsutil PATH ────────────────────────────────────────────────────
GCLOUD=/opt/homebrew/bin/gcloud
_GSUTIL=/opt/homebrew/bin/gsutil
export CLOUDSDK_PYTHON=/opt/homebrew/opt/python@3.13/bin/python3.13
# gsutil on macOS hits a Python 3 multiprocessing bug (sys.maxint removed in Py3).
# Disable parallel process count to avoid it; -m (multithreading) still works.
gsutil() { "$_GSUTIL" -o "GSUtil:parallel_process_count=1" "$@"; }

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ── Config (mirrors Makefile variables) ───────────────────────────────────────
# Web
WEB_BUCKET_DEV="askcivic-site-dev"
WEB_BUCKET_PROD="askcivic-site"
URL_MAP_DEV="askcivic-map"
URL_MAP_PROD="askcivic-map"
SITE_URL_DEV="https://dev.askcivic.com"
SITE_URL_PROD="https://askcivic.com"
CDN_PROJECT="pax-dev-469018"

# Backend
BACKEND_IMAGE_DEV="gcr.io/pax-dev-469018/pax-chat-image"
BACKEND_IMAGE_PROD="gcr.io/pax-prod-467920/pax-chat-image"
BACKEND_CONFIG_DEV="deploy/pax-development.yaml"
BACKEND_CONFIG_PROD="deploy/pax-production.yaml"

# Proxies (both use same image name per env, different configs/services)
PROXY_IMAGE_DEV="gcr.io/pax-dev-469018/pax-widget-proxy"
PROXY_IMAGE_PROD="gcr.io/pax-prod-467920/pax-widget-proxy"
WP_CONFIG_DEV="deploy/pax-widget-proxy-development.yaml"
WP_CONFIG_PROD="deploy/pax-widget-proxy-production.yaml"
CP_CONFIG_DEV="deploy/pax-google-chat-proxy-development.yaml"
CP_CONFIG_PROD="deploy/pax-google-chat-proxy-production.yaml"

usage() {
    cat << 'EOF'
deploy-mac - Mac-native deploy (no WSL required)

Usage:
  deploy-mac                    Deploy backend to dev (default)
  deploy-mac backend            Deploy backend to dev
  deploy-mac backend prod       Deploy backend to production
  deploy-mac web                Deploy widget to dev
  deploy-mac web prod           Deploy widget to production
  deploy-mac widget-proxy       Deploy widget proxy to dev
  deploy-mac chat-proxy         Deploy chat proxy to dev
  deploy-mac proxies            Deploy both proxies to dev
  deploy-mac proxies prod       Deploy both proxies to production

Options:
  -p, --skip-build    Skip docker build, push last built image
  -y, --skip-push     Skip build + push, deploy with last pushed image
  -ft                 Run user cleanup (cmlanier) async during deploy
  --prod              Deploy to production environment

Prerequisites:
  brew install --cask google-cloud-sdk
  Docker Desktop must be running (for backend/proxy deploys)
  gcloud auth activate-service-account --key-file=deploy/dev-service-account.json
EOF
    exit 0
}

# ── Parse args ────────────────────────────────────────────────────────────────
SERVICE=""
ENV="development"
SKIP_BUILD=false
SKIP_PUSH=false
RUN_FT=false

for arg in "$@"; do
    case "$arg" in
        -h|--help) usage ;;
        web|frontend) SERVICE="web" ;;
        backend) SERVICE="backend" ;;
        widget-proxy) SERVICE="widget-proxy" ;;
        chat-proxy) SERVICE="chat-proxy" ;;
        proxies) SERVICE="proxies" ;;
        prod|production|--prod) ENV="production" ;;
        dev|development) ENV="development" ;;
        -p|--skip-build) SKIP_BUILD=true ;;
        -y|--skip-push) SKIP_PUSH=true; SKIP_BUILD=true ;;
        -ft) RUN_FT=true ;;
        *)
            echo "Unknown argument: $arg" >&2
            echo "Use --help for usage" >&2
            exit 1
            ;;
    esac
done

# Default service is backend
if [[ -z "$SERVICE" ]]; then
    SERVICE="backend"
fi

# ── Locate project root ───────────────────────────────────────────────────────
GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "Error: must be run from within a git repository" >&2
    exit 1
}

# ── Pre-flight checks ─────────────────────────────────────────────────────────
if [[ ! -x "$GCLOUD" ]]; then
    echo -e "${RED}❌ gcloud not found at $GCLOUD${NC}"
    echo "  Run: brew install --cask google-cloud-sdk"
    exit 1
fi

# Resolve env-specific service account
if [[ "$ENV" == "production" ]]; then
    SA_KEY="$GIT_ROOT/deploy/prod-service-account.json"
    PROJECT="pax-prod-467920"
else
    SA_KEY="$GIT_ROOT/deploy/dev-service-account.json"
    PROJECT="pax-dev-469018"
fi

if [[ ! -f "$SA_KEY" ]]; then
    echo -e "${RED}❌ Service account key not found: $SA_KEY${NC}"
    exit 1
fi

# Activate service account (idempotent)
"$GCLOUD" auth activate-service-account --key-file="$SA_KEY" --quiet 2>/dev/null

# ── User cleanup (-ft) ────────────────────────────────────────────────────────
FT_PID=""
if [[ "$RUN_FT" == "true" ]]; then
    FT_ENV="dev"
    [[ "$ENV" == "production" ]] && FT_ENV="prod"
    echo "Starting user cleanup (async, env=$FT_ENV)..."
    cd "$GIT_ROOT"
    UV_NO_SYNC=1 uv run scripts/user_cleanup.py cmlanier@civicinitiatives.com --env "$FT_ENV" &
    FT_PID=$!
fi

wait_for_ft() {
    if [[ -n "$FT_PID" ]]; then
        echo ""
        if wait "$FT_PID" 2>/dev/null; then
            echo -e "${GREEN}User cleanup completed${NC}"
        else
            echo -e "${RED}WARNING: User cleanup failed (exit $?)${NC}"
        fi
    fi
}

# ── Docker pre-flight (for backend/proxy) ─────────────────────────────────────
require_docker() {
    if ! docker info >/dev/null 2>&1; then
        echo -e "${RED}❌ Docker is not running${NC}"
        echo "  Start Docker Desktop and try again"
        exit 1
    fi
}

# ── deploy_backend ────────────────────────────────────────────────────────────
deploy_backend() {
    local image config
    if [[ "$ENV" == "production" ]]; then
        image="$BACKEND_IMAGE_PROD"
        config="$GIT_ROOT/$BACKEND_CONFIG_PROD"
    else
        image="$BACKEND_IMAGE_DEV"
        config="$GIT_ROOT/$BACKEND_CONFIG_DEV"
    fi

    if [[ ! -f "$config" ]]; then
        echo -e "${RED}❌ Config not found: $config${NC}"
        exit 1
    fi

    require_docker

    echo -e "${YELLOW}🚀 Deploying backend to $ENV${NC}"

    # Build
    if [[ "$SKIP_BUILD" == "false" ]]; then
        echo -e "${YELLOW}🛠  Building docker image (linux/amd64)...${NC}"
        docker build --platform linux/amd64 --target runtime \
            -f "$GIT_ROOT/deploy/Dockerfile" \
            -t "$image:latest" \
            "$GIT_ROOT"
    else
        echo -e "${YELLOW}⏭  Skipping build (using last built image)${NC}"
    fi

    # Push
    if [[ "$SKIP_PUSH" == "false" ]]; then
        echo -e "${YELLOW}📤 Configuring docker auth + pushing...${NC}"
        "$GCLOUD" auth configure-docker gcr.io --quiet
        docker push "$image:latest"
    else
        echo -e "${YELLOW}⏭  Skipping push (using last pushed image)${NC}"
    fi

    # Get digest
    echo -e "${YELLOW}🔍 Getting image digest...${NC}"
    local digest
    digest=$("$GCLOUD" container images describe "$image:latest" \
        --format='value(image_summary.digest)')
    echo "  Digest: $digest"

    # Create temp config with pinned digest
    local temp_config
    temp_config=$(mktemp -t deploy-yaml)
    sed "s|$image:latest|$image@$digest|g" "$config" > "$temp_config"

    # Deploy
    echo -e "${YELLOW}🚀 Deploying to Cloud Run...${NC}"
    "$GCLOUD" run services replace "$temp_config" \
        --region us-central1 --platform managed --project "$PROJECT"

    # Cleanup
    rm -f "$temp_config"

    echo -e "${GREEN}✅ Backend deployed to $ENV${NC}"
}

# ── deploy_proxy ──────────────────────────────────────────────────────────────
deploy_proxy() {
    local service_name="$1"
    local config="$2"
    local image="$3"

    if [[ ! -f "$config" ]]; then
        echo -e "${RED}❌ Config not found: $config${NC}"
        exit 1
    fi

    require_docker

    echo -e "${YELLOW}🚀 Deploying $service_name to $ENV${NC}"

    # Build
    if [[ "$SKIP_BUILD" == "false" ]]; then
        echo -e "${YELLOW}🛠  Building docker image (linux/amd64)...${NC}"
        docker build --platform linux/amd64 \
            -f "$GIT_ROOT/deploy/Dockerfile.proxy" \
            -t "$image:latest" \
            "$GIT_ROOT"
    else
        echo -e "${YELLOW}⏭  Skipping build (using last built image)${NC}"
    fi

    # Push
    if [[ "$SKIP_PUSH" == "false" ]]; then
        echo -e "${YELLOW}📤 Configuring docker auth + pushing...${NC}"
        "$GCLOUD" auth configure-docker gcr.io --quiet
        docker push "$image:latest"
    else
        echo -e "${YELLOW}⏭  Skipping push (using last pushed image)${NC}"
    fi

    # Get digest
    echo -e "${YELLOW}🔍 Getting image digest...${NC}"
    local digest
    digest=$("$GCLOUD" container images describe "$image:latest" \
        --format='value(image_summary.digest)')
    echo "  Digest: $digest"

    # Create temp config with pinned digest
    local temp_config
    temp_config=$(mktemp -t deploy-yaml)
    sed "s|$image:latest|$image@$digest|g" "$config" > "$temp_config"

    # Deploy
    echo -e "${YELLOW}🚀 Deploying to Cloud Run...${NC}"
    "$GCLOUD" run services replace "$temp_config" \
        --region us-central1 --platform managed --project "$PROJECT"

    # IAM: ensure public access
    # Extract service name from the YAML (metadata.name field)
    local cr_service
    cr_service=$(grep -E '^\s+name:' "$config" | head -1 | awk '{print $2}')
    if [[ -n "$cr_service" ]]; then
        echo -e "${YELLOW}🔓 Setting IAM for public access...${NC}"
        "$GCLOUD" run services add-iam-policy-binding "$cr_service" \
            --region us-central1 --project "$PROJECT" \
            --member="allUsers" --role="roles/run.invoker" --quiet 2>/dev/null || true
    fi

    # Cleanup
    rm -f "$temp_config"

    echo -e "${GREEN}✅ $service_name deployed to $ENV${NC}"
}

# ── deploy_web ────────────────────────────────────────────────────────────────
deploy_web() {
    if [[ ! -f "$GIT_ROOT/widget/package.json" ]]; then
        echo -e "${RED}❌ widget/package.json not found in $GIT_ROOT${NC}"
        echo "Run deploy-mac from within the askCivic worktree"
        exit 1
    fi

    local mode bucket url_map site_url
    if [[ "$ENV" == "production" ]]; then
        mode="production"
        bucket="$WEB_BUCKET_PROD"
        url_map="$URL_MAP_PROD"
        site_url="$SITE_URL_PROD"
    else
        mode="development"
        bucket="$WEB_BUCKET_DEV"
        url_map="$URL_MAP_DEV"
        site_url="$SITE_URL_DEV"
    fi

    local cdn_host="${site_url#https://}"
    cdn_host="${cdn_host#http://}"
    cdn_host="${cdn_host%%/*}"

    # ── Build ─────────────────────────────────────────────────────────────────
    echo -e "${YELLOW}🚀 Building widget bundle for $mode (bucket: gs://$bucket)...${NC}"

    cd "$GIT_ROOT/widget"

    echo -e "${YELLOW}🛠  Running Vite app build (mode=$mode)...${NC}"
    npx vite build --mode "$mode"

    echo -e "${YELLOW}🔄 Running post-build...${NC}"
    node post-build.js

    echo -e "${YELLOW}🧱 Building embeddable widget (mode=$mode)...${NC}"
    BUILD_MODE=lib npx vite build --mode "$mode"

    # Verify bundle contains expected API URL
    echo "Verifying build environment..."
    local expected_host
    expected_host=$(grep -E '^VITE_API_URL=' ".env.$mode" | sed 's|.*://||')
    if [[ -z "$expected_host" ]]; then
        echo -e "${RED}❌ Cannot read VITE_API_URL from widget/.env.$mode${NC}"
        exit 1
    fi
    if ! grep -rq "$expected_host" dist/app/assets/; then
        echo -e "${RED}❌ Bundle does not contain expected API URL: $expected_host${NC}"
        local actual
        actual=$(grep -roh 'pax-widget-proxy-[0-9]*' dist/app/assets/ 2>/dev/null | head -1 || true)
        echo "  Found in bundle: ${actual:-none}"
        exit 1
    fi
    echo -e "${GREEN}  Build verified: $expected_host${NC}"

    # ── Upload ────────────────────────────────────────────────────────────────
    echo -e "${YELLOW}📤 Deploying assets with long cache (1 year)...${NC}"
    gsutil -h "Cache-Control:public, max-age=31536000, immutable" -m rsync -r dist/app/assets/ "gs://$bucket/assets/"

    echo -e "${YELLOW}📤 Deploying HTML files with short cache (60s)...${NC}"
    while IFS= read -r f; do
        local rel_path="${f#dist/app/}"
        gsutil -h "Cache-Control:public, max-age=60, must-revalidate" cp "$f" "gs://$bucket/$rel_path"
    done < <(find dist/app -name "*.html")

    echo -e "${YELLOW}📤 Deploying other files...${NC}"
    while IFS= read -r f; do
        local rel_path="${f#dist/app/}"
        gsutil cp "$f" "gs://$bucket/$rel_path"
    done < <(find dist/app -type f -not -name "*.html" -not -path "*/assets/*")

    # ── SPA routing ───────────────────────────────────────────────────────────
    echo -e "${YELLOW}🔧 Configuring SPA routing on gs://$bucket...${NC}"
    gsutil web set -m index.html -e index.html "gs://$bucket" 2>&1 || \
        echo -e "${YELLOW}  ⚠️  SPA routing config skipped (already set or insufficient perms)${NC}"

    # ── CDN invalidation ──────────────────────────────────────────────────────
    if "$GCLOUD" --project "$CDN_PROJECT" compute url-maps describe "$url_map" >/dev/null 2>&1; then
        echo -e "${YELLOW}🔄 Invalidating CDN cache for $url_map (host=$cdn_host)...${NC}"
        "$GCLOUD" --project "$CDN_PROJECT" compute url-maps invalidate-cdn-cache "$url_map" --path '/*' --host "$cdn_host"
    else
        echo -e "${YELLOW}⚠️  URL map $url_map not found; skipping CDN invalidation${NC}"
    fi

    # ── Verify CDN propagation ────────────────────────────────────────────────
    echo -e "${YELLOW}🔍 Verifying CDN propagation at $site_url ...${NC}"
    local gcs_gen
    gcs_gen=$(gsutil stat "gs://$bucket/index.html" 2>/dev/null | grep 'Generation:' | awk '{print $2}')
    if [[ -z "$gcs_gen" ]]; then
        echo -e "${RED}❌ Could not read GCS generation for gs://$bucket/index.html${NC}"
        exit 1
    fi
    echo "  GCS generation: $gcs_gen"

    local attempts=0
    local max_attempts=12
    while [[ $attempts -lt $max_attempts ]]; do
        local cdn_gen
        cdn_gen=$(curl -sI "$site_url/" 2>/dev/null | grep -i 'x-goog-generation:' | awk '{print $2}' | tr -d '\r')
        if [[ "$cdn_gen" == "$gcs_gen" ]]; then
            echo -e "${GREEN}  CDN generation matches after $((attempts * 10))s${NC}"
            break
        fi
        attempts=$((attempts + 1))
        if [[ $attempts -eq $max_attempts ]]; then
            echo -e "${RED}❌ CDN still stale after 120s${NC}"
            echo "  Expected: $gcs_gen  CDN: ${cdn_gen:-none}"
            echo -e "${YELLOW}  Try: $GCLOUD compute url-maps invalidate-cdn-cache $url_map --path '/*' --host $cdn_host --project $CDN_PROJECT${NC}"
            exit 1
        fi
        echo "  Waiting for CDN... (attempt $attempts/$max_attempts, CDN gen: ${cdn_gen:-none})"
        sleep 10
    done

    echo -e "${GREEN}✅ Website deployed and verified at $site_url${NC}"
}

# ── Service dispatch ──────────────────────────────────────────────────────────
case "$SERVICE" in
    backend)
        deploy_backend
        wait_for_ft
        ;;
    web)
        deploy_web
        wait_for_ft
        ;;
    widget-proxy)
        if [[ "$ENV" == "production" ]]; then
            deploy_proxy "widget-proxy" "$GIT_ROOT/$WP_CONFIG_PROD" "$PROXY_IMAGE_PROD"
        else
            deploy_proxy "widget-proxy" "$GIT_ROOT/$WP_CONFIG_DEV" "$PROXY_IMAGE_DEV"
        fi
        wait_for_ft
        ;;
    chat-proxy)
        if [[ "$ENV" == "production" ]]; then
            deploy_proxy "chat-proxy" "$GIT_ROOT/$CP_CONFIG_PROD" "$PROXY_IMAGE_PROD"
        else
            deploy_proxy "chat-proxy" "$GIT_ROOT/$CP_CONFIG_DEV" "$PROXY_IMAGE_DEV"
        fi
        wait_for_ft
        ;;
    proxies)
        if [[ "$ENV" == "production" ]]; then
            deploy_proxy "widget-proxy" "$GIT_ROOT/$WP_CONFIG_PROD" "$PROXY_IMAGE_PROD"
            deploy_proxy "chat-proxy" "$GIT_ROOT/$CP_CONFIG_PROD" "$PROXY_IMAGE_PROD"
        else
            deploy_proxy "widget-proxy" "$GIT_ROOT/$WP_CONFIG_DEV" "$PROXY_IMAGE_DEV"
            deploy_proxy "chat-proxy" "$GIT_ROOT/$CP_CONFIG_DEV" "$PROXY_IMAGE_DEV"
        fi
        wait_for_ft
        ;;
esac
