#!/usr/bin/env python3
# token-status - Quick Token-API status check
# TAGS: token-api
# AUDIENCE: human, agent
"""Quick Token-API status check without launching full TUI.

Usage:
    token-status              # Show active instances and server health
    token-status --watch      # Continuous monitoring (2s refresh)
    token-status --json       # JSON output
"""

import json
import os
import sys
import urllib.parse
import urllib.request
from datetime import datetime

API_URL = os.environ.get("TOKEN_API_URL", "http://localhost:7777").rstrip("/")
REQUEST_TIMEOUT_SECONDS = 5

LIVE_STATUSES = {
    "idle",
    "working",
    "questioning",
    "preplanning",
    "planning",
    "compacting",
    "reviewing",
    "victorious",
}
NOT_LIVE_STATUSES = {"stopped", "archived"}


def api_url(path, **query):
    url = f"{API_URL}{path}"
    if query:
        url = f"{url}?{urllib.parse.urlencode(query)}"
    return url


def check_health():
    try:
        req = urllib.request.Request(api_url("/health"), method="GET")
        with urllib.request.urlopen(req, timeout=REQUEST_TIMEOUT_SECONDS) as resp:
            return True, json.loads(resp.read().decode())
    except Exception as e:
        return False, str(e)


def get_instances():
    """Read the canonical instance read-model only; no tmux/runtime enrichment."""
    try:
        req = urllib.request.Request(
            api_url("/api/instances", include_runtime="false"), method="GET"
        )
        with urllib.request.urlopen(req, timeout=REQUEST_TIMEOUT_SECONDS) as resp:
            return json.loads(resp.read().decode())
    except Exception:
        return []


def format_duration(created_at):
    try:
        start = datetime.fromisoformat(str(created_at).replace("Z", "+00:00"))
        now = datetime.now(start.tzinfo) if start.tzinfo else datetime.now()
        delta = now - start
        mins = max(0, int(delta.total_seconds() // 60))
        if mins >= 60:
            return f"{mins // 60}h{mins % 60}m"
        return f"{mins}m"
    except Exception:
        return "?"


def display_name(inst):
    return inst.get("name") or "?"


def display_status(json_output=False):
    healthy, health_data = check_health()
    instances = get_instances()

    if json_output:
        print(
            json.dumps(
                {
                    "healthy": healthy,
                    "health": health_data if healthy else None,
                    "instances": instances,
                },
                indent=2,
                default=str,
            )
        )
        return

    # Header
    status_icon = "\033[32m●\033[0m" if healthy else "\033[31m●\033[0m"
    print(f"{status_icon} Token-API @ {API_URL}")

    if not healthy:
        print(f"  \033[31mError: {health_data}\033[0m")
        return

    # Instances
    active = [i for i in instances if i.get("status") in LIVE_STATUSES]
    stopped = [i for i in instances if i.get("status") in NOT_LIVE_STATUSES]

    print(f"\n  Active: {len(active)}  Stopped: {len(stopped)}")

    if active:
        print()
        for inst in active:
            status = inst.get("status") or "?"
            label = inst.get("cockpit_label") or status
            name = display_name(inst)
            device = inst.get("device_id") or "?"
            duration = format_duration(inst.get("created_at"))
            working_dir = inst.get("working_dir") or "?"
            marker = "\033[33m>\033[0m" if status == "working" else " "
            print(
                f"  {marker} {label[:12]:<12} {name[:25]:<25} "
                f"{device:<12} {duration:<7} {working_dir}"
            )


def main():
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    json_output = "--json" in args

    if "--watch" in args or "-w" in args:
        import time

        try:
            while True:
                print("\033[2J\033[H", end="")  # Clear screen
                display_status(json_output=json_output)
                print(f"\n  \033[2m(Ctrl+C to exit, refreshing every 2s)\033[0m")
                time.sleep(2)
        except KeyboardInterrupt:
            print()
    else:
        display_status(json_output=json_output)


if __name__ == "__main__":
    main()
