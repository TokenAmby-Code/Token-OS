#!/usr/bin/env bash
# tmux-pane-respawn — Global pane-died hook handler
# TAGS: tmux, lifecycle
# AUDIENCE: system (called by tmux pane-died hook, not directly)
#
# Respawns any dead pane.
# Generic panes get a 1s delay to prevent tight crash loops.


# 410-on-touch shim: this cold CLI/keybind path is retired.  The dead body
# below is intentionally retained for the separately-gated atomic wipe.
echo "tmux-pane-respawn: HTTP 410 Gone — pane-died live path is tmuxctld-ping POST /event." >&2
exit 154  # 410 modulo POSIX shell's 8-bit exit status

set -euo pipefail

PANE_ID="${1:?Usage: tmux-pane-respawn <pane_id>}"

# Check if pane still exists (race: hook fires but pane already killed by layout change)
if ! tmux has-session -t "$PANE_ID" 2>/dev/null; then
    exit 0
fi

PANE_TYPE=$(tmux show-options -pv -t "$PANE_ID" @PANE_TYPE 2>/dev/null || echo "")
PANE_ROLE=$(tmux show-options -pv -t "$PANE_ID" @PANE_ID 2>/dev/null || echo "")
WINDOW_NAME=$(tmux display-message -p -t "$PANE_ID" '#{window_name}' 2>/dev/null || echo "")
WINDOW_BASE="${WINDOW_NAME%%(*}"
WINDOW_TARGET=$(tmux display-message -p -t "$PANE_ID" '#{session_name}:#{window_index}' 2>/dev/null || echo "")

# Perpetual singleton persona seats self-heal through the tmuxctld daemon, not a
# bare respawn. When one's agent dies, hand re-seating to the engine via a
# fire-and-forget POST /event: the daemon respawns the thin persona-seat shim into
# the pane (event-driven, no poll — the 2-min assert-personas cron that used to do
# this was retired). We must NOT also bare-respawn the pane here: that would race
# the daemon's reseat and could clobber a freshly-seated agent. The daemon's
# boot-grace dedups concurrent reseats; this hook just rings the bell once.
case "$PANE_ROLE" in
    council:custodes|council:malcador|council:administratum|council:pax|mechanicus:fabricator-general|mechanicus:orchestrator)
        PORT="${TMUXCTLD_PORT:-7778}"
        curl -s -o /dev/null --connect-timeout 1 --max-time 3 \
            -X POST "http://127.0.0.1:${PORT}/event" \
            -H 'Content-Type: application/json' \
            -d "{\"event\":\"pane-died\",\"pane\":\"${PANE_ROLE}\"}" >/dev/null 2>&1 || true
        exit 0
        ;;
esac

# Pre-allocated palace/somnium SLOT panes. A slot exit is CLEARED IN PLACE by the
# tmuxctld router (runtime stamps scrubbed + the shell revived in place) so the
# fixed slot is PRESERVED and returned to the freelist — never bare-respawned with
# stale stamps, and never culled (the morning over-reap killed such a slot). Hand
# off to the daemon via /event; fire-and-forget — it no-ops a still-live pane.
case "$WINDOW_BASE" in
    palace|somnium)
        PORT="${TMUXCTLD_PORT:-7778}"
        EVENT_PANE="${PANE_ROLE:-$PANE_ID}"
        curl -s -o /dev/null --connect-timeout 1 --max-time 3 \
            -X POST "http://127.0.0.1:${PORT}/event" \
            -H 'Content-Type: application/json' \
            -d "{\"event\":\"pane-died\",\"pane\":\"${EVENT_PANE}\"}" >/dev/null 2>&1 || true
        exit 0
        ;;
esac

case "$WINDOW_BASE:$PANE_ROLE" in
    council:*)
        # The council true-terminal (a plain shell, not a persona) is perpetual;
        # let the default respawn restore it rather than killing.
        ;;
    mechanicus:*)
        # Stack workers are disposable process panes. If the process exits,
        # remove the pane instead of respawning a blank shell, then reassert
        # the remaining page layout.
        tmux kill-pane -t "$PANE_ID" 2>/dev/null || true
        if [[ -n "$WINDOW_TARGET" ]]; then
            tmux-run tmuxctl stack enforce --window "$WINDOW_TARGET" >/dev/null 2>&1 || true
        fi
        exit 0
        ;;
esac

if [[ "$PANE_TYPE" == "tombstone" ]]; then
    SOURCE=$(tmux show-options -pv -t "$PANE_ID" @TOMBSTONE_SOURCE 2>/dev/null || echo "unknown")
    TARGET=$(tmux show-options -pv -t "$PANE_ID" @TOMBSTONE_TARGET 2>/dev/null || echo "unknown")
    tmux respawn-pane -k -t "$PANE_ID" "tmux-tombstone '$SOURCE' '$TARGET'"
else
    sleep 1
    tmux respawn-pane -t "$PANE_ID"
fi
