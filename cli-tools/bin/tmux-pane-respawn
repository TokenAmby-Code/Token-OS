#!/usr/bin/env bash
# tmux-pane-respawn — Global pane-died hook handler
# TAGS: tmux, lifecycle
# AUDIENCE: system (called by tmux pane-died hook, not directly)
#
# Respawns any dead pane.
# Generic panes get a 1s delay to prevent tight crash loops.

set -euo pipefail

PANE_ID="${1:?Usage: tmux-pane-respawn <pane_id>}"

# Check if pane still exists (race: hook fires but pane already killed by layout change)
if ! tmux has-session -t "$PANE_ID" 2>/dev/null; then
    exit 0
fi

PANE_TYPE=$(tmux show-options -pv -t "$PANE_ID" @PANE_TYPE 2>/dev/null || echo "")
PANE_ROLE=$(tmux show-options -pv -t "$PANE_ID" @PANE_ID 2>/dev/null || echo "")
WINDOW_NAME=$(tmux display-message -p -t "$PANE_ID" '#{window_name}' 2>/dev/null || echo "")
WINDOW_BASE="${WINDOW_NAME%%(*}"
WINDOW_TARGET=$(tmux display-message -p -t "$PANE_ID" '#{session_name}:#{window_index}' 2>/dev/null || echo "")

case "$WINDOW_BASE:$PANE_ROLE" in
    legion:council:custodes|mechanicus:mechanicus:fabricator-general|mechanicus:council:administratum)
        ;;
    legion:*|mechanicus:*)
        # Stack workers are disposable process panes. If the process exits,
        # remove the pane instead of respawning a blank shell, then reassert
        # the remaining page layout.
        tmux kill-pane -t "$PANE_ID" 2>/dev/null || true
        if [[ -n "$WINDOW_TARGET" ]]; then
            tmux-run tmuxctl stack enforce --window "$WINDOW_TARGET" >/dev/null 2>&1 || true
        fi
        exit 0
        ;;
esac

if [[ "$PANE_TYPE" == "tombstone" ]]; then
    SOURCE=$(tmux show-options -pv -t "$PANE_ID" @TOMBSTONE_SOURCE 2>/dev/null || echo "unknown")
    TARGET=$(tmux show-options -pv -t "$PANE_ID" @TOMBSTONE_TARGET 2>/dev/null || echo "unknown")
    tmux respawn-pane -k -t "$PANE_ID" "tmux-tombstone '$SOURCE' '$TARGET'"
else
    sleep 1
    tmux respawn-pane -t "$PANE_ID"
fi
