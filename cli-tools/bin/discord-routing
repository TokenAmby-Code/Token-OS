#!/usr/bin/env python3
# discord-routing - Diagnose Discord voice routing through tmuxctld
# TAGS: discord, voice, routing, diagnostic
# AUDIENCE: agent, user
"""Diagnose Discord voice routing without crossing the Discord/tmux boundary.

Discord does not inspect panes. This diagnostic asks tmuxctld for semantic
voice targets and active voice-session state.

Usage:
    discord-routing              # status table
    discord-routing --json       # JSON output
    discord-routing --fix        # Print fix suggestions only
"""

from __future__ import annotations

import json
import os
import sys
import urllib.parse
import urllib.request

TMUXCTLD_URL = os.environ.get("TMUXCTLD_URL", "http://127.0.0.1:7778").rstrip("/")
TOKEN_API_URL = os.environ.get("TOKEN_API_URL", "http://localhost:7777").rstrip("/")
ROUTABLE_BOTS = ["custodes", "mechanicus", "imperial_guard"]


def http_json(url: str, timeout: float = 5.0):
    try:
        with urllib.request.urlopen(url, timeout=timeout) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except Exception:
        return None


def tmuxctld_get(path: str, params: dict[str, str] | None = None):
    query = ""
    if params:
        query = "?" + urllib.parse.urlencode(params)
    payload = http_json(f"{TMUXCTLD_URL}{path}{query}")
    if not payload:
        return None
    if payload.get("ok") is False:
        return {"ok": False, "error": payload.get("error") or {}}
    return {"ok": True, "result": payload.get("result", payload)}


def token_api_get(path: str):
    return http_json(f"{TOKEN_API_URL}{path}", timeout=2.0)


def check_tmuxctld_reachable() -> bool:
    payload = http_json(f"{TMUXCTLD_URL}/health", timeout=2.0)
    return bool(payload and payload.get("ok"))


def check_dictation_state():
    return token_api_get("/api/dictation")


def check_bot(bot_name: str) -> dict[str, object]:
    result: dict[str, object] = {
        "bot_name": bot_name,
        "target_role": None,
        "active_sessions": 0,
        "issues": [],
        "fixes": [],
        "verdict": "BROKEN",
    }
    target = tmuxctld_get("/voice/target", {"bot_name": bot_name})
    if not target or not target.get("ok"):
        message = (target or {}).get("error", {}).get("message") or "tmuxctld unavailable"
        result["issues"].append(f"No semantic target: {message}")
        if bot_name == "imperial_guard":
            result["fixes"].append("Attach a routable operator client to a pane with a public @PANE_ID")
        else:
            result["fixes"].append(f"Restore the {bot_name} persona pane in the managed workspace")
        return result

    target_role = target["result"].get("target_role")
    result["target_role"] = target_role

    status = tmuxctld_get("/voice/status", {"bot_name": bot_name})
    if status and status.get("ok"):
      sessions = status["result"].get("sessions") or []
      result["active_sessions"] = len(sessions)

    result["verdict"] = "OK"
    return result


def print_table(results, dictation_data, tmuxctld_ok):
    print()
    print("  Discord Voice Routing Diagnostic")
    print(f"  tmuxctld: {TMUXCTLD_URL} {'[OK]' if tmuxctld_ok else '[UNREACHABLE]'}")
    if dictation_data:
        print(f"  Dictation: {'ON' if dictation_data.get('active') else 'OFF'}")
    print()
    cols = ["Bot", "Target Role", "Sessions", "Verdict"]
    widths = [16, 32, 8, 8]
    print("  " + "  ".join(c.ljust(w) for c, w in zip(cols, widths)))
    print("  " + "  ".join("-" * w for w in widths))
    for item in results:
        row = [
            str(item["bot_name"]).ljust(widths[0]),
            str(item.get("target_role") or "-").ljust(widths[1]),
            str(item.get("active_sessions") or 0).ljust(widths[2]),
            str(item["verdict"]).ljust(widths[3]),
        ]
        print("  " + "  ".join(row))
    print()
    issues = [(r["bot_name"], issue) for r in results for issue in r["issues"]]
    if issues:
        print("  Issues:")
        for bot, issue in issues:
            print(f"    [{bot}] {issue}")
        print()
    else:
        print("  All routing chains healthy.")
        print()


def main() -> None:
    args = sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__)
        return
    json_mode = "--json" in args
    fix_mode = "--fix" in args

    tmuxctld_ok = check_tmuxctld_reachable()
    dictation_data = check_dictation_state()
    results = [check_bot(bot) for bot in ROUTABLE_BOTS]

    if json_mode:
        print(json.dumps({
            "tmuxctld_reachable": tmuxctld_ok,
            "tmuxctld_url": TMUXCTLD_URL,
            "dictation": dictation_data,
            "bots": results,
        }, indent=2))
        return

    if fix_mode:
        fixes = [fix for item in results for fix in item["fixes"]]
        if fixes:
            print("\n".join(fixes))
        else:
            print("No fixes needed — all routing chains healthy.")
        return

    print_table(results, dictation_data, tmuxctld_ok)


if __name__ == "__main__":
    main()
