#!/usr/bin/env bash
# open-session-doc — Open a session doc in Obsidian by id (or for the current pane).
# TAGS: tmux, obsidian, session
# AUDIENCE: tmux binding, ops cockpit
#
# The single "open session doc by id" entry point. Resolves a session doc to its
# stable id, then POSTs the one open-by-id endpoint
# (POST /api/session-docs/{id}/open), which invokes the obsidian CLI server-side
# on the Mac to focus/open the note. Both signals route through that endpoint:
# this tmux `prefix + S` keybind, and the ops cockpit's double-click on a fleet
# row (which calls the endpoint directly).
#
# Usage:
#   open-session-doc <doc_id>      # open a specific session doc by id
#   open-session-doc current       # resolve the current pane's doc, then open
#   open-session-doc               # same as `current`
#
# Pane resolution uses cardinal pane identity via tmuxctl — never raw tmux %pane ids.

set -u

_LIB="$(dirname "$(readlink -f "$0")")/../lib"
# shellcheck source=../lib/nas-path.sh
source "$_LIB/nas-path.sh"

API_URL="${TOKEN_API_URL:-http://localhost:7777}"

ARG="${1:-current}"

# --- 1. Resolve to a session doc id ---
if [[ "$ARG" =~ ^[0-9]+$ ]]; then
    DOC_ID="$ARG"
else
    # Pane mode: resolve the cardinal pane (default: current) to its doc id.
    PANE="${ARG:-current}"
    DOC_ID=$(tmuxctl session-doc --pane "$PANE" --format id 2>/dev/null) || {
        tmux display-message "open-session-doc: no doc for pane $PANE" 2>/dev/null || true
        echo "open-session-doc: tmuxctl session-doc failed for pane '$PANE'" >&2
        exit 1
    }
fi

if [[ -z "${DOC_ID:-}" || ! "$DOC_ID" =~ ^[0-9]+$ ]]; then
    tmux display-message "open-session-doc: no session doc resolved" 2>/dev/null || true
    echo "open-session-doc: no session doc id resolved (got '${DOC_ID:-}')" >&2
    exit 1
fi

# --- 2. Open by id through the one endpoint (obsidian CLI runs server-side) ---
RESP=$(curl -fsS -X POST "$API_URL/api/session-docs/$DOC_ID/open" 2>/dev/null) || {
    tmux display-message "open-session-doc: open failed for doc $DOC_ID" 2>/dev/null || true
    echo "open-session-doc: POST /api/session-docs/$DOC_ID/open failed" >&2
    exit 1
}

TITLE=$(python3 -c 'import sys, json; print(json.load(sys.stdin).get("title") or "")' <<< "$RESP" 2>/dev/null || echo "")
tmux display-message "opened: ${TITLE:-doc $DOC_ID}" 2>/dev/null || true
