#!/usr/bin/env bash
# open-session-doc — Open the session doc linked to a tmux pane in Obsidian.
# TAGS: tmux, obsidian, origin, session
# AUDIENCE: tmux binding
#
# Resolves: cardinal pane id → claude_instances → session_documents → file_path
# Routes:   open on the machine that triggered the keystroke (origin_machine)
#
# Usage:
#   open-session-doc [cardinal-pane-id|current] [client_pid]
#
# Both args are optional. Without a pane id, tmuxctl resolves the current pane's
# stable @PANE_ID cardinal label. Do not pass raw tmux %pane ids here.

set -u

# --- Shell plumbing (needed even when invoked outside login shell) ---
_LIB="$(dirname "$(readlink -f "$0")")/../lib"
# shellcheck source=../lib/nas-path.sh
source "$_LIB/nas-path.sh"
# shellcheck source=../lib/origin.sh
source "$_LIB/origin.sh"

PANE_ID="${1:-current}"
CLIENT_PID="${2:-}"

if [[ -z "$PANE_ID" ]]; then
    echo "open-session-doc: no pane id" >&2
    exit 1
fi

# --- 1. Ask tmuxctl for the session doc using cardinal pane identity ---
body=$(tmuxctl session-doc --pane "$PANE_ID" --format json 2>&1) || {
    tmux display-message "open-session-doc: no doc for cardinal pane $PANE_ID" 2>/dev/null || true
    echo "open-session-doc: tmuxctl session-doc failed: $body" >&2
    exit 1
}

# --- 2. Parse doc fields (python to avoid jq dep) ---
read -r VAULT FILE_PATH TITLE < <(python3 -c '
import sys, json
d = json.loads(sys.stdin.read())
print("Imperium-ENV", d["file_path"], d.get("title", ""))
' <<< "$body")

if [[ -z "$VAULT" || -z "$FILE_PATH" ]]; then
    echo "open-session-doc: malformed response: $body" >&2
    exit 1
fi

# --- 3. Resolve the origin machine for routing ---
TARGET=$(origin_machine "$CLIENT_PID")

# --- 4. Dispatch ---
case "$TARGET" in
    mac)
        obsidian "vault=$VAULT" open "path=$FILE_PATH"
        tmux display-message "opened: $TITLE" 2>/dev/null || true
        ;;
    wsl|phone|linux|unknown)
        # TODO: cross-machine routing. For wsl/linux: ssh-connect and run the
        # obsidian wrapper there (WSL proxies to Obsidian.exe which opens via
        # native CLI). For phone: push an obsidian:// intent via Token-API.
        tmux display-message "open-session-doc: routing to '$TARGET' not yet implemented" 2>/dev/null || true
        echo "open-session-doc: origin resolved to '$TARGET' (cross-machine routing TODO)" >&2
        echo "  vault=$VAULT  file=$FILE_PATH" >&2
        exit 2
        ;;
    *)
        echo "open-session-doc: unknown origin '$TARGET'" >&2
        exit 1
        ;;
esac
