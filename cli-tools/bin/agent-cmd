#!/usr/bin/env bash
# agent-cmd - Engine-neutral live agent prompt injection via tmux.
set -euo pipefail

_BIN_DIR="$(dirname "$(readlink -f "$0")")"
_LIB_DIR="${_BIN_DIR}/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true
source "${_LIB_DIR}/tmux-guard.sh"

API_URL="${TOKEN_API_URL:-http://localhost:7777}"
TMUXCTLD_URL="${TMUXCTLD_URL:-http://127.0.0.1:7778}"
TMUXCTL_BIN="${TMUXCTL_BIN:-${_BIN_DIR}/tmuxctl}"
TARGET_MODE="self"
TARGET_VALUE=""
DETACH=false
RESOLVE_ONLY=false
NO_ESCAPE=false
NO_SUBMIT=false
COMMAND=""

usage() {
    cat <<'USAGE'
agent-cmd - Send a prompt/command to a live Claude or Codex pane

Usage: agent-cmd [--self|--pane PANE|--instance ID] [--detach] [--resolve-only] [--no-escape] [--no-submit] <prompt>

  --no-submit   Insert the prompt as a DRAFT (no Enter/submit). Attended-safe:
                routes through tmuxctl send-text --no-submit (insert-only), so it
                can never auto-submit over a human's in-progress draft.
USAGE
}

parent_pid_of() {
    local pid="$1"
    if [[ "$(uname -s)" == Darwin ]]; then
        ps -p "$pid" -o ppid= 2>/dev/null | tr -d ' '
    else
        awk '{print $4}' "/proc/$pid/stat" 2>/dev/null
    fi
}

find_agent_pid() {
    local current="${1:-$PPID}" comm next
    for _ in 1 2 3 4 5 6 7 8; do
        [[ -z "$current" || "$current" == "1" || "$current" == "0" ]] && break
        if [[ "$(uname -s)" == Darwin ]]; then
            comm=$(ps -p "$current" -o comm= 2>/dev/null) || break
        else
            comm=$(cat "/proc/$current/comm" 2>/dev/null) || break
        fi
        case "$comm" in
            *claude*|*codex*) echo "$current"; return 0 ;;
        esac
        next=$(parent_pid_of "$current") || break
        current="$next"
    done
    return 1
}

find_tmux_pane() {
    local target_pid="$1"
    IMPERIUM_TMUX_RAW=1 tmux list-panes -a -F '#{pane_id} #{pane_pid}' 2>/dev/null | while read -r pane_id pane_pid; do
        local check_pid="$target_pid"
        while [[ -n "$check_pid" && "$check_pid" != "1" && "$check_pid" != "0" ]]; do
            if [[ "$check_pid" == "$pane_pid" ]]; then
                echo "$pane_id"
                return 0
            fi
            check_pid=$(parent_pid_of "$check_pid") || break
        done
    done | head -1
}

resolve_instance_id() {
    local pid="$1"
    local cache_file="${HOME}/.claude/session-pids/${pid}"
    [[ -f "$cache_file" ]] && cat "$cache_file" 2>/dev/null || true
}

resolve_pane() {
    local target="${1:-}"
    if [[ "$target" =~ ^%[0-9]+$ ]]; then
        printf '%s\n' "$target"
        return 0
    fi
    if ! tmuxctld_resolve physical target "$target"; then
        printf 'agent-cmd: pane target not found: %s\n' "$target" >&2
        return 1
    fi
}

tmuxctld_resolve() {
    local format="$1" key="$2" value="$3"
    python3 - "$TMUXCTLD_URL" "$format" "$key" "$value" <<'PY'
import json
import sys
import urllib.error
import urllib.parse
import urllib.request

base_url, fmt, key, value = sys.argv[1:]
query = urllib.parse.urlencode({key: value, "format": fmt})
try:
    with urllib.request.urlopen(
        base_url.rstrip("/") + "/resolve-pane?" + query, timeout=10
    ) as response:
        payload = json.loads(response.read().decode("utf-8") or "{}")
except (OSError, ValueError, urllib.error.URLError):
    raise SystemExit(1)

result = payload.get("result") if isinstance(payload, dict) and payload.get("ok") is True else None
if not isinstance(result, str) or not result:
    raise SystemExit(1)
print(result)
PY
}

payload_hash() {
    python3 -c 'import sys,hashlib,re; s=re.sub(r"[\r\n]+", " ", sys.stdin.read()).rstrip(); print(hashlib.sha256(s.encode()).hexdigest())'
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --self) TARGET_MODE="self"; shift ;;
        --pane) TARGET_MODE="pane"; TARGET_VALUE="$2"; shift 2 ;;
        --instance) TARGET_MODE="instance"; TARGET_VALUE="$2"; shift 2 ;;
        --detach) DETACH=true; shift ;;
        --resolve-only) RESOLVE_ONLY=true; shift ;;
        --no-escape) NO_ESCAPE=true; shift ;;  # accepted for claude-cmd compatibility
        --no-submit) NO_SUBMIT=true; shift ;;  # insert as draft, never submit
        -h|--help) usage; exit 0 ;;
        *) COMMAND="$1"; shift ;;
    esac
done

if [[ "$RESOLVE_ONLY" != true && -z "$COMMAND" ]]; then
    echo "Error: No command specified." >&2
    usage >&2
    exit 1
fi

PANE=""
INSTANCE_ID=""
case "$TARGET_MODE" in
    self)
        AGENT_PID=$(find_agent_pid || true)
        [[ -z "$AGENT_PID" ]] && { echo "Error: Could not find agent ancestor process." >&2; exit 1; }
        PANE=$(find_tmux_pane "$AGENT_PID")
        INSTANCE_ID=$(resolve_instance_id "$AGENT_PID")
        ;;
    pane)
        PANE="$TARGET_VALUE"
        ;;
    instance)
        INSTANCE_ID="$TARGET_VALUE"
        PANE=$(tmuxctld_resolve physical instance_id "$TARGET_VALUE" || true)
        [[ -z "$PANE" ]] && { echo "Error: Could not find pane for instance '$TARGET_VALUE'." >&2; exit 1; }
        ;;
esac

[[ -n "$PANE" ]] && PANE=$(resolve_pane "$PANE")
if [[ "$RESOLVE_ONLY" == true ]]; then
    echo "$PANE"
    exit 0
fi

send_command() {
    local pane="$1" cmd="$2" locker="agent-cmd-$$" locked=false rc=0 out lock_resp
    local dispatch_id hash
    local blocked=false reason="" verification_status="unverified" verified_by="tmuxctld"
    # Swallowed-submit recovery surface (memories: ack-is-hack,
    # no-error-suppressing-debounce). Defaults are mouse-free safe values: the
    # direct/blocked paths neither hold the green agent guard nor sniff for a
    # swallowed submit, so they report no hold, no detection, no recovery.
    local guard_held=false swallowed_submit_detected=false recovery_attempts=0 failures='[]'
    dispatch_id=$(python3 -c 'import uuid; print(uuid.uuid4())')
    hash=$(printf '%s' "$cmd" | payload_hash)

    if [[ -n "${INSTANCE_ID:-}" ]]; then
        for _ in {1..20}; do
            lock_resp=$(curl -s --connect-timeout 1 --max-time 10 \
                -X POST "$API_URL/api/instances/$INSTANCE_ID/input-lock?locker=$locker" 2>/dev/null || true)
            if echo "$lock_resp" | grep -q '"acquired": *true'; then
                locked=true
                break
            fi
            sleep 0.5
        done
    fi

    # Prefer the daemon-native send (verified handshake). Exit codes from the
    # helper: 0 = ok, 2 = daemon RESPONDED with ok:false (a real, handled
    # failure — do NOT fall back, the daemon owns it), 3 = daemon UNREACHABLE
    # (connection refused / timeout — fall back to direct tmuxctl so a daemon
    # that is down or mid-restart never wedges a send).
    out=$(python3 - "$TMUXCTLD_URL" "$pane" "$cmd" "$NO_SUBMIT" <<'PY' 2>&1
import json
import sys
import urllib.error
import urllib.request

url, pane, text, no_submit = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4] == "true"
body = {
    "pane": pane,
    "text": text,
    "submit": not no_submit,
    "verify": not no_submit,
    "verify_timeout": 30.0,
}
req = urllib.request.Request(
    url.rstrip("/") + "/send-text",
    data=json.dumps(body).encode("utf-8"),
    headers={"Content-Type": "application/json"},
    method="POST",
)
try:
    with urllib.request.urlopen(req, timeout=90) as resp:
        payload = json.loads(resp.read().decode("utf-8") or "{}")
except urllib.error.HTTPError as exc:  # daemon answered with a transport error
    sys.stderr.write(f"tmuxctld http error: {exc}\n")
    raise SystemExit(2)
except urllib.error.URLError as exc:  # daemon down / unreachable -> fall back
    sys.stderr.write(f"tmuxctld unreachable: {exc}\n")
    raise SystemExit(3)
print(json.dumps(payload, separators=(",", ":")))
if not payload.get("ok"):
    raise SystemExit(2)
PY
    ) || rc=$?
    if [[ "$rc" == 3 ]]; then
        # Daemon unreachable — fall back to the direct tmuxctl send path so the
        # send still lands (still routed through the universal send gate).
        local -a send_args=(send-text --pane "$pane" --text "$cmd")
        [[ "$NO_SUBMIT" == true ]] && send_args+=(--no-submit)
        if out=$("$TMUXCTL_BIN" "${send_args[@]}" 2>&1); then
            rc=0
            verification_status="sent"
            verified_by="tmuxctl"
        else
            echo "$out" >&2
            rc=1
            verification_status="failed"
            verified_by="tmuxctl"
        fi
    elif [[ "$rc" != 0 ]]; then
        echo "$out" >&2
        # A daemon `ok:false` with error.code=="gated" means ZERO bytes were
        # written and the send is re-queueable — surface it as blocked (with the
        # gate reason) rather than collapsing it to a generic failure, so the
        # caller keeps the no-bytes-written retry signal (surface-don't-suppress).
        local gate_code=""
        gate_code=$(python3 -c 'import json,sys
try:
    p=json.loads(sys.stdin.read())
except Exception:
    p={}
print((p.get("error") or {}).get("code") or "" if isinstance(p, dict) else "")' <<<"$out" 2>/dev/null || true)
        if [[ "$gate_code" == "gated" ]]; then
            blocked=true
            verification_status="gated"
            verified_by=""
            reason=$(python3 -c 'import json,sys
try:
    p=json.loads(sys.stdin.read())
except Exception:
    p={}
err=(p.get("error") or {}) if isinstance(p, dict) else {}
detail=err.get("detail") if isinstance(err.get("detail"), dict) else {}
print(detail.get("reason") or err.get("message") or "gated")' <<<"$out" 2>/dev/null || echo "gated")
        else
            verification_status="failed"
            verified_by="tmuxctld"
        fi
    fi
    if [[ "$rc" == 0 && "$verified_by" == "tmuxctld" ]]; then
        verification_status=$(python3 -c 'import json,sys; p=json.loads(sys.stdin.read()); print((p.get("result") or {}).get("verification_status") or "unverified")' <<<"$out" 2>/dev/null || echo "unverified")
        # Keep verified_by empty (-> null in the envelope) when the daemon reports
        # no verifier — do NOT invent "tmuxctld" for an unverified send.
        verified_by=$(python3 -c 'import json,sys; print((json.loads(sys.stdin.read()).get("result") or {}).get("verified_by") or "")' <<<"$out" 2>/dev/null || echo "")
        dispatch_id=$(python3 -c 'import json,sys; p=json.loads(sys.stdin.read()); print((p.get("result") or {}).get("dispatch_id") or "")' <<<"$out" 2>/dev/null || true)
        [[ -n "$dispatch_id" ]] || dispatch_id=$(python3 -c 'import uuid; print(uuid.uuid4())')
        # Surface the swallowed-submit recovery telemetry the daemon now exposes
        # so a caller can see a submit was eaten and re-driven. Booleans/ints are
        # emitted lower-case/unquoted; failures stays raw JSON for a real array.
        guard_held=$(python3 -c 'import json,sys; print(str(bool((json.loads(sys.stdin.read()).get("result") or {}).get("guard_held"))).lower())' <<<"$out" 2>/dev/null || echo false)
        swallowed_submit_detected=$(python3 -c 'import json,sys; print(str(bool((json.loads(sys.stdin.read()).get("result") or {}).get("swallowed_submit_detected"))).lower())' <<<"$out" 2>/dev/null || echo false)
        recovery_attempts=$(python3 -c 'import json,sys; print(int((json.loads(sys.stdin.read()).get("result") or {}).get("recovery_attempts") or 0))' <<<"$out" 2>/dev/null || echo 0)
        failures=$(python3 -c 'import json,sys; print(json.dumps((json.loads(sys.stdin.read()).get("result") or {}).get("failures") or []))' <<<"$out" 2>/dev/null || echo '[]')
    fi

    if [[ "$locked" == true ]]; then
        curl -s --connect-timeout 1 --max-time 2 \
            -X DELETE "$API_URL/api/instances/$INSTANCE_ID/input-lock?locker=$locker" \
            >/dev/null 2>&1 || true
    fi

    # Build the envelope with json.dumps so the raw `failures` JSON array and any
    # special chars in the fields can't corrupt the output under set -euo pipefail.
    python3 - "$dispatch_id" "$hash" "$pane" "${INSTANCE_ID:-}" "$verification_status" \
        "$verified_by" "$blocked" "$reason" "$guard_held" "$swallowed_submit_detected" \
        "$recovery_attempts" "$failures" <<'PY'
import json
import sys

(
    dispatch_id, payload_hash, pane, instance_id, verification_status,
    verified_by, blocked, reason, guard_held, swallowed, recovery_attempts, failures,
) = sys.argv[1:13]
try:
    failures_val = json.loads(failures or "[]")
except (ValueError, TypeError):
    failures_val = []
print(json.dumps({
    "dispatch_id": dispatch_id,
    "payload_hash": payload_hash,
    "pane": pane,
    "instance_id": instance_id,
    "verification_status": verification_status,
    "verified_by": verified_by or None,
    "blocked": blocked == "true",
    "reason": reason,
    "guard_held": guard_held == "true",
    "swallowed_submit_detected": swallowed == "true",
    "recovery_attempts": int(recovery_attempts or 0),
    "failures": failures_val,
}, separators=(",", ":")))
PY
    return "$rc"
}

if [[ "$DETACH" == true ]]; then
    (send_command "$PANE" "$COMMAND" >/dev/null 2>>"${TMUX_GUARD_LOG_STDERR:-/tmp/agent-cmd-detached.err}") &
    disown 2>/dev/null || true
else
    send_command "$PANE" "$COMMAND"
fi
