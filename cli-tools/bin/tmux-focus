#!/usr/bin/env bash
# tmux-focus — Focus / unfocus toggle for palace + somnium grid windows.
# TAGS: tmux, focus
# AUDIENCE: human (keybind: prefix + F via `tx toggle-focus`)
#
# Focus drops the side column(s), exposing the full 2x2 grid.
#   palace  → kills both side columns (SL + SR), 20% each
#   somnium → kills the right TUI column (SR), 33%
# Unfocus restores the side column(s). Somnium SR auto-launches tui-pane-guard.
#
# This is the remaining shell helper for focus state management; a Python port
# lives in the Phase B scope. Everything else routes through `tmuxctl`.
#
# Usage:
#   tmux-focus focus
#   tmux-focus unfocus
#   tmux-focus toggle

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
# shellcheck source=../lib/pane-id.sh
source "${_LIB_DIR}/pane-id.sh" 2>/dev/null || true

PALACE_SIDE_RATIO=20
SOMNIUM_SIDE_RATIO=33

window_option() {
    local target="$1" option="$2" default="${3:-}"
    tmux show-options -wv -t "$target" "$option" 2>/dev/null || echo "$default"
}

pane_exists() {
    tmux display-message -t "$1" -p '' >/dev/null 2>&1
}

retract_transient_expansions() {
    local target="$1"
    local pane_for_retract=""
    local grid_exp generic_exp side_exp
    grid_exp=$(window_option "$target" @GRID_EXPANDED "none")
    generic_exp=$(window_option "$target" @GENERIC_EXPANDED "none")
    side_exp=$(window_option "$target" @SIDE_EXPANDED "none")

    if [[ "$grid_exp" != "none" && -n "$grid_exp" ]] && pane_exists "$grid_exp"; then
        pane_for_retract="$grid_exp"
    elif [[ "$generic_exp" != "none" && -n "$generic_exp" ]] && pane_exists "$generic_exp"; then
        pane_for_retract="$generic_exp"
    elif [[ "$side_exp" != "none" && -n "$side_exp" ]] && pane_exists "$side_exp"; then
        pane_for_retract="$side_exp"
    fi

    if [[ -n "$pane_for_retract" ]]; then
        tmux-grid-expand --pane "$pane_for_retract" --retract >/dev/null 2>&1 || true
    else
        [[ "$grid_exp" == "none" && "$generic_exp" == "none" && "$side_exp" == "none" ]] && return 0
        tmux set-option -w -t "$target" @GRID_EXPANDED "none" 2>/dev/null || true
        tmux set-option -w -t "$target" @GRID_STASH "" 2>/dev/null || true
        tmux set-option -w -t "$target" @GENERIC_EXPANDED "none" 2>/dev/null || true
        tmux set-option -w -t "$target" @GENERIC_STASH "" 2>/dev/null || true
        tmux set-option -w -t "$target" @SIDE_EXPANDED "none" 2>/dev/null || true
    fi
}

focus_mode() {
    local session window window_name target
    session=$(tmux display-message -p '#{session_name}')
    window=$(tmux display-message -p '#{window_index}')
    window_name=$(tmux display-message -p '#{window_name}')
    window_name="${window_name%%(*}"
    target="${session}:${window}"

    retract_transient_expansions "$target"

    local side_panes=()
    while IFS= read -r line; do
        local pane_id state
        pane_id=$(echo "$line" | cut -d' ' -f1)
        state=$(echo "$line" | cut -d' ' -f2)
        if [[ "$state" == "side" ]]; then
            side_panes+=("$pane_id")
        fi
    done < <(tmux list-panes -t "$target" -F '#{pane_id} #{@GRID_STATE}')

    local tui_panes=()
    while IFS=$'\t' read -r pid reserved ptype; do
        if [[ "$reserved" == "true" && "$ptype" == "tui" ]]; then
            tui_panes+=("$pid")
        fi
    done < <(tmux list-panes -t "$target" -F '#{pane_id}	#{@GRID_RESERVED}	#{@PANE_TYPE}')

    local side_count=${#side_panes[@]}
    local tui_count=${#tui_panes[@]}

    if [[ $side_count -eq 0 && $tui_count -eq 0 ]]; then
        return 0
    fi

    tmux set-option -w -t "$target" @FOCUSED "true"

    if [[ $side_count -gt 0 ]]; then
        for pid in "${side_panes[@]}"; do
            tmux kill-pane -t "$pid"
        done
    fi

    if [[ $tui_count -gt 0 ]]; then
        local stash_window="_fstash_${window_name}"
        local stash_exists=false
        if tmux list-windows -t "$session" -F '#{window_name}' | grep -q "^${stash_window}$"; then
            stash_exists=true
        fi

        local tui_manifest=""
        for pid in "${tui_panes[@]}"; do
            local ph
            ph=$(tmux display-message -t "$pid" -p '#{pane_height}')
            if [[ "$stash_exists" == false ]]; then
                tmux break-pane -d -s "$pid" -n "$stash_window" 2>/dev/null || true
                stash_exists=true
            else
                tmux move-pane -d -t "${session}:${stash_window}" -s "$pid" 2>/dev/null || true
            fi
            tui_manifest="${tui_manifest:+${tui_manifest},}${pid}:${ph}"
        done
        tmux set-option -w -t "$target" @FOCUS_TUI_STASH "$tui_manifest"
    fi
}

unfocus_mode() {
    local session window window_name target
    session=$(tmux display-message -p '#{session_name}')
    window=$(tmux display-message -p '#{window_index}')
    window_name=$(tmux display-message -p '#{window_name}')
    window_name="${window_name%%(*}"
    target="${session}:${window}"

    retract_transient_expansions "$target"

    local focused
    focused=$(tmux show-options -wv -t "$target" @FOCUSED 2>/dev/null || echo "false")
    if [[ "$focused" != "true" ]]; then
        return 0
    fi

    local total_w
    total_w=$(tmux display-message -t "$target" -p '#{window_width}')

    local has_sl=false has_sr=false
    while IFS=$'\t' read -r pid state role; do
        [[ "$state" == "side" ]] || continue
        case "$role" in
            palace:SL|somnium:SL) has_sl=true ;;
            palace:SR|somnium:SR) has_sr=true ;;
        esac
    done < <(tmux list-panes -t "$target" -F '#{pane_id}	#{@GRID_STATE}	#{@PANE_ID}')

    if [[ "$window_name" == "palace" ]]; then
        local usable=$((total_w - 5))
        local side_w=$((usable * PALACE_SIDE_RATIO / 100))

        if [[ "$has_sl" != true ]]; then
            local first_pane left_col
            first_pane=$(tmux list-panes -t "$target" -F '#{pane_id}' | head -1)
            left_col=$(tmux split-window -fh -b -t "$first_pane" -l "$side_w" -P -F '#{pane_id}' -c "$HOME")
            pane_tag "$left_col" "palace:SL"
            tmux set-option -p -t "$left_col" @GRID_RESERVED "false"
        fi

        if [[ "$has_sr" != true ]]; then
            local last_pane right_col
            last_pane=$(tmux list-panes -t "$target" -F '#{pane_id}' | tail -1)
            right_col=$(tmux split-window -fh -t "$last_pane" -l "$side_w" -P -F '#{pane_id}' -c "$HOME")
            pane_tag "$right_col" "palace:SR"
            tmux set-option -p -t "$right_col" @GRID_RESERVED "false"
        fi
    elif [[ "$window_name" == "somnium" && "$has_sr" != true ]]; then
        local usable=$((total_w - 2))
        local right_w=$((usable * SOMNIUM_SIDE_RATIO / 100))
        local last_pane right_col
        last_pane=$(tmux list-panes -t "$target" -F '#{pane_id}' | tail -1)
        right_col=$(tmux split-window -fh -t "$last_pane" -l "${right_w}" -P -F '#{pane_id}')
        pane_tag "$right_col" "somnium:SR"
        tmux set-option -p -t "$right_col" @PANE_TYPE "tui"
        tmux set-option -p -t "$right_col" @GRID_RESERVED "false"
        tmux send-keys -t "$right_col" "exec tui-pane-guard" Enter
    fi

    # Restore stashed TUI monitor panes (none expected on somnium archetype, but keep
    # the slot for any callers that stashed via @FOCUS_TUI_STASH).
    local tui_manifest
    tui_manifest=$(tmux show-options -wv -t "$target" @FOCUS_TUI_STASH 2>/dev/null || echo "")
    if [[ -n "$tui_manifest" ]]; then
        local stash_window="_fstash_${window_name}"
        local first_pane
        first_pane=$(tmux list-panes -t "$target" -F '#{pane_id}' | head -1)

        IFS=',' read -ra tui_entries <<< "$tui_manifest"
        for entry in "${tui_entries[@]}"; do
            local pid="${entry%%:*}"
            local saved_h="${entry#*:}"

            if tmux display-message -t "$pid" -p '' 2>/dev/null; then
                tmux join-pane -d -vb -t "$first_pane" -s "$pid" -l "$saved_h" 2>/dev/null || true
            fi
        done

        tmux set-option -w -t "$target" @FOCUS_TUI_STASH ""

        if tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null | grep -q "^${stash_window}$"; then
            local stash_count
            stash_count=$(tmux list-panes -t "${session}:${stash_window}" 2>/dev/null | wc -l | tr -d ' ')
            if [[ "${stash_count:-0}" -le 1 ]]; then
                tmux kill-window -t "${session}:${stash_window}" 2>/dev/null || true
            fi
        fi
    fi

    tmux set-option -w -t "$target" @FOCUSED "false"

    local grid_count
    grid_count=$(tmux list-panes -t "$target" -F '#{@GRID_STATE}' | grep -c "small" || echo "0")
    if [[ "$grid_count" -gt 0 ]]; then
        tmux-refresh-layout 2>/dev/null || true
    fi
}

case "${1:-toggle}" in
    focus)
        focus_mode
        ;;
    unfocus)
        unfocus_mode
        ;;
    toggle)
        target=$(tmux display-message -p '#{session_name}:#{window_index}')
        state=$(tmux show-options -wv -t "$target" @FOCUSED 2>/dev/null || echo "false")
        if [[ "$state" == "true" ]]; then
            unfocus_mode
        else
            focus_mode
        fi
        ;;
    *)
        echo "Usage: tmux-focus {focus|unfocus|toggle}" >&2
        exit 1
        ;;
esac
