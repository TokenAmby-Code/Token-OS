#!/usr/bin/env bash
# dispatch - Canonical launcher for new/resumed agent sessions
# TAGS: instance, dispatch, launcher
# AUDIENCE: human, agent

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib"
CALLER_IMPERIUM="${IMPERIUM:-}"
source "${LIB_DIR}/nas-path.sh" 2>/dev/null || true
source "${LIB_DIR}/pane-id.sh" 2>/dev/null || true
source "${LIB_DIR}/agent-wrapper-common.sh" 2>/dev/null || true
# Tests and callers may intentionally point dispatch at an alternate vault root.
[[ -n "$CALLER_IMPERIUM" ]] && export IMPERIUM="$CALLER_IMPERIUM"
source "${LIB_DIR}/git-remote.sh"

# Harden the ctype locale internally. dispatch pipes arbitrary prompt/title text
# (which routinely contains non-ASCII: →, ✓, emoji) through sed/tr/cut. Under a
# C/POSIX LC_CTYPE — the default in cron/launchd and many shells — BSD regex
# tooling aborts with `sed: RE error: illegal byte sequence` on multibyte input.
# A user must NEVER have to export LC_ALL=en_US.UTF-8 themselves to launch a
# worker. We pin a concrete UTF-8 LC_CTYPE (not just trust an inherited LANG,
# which BSD libc does not always honour for ctype). LC_ALL overrides every LC_*
# category, so a hostile LC_ALL=C must be cleared for the override to take effect.
# (One sed — the %pane redactor — runs over bash `printf %q` output, which on
# macOS can contain invalid UTF-8; it pins LC_ALL=C locally for byte-safe
# matching. See redact_tmux_panes_for_display.)
dispatch_force_utf8_ctype() {
  case "${LC_ALL:-}" in
    ""|*.UTF-8|*.utf-8|*.UTF8|*.utf8) ;;    # unset or already UTF-8: leave it
    *) unset LC_ALL ;;                      # e.g. LC_ALL=C — clear so LC_CTYPE wins
  esac
  case "${LC_ALL:-}" in
    *.UTF-8|*.utf-8|*.UTF8|*.utf8) return 0 ;;  # a UTF-8 LC_ALL already governs all
  esac
  case "${LC_CTYPE:-}" in
    *.UTF-8|*.utf-8|*.UTF8|*.utf8) return 0 ;;  # an explicit UTF-8 ctype is in force
  esac
  local loc
  for loc in "${LANG:-}" en_US.UTF-8 C.UTF-8 UTF-8; do
    case "$loc" in *.UTF-8|*.utf-8|*.UTF8|*.utf8) ;; *) continue ;; esac
    if locale -a 2>/dev/null | grep -qix "$loc"; then
      export LC_CTYPE="$loc"
      return 0
    fi
  done
  # en_US.UTF-8 ships on essentially every macOS install; use it as a last resort.
  export LC_CTYPE="en_US.UTF-8"
}
dispatch_force_utf8_ctype

usage() {
  cat <<'USAGE'
dispatch — canonical launcher for new or resumed agent sessions

Usage:
  dispatch [legion|mechanicus|civic|palace|somnium] [options]

  The optional leading word is target shorthand:
    dispatch legion ...       ≡  dispatch --target mechanicus:new ...
    dispatch mechanicus ...   ≡  dispatch --target mechanicus:new ...
    dispatch civic ...        ≡  dispatch --target civic:new ...
    dispatch palace ...       ≡  dispatch --target palace:new ...
    dispatch somnium ...      ≡  dispatch --target somnium:new ...

Options:
  --engine claude|codex        Agent engine (default: claude)
  --model <model>              Claude model alias/name for Claude launches
  --repo <name>                Branch from a known project's checkout by name,
                               resolving ~/.config/worktrees/<name>.conf
                               (case-insensitive); avoids passing a full --dir
  --id, --resume, -r <id>      Resume an existing agent session by instance id or session_id
  --aspirant                  Create an aspirant instead of launching directly
  --aspirant-kind <kind>      dispatch, deploy_p, or deploy_d (with --aspirant)
  --intake-only               With dispatch aspirants, create note/session only
  --kind <kind>               Compatibility alias for --aspirant-kind; requires --aspirant
  --direct                    Force direct launch; disable auto-aspirant policy
  --session-domain <domain>   Aspirant session-doc domain hint: terra or mars
  --persona <name>             Persona name (dispatch-managed)
  --dir <path>                 Working directory (aspirant default: Imperium-ENV vault root)
  --title <text>               Aspirant title metadata
  --objective <text>           Aspirant objective metadata
  --victory-condition <text>  Aspirant victory condition; may repeat
  --source <name>             Aspirant source metadata (default: dispatch)
  --session-doc <path>         Session doc path to bind at SessionStart
  --prompt <text>              Initial prompt
  --prompt-file <path>         Read initial prompt from file
  --system-prompt <text>       Append a Claude system prompt
  --system-prompt-file <path>  Read appended Claude system prompt from file
  --target <target>            mechanicus:new, palace:new, or a tmux pane id
  --pane <target|self>         Alias for --target; with --id, pane to resume into
  --self                       Explicit same-pane self handoff/transplant launch
  --gt | --no-gt               Golden Throne lane toggle (default: --no-gt)
  --zealotry <1-10>            Zealotry (default: 5 with --gt, 3 with --no-gt)
  --sync                       Sync-session lane
  --instance-type <type>        Explicit instance type (one_off, sync, golden_throne, hook_driven)
  --with-browser               Request browser MCP/profile metadata
  --with-desktop               Request desktop MCP/profile metadata
  --with-mcp <list>            Comma-separated MCP request metadata
  --discord <id>               Discord thread/channel id hosted by this launch
  --worktree <branch>          Isolate this dispatch into a fresh per-branch worktree
  --no-worktree                Opt out of default worktree isolation (run in --dir as-is)
  --dry-run                    Resolve and print without mutating state
  --interactive                Minimal interactive launcher
  --help, -h                   Show this help
USAGE
}

err() { echo "dispatch: $*" >&2; }
warn() { echo "dispatch: warning: $*" >&2; }
quote() { printf '%q' "$1"; }

ENGINE="claude"
ENGINE_EXPLICIT=false
DISPATCH_MENU_HARNESS="$ENGINE"
RESUME_ID=""
RESUME_INSTANCE_ID=""
RESUME_REQUESTED=false
RESUME_ROW_FOUND=false
ASPIRANT=false
ASPIRANT_KIND="dispatch"
INTAKE_ONLY=false
KIND_ALIAS_USED=false
DIRECT=false
SESSION_DOMAIN=""
PERSONA=""
WORK_DIR="$(pwd)"
WORK_DIR_EXPLICIT=false
TITLE=""
OBJECTIVE=""
OBJECTIVE_EXPLICIT=false
VICTORY_CONDITIONS=()
ASPIRANT_SOURCE="dispatch"
SESSION_DOC=""
PROMPT=""
PROMPT_FILE=""
SYSTEM_PROMPT=""
SYSTEM_PROMPT_FILE=""
SYSTEM_PROMPT_INLINE_USED=false
TARGET=""
GT_MODE=false
ZEALOTRY=""
SYNC=false
INSTANCE_TYPE_OVERRIDE=""
REPO=""
WITH_BROWSER=false
WITH_DESKTOP=false
WITH_MCP=""
CODEX_PROFILE="${TOKEN_API_CODEX_PROFILE:-}"
# Static model pin: claude dispatches default to opus unless explicitly
# overridden (--model / TOKEN_API_CLAUDE_MODEL). In-session model changes are
# volatile by design — the next launch re-pins from here, never from the
# harness's sticky "saved default".
CLAUDE_MODEL="${TOKEN_API_CLAUDE_MODEL:-opus}"
DISCORD_CHANNEL=""
NO_WORKTREE=false
WORKTREE_BRANCH=""
DRY_RUN=false
INTERACTIVE=false
DISPATCH_SELF=false
DISPATCH_AUTO_EXPANDED_PANE=""
DB_PATH="${TOKEN_API_DB:-$HOME/.claude/agents.db}"

# Positional target shorthand: `dispatch legion ...` ≡ `dispatch --target mechanicus:new ...`
# (same for mechanicus/civic and fixed prealloc pages palace/somnium). Only the
# leading token is consumed so a prompt word like "legion" is never swallowed.
# An explicit --target later still wins.
case "${1:-}" in
  legion|mechanicus)
    TARGET="mechanicus:new"
    shift
    ;;
  civic|palace|somnium)
    TARGET="$1:new"
    shift
    ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --engine) ENGINE="${2:-}"; ENGINE_EXPLICIT=true; shift 2 ;;
    --model) CLAUDE_MODEL="${2:-}"; shift 2 ;;
    --repo) REPO="${2:-}"; shift 2 ;;
    --id|--resume|-r)
      if [[ $# -lt 2 || "${2:-}" == --* ]]; then
        err "--id/--resume/-r requires an instance id or session_id"
        exit 64
      fi
      RESUME_REQUESTED=true
      RESUME_ID="$2"
      shift 2
      ;;
    --aspirant) ASPIRANT=true; shift ;;
    --aspirant-kind) ASPIRANT_KIND="${2:-}"; shift 2 ;;
    --intake-only) INTAKE_ONLY=true; shift ;;
    --kind) ASPIRANT_KIND="${2:-}"; KIND_ALIAS_USED=true; shift 2 ;;
    --direct) DIRECT=true; shift ;;
    --session-domain) SESSION_DOMAIN="${2:-}"; shift 2 ;;
    --persona) PERSONA="${2:-}"; shift 2 ;;
    --primarch) err "--primarch is deprecated; use --persona"; exit 64 ;;
    --dir|-C) WORK_DIR="${2:-}"; WORK_DIR_EXPLICIT=true; shift 2 ;;
    --title) TITLE="${2:-}"; shift 2 ;;
    --objective) OBJECTIVE="${2:-}"; OBJECTIVE_EXPLICIT=true; shift 2 ;;
    --victory-condition|--victory-conditions) VICTORY_CONDITIONS+=("${2:-}"); shift 2 ;;
    --source) ASPIRANT_SOURCE="${2:-}"; shift 2 ;;
    --session-doc) SESSION_DOC="${2:-}"; shift 2 ;;
    --prompt) PROMPT="${2:-}"; shift 2 ;;
    --prompt-file) PROMPT_FILE="${2:-}"; shift 2 ;;
    --system-prompt) SYSTEM_PROMPT="${2:-}"; SYSTEM_PROMPT_INLINE_USED=true; shift 2 ;;
    --system-prompt-file) SYSTEM_PROMPT_FILE="${2:-}"; shift 2 ;;
    --target|--pane) TARGET="${2:-}"; shift 2 ;;
    --self) DISPATCH_SELF=true; TARGET="self"; shift ;;
    --gt) GT_MODE=true; shift ;;
    --no-gt) GT_MODE=false; shift ;;
    --zealotry) ZEALOTRY="${2:-}"; shift 2 ;;
    --sync) SYNC=true; GT_MODE=true; shift ;;
    --instance-type) INSTANCE_TYPE_OVERRIDE="${2:-}"; shift 2 ;;
    --with-browser) WITH_BROWSER=true; shift ;;
    --with-desktop) WITH_DESKTOP=true; shift ;;
    --with-mcp) WITH_MCP="${2:-}"; shift 2 ;;
    --discord) DISCORD_CHANNEL="${2:-}"; shift 2 ;;
    --no-worktree) NO_WORKTREE=true; shift ;;
    --worktree)
      if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == -* ]]; then
        err "--worktree requires a branch name"; exit 64
      fi
      WORKTREE_BRANCH="$2"; shift 2 ;;
    --dry-run) DRY_RUN=true; shift ;;
    --interactive) INTERACTIVE=true; shift ;;
    --help|-h) usage; exit 0 ;;
    --) shift; break ;;
    -*) err "unknown option: $1"; usage >&2; exit 64 ;;
    *)
      if [[ -z "$PROMPT" ]]; then PROMPT="$1"; else PROMPT+=$' '"$1"; fi
      shift
      ;;
  esac
done

dispatch_origin_is_human_surface() {
  local origin="${TOKEN_API_DISPATCH_ORIGIN:-${DISPATCH_ORIGIN:-}}"
  case "$origin" in
    d|cdc|human:d|human:cdc) return 0 ;;
    *) return 1 ;;
  esac
}

dispatch_menu_already_consumed() {
  [[ -n "${TOKEN_API_DISPATCH_MENU_CONSUMED:-${DISPATCH_MENU_CONSUMED:-}}" ]]
}

# d/cdc are human launcher surfaces. They should always get the interactive
# selector. Aspirant intake is no longer the default path; it remains available
# only through explicit --aspirant. A dispatch launch chain gets exactly one
# menu; recursive dispatches spawned after an interactive selection must not
# re-open fzf.
if dispatch_menu_already_consumed; then
  INTERACTIVE=false
elif ! $INTERACTIVE && dispatch_origin_is_human_surface; then
  INTERACTIVE=true
fi

if $RESUME_REQUESTED && { [[ -z "$RESUME_ID" ]] || [[ "$RESUME_ID" == --* ]]; }; then
  err "--id/--resume/-r requires an instance id or session_id"
  exit 64
fi

dispatch_tmux_pane() {
  if [[ -n "${TMUX_PANE:-}" ]]; then
    printf '%s' "$TMUX_PANE"
  elif command -v tmux >/dev/null 2>&1 && [[ -n "${TMUX:-}" ]]; then
    IMPERIUM_TMUX_RAW=1 tmux display-message -p '#{pane_id}' 2>/dev/null || true
  fi
}

dispatch_expand_for_fzf() {
  $DRY_RUN && return 0
  [[ -n "${TMUX:-}" ]] || return 0
  command -v tmux-grid-expand >/dev/null 2>&1 || return 0
  local pane
  pane="$(dispatch_tmux_pane)"
  [[ -n "$pane" ]] || return 0
  tmux-grid-expand --pane "$pane" --expand >/dev/null 2>&1 || return 0
  DISPATCH_AUTO_EXPANDED_PANE="$pane"
}

dispatch_retract_after_cli_prompt() {
  $DRY_RUN && return 0
  [[ -n "$DISPATCH_AUTO_EXPANDED_PANE" ]] || return 0
  [[ -n "$PROMPT" ]] || return 0
  command -v tmux-grid-expand >/dev/null 2>&1 || return 0
  tmux-grid-expand --pane "$DISPATCH_AUTO_EXPANDED_PANE" --retract >/dev/null 2>&1 || true
  DISPATCH_AUTO_EXPANDED_PANE=""
}


expand_path() {
  local path="$1"
  if [[ "$path" == "~" ]]; then
    path="$HOME"
  elif [[ "$path" == ~/* ]]; then
    path="$HOME/${path#~/}"
  fi
  printf '%s' "$path"
}

sqlite_query() {
  local sql="$1"
  [[ -f "$DB_PATH" ]] || return 0
  command -v sqlite3 >/dev/null 2>&1 || return 0
  sqlite3 -readonly -separator $'\t' "$DB_PATH" "$sql" 2>/dev/null || true
}

sqlite_query_usv() {
  local sql="$1"
  [[ -f "$DB_PATH" ]] || return 0
  command -v sqlite3 >/dev/null 2>&1 || return 0
  sqlite3 -readonly -separator $'\x1f' "$DB_PATH" "$sql" 2>/dev/null || true
}

sql_literal() {
  printf "%s" "$1" | sed "s/'/''/g"
}

ledger_resolve_field() {
  local query_key="$1" query_value="$2" field="$3"
  [[ -n "$query_value" ]] || return 0
  local tmuxctld_url="${TMUXCTLD_URL:-http://127.0.0.1:7778}"
  TMUXCTLD_URL="$tmuxctld_url" QUERY_KEY="$query_key" QUERY_VALUE="$query_value" FIELD="$field" python3 - <<'PYLEDGER'
import json
import os
import sys
import urllib.parse
import urllib.request

base = os.environ.get("TMUXCTLD_URL", "http://127.0.0.1:7778").rstrip("/")
key = os.environ.get("QUERY_KEY", "")
value = os.environ.get("QUERY_VALUE", "")
field = os.environ.get("FIELD", "")
if not key or not value or not field:
    sys.exit(0)
url = f"{base}/ledger/resolve?{urllib.parse.urlencode({key: value})}"
try:
    with urllib.request.urlopen(url, timeout=1) as resp:
        data = json.loads(resp.read().decode("utf-8"))
except Exception:
    sys.exit(0)
if not isinstance(data, dict) or not data.get("ok"):
    sys.exit(0)
result = data.get("result") if isinstance(data.get("result"), dict) else {}
if not result.get("found"):
    sys.exit(0)
row = result.get("row") if isinstance(result.get("row"), dict) else {}
value = row.get(field) or result.get(field) or ""
if value:
    print(str(value), end="")
PYLEDGER
}

pane_instance_id() {
  local pane="$1"
  local tmuxctld_url="${TMUXCTLD_URL:-http://127.0.0.1:7778}"
  TMUXCTLD_URL="$tmuxctld_url" PANE="$pane" python3 - <<'PYINSTANCE'
import json
import os
import sys
import urllib.parse
import urllib.request

base = os.environ.get("TMUXCTLD_URL", "http://127.0.0.1:7778").rstrip("/")
pane = os.environ.get("PANE", "")
if not pane:
    sys.exit(0)
url = f"{base}/tmux/instance-id-for-pane?{urllib.parse.urlencode({'pane': pane})}"
try:
    with urllib.request.urlopen(url, timeout=1) as resp:
        data = json.loads(resp.read().decode("utf-8"))
except Exception:
    sys.exit(0)
result = data.get("result") if isinstance(data, dict) else {}
value = result.get("instance_id") if isinstance(result, dict) else ""
if value:
    print(str(value), end="")
PYINSTANCE
}


resolve_caller_instance_id() {
  local row
  # tmuxctld ledger is the runtime oracle. Prefer wrapper_id because plan-cycle
  # re-execs churn engine session ids while the wrapper process persists.
  row="$(ledger_resolve_field wrapper_id "${TOKEN_API_WRAPPER_ID:-${TOKEN_API_WRAPPER_LAUNCH_ID:-}}" instance_id || true)"
  [[ -n "$row" ]] && { printf '%s' "$row"; return 0; }
  # TOKEN_API_INSTANCE_ID identifies the dispatcher. It is never forwarded as the
  # child's own instance id, but it is valid commander-edge input when no ledger
  # lookup is available (for example hermetic tests or hooks with stripped tmux).
  row="${TOKEN_API_INSTANCE_ID:-${INSTANCE_ID:-}}"
  [[ -n "$row" ]] && { printf '%s' "$row"; return 0; }
  if [[ -n "${TMUX_PANE:-}" ]]; then
    row="$(pane_instance_id "$TMUX_PANE" || true)"
    [[ -n "$row" ]] && { printf '%s' "$row"; return 0; }
  fi
  return 0
}

infer_engine() {
  local engine="$1" launcher="$2"
  if [[ -n "$engine" ]]; then
    printf '%s' "$engine"
  elif [[ "$launcher" == *codex* ]]; then
    printf 'codex'
  else
    printf 'claude'
  fi
}

normalize_persona_key() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr '_' '-'
}

persona_engine_binding() {
  case "$(normalize_persona_key "$1")" in
    custodes) printf 'claude' ;;
    inquisitor|inquisition) printf 'codex' ;;
  esac
}

apply_persona_engine_binding() {
  local bound=""
  [[ -n "$PERSONA" ]] || return 0
  bound="$(persona_engine_binding "$PERSONA")"
  [[ -n "$bound" ]] && ENGINE="$bound"
  return 0
}

apply_codex_profile_default() {
  # dispatch never derives a Codex CLI profile from persona/harness choice.
  # TOKEN_API_CODEX_PROFILE is passthrough-only when the caller supplied it.
  return 0
}

resolve_persona_name() {
  local input="$1" row
  [[ -n "$input" ]] || return 0
  row="$(PYTHONPATH="${LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" python3 - "$input" <<'PY_RESOLVE_PERSONA' 2>/dev/null || true
import sys
from persona_behavior import resolve_persona
row = resolve_persona(sys.argv[1])
if row:
    print(row.slug)
PY_RESOLVE_PERSONA
)"
  [[ -n "$row" ]] && printf '%s' "$row"
  return 0
}

persona_behavior_file_for() {
  local input="$1" file
  [[ -n "$input" ]] || return 0
  file="$(PYTHONPATH="${LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" python3 - "$input" <<'PY_PERSONA_FILE' 2>/dev/null || true
import sys
from persona_behavior import resolve_behavior_file
path = resolve_behavior_file(sys.argv[1])
if path:
    print(path)
PY_PERSONA_FILE
)"
  [[ -n "$file" ]] && printf '%s' "$file"
  return 0
}

check_persona_behavior_invariant() {
  local output rc
  output="$(PYTHONPATH="${LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" python3 -m persona_behavior check 2>&1)" || rc=$?
  rc="${rc:-0}"
  if [[ "$rc" != "0" ]]; then
    while IFS= read -r line; do
      [[ -n "$line" ]] && err "$line"
    done <<< "$output"
    err "persona behavior-file invariant failed; refusing dispatch to prevent persona inheritance/theft"
    exit 66
  fi
}

canonicalize_persona() {
  local canonical
  [[ -n "$PERSONA" ]] || return 0
  canonical="$(resolve_persona_name "$PERSONA")"
  [[ -n "$canonical" ]] && PERSONA="$canonical"
  return 0
}

persona_vault_root() {
  local vault_name="$1"
  case "$vault_name" in
    Imperium-ENV|imperium|Imperium)
      if [[ -n "${IMPERIUM:-}" && -d "${IMPERIUM}/Imperium-ENV" ]]; then
        printf '%s/Imperium-ENV' "$IMPERIUM"
      fi
      ;;
    Pax-ENV|civic|Civic)
      if [[ -n "${CIVIC:-}" && -d "${CIVIC}/Pax-ENV" ]]; then
        printf '%s/Pax-ENV' "$CIVIC"
      fi
      ;;
  esac
  return 0
}

find_local_persona_file() {
  local name="$1" dir candidate cap_name
  cap_name="$(printf '%s' "$name" | awk -F- '{for(i=1;i<=NF;i++){ $i=toupper(substr($i,1,1)) substr($i,2)}; print}' OFS='-')"
  for dir in "$WORK_DIR" "$(pwd)" "$(vault_root_for_aspirant 2>/dev/null || true)"; do
    [[ -n "$dir" && -d "$dir/Personas" ]] || continue
    for candidate in "$dir/Personas/${name}.md" "$dir/Personas/${cap_name}.md"; do
      [[ -f "$candidate" ]] && { printf '%s' "$candidate"; return 0; }
    done
    candidate="$(find "$dir/Personas" -maxdepth 1 -type f -iname "${name}.md" -print -quit 2>/dev/null || true)"
    [[ -n "$candidate" ]] && { printf '%s' "$candidate"; return 0; }
  done
  return 0
}

# Operational metadata for a persona launch — vault domain and linked session-doc
# id. The DOCTRINE body (the rank+persona system-doc staple)
# is no longer assembled here: the agent wrapper is now the single injector
# (token_wrapper_system_doc reads Personas/*.md + Ranks/*.md, rank-first). Dispatch
# only forwards this *operational* metadata as env vars the wrapper folds in beneath
# the staple (token_wrapper_operational_appendix). Emits vault_name<US>doc_id
# on stdout; any field may be empty (the wrapper omits the corresponding lines).
persona_operational_env() {
  local persona="$1" persona_sql row title vault_name note_path vault_root persona_file doc_id
  [[ -n "$persona" ]] || return 0
  persona_file="$(persona_behavior_file_for "$persona")"
  persona_sql="$(sql_literal "$persona")"
  row="$(sqlite_query_usv "
    SELECT COALESCE(title, ''), COALESCE(vault, ''), COALESCE(vault_note_path, '')
    FROM primarchs
    WHERE name = '${persona_sql}'
    LIMIT 1;
  ")"
  if [[ -n "$row" ]]; then
    IFS=$'\x1f' read -r title vault_name note_path <<< "$row"
    vault_root="$(persona_vault_root "$vault_name")"
    [[ -z "${persona_file:-}" && -n "$vault_root" && -n "$note_path" ]] && persona_file="$vault_root/$note_path"
  fi
  if [[ -z "${persona_file:-}" || ! -f "$persona_file" ]]; then
    persona_file="$(find_local_persona_file "$persona")"
  fi
  # Vault domain falls back to the persona file's owning vault (…/<Vault>/Personas/x.md).
  if [[ -z "${vault_name:-}" && -n "${persona_file:-}" && -f "$persona_file" ]]; then
    vault_name="$(basename "$(dirname "$(dirname "$persona_file")")")"
  fi
  doc_id="$(sqlite_query "SELECT session_doc_id FROM primarch_session_docs WHERE primarch_name = '${persona_sql}' AND unlinked_at IS NULL LIMIT 1;")"
  printf '%s\x1f%s' "${vault_name:-}" "${doc_id:-}"
}

dedupe_tsv() {
  awk -F '\t' 'NF && !seen[$1]++'
}

compact_path() {
  local path="$1"
  path="${path/#$HOME/~}"
  printf '%s' "$path"
}

directory_candidates() {
  local current
  current="$(expand_path "$WORK_DIR")"
  printf '%s\tcurrent: %s\n' "$current" "$(compact_path "$current")"

  local path label
  for path in \
    "/Volumes/Imperium/Imperium-ENV" \
    "/Volumes/Civic/Pax-ENV" \
    "${TOKEN_OS_RUNTIME_CHECKOUT:-$HOME/runtimes/Token-OS/live}" \
    "$HOME/worktrees/Token-OS" \
    "$HOME/worktrees/askCivic" \
    "${TERMINUS_RUNTIME_CHECKOUT:-$HOME/runtimes/askCivic/terminus-preview}" \
    "/Volumes/Civic/askcivic.git"
  do
    [[ -d "$path" ]] || continue
    label="$(basename "$path")"
    printf '%s\t%s\n' "$path" "$label"
  done

  sqlite_query "
    SELECT DISTINCT working_dir, COALESCE(MAX(last_activity), '')
    FROM instances
    WHERE working_dir IS NOT NULL AND working_dir != ''
    GROUP BY working_dir
    ORDER BY MAX(last_activity) DESC
    LIMIT 40;
  " | while IFS=$'\t' read -r path _ts; do
    [[ -n "$path" && -d "$path" ]] || continue
    printf '%s\trecent: %s\n' "$path" "$(compact_path "$path")"
  done
}

session_doc_candidates() {
  printf '%s\t%s\n' '__none__' 'new session doc'
  printf '%s\t%s\n' '__resume__' 'resume a session'
  sqlite_query "
    SELECT file_path,
           COALESCE(NULLIF(title, ''), '')
    FROM session_documents
    WHERE file_path IS NOT NULL AND file_path != ''
    ORDER BY CASE status WHEN 'active' THEN 0 ELSE 1 END, updated_at DESC
    LIMIT 80;
  " | while IFS=$'\t' read -r file_path title; do
    [[ -n "$file_path" ]] || continue
    local label="$title"
    if [[ -z "$label" ]]; then
      label="$(basename "$file_path")"
      label="${label%.md}"
    fi
    printf '%s\t%s\n' "$file_path" "$label"
  done
}

resume_session_candidates() {
  sqlite_query "
    SELECT id,
           COALESCE(NULLIF(name, ''), NULLIF(pane_label, ''), NULLIF(engine, ''), substr(id, 1, 8))
    FROM instances
    WHERE id IS NOT NULL AND id != ''
    ORDER BY last_activity DESC
    LIMIT 80;
  " | while IFS=$'\t' read -r session_id label; do
    [[ -n "$session_id" ]] || continue
    printf '%s\t%s\n' "$session_id" "${label:-${session_id:0:8}}"
  done
}

normalize_harness() {
  case "$1" in
    claude|codex) printf '%s' "$1" ;;
    *) printf 'claude' ;;
  esac
}

dispatch_harness_state_file() {
  expand_path "${DISPATCH_HARNESS_STATE_FILE:-$HOME/.config/imperium/dispatch-harness}"
}

dispatch_harness_state_allowed() {
  dispatch_origin_is_human_surface || return 1
  [[ -z "${TOKEN_API_INTERNAL_DISPATCH:-}" ]] || return 1
  return 0
}

read_dispatch_harness_state() {
  local state_file value
  dispatch_harness_state_allowed || { printf 'claude'; return 0; }
  state_file="$(dispatch_harness_state_file)"
  value="$(cat "$state_file" 2>/dev/null || true)"
  normalize_harness "$value"
}

write_dispatch_harness_state() {
  local value="$1" state_file dir
  dispatch_harness_state_allowed || return 0
  value="$(normalize_harness "$value")"
  state_file="$(dispatch_harness_state_file)"
  dir="$(dirname "$state_file")"
  mkdir -p "$dir" 2>/dev/null || true
  printf '%s\n' "$value" >"$state_file" 2>/dev/null || true
}

persona_harness_label() {
  case "$(normalize_harness "$1")" in
    codex) printf 'Codex' ;;
    *) printf 'Claude' ;;
  esac
}

persona_candidate_default() {
  local harness="$1"
  printf '__astartes__\tAstartes — %s\n' "$(persona_harness_label "$harness")"
}

persona_candidate_rows() {
  local name title group rank

  sqlite_query "
    SELECT name, COALESCE(title, ''), COALESCE(launcher_group, ''), COALESCE(launcher_rank, 100)
    FROM primarchs
    WHERE COALESCE(launcher_hidden, 0) = 0
    ORDER BY CASE COALESCE(launcher_group, '') WHEN 'common' THEN 0 WHEN 'default' THEN 1 ELSE 2 END,
             COALESCE(launcher_rank, 100), name;
  " | while IFS=$'\t' read -r name title group rank; do
    [[ -n "$name" ]] || continue
    printf '%s\t%s%s\n' "$name" "$name" "${title:+ — $title}"
  done
}

persona_candidates() {
  local harness="${1:-$ENGINE}"
  persona_candidate_default "$harness"
  persona_candidate_rows
}

mode_candidates() {
  local default_mode="$1"
  case "$default_mode" in
    golden_throne) printf 'golden_throne\tGolden Throne (--gt, zealotry 5)\n' ;;
    sync)          printf 'sync\tSync session (--sync, zealotry 5)\n' ;;
    one_off)       printf 'one_off\tOne-off (--no-gt, zealotry 3)\n' ;;
  esac
  [[ "$default_mode" != "golden_throne" ]] && printf 'golden_throne\tGolden Throne (--gt, zealotry 5)\n'
  [[ "$default_mode" != "sync" ]] && printf 'sync\tSync session (--sync, zealotry 5)\n'
  [[ "$default_mode" != "one_off" ]] && printf 'one_off\tOne-off (--no-gt, zealotry 3)\n'
  return 0
}

interactive_override_for() {
  case "$1" in
    dir) printf '%s' "${DISPATCH_INTERACTIVE_DIR:-}" ;;
    session_doc) printf '%s' "${DISPATCH_INTERACTIVE_SESSION_DOC:-}" ;;
    resume) printf '%s' "${DISPATCH_INTERACTIVE_RESUME:-}" ;;
    persona) printf '%s' "${DISPATCH_INTERACTIVE_PERSONA:-}" ;;
    mode) printf '%s' "${DISPATCH_INTERACTIVE_MODE:-}" ;;
  esac
}

read_interactive_objective() {
  local override="${DISPATCH_INTERACTIVE_OBJECTIVE:-}" objective=""
  if [[ -n "$override" ]]; then
    printf '%s' "$override"
    return 0
  fi
  [[ -t 0 && -r /dev/tty ]] || return 0
  printf 'objective> ' > /dev/tty
  IFS= read -r objective < /dev/tty || true
  [[ -n "$objective" ]] || { err "interactive aspirant objective cancelled"; exit 130; }
  printf '%s' "$objective"
}

pick_fzf_value() {
  local key="$1" prompt="$2" default_value="$3" input selection override
  input="$(cat)"
  override="$(interactive_override_for "$key")"
  if [[ -n "$override" ]]; then
    case "$override" in none|NONE|__none__) printf '__none__';; *) printf '%s' "$override";; esac
    return 0
  fi

  if [[ ! -t 2 || ! -r /dev/tty ]]; then
    printf '%s' "$default_value"
    return 0
  fi

  command -v fzf >/dev/null 2>&1 || { err "fzf is required for --interactive"; exit 69; }
  selection="$(printf '%s\n' "$input" | fzf --height=40% --reverse --cycle --bind='tab:down,btab:up' --delimiter=$'\t' --with-nth=2.. --prompt="$prompt" || true)"
  [[ -n "$selection" ]] || { err "interactive selection cancelled"; exit 130; }
  printf '%s' "${selection%%$'\t'*}"
}

pick_persona_value() {
  local default_value="$1" current_harness="$2" selection override tmp_harness tmp_rows state_file toggle_cmd reload_cmd
  override="$(interactive_override_for persona)"
  if [[ -n "$override" ]]; then
    case "$override" in none|NONE|__none__) printf '__none__';; *) printf '%s' "$override";; esac
    return 0
  fi

  if [[ ! -t 2 || ! -r /dev/tty ]]; then
    printf '%s' "$default_value"
    return 0
  fi

  command -v fzf >/dev/null 2>&1 || { err "fzf is required for --interactive"; exit 69; }
  tmp_harness="$(mktemp -t dispatch-harness.XXXXXX)"
  tmp_rows="$(mktemp -t dispatch-personas.XXXXXX)"
  printf '%s\n' "$(normalize_harness "$current_harness")" >"$tmp_harness"
  persona_candidate_rows >"$tmp_rows"
  state_file=""
  dispatch_harness_state_allowed && state_file="$(dispatch_harness_state_file)"

  reload_cmd='h="$(cat "$1" 2>/dev/null || printf claude)"; case "$h" in codex) label=Codex ;; *) h=claude; label=Claude ;; esac; printf "__astartes__\tAstartes — %s\n" "$label"; cat "$2"'
  toggle_cmd='h="$(cat "$1" 2>/dev/null || printf claude)"; case "$h" in codex) n=claude ;; *) n=codex ;; esac; printf "%s\n" "$n" > "$1"; if [[ -n "${2:-}" ]]; then mkdir -p "$(dirname "$2")" 2>/dev/null || true; printf "%s\n" "$n" > "$2" 2>/dev/null || true; fi'
  selection="$(
    bash -c "$reload_cmd" dispatch-personas "$tmp_harness" "$tmp_rows" |
      fzf --height=40% --reverse --cycle \
        --bind="tab:execute-silent(bash -c $(printf '%q' "$toggle_cmd") dispatch-toggle $(printf '%q' "$tmp_harness") $(printf '%q' "$state_file"))+reload(bash -c $(printf '%q' "$reload_cmd") dispatch-personas $(printf '%q' "$tmp_harness") $(printf '%q' "$tmp_rows"))" \
        --bind='btab:up' \
        --delimiter=$'\t' --with-nth=2.. --prompt='persona> ' || true
  )"
  DISPATCH_MENU_HARNESS="$(normalize_harness "$(cat "$tmp_harness" 2>/dev/null || true)")"
  rm -f "$tmp_harness" "$tmp_rows"
  [[ -n "$selection" ]] || { err "interactive selection cancelled"; exit 130; }
  printf '%s' "${selection%%$'\t'*}"
}

run_interactive_selection() {
  local selected default_mode

  DISPATCH_MENU_HARNESS="$(normalize_harness "$ENGINE")"
  if dispatch_harness_state_allowed; then
    if $ENGINE_EXPLICIT; then
      DISPATCH_MENU_HARNESS="$(normalize_harness "$ENGINE")"
    else
      DISPATCH_MENU_HARNESS="$(read_dispatch_harness_state)"
      ENGINE="$DISPATCH_MENU_HARNESS"
    fi
  fi

  WORK_DIR="$(expand_path "$WORK_DIR")"
  if ! $WORK_DIR_EXPLICIT; then
    selected="$(directory_candidates | dedupe_tsv | pick_fzf_value dir 'dir> ' "$WORK_DIR")"
    [[ -n "$selected" ]] && WORK_DIR="$selected"
  fi

  selected="$(session_doc_candidates | dedupe_tsv | pick_fzf_value session_doc 'session-doc> ' "${SESSION_DOC:-__none__}")"
  case "$selected" in
    __none__|none)
      SESSION_DOC=""
      ;;
    __resume__|resume)
      selected="$(resume_session_candidates | dedupe_tsv | pick_fzf_value resume 'resume> ' "${RESUME_ID:-}")"
      [[ -n "$selected" ]] || { err "no resumable sessions found"; exit 66; }
      RESUME_ID="$selected"
      ASPIRANT=false
      DIRECT=true
      return 0
      ;;
    *)
      SESSION_DOC="$selected"
      ;;
  esac

  local default_persona
  if [[ -n "$PERSONA" ]]; then
    default_persona="$PERSONA"
  else
    default_persona="__astartes__"
  fi
  selected="$(pick_persona_value "$default_persona" "$DISPATCH_MENU_HARNESS")"
  case "$selected" in
    __astartes__|astartes)
      PERSONA=""
      ENGINE="$(normalize_harness "$DISPATCH_MENU_HARNESS")"
      ;;
    __none__|none)
      PERSONA=""
      ;;
    *)
      PERSONA="$selected"
      ENGINE="$(normalize_harness "$DISPATCH_MENU_HARNESS")"
      ;;
  esac

  if $SYNC; then default_mode="sync"; elif $GT_MODE; then default_mode="golden_throne"; else default_mode="one_off"; fi
  selected="$(mode_candidates "$default_mode" | dedupe_tsv | pick_fzf_value mode 'mode> ' "$default_mode")"
  case "$selected" in
    golden_throne) GT_MODE=true;  SYNC=false ;;
    sync)          GT_MODE=true;  SYNC=true ;;
    one_off)       GT_MODE=false; SYNC=false ;;
    *) err "unknown interactive mode: $selected"; exit 64 ;;
  esac
  return 0
}

if $INTERACTIVE && [[ -z "$RESUME_ID" ]]; then
  dispatch_expand_for_fzf
  run_interactive_selection
  export TOKEN_API_DISPATCH_MENU_CONSUMED=1
  export DISPATCH_MENU_CONSUMED=1
fi

default_human_surface_target() {
  # A typed `d`/`cdc` dispatch from inside tmux should occupy the invoking pane by
  # default. Prefix+Space remains the explicit new-legion-pane launcher because it
  # passes --target mechanicus:new.
  [[ -z "$TARGET" ]] || return 0
  dispatch_origin_is_human_surface || return 0
  [[ -n "$(dispatch_tmux_pane)" ]] || return 0
  TARGET="self"
}
default_human_surface_target

if $KIND_ALIAS_USED && ! $ASPIRANT; then
  err "--kind is only valid as an alias for --aspirant-kind when --aspirant is set"
  exit 64
fi
case "$ASPIRANT_KIND" in
  dispatch|deploy_p|deploy_d) ;;
  *) err "--aspirant-kind must be dispatch, deploy_p, or deploy_d"; exit 64 ;;
esac
case "$SESSION_DOMAIN" in
  ""|terra|mars) ;;
  *) err "--session-domain must be terra or mars"; exit 64 ;;
esac
if $ASPIRANT && $DIRECT; then
  err "--aspirant and --direct are mutually exclusive"
  exit 64
fi

auto_aspirant_policy_applies() {
  # Temporary safety valve while the Aspirant + Golden Throne systems are not
  # reliable enough to be defaults. Explicit --aspirant still works, and the
  # old auto-intake behavior can be restored per-call/session by setting
  # TOKEN_API_DISPATCH_AUTO_ASPIRANT=1.
  [[ "${TOKEN_API_DISPATCH_AUTO_ASPIRANT:-}" == "1" ]] || return 1
  $DIRECT && return 1
  [[ -n "$RESUME_ID" ]] && return 1
  [[ -n "${TOKEN_API_INTERNAL_DISPATCH:-}" ]] && return 1
  [[ -n "${TOKEN_API_ASPIRANT_PIPELINE:-}" ]] && return 1
  [[ -n "$PERSONA" ]] && return 1

  dispatch_origin_is_human_surface
}

if ! $ASPIRANT && auto_aspirant_policy_applies; then
  ASPIRANT=true
  ASPIRANT_KIND="dispatch"
fi

RESUME_INSTANCE_TYPE=""
RESUME_LAUNCHER=""
RESUME_PRIMARCH=""
RESUME_PARENT_INSTANCE_ID=""
RESUME_DISPATCH_TARGET=""
RESUME_DISPATCH_WINDOW=""
RESUME_DISPATCH_MODE=""
RESUME_DISPATCH_SLOT=""
RESUME_LAUNCH_MODE=""
RESUME_TMUX_PANE=""
RESUME_DISCORD_HOSTED=""
RESUME_DISCORD_CHANNEL=""
RESUME_DISCORD_BOT=""

api_instance_resume_row() {
  local instance_id="$1"
  local api_url="${TOKEN_API_URL:-http://localhost:7777}"
  API_URL="$api_url" INSTANCE_ID="$instance_id" python3 - <<'PYAPI'
import json
import os
import sys
import urllib.error
import urllib.parse
import urllib.request

api = os.environ.get("API_URL", "http://localhost:7777").rstrip("/")
iid = os.environ.get("INSTANCE_ID", "")
if not iid:
    sys.exit(0)

url = f"{api}/api/instances/{urllib.parse.quote(iid, safe='')}"
try:
    with urllib.request.urlopen(url, timeout=2) as resp:
        data = json.loads(resp.read().decode("utf-8"))
except urllib.error.HTTPError as exc:
    if exc.code == 404:
        sys.exit(0)
    print(f"Token API instance lookup failed for {iid}: HTTP {exc.code}", file=sys.stderr)
    sys.exit(1)
except Exception as exc:
    print(f"Token API instance lookup failed for {iid}: {exc}", file=sys.stderr)
    sys.exit(1)

if not isinstance(data, dict) or data.get("id") != iid:
    print(f"Token API instance lookup returned invalid payload for {iid}", file=sys.stderr)
    sys.exit(1)
if not data.get("engine") or not (data.get("target_working_dir") or data.get("working_dir")):
    print(f"Token API instance lookup returned incomplete metadata for {iid}", file=sys.stderr)
    sys.exit(1)

session_doc = data.get("session_doc") if isinstance(data.get("session_doc"), dict) else {}
persona = data.get("persona") if isinstance(data.get("persona"), dict) else {}
instance_type = data.get("instance_type")
if not instance_type:
    gt = data.get("golden_throne")
    if gt == "sync":
        instance_type = "sync"
    elif gt is not None and gt != "":
        instance_type = "golden_throne"
    else:
        instance_type = "one_off"

parent = data.get("parent_instance_id")
if not parent and data.get("commander_type") == "chapter":
    parent = data.get("commander_id")

values = [
    data.get("id"),
    data.get("engine"),
    data.get("launcher"),
    data.get("target_working_dir"),
    data.get("working_dir"),
    data.get("dispatch_session_doc_path"),
    session_doc.get("file_path"),
    instance_type,
    data.get("zealotry"),
    data.get("dispatch_target"),
    data.get("dispatch_window"),
    data.get("dispatch_mode"),
    data.get("dispatch_slot"),
    data.get("launch_mode"),
    data.get("tmux_pane") or data.get("runtime_pane") or data.get("pane_id"),
    persona.get("slug") or data.get("persona_slug") or data.get("profile_name") or data.get("legion"),
    parent,
    data.get("discord_hosted"),
    data.get("discord_channel"),
    data.get("discord_bot"),
]
print("\x1f".join("" if v is None else str(v) for v in values))
PYAPI
}

resolve_resume_id() {
  local row status
  set +e
  row="$(api_instance_resume_row "$RESUME_ID")"
  status=$?
  set -e
  if (( status != 0 )); then
    err "--id ${RESUME_ID} metadata lookup failed via Token API"
    exit 70
  fi

  if [[ -z "$row" ]]; then
    if ! $ENGINE_EXPLICIT || ! $WORK_DIR_EXPLICIT; then
      err "--id ${RESUME_ID} was not found via Token API; pass explicit --engine and --dir to resume without API metadata"
      exit 66
    fi
    RESUME_ROW_FOUND=false
    return 0
  fi

  RESUME_ROW_FOUND=true
  local row_id row_engine row_launcher row_target_dir row_work_dir row_dispatch_doc row_doc_path row_type row_zealotry
  IFS=$'\x1f' read -r row_id row_engine row_launcher row_target_dir row_work_dir row_dispatch_doc row_doc_path row_type row_zealotry \
    RESUME_DISPATCH_TARGET RESUME_DISPATCH_WINDOW RESUME_DISPATCH_MODE RESUME_DISPATCH_SLOT RESUME_LAUNCH_MODE \
    RESUME_TMUX_PANE RESUME_PRIMARCH RESUME_PARENT_INSTANCE_ID RESUME_DISCORD_HOSTED RESUME_DISCORD_CHANNEL RESUME_DISCORD_BOT <<< "$row"

  # Canonical instance id (== @INSTANCE_ID stamped by SessionStart). RESUME_ID may
  # already is an instance id; stamp that canonical id.
  RESUME_INSTANCE_ID="$row_id"
  ENGINE="$(infer_engine "$row_engine" "$row_launcher")"
  RESUME_LAUNCHER="$row_launcher"
  [[ -n "$row_target_dir" ]] && WORK_DIR="$row_target_dir"
  [[ -z "$row_target_dir" && -n "$row_work_dir" ]] && WORK_DIR="$row_work_dir"
  [[ -n "$row_dispatch_doc" ]] && SESSION_DOC="$row_dispatch_doc"
  [[ -z "$row_dispatch_doc" && -n "$row_doc_path" ]] && SESSION_DOC="$row_doc_path"
  RESUME_INSTANCE_TYPE="$row_type"
  [[ -n "$row_zealotry" ]] && ZEALOTRY="$row_zealotry"

  case "$RESUME_INSTANCE_TYPE" in
    sync) SYNC=true; GT_MODE=true ;;
    golden_throne) SYNC=false; GT_MODE=true ;;
    one_off) SYNC=false; GT_MODE=false ;;
  esac
}

if [[ -n "$RESUME_ID" ]]; then
  resolve_resume_id
fi

canonicalize_persona
apply_persona_engine_binding
apply_codex_profile_default

case "$ENGINE" in
  claude|codex) ;;
  *) err "--engine must be claude or codex"; exit 64 ;;
esac

if [[ -n "$PROMPT_FILE" ]]; then
  [[ -f "$PROMPT_FILE" ]] || { err "prompt file not found: $PROMPT_FILE"; exit 66; }
  FILE_PROMPT="$(cat "$PROMPT_FILE")"
  if [[ -n "$PROMPT" ]]; then PROMPT="${PROMPT}"$'\n\n'"${FILE_PROMPT}"; else PROMPT="$FILE_PROMPT"; fi
fi
if [[ -n "$SYSTEM_PROMPT_FILE" ]]; then
  [[ -f "$SYSTEM_PROMPT_FILE" ]] || { err "system prompt file not found: $SYSTEM_PROMPT_FILE"; exit 66; }
  FILE_SYSTEM_PROMPT="$(cat "$SYSTEM_PROMPT_FILE")"
  if [[ -n "$SYSTEM_PROMPT" ]]; then SYSTEM_PROMPT="${SYSTEM_PROMPT}"$'\n\n'"${FILE_SYSTEM_PROMPT}"; else SYSTEM_PROMPT="$FILE_SYSTEM_PROMPT"; fi
fi
if $INTERACTIVE && $ASPIRANT && [[ -z "$PROMPT" && -z "$OBJECTIVE" ]]; then
  PROMPT="$(read_interactive_objective)"
fi
# Worktree dispatches derive metadata from the branch + prompt heading when the
# caller omitted it (Fix #5): a short objective from the prompt's first non-blank
# line (heading marker stripped) rather than the whole prompt, and a title from
# the branch name. Explicit --title/--objective always win.
if [[ -n "$WORKTREE_BRANCH" ]]; then
  if [[ -z "$OBJECTIVE" && -n "$PROMPT" ]]; then
    OBJECTIVE="$(printf '%s\n' "$PROMPT" | sed -E '/^[[:space:]]*$/d' | head -n1 | sed -E 's/^[[:space:]]*#+[[:space:]]*//')"
  fi
  if [[ -z "$TITLE" ]]; then
    TITLE="$(printf '%s' "$WORKTREE_BRANCH" | tr '_-' '  ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//')"
  fi
fi
if [[ -z "$OBJECTIVE" && -n "$PROMPT" ]]; then
  OBJECTIVE="$PROMPT"
fi
if [[ -z "$TITLE" && -n "$OBJECTIVE" ]]; then
  TITLE="$(printf '%s' "$OBJECTIVE" | tr '\n' ' ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//' | cut -c1-80)"
fi
[[ -z "$TITLE" ]] && TITLE="Dispatch aspirant"

# --objective is aspirant-only metadata: for the aspirant pipeline it becomes the
# note's goal and (via prompt-fallback) the brief. A DIRECT launch, by contrast,
# delivers its task through --prompt/--prompt-file or --session-doc; --objective
# carries nowhere. So a direct launch given --objective but neither a prompt nor a
# session doc boots the agent idle with no instructions — the exact trap that left
# the 2026-06-20 canary briefless. Warn (don't hard-fail, to avoid breaking any
# existing caller) so the operator knows to attach a real brief.
if ! $ASPIRANT && $OBJECTIVE_EXPLICIT && [[ -z "$RESUME_ID" && -z "$PROMPT" && -z "$SESSION_DOC" ]]; then
  err "warning: --objective is aspirant-only metadata and does not brief a direct launch;"
  err "         the agent will boot idle. Pass --prompt/--prompt-file or --session-doc to deliver the task."
fi

if [[ -n "$SYSTEM_PROMPT" && "$ENGINE" == "codex" ]]; then
  err "--system-prompt/--system-prompt-file are not supported for --engine codex"
  exit 64
fi
if $ASPIRANT && $SYSTEM_PROMPT_INLINE_USED; then
  err "--system-prompt text is not supported with --aspirant yet; use --system-prompt-file"
  exit 64
fi

# --repo <name> resolves the worktree config in ~/.config/worktrees/<name>.conf
# (case-insensitively — confs are e.g. Token-OS.conf but `--repo token-os` is
# natural) and branches the dispatch from that project's prod checkout, so the
# common path need not pass a full --dir. maybe_enter_worktree then auto-detects
# the project from that dir. An explicit --dir always wins.
if [[ -n "$REPO" ]]; then
  REPO_CONF=""
  if [[ -f "$HOME/.config/worktrees/${REPO}.conf" ]]; then
    REPO_CONF="$HOME/.config/worktrees/${REPO}.conf"
  else
    repo_lc="$(printf '%s' "$REPO" | tr '[:upper:]' '[:lower:]')"
    for _conf in "$HOME"/.config/worktrees/*.conf; do
      [[ -f "$_conf" ]] || continue
      if [[ "$(basename "$_conf" .conf | tr '[:upper:]' '[:lower:]')" == "$repo_lc" ]]; then
        REPO_CONF="$_conf"; break
      fi
    done
  fi
  [[ -n "$REPO_CONF" ]] || { err "--repo '$REPO': no config at ~/.config/worktrees/${REPO}.conf"; exit 66; }
  # Anchor the dispatch on BARE_REPO: worktree-setup always cuts the new worktree
  # from it, so it is the single source of truth for the base. Token-OS PROTECTED_ROOT
  # is the legacy NAS archive guard, not a checkout to branch from; anchoring there
  # made --repo land in / cut from the stale archived tree (P3, 2026-06-18). Prefer
  # BARE_REPO when present on disk; fall back to PROTECTED_ROOT/SECRETS_DIR only when
  # the bare is unreachable so configs whose bare lives on an unmounted NAS still
  # resolve to their local guard. maybe_enter_worktree redirects a BARE_REPO anchor
  # into a fresh per-branch worktree, never running an agent in the bare repo.
  REPO_ROOT="$( BARE_REPO=""; WORKTREE_PARENT=""; SECRETS_DIR=""; PROTECTED_ROOT=""; RUNTIME_CHECKOUT=""; SYNC_SUBDIR=""
    # shellcheck disable=SC1090
    source "$REPO_CONF" 2>/dev/null || true
    if [[ -n "$BARE_REPO" && -d "$BARE_REPO" ]]; then printf '%s' "$BARE_REPO";
    elif [[ -n "$PROTECTED_ROOT" ]]; then printf '%s' "$PROTECTED_ROOT";
    elif [[ -n "$SECRETS_DIR" ]]; then printf '%s' "$SECRETS_DIR";
    else printf '%s' "$BARE_REPO"; fi )"
  [[ -n "$REPO_ROOT" ]] || { err "--repo '$REPO': config has no PROTECTED_ROOT, SECRETS_DIR, or BARE_REPO ($REPO_CONF)"; exit 66; }
  # Quarantine guard (incident 2026-06-22): never anchor on a bare/checkout in a
  # recycle bin or dated legacy archive — worktrees cut from it bind their
  # commondir into a purge target (silent data loss when the bin empties).
  if declare -f imperium_path_is_quarantined >/dev/null 2>&1 \
        && imperium_path_is_quarantined "$REPO_ROOT"; then
    err "--repo '$REPO': resolved root is quarantined (recycle bin / legacy archive): $REPO_ROOT"
    err "Fix BARE_REPO in $REPO_CONF to point at the canonical bare."
    exit 64
  fi
  if ! $WORK_DIR_EXPLICIT; then
    WORK_DIR="$REPO_ROOT"
    WORK_DIR_EXPLICIT=true
  fi
fi

WORK_DIR="$(eval echo "$WORK_DIR")"
if ! $ASPIRANT || [[ "$ASPIRANT_KIND" == "dispatch" ]]; then
  [[ -d "$WORK_DIR" ]] || { err "working directory does not exist: $WORK_DIR"; exit 65; }
  WORK_DIR="$(cd "$WORK_DIR" && pwd)"
fi

dispatch_retract_after_cli_prompt

if [[ -n "$INSTANCE_TYPE_OVERRIDE" ]]; then
  INSTANCE_TYPE="$INSTANCE_TYPE_OVERRIDE"
elif [[ -n "$RESUME_INSTANCE_TYPE" ]]; then
  INSTANCE_TYPE="$RESUME_INSTANCE_TYPE"
elif $SYNC; then
  INSTANCE_TYPE="sync"
elif $GT_MODE; then
  INSTANCE_TYPE="golden_throne"
else
  INSTANCE_TYPE="one_off"
fi
case "$INSTANCE_TYPE" in one_off|sync|golden_throne|hook_driven|archived) ;; *) err "--instance-type must be one of one_off, sync, golden_throne, hook_driven, archived"; exit 64 ;; esac
if [[ "$INSTANCE_TYPE" == "hook_driven" ]]; then GT_MODE=false; SYNC=false; fi
if [[ -z "$ZEALOTRY" ]]; then
  if $GT_MODE; then ZEALOTRY=5; else ZEALOTRY=3; fi
fi
if ! [[ "$ZEALOTRY" =~ ^[0-9]+$ ]] || (( ZEALOTRY < 1 || ZEALOTRY > 10 )); then
  err "--zealotry must be an integer from 1 to 10"
  exit 64
fi

build_aspirant_create_args() {
  ASPIRANT_CREATE_ARGS=(--kind "$ASPIRANT_KIND" --title "$TITLE" --objective "$OBJECTIVE" --source "$ASPIRANT_SOURCE")
  [[ -n "$SESSION_DOMAIN" ]] && ASPIRANT_CREATE_ARGS+=(--session-domain "$SESSION_DOMAIN")
  if [[ "$ASPIRANT_KIND" == "dispatch" ]]; then
    ASPIRANT_CREATE_ARGS+=(--engine "$ENGINE" --dir "$WORK_DIR" --zealotry "$ZEALOTRY")
    [[ -n "$PERSONA" ]] && ASPIRANT_CREATE_ARGS+=(--persona "$PERSONA")
    [[ -n "$TARGET" ]] && ASPIRANT_CREATE_ARGS+=(--target "$TARGET")
    [[ -n "$SESSION_DOC" ]] && ASPIRANT_CREATE_ARGS+=(--session-doc "$SESSION_DOC")
    [[ -n "$SYSTEM_PROMPT_FILE" ]] && ASPIRANT_CREATE_ARGS+=(--system-prompt-file "$SYSTEM_PROMPT_FILE")
    [[ -n "$PROMPT_FILE" ]] && ASPIRANT_CREATE_ARGS+=(--prompt-file "$PROMPT_FILE")
    local vc
    if ((${#VICTORY_CONDITIONS[@]})); then
      for vc in "${VICTORY_CONDITIONS[@]}"; do
        ASPIRANT_CREATE_ARGS+=(--victory-condition "$vc")
      done
    fi
  fi
}

run_internal_aspirant_create() {
  PYTHONPATH="${LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" python3 -m aspirant_create "${ASPIRANT_CREATE_ARGS[@]}"
}

vault_root_for_aspirant() {
  if [[ -n "${IMPERIUM:-}" ]]; then
    printf '%s/Imperium-ENV' "$IMPERIUM"
  else
    printf '%s' "/Volumes/Imperium/Imperium-ENV"
  fi
}

abs_vault_path() {
  local path="$1" vault
  vault="$(vault_root_for_aspirant)"
  if [[ "$path" = /* ]]; then
    printf '%s' "$path"
  else
    printf '%s/%s' "$vault" "$path"
  fi
}

build_aspirant_launch_prompt_file() {
  local note_rel="$1" session_doc_rel="$2" note_abs session_doc_abs prompt_file
  note_abs="$(abs_vault_path "$note_rel")"
  session_doc_abs="$(abs_vault_path "$session_doc_rel")"
  prompt_file="$(mktemp "${TMPDIR:-/tmp}/dispatch-aspirant-prompt.XXXXXX")"
  cat >"$prompt_file" <<EOF_ASPIRANT_PROMPT
# Aspirant Session Startup

You are launching a full aspirant trials session.

Read these files before acting:
- Aspirant note: ${note_abs}
- Session doc: ${session_doc_abs}

The aspirant note contains the gene-seed content. The session doc is your linked session memory.

Startup instructions:
- Orient from the linked session doc and vault context before making decisions.
- Perform concrete implantation/trials work: inspect related vault notes, validate dispatch metadata, challenge assumptions, and identify blockers.
- Append your useful output back to the aspirant note under clear \`## Implantation\` and/or \`## Trials\` sections, or concise continuations if those sections already exist.
- Maintain frontmatter \`questions\` as an array of objects. Append new entries to the end of the array; close each entry as it is answered or explicitly waived.
- Do not launch downstream workers from this aspirant session.
EOF_ASPIRANT_PROMPT
  printf '%s' "$prompt_file"
}

launch_dispatch_aspirant_session() {
  local result_json="$1" note_rel session_doc_rel vault prompt_file session_doc_abs persona_prompt mode_flag
  local -a launch_args
  note_rel="$(python3 -c 'import json,sys; print(json.load(sys.stdin).get("note_path") or "")' <<<"$result_json")"
  session_doc_rel="$(python3 -c 'import json,sys; print(json.load(sys.stdin).get("session_doc") or "")' <<<"$result_json")"
  [[ -n "$note_rel" && -n "$session_doc_rel" ]] || { err "aspirant creation did not return note/session paths"; return 70; }
  vault="$(vault_root_for_aspirant)"
  session_doc_abs="$(abs_vault_path "$session_doc_rel")"
  prompt_file="$(build_aspirant_launch_prompt_file "$note_rel" "$session_doc_rel")"

  if [[ "$INSTANCE_TYPE" == "sync" ]]; then
    mode_flag="--sync"
  elif [[ "$INSTANCE_TYPE" == "golden_throne" ]]; then
    mode_flag="--gt"
  else
    mode_flag="--no-gt"
  fi

  local launch_target="${TARGET:-mechanicus:new}"
  launch_args=(
    --direct
    --engine "$ENGINE"
    --dir "$vault"
    --target "$launch_target"
    --session-doc "$session_doc_abs"
    --prompt-file "$prompt_file"
    "$mode_flag"
    --zealotry "$ZEALOTRY"
  )
  [[ -n "$PERSONA" ]] && launch_args+=(--persona "$PERSONA")
  if [[ "$ENGINE" == "claude" ]]; then
    persona_prompt="$(aspirant_persona_prompt_path 2>/dev/null || printf '%s' "${TOKEN_OS_ROOT:-$TOKEN_OS}/cli-tools/prompts/aspirant-persona.md")"
    launch_args+=(--system-prompt-file "$persona_prompt")
  fi

  printf 'launch_action: dispatch'
  local arg
  for arg in "${launch_args[@]}"; do printf ' %q' "$arg"; done
  printf '\n'
  TOKEN_API_DISPATCH_MENU_CONSUMED=1 \
  TOKEN_API_INTERNAL_DISPATCH=1 \
  TOKEN_API_PERSONA="${PERSONA:-}" \
  TOKEN_API_CODEX_PROFILE="$CODEX_PROFILE" \
  "${SCRIPT_DIR}/dispatch" "${launch_args[@]}"
}

aspirant_persona_prompt_path() {
  printf '%s' "$(cd "${SCRIPT_DIR}/.." && pwd)/prompts/aspirant-persona.md"
}

if $ASPIRANT; then
  if [[ -z "$OBJECTIVE" ]]; then
    err "--aspirant requires --objective or prompt text"
    exit 64
  fi
  build_aspirant_create_args
  if $DRY_RUN; then
    cat <<EOF_ASPIRANT_DRY
dispatch aspirant dry-run
  aspirant_kind:  $ASPIRANT_KIND
  title:          $TITLE
  objective:      $OBJECTIVE
  source:         $ASPIRANT_SOURCE
  engine:         $ENGINE
  dir:            $WORK_DIR
  target:         ${TARGET:-none}
  persona:        ${PERSONA:-none}
  zealotry:       $ZEALOTRY
  session_domain: ${SESSION_DOMAIN:-default}
  internal_action: create aspirant note/session via cli-tools/lib/aspirant_create.py
  dispatch_ready:  false
  trials_verdict:  pending
EOF_ASPIRANT_DRY
    exit 0
  fi
  if [[ "$ASPIRANT_KIND" == "dispatch" && "$INTAKE_ONLY" != true ]]; then
    ASPIRANT_CREATE_ARGS+=(--json)
    ASPIRANT_RESULT="$(run_internal_aspirant_create)"
    printf '%s\n' "$ASPIRANT_RESULT"
    launch_dispatch_aspirant_session "$ASPIRANT_RESULT"
    exit $?
  fi
  run_internal_aspirant_create
  exit $?
fi

# ── Default-on worktree isolation (super-workflow Gap 1, D3) ──────────────────
# A code-touching dispatch — one whose working dir IS a configured project's
# shared prod checkout — creates and enters a fresh per-branch worktree instead
# of piling work onto the shared tree (yesterday's clobber). Opt out with
# --no-worktree. Dirs already under a worktree parent (isolated), resumes,
# aspirants, and non-project dirs are left untouched. Creation goes through
# `worktree-setup --require-free`, so a 2nd dispatch on a live branch is refused
# (the agent passes --worktree <new> or --no-worktree).
WORKTREE_DECISION="n/a (not a code checkout)"
# True only when THIS invocation cut a fresh worktree via worktree-setup
# --require-free (so the dir is provably exclusive). Every other launch enters a
# pre-existing dir and must pass the duplicate-refusal guard before launching.
WORKTREE_FRESHLY_CREATED=false

dispatch_conf_var() {
  ( BARE_REPO=""; WORKTREE_PARENT=""; SECRETS_DIR=""; SYNC_SUBDIR=""
    # shellcheck disable=SC1090
    source "$1" 2>/dev/null || true
    eval "printf '%s' \"\${$2:-}\"" )
}

assert_worktree_pr_capable() {
  local dir="$1" proj="$2" origin=""
  if ! git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    err "worktree is not PR-capable; not a git worktree: $dir"
    exit 64
  fi
  origin="$(git -C "$dir" remote get-url origin 2>/dev/null || true)"
  if [[ "$proj" == "Token-OS" ]]; then
    if ! token_os_github_remote "$origin"; then
      err "worktree is not PR-capable; expected TokenAmby-Code/Token-OS GitHub remote"
      err "origin remote: ${origin:-<missing>}"
      exit 64
    fi
    return 0
  fi
  if dead_or_quarantined_remote "$origin"; then
    err "worktree is not PR-capable; origin remote is missing, dead, or quarantined: ${origin:-<missing>}"
    exit 64
  fi
  case "${origin%.git}" in
    git@github.com:*/*|ssh://git@github.com/*/*|https://github.com/*/*)
      return 0
      ;;
  esac
  err "worktree is not PR-capable; origin remote does not map to GitHub: $origin"
  exit 64
}

slugify_branch() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's#[^a-z0-9]+#-#g; s#^-+##; s#-+$##' \
    | cut -c1-48
}

enter_worktree_for_project() {
  local proj="$1" parent="$2" root="$3" branch=""
  branch="$WORKTREE_BRANCH"
  [[ -z "$branch" && -n "$SESSION_DOC" ]] && branch="$(slugify_branch "$(basename "${SESSION_DOC%.*}")")"
  [[ -z "$branch" && -n "$TITLE" && "$TITLE" != "Dispatch aspirant" ]] && branch="$(slugify_branch "$TITLE")"
  [[ -z "$branch" && -n "$OBJECTIVE" ]] && branch="$(slugify_branch "$OBJECTIVE")"
  [[ -z "$branch" && -n "$PROMPT" ]] && branch="$(slugify_branch "$PROMPT")"
  if [[ -z "$branch" ]]; then
    # No name to isolate under. NEVER fall through to the shared checkout — that
    # is exactly the clobber we are preventing. Report in dry-run, else refuse.
    WORKTREE_DECISION="SKIPPED (no derivable branch — pass --worktree or --no-worktree)"
    $DRY_RUN && return 0
    err "worktree isolation wanted for shared checkout but no branch name derivable; pass --worktree <branch> or --no-worktree"
    exit 64
  fi
  # Preserve any nested cwd under the shared checkout (repo/subdir → wt/subdir).
  local rel="${WORK_DIR#"$root"}"; rel="${rel#/}"
  local wt_path="$parent/wt-$branch"
  local dest="$wt_path"; [[ -n "$rel" ]] && dest="$wt_path/$rel"
  if $DRY_RUN; then
    WORKTREE_DECISION="would create+enter $dest (branch $branch)"
    return 0
  fi
  if worktree-setup "$branch" --project "$proj" --no-transplant --require-free --skip-sync >&2; then
    if [[ -n "$rel" && -d "$wt_path/$rel" ]]; then
      WORK_DIR="$(cd "$wt_path/$rel" && pwd)"
    else
      WORK_DIR="$(cd "$wt_path" && pwd)"
    fi
    assert_worktree_pr_capable "$wt_path" "$proj"
    WORKTREE_DECISION="created+entered $WORK_DIR (branch $branch)"
    WORKTREE_FRESHLY_CREATED=true
  else
    err "worktree-setup refused/failed for branch '$branch' (already claimed?); refusing to dispatch into shared checkout $WORK_DIR"
    err "pass --worktree <new-branch> or --no-worktree"
    exit 1
  fi
}

maybe_enter_worktree() {
  $ASPIRANT && { WORKTREE_DECISION="n/a (aspirant)"; return 0; }

  local conf proj parent secrets protected runtime bare root
  if [[ -n "$RESUME_ID" && -n "$WORKTREE_BRANCH" ]]; then
    local -a resume_worktree_matches=()
    for conf in "$HOME"/.config/worktrees/*.conf; do
      [[ -f "$conf" ]] || continue
      parent="$(dispatch_conf_var "$conf" WORKTREE_PARENT)"
      [[ -n "$parent" ]] || continue
      if [[ -d "$parent/wt-$WORKTREE_BRANCH" ]]; then
        resume_worktree_matches+=("$parent/wt-$WORKTREE_BRANCH")
      fi
    done
    if (( ${#resume_worktree_matches[@]} == 1 )); then
      WORK_DIR="$(cd "${resume_worktree_matches[0]}" && pwd)"
      WORKTREE_DECISION="resume entered existing $WORK_DIR (branch $WORKTREE_BRANCH)"
      return 0
    fi
    if (( ${#resume_worktree_matches[@]} > 1 )); then
      WORKTREE_DECISION="resume requested ambiguous worktree branch $WORKTREE_BRANCH"
      $DRY_RUN && return 0
      err "--worktree $WORKTREE_BRANCH matches multiple existing worktrees; pass --dir for the intended project or use a unique branch"
      local match
      for match in "${resume_worktree_matches[@]}"; do err "  match: $match"; done
      exit 66
    fi
    WORKTREE_DECISION="resume requested missing worktree branch $WORKTREE_BRANCH"
    $DRY_RUN && return 0
    err "--worktree $WORKTREE_BRANCH was requested for resume but no existing wt-$WORKTREE_BRANCH was found"
    exit 66
  fi
  [[ -n "$RESUME_ID" ]] && { WORKTREE_DECISION="n/a (resume reuses existing dir)"; return 0; }
  for conf in "$HOME"/.config/worktrees/*.conf; do
    [[ -f "$conf" ]] || continue
    proj="$(basename "$conf" .conf)"
    parent="$(dispatch_conf_var "$conf" WORKTREE_PARENT)"
    secrets="$(dispatch_conf_var "$conf" SECRETS_DIR)"
    protected="$(dispatch_conf_var "$conf" PROTECTED_ROOT)"
    runtime="$(dispatch_conf_var "$conf" RUNTIME_CHECKOUT)"
    bare="$(dispatch_conf_var "$conf" BARE_REPO)"
    if [[ -n "$parent" && ( "$WORK_DIR" == "$parent" || "$WORK_DIR" == "$parent"/* ) ]]; then
      assert_worktree_pr_capable "$WORK_DIR" "$proj"
      WORKTREE_DECISION="n/a (already isolated worktree)"
      return 0
    fi
    # BARE_REPO is a redirect trigger too: `--repo` now anchors on it (see above), and
    # an agent must never run in a bare repo — always redirect into a fresh worktree.
    for root in "$protected" "$runtime" "$secrets" "$bare"; do
      [[ -n "$root" ]] || continue
      [[ "$WORK_DIR" == "$root" || "$WORK_DIR" == "$root"/* ]] || continue
      if $NO_WORKTREE; then
        err "refusing to dispatch into protected/runtime/secrets/bare root with --no-worktree: $WORK_DIR"
        err "use --worktree <branch> (preferred) or choose an existing branch worktree under $parent"
        exit 64
      fi
      enter_worktree_for_project "$proj" "$parent" "$root"
      return 0
    done
  done
  $NO_WORKTREE && { WORKTREE_DECISION="opt-out (--no-worktree)"; return 0; }
  return 0
}

maybe_enter_worktree

check_persona_behavior_invariant

DISPATCH_WINDOW=""
DISPATCH_MODE=""
DISPATCH_SLOT=""
RESOLVED_TARGET="$TARGET"
LAUNCH_MODE="direct"
if [[ -n "$TARGET" ]]; then
  if [[ "$TARGET" == "self" || "$TARGET" == "current" ]]; then
    DISPATCH_SELF_PANE="$(dispatch_tmux_pane)"
    if [[ -z "$DISPATCH_SELF_PANE" ]]; then
      err "--pane $TARGET requires a tmux pane"
      exit 69
    fi
    LAUNCH_MODE="direct"
    RESOLVED_TARGET="$DISPATCH_SELF_PANE"
  elif [[ -n "${TMUX_PANE:-}" && "$TARGET" == "$TMUX_PANE" ]]; then
    LAUNCH_MODE="direct"
  elif [[ "$TARGET" == *:* ]]; then
    DISPATCH_WINDOW="${TARGET%%:*}"
    DISPATCH_SLOT="${TARGET#*:}"
    DISPATCH_MODE="$DISPATCH_SLOT"
    if [[ "$DISPATCH_SLOT" == "new" ]]; then
      LAUNCH_MODE="tmux_stack_new"
    else
      LAUNCH_MODE="tmux_target"
    fi
  else
    LAUNCH_MODE="tmux_target"
  fi
fi
if [[ -n "$RESUME_ID" ]]; then
  # An explicit --target wins over restored resume metadata. Without the
  # `-z "$TARGET"` guards, resuming with `--target mechanicus:new` would relocate
  # the worker back to its origin window (e.g. legion) because the resume row's
  # DISPATCH_WINDOW/MODE/SLOT silently clobber the values just parsed from --target.
  [[ -n "$RESUME_DISPATCH_TARGET" && -z "$TARGET" ]] && RESOLVED_TARGET="$RESUME_DISPATCH_TARGET"
  [[ -n "$RESUME_DISPATCH_WINDOW" && -z "$TARGET" ]] && DISPATCH_WINDOW="$RESUME_DISPATCH_WINDOW"
  [[ -n "$RESUME_DISPATCH_MODE" && -z "$TARGET" ]] && DISPATCH_MODE="$RESUME_DISPATCH_MODE"
  [[ -n "$RESUME_DISPATCH_SLOT" && -z "$TARGET" ]] && DISPATCH_SLOT="$RESUME_DISPATCH_SLOT"
  [[ -n "$RESUME_LAUNCH_MODE" ]] && LAUNCH_MODE="$RESUME_LAUNCH_MODE"
  if [[ -n "$TARGET" ]]; then
    if [[ "$TARGET" == "self" || "$TARGET" == "current" ]]; then
      DISPATCH_SELF_PANE="$(dispatch_tmux_pane)"
      if [[ -z "$DISPATCH_SELF_PANE" ]]; then
        err "--pane $TARGET requires a tmux pane"
        exit 69
      fi
      LAUNCH_MODE="direct"
      RESOLVED_TARGET="$DISPATCH_SELF_PANE"
    elif [[ -n "${TMUX_PANE:-}" && "$TARGET" == "$TMUX_PANE" ]]; then
      LAUNCH_MODE="direct"
    elif [[ "$TARGET" == *:new ]]; then
      # Resume into a freshly allocated stack pane: keep the tmux_stack_new path
      # (it pins --session main and supports resume via stamp_resume_instance_id).
      # tmux_target would send-keys to the literal ":new" allocation token, and
      # tmux would read the window name (e.g. mechanicus) as a missing session.
      LAUNCH_MODE="tmux_stack_new"
    else
      LAUNCH_MODE="tmux_target"
    fi
  elif [[ -n "${TMUX_PANE:-}" ]]; then
    RESOLVED_TARGET="${TMUX_PANE}"
  elif [[ -n "$RESUME_TMUX_PANE" && -z "$RESOLVED_TARGET" ]]; then
    RESOLVED_TARGET="$RESUME_TMUX_PANE"
  fi
fi

tmuxctld_result_max_time() {
  # curl max-time is a transport budget, not the dispatch protocol bound.  The
  # stack allocator must be allowed to return its real daemon verdict: aborting
  # POST /stack/dispatch at an arbitrary 60s client ceiling leaves the daemon
  # thread free to finish later, after the caller has abandoned the pane.  Other
  # routes keep the legacy 60s transport budget unless explicitly overridden.
  case "${1:-} ${2:-}" in
    "POST /stack/dispatch") printf '%s' "${TMUXCTLD_STACK_DISPATCH_MAX_TIME:-0}" ;;
    *) printf '%s' "${TMUXCTLD_MAX_TIME:-60}" ;;
  esac
}

tmuxctld_result() {
  # Return the tmuxctld {ok:true,result:...} payload as a shell scalar/JSON.
  # This is dispatch's daemon-native replacement for cold `tmuxctl` subprocesses
  # on the launch path. tmuxctld-ping owns transport; dispatch only unwraps the
  # standard envelope so it can learn the newly allocated canonical pane id.
  local response max_time
  if ! command -v tmuxctld-ping >/dev/null 2>&1; then
    return 127
  fi
  max_time="$(tmuxctld_result_max_time "$@")"
  response="$(TMUXCTLD_PING_PRINT_RESPONSE=1 TMUXCTLD_MAX_TIME="$max_time" tmuxctld-ping "$@")" || return $?
  TMUXCTLD_RESPONSE="$response" python3 - <<'PY'
import json
import os
import sys

raw = os.environ.get("TMUXCTLD_RESPONSE", "")
try:
    payload = json.loads(raw)
except json.JSONDecodeError:
    # Test fakes may return the bare scalar. Production tmuxctld always returns
    # the standard envelope.
    sys.stdout.write(raw)
    raise SystemExit(0)

if not isinstance(payload, dict) or not payload.get("ok"):
    err = payload.get("error", {}) if isinstance(payload, dict) else {}
    message = err.get("message") or raw
    print(message, file=sys.stderr)
    raise SystemExit(1)
result = payload.get("result", "")
if isinstance(result, (dict, list)):
    sys.stdout.write(json.dumps(result, separators=(",", ":")))
elif result is None:
    sys.stdout.write("")
else:
    sys.stdout.write(str(result))
PY
}

tmuxctld_stack_dispatch() {
  local base="$1" session="$2" cwd="$3" command_text="$4"
  tmuxctld_result POST /stack/dispatch \
    base="$base" \
    session="$session" \
    cwd="$cwd" \
    focus=false \
    command="$command_text"
}

dispatch_tmuxctld_python() {
  local lib_dir
  lib_dir="$(cd "${SCRIPT_DIR}/../../tmuxctld/lib" 2>/dev/null && pwd || true)"
  [[ -n "$lib_dir" ]] || return 2
  PYTHONPATH="$lib_dir${PYTHONPATH:+:$PYTHONPATH}" python3 "$@"
}

dispatch_prealloc_page_probe() {
  # Exit 0 when the page is a fixed pre-allocated SLOT page (palace/somnium).
  # Source the page class from tmuxctld's teardown/window config, not from a
  # shell-maintained duplicate list.  Fail open as "not prealloc" if the helper
  # cannot be imported, preserving stack behavior for managed stack pages.
  local page="$1"
  [[ -n "$page" ]] || return 1
  PAGE="$page" dispatch_tmuxctld_python - <<'PY'
import os
import sys

try:
    from tmuxctl.prealloc import is_prealloc_page
except Exception:
    raise SystemExit(1)

raise SystemExit(0 if is_prealloc_page(os.environ.get("PAGE", "")) else 1)
PY
}

dispatch_window_name_for_index() {
  # Numeric public targets such as `2:N` are valid positional aliases.  `2:new`
  # must be classified by the live window's page name before stack-vs-prealloc
  # allocation, otherwise dispatch treats base="2" as a spawnable stack and
  # calls /stack/dispatch, which fails with "not a stack window: 2" after the
  # worktree half has already run.
  local index="$1" name=""
  [[ "$index" =~ ^[0-9]+$ ]] || return 1
  if command -v tmux >/dev/null 2>&1; then
    name="$(tmux display-message -t "main:${index}" -p "#{window_name}" 2>/dev/null || true)"
  fi
  [[ -n "$name" ]] || return 1
  printf '%s' "$name"
}

dispatch_prealloc_page_base() {
  # Print the fixed SLOT page base for a launch page.  Accept both named pages
  # (`somnium:new`) and numeric window aliases (`2:new` when main:2 is somnium).
  local page="$1" resolved_page
  [[ -n "$page" ]] || return 1
  if dispatch_prealloc_page_probe "$page"; then
    printf '%s' "$page"
    return 0
  fi
  resolved_page="$(dispatch_window_name_for_index "$page" || true)"
  [[ -n "$resolved_page" ]] || return 1
  dispatch_prealloc_page_probe "$resolved_page" || return 1
  printf '%s' "$resolved_page"
}

dispatch_first_free_prealloc_pane() {
  # Print the configured first free role for a pre-allocated page, using the
  # daemon's ledger-derived freelist for occupancy.  No DB rows, @PANE_CLEAN, or
  # shell process heuristics participate.
  local page="$1" freelist_json
  [[ -n "$page" ]] || return 2
  freelist_json="$(tmuxctld_result GET /freelist)" || return $?
  PAGE="$page" FREELIST_JSON="$freelist_json" dispatch_tmuxctld_python - <<'PY'
import json
import os
import sys

try:
    from tmuxctl.prealloc import first_free_prealloc_role, ordered_prealloc_roles
except Exception as exc:
    print(f"prealloc resolver import failed: {exc}", file=sys.stderr)
    raise SystemExit(2)

page = os.environ.get("PAGE", "")
raw = os.environ.get("FREELIST_JSON", "")
try:
    freelist = json.loads(raw) if raw else []
except json.JSONDecodeError as exc:
    print(f"invalid tmuxctld freelist JSON: {exc}", file=sys.stderr)
    raise SystemExit(2)

if not isinstance(freelist, list):
    print("invalid tmuxctld freelist: expected list", file=sys.stderr)
    raise SystemExit(2)

role = first_free_prealloc_role(page, freelist)
if role:
    print(role, end="")
    raise SystemExit(0)

order = ordered_prealloc_roles(page)
if order:
    print(f"no free pre-allocated panes on {page}", file=sys.stderr)
    raise SystemExit(3)
print(f"{page} is not a pre-allocated page", file=sys.stderr)
raise SystemExit(4)
PY
}

maybe_resolve_prealloc_new_target() {
  # Split the public :new surface by page type:
  #   * managed stack pages stay on tmux_stack_new exactly as before;
  #   * pre-allocated pages resolve greedily to a concrete free SLOT and use the
  #     normal tmux_target send path (no spawn, no teardown).
  # Numeric positional aliases (`2:new`) are normalized to their live window base
  # before this decision so fixed pages cannot fall through to /stack/dispatch.
  [[ "$LAUNCH_MODE" == "tmux_stack_new" && "$DISPATCH_SLOT" == "new" && -n "$DISPATCH_WINDOW" ]] || return 0
  local prealloc_page
  prealloc_page="$(dispatch_prealloc_page_base "$DISPATCH_WINDOW" || true)"
  [[ -n "$prealloc_page" ]] || return 0
  if ! command -v tmuxctld-ping >/dev/null 2>&1; then
    err "tmuxctld-ping is required to allocate ${DISPATCH_WINDOW}:new"
    exit 69
  fi
  local free_pane rc
  if free_pane="$(dispatch_first_free_prealloc_pane "$prealloc_page")"; then
    rc=0
  else
    rc=$?
  fi
  if [[ "$rc" -ne 0 ]]; then
    case "$rc" in
      3) err "no free pre-allocated panes on ${prealloc_page} for ${TARGET}" ;;
      *) err "failed to resolve ${TARGET} from tmuxctld freelist" ;;
    esac
    exit 73
  fi
  DISPATCH_WINDOW="$prealloc_page"
  RESOLVED_TARGET="$free_pane"
  LAUNCH_MODE="tmux_target"
}

tmuxctld_pane_live() {
  local pane="$1" result
  result="$(tmuxctld_result POST /pane-live pane="$pane")" || return 2
  TMUXCTLD_RESULT="$result" python3 - <<'PY'
import json
import os

try:
    payload = json.loads(os.environ.get("TMUXCTLD_RESULT", ""))
except json.JSONDecodeError:
    raise SystemExit(2)
raise SystemExit(0 if payload.get("live") else 1)
PY
}

# Materialize a physical %NNN from a canonical page:index id immediately before a
# raw `tmux ... -t` syscall — the only place a physical id is allowed to exist.
# Everything above this line speaks canonical; this is the irreducible floor where
# the working id touches tmux. Fail open to the input so an already-physical %NNN,
# a `self`/`current` token already resolved upstream, or a pane the oracle cannot
# map keeps today's behavior (no regression).
materialize_physical_pane() {
  local target="$1" resolved
  [[ -n "$target" ]] || return 0
  resolved="$(tmuxctld_result GET /resolve-pane target="$target" format=physical 2>/dev/null || true)"
  [[ -n "$resolved" ]] && { printf '%s' "$resolved"; return 0; }
  printf '%s' "$target"
}

resolve_pane_label_for_env() {
  local pane="$1" label=""
  [[ -n "$pane" ]] || return 0
  if command -v tmux >/dev/null 2>&1; then
    label="$(tmux show-options -pv -t "$pane" @PANE_ID 2>/dev/null || true)"
  fi
  if [[ -z "$label" && "$pane" =~ ^[a-z][a-z0-9-]*:[A-Za-z0-9-]+$ ]]; then
    label="$pane"
  fi
  printf '%s' "$label"
}

pane_has_active_agent_process() {
  # root_pid: the target pane's pane_pid; scan its process subtree for a live agent.
  # self_pid: this dispatch process's own pid. On the resume path dispatch is typed
  #   INTO the target pane's shell (executor send_keys), so the running dispatch — and
  #   its staged temp-script child, and the ps|awk pipeline below — are themselves
  #   descendants of pane_pid. Excluding self's lineage stops the guard from counting
  #   itself as a "live agent" and refusing its own dispatch. Defaults to 0 (no
  #   exclusion) for backward-compatible single-arg callers.
  # needles: match agent *program* forms only — the launcher binary paths
  #   (.../claude, .../codex, the .token-os-real real-binaries) and agent-wrapper.
  #   The claude/codex program forms anchor the name to the *start of the
  #   command* or a leading slash ((^|/)claude, (^|/)codex) so they catch both a
  #   bare PATH-launched argv[0] (`codex resume …`) and an absolute launcher path
  #   (`.../bin/codex …`), while a `--engine codex|claude` flag *value* in an argv
  #   (space-delimited, mid-command, no slash) can never masquerade as a live
  #   agent — that was the self-referential bug.
  #   Literal dots are written [.] so the awk program's own command line (which
  #   carries this very pattern via -v) cannot match the needle it scans for.
  local root_pid="$1" self_pid="${2:-0}"
  local needles='(^|/)claude( |$)|claude[.]token-os-real|(^|/)codex( |$)|codex[.]token-os-real|agent-wrapper[.]sh'
  [[ -n "$root_pid" && "$root_pid" =~ ^[0-9]+$ && "$root_pid" != "0" ]] || return 1
  # -ww: unlimited output width. Without it Linux procps truncates `command` to
  # ~80 cols when stdout is not a TTY, which can lop the launcher basename off a
  # long argv/path and hide a real agent from the needle. (BSD/macOS ps honours
  # -ww too; it never truncates by default.)
  ps -ww -A -o pid=,ppid=,command= 2>/dev/null | awk -v root="$root_pid" -v self="$self_pid" -v needles="$needles" '
    {
      pid=$1; ppid=$2; $1=""; $2=""; sub(/^  */, "", $0)
      parent[pid]=ppid
      cmd[pid]=tolower($0)
    }
    function is_self_lineage(p,   c) {
      if (self == "" || self == "0") return 0
      c = p
      while (c in parent) {
        if (c == self) return 1
        c = parent[c]
      }
      return (p == self)
    }
    END {
      for (pid in parent) {
        cur=pid
        while (cur in parent) {
          if (parent[cur] == root) {
            if (cmd[pid] ~ needles && !is_self_lineage(pid)) exit 0
            break
          }
          cur=parent[cur]
        }
      }
      exit 1
    }
  '
}

assert_dispatch_target_unoccupied() {
  # Caller passes the canonical working id; resolve to physical once, here, at the
  # raw-tmux boundary.
  local pane meta cmd title pane_label pane_pid instance_id
  [[ "${TOKEN_API_DISPATCH_FORCE_OCCUPIED:-}" == "1" ]] && return 0
  pane="$(materialize_physical_pane "$1")"
  meta="$(tmux display-message -p -t "$pane" '#{pane_current_command}|#{pane_title}|#{@PANE_ID}|#{pane_pid}|#{@INSTANCE_ID}' 2>/dev/null || true)"
  [[ -n "$meta" ]] || return 0
  cmd="${meta%%|*}"
  meta="${meta#*|}"
  title="${meta%%|*}"
  meta="${meta#*|}"
  pane_label="${meta%%|*}"
  meta="${meta#*|}"
  pane_pid="${meta%%|*}"
  instance_id="${meta#*|}"
  case "$pane_label" in
    council:custodes|legion:custodes|council:malcador|mechanicus:fabricator-general|council:administratum|mechanicus:admin|council:pax|mechanicus:orchestrator)
      err "target pane $TARGET is a protected singleton seat ($pane_label); refusing dispatch injection"
      err "use a worker pane, a :new target, or set TOKEN_API_DISPATCH_FORCE_OCCUPIED=1 if intentional"
      exit 73
      ;;
  esac
  if [[ -n "$instance_id" ]]; then
    err "target pane $TARGET appears occupied (@INSTANCE_ID=$instance_id); refusing to inject dispatch command"
    err "use an empty shell pane, a :new target, or set TOKEN_API_DISPATCH_FORCE_OCCUPIED=1 if intentional"
    exit 73
  fi
  if pane_has_active_agent_process "$pane_pid" "$$"; then
    err "target pane $TARGET has a live Claude/Codex descendant (pane_pid=$pane_pid); refusing dispatch injection"
    err "use an empty shell pane, a :new target, or set TOKEN_API_DISPATCH_FORCE_OCCUPIED=1 if intentional"
    exit 73
  fi
  case "$cmd" in
    node|claude|codex)
      err "target pane $TARGET appears occupied (command=$cmd, title=$title); refusing to inject dispatch command"
      err "use an empty shell pane, a :new target, or set TOKEN_API_DISPATCH_FORCE_OCCUPIED=1 if intentional"
      exit 73
      ;;
  esac
  case "$title" in
    ✳*|⠼*)
      err "target pane $TARGET appears occupied (command=$cmd, title=$title); refusing to inject dispatch command"
      err "use an empty shell pane, a :new target, or set TOKEN_API_DISPATCH_FORCE_OCCUPIED=1 if intentional"
      exit 73
      ;;
  esac
}

# RESOLVED_TARGET already carries the canonical working id (the user's --target, a
# stack pane's page:index, or an already-physical %NNN for direct/self launches).
# No boundary resolve here — physical materializes only at the raw-tmux send sites.
maybe_resolve_prealloc_new_target

DISCORD_BOT=""
if [[ -n "$DISCORD_CHANNEL" ]]; then
  PERSONA_LOWER="$(printf '%s' "$PERSONA" | tr '[:upper:]' '[:lower:]')"
  case "$PERSONA_LOWER" in
    custodes) DISCORD_BOT="custodes" ;;
    inquisitor|inquisition) DISCORD_BOT="inquisition" ;;
    *) DISCORD_BOT="mechanicus" ;;
  esac
fi

# Derive the CHILD's legion fresh from explicit args only — NEVER from the inherited
# TOKEN_API_LEGION. A dispatching pane carries its own exported TOKEN_API_LEGION (set
# when that pane was itself launched); seeding the child from it stamped the worker
# with the dispatcher's legion, and the server then inferred the dispatcher's persona
# from that legion — the custodes persona-theft via the emperor-commander path (P1,
# 2026-06-18). Legion/persona are NOT env-injectable: sources of truth are the tmux
# pane stamp + the DB. Leave NULL when no --persona / non-custodes target so the server
# assigns a fresh worker (astartes) identity. Automated custodes launches still bind
# correctly: they target the `council:custodes` slot, handled by the DISPATCH_SLOT case
# below.
LEGION=""
if [[ -z "$LEGION" && -n "$PERSONA" ]]; then
  case "$(printf '%s' "$PERSONA" | tr '[:upper:]' '[:lower:]')" in
    custodes) LEGION="custodes" ;;
    inquisitor|inquisition) LEGION="inquisition" ;;
  esac
fi
# The state-hook dispatcher targets the `council:custodes` slot without a persona.
if [[ -z "$LEGION" ]]; then
  case "$(printf '%s' "$DISPATCH_SLOT" | tr '[:upper:]' '[:lower:]')" in
    custodes) LEGION="custodes" ;;
  esac
fi

MCP_DECISION="default"
MCP_REQUESTS=()
$WITH_BROWSER && MCP_REQUESTS+=("browser")
$WITH_DESKTOP && MCP_REQUESTS+=("desktop")
[[ -n "$WITH_MCP" ]] && MCP_REQUESTS+=("$WITH_MCP")
if [[ ${#MCP_REQUESTS[@]} -gt 0 ]]; then
  MCP_DECISION="requested: $(IFS=,; echo "${MCP_REQUESTS[*]}")"
fi

AUTO_PARENT_INSTANCE_ID=""
# Resolve the dispatcher only as a commander edge. This is control/parentage,
# not identity inheritance: the child still receives a fresh wrapper id and the
# inherited identity/persona env is scrubbed below. Never trust an inherited
# TOKEN_API_PARENT_INSTANCE_ID here; that names the caller's commander, not the
# caller.
if ! $DISPATCH_SELF; then
  AUTO_PARENT_INSTANCE_ID="$(resolve_caller_instance_id || true)"
fi

# A dispatched worker is always a NEW wrapper launch, so it must mint its OWN
# wrapper_id — never inherit the dispatching agent's. token-api SessionStart
# treats wrapper_id as unique per wrapper launch and re-keys the most-recent
# row carrying it (routes/hooks.py branch 5); inheriting the dispatcher's id makes
# the worker supplant the dispatcher's registry row and clobber its (singleton)
# persona — the systemic singleton-decapitation channel. The caller-pane-identity
# guard above (TMUX_PANE/INSTANCE_ID/PARENT/PERSONA) missed this one leak channel.
WRAPPER_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
COMMON_ENV=(
  "TOKEN_API_LAUNCHER=dispatch"
  "TOKEN_API_ENGINE=${ENGINE}"
  "TOKEN_API_WRAPPER_ID=${WRAPPER_ID}"
  "TOKEN_API_DISPATCH_TARGET=${TARGET}"
  "TOKEN_API_LEGION=${LEGION}"
  "TOKEN_API_DISPATCH_WINDOW=${DISPATCH_WINDOW}"
  "TOKEN_API_DISPATCH_MODE=${DISPATCH_MODE}"
  "TOKEN_API_DISPATCH_SLOT=${DISPATCH_SLOT}"
  "TOKEN_API_DISPATCH_SESSION_DOC_PATH=${SESSION_DOC}"
  "TOKEN_API_TARGET_WORKING_DIR=${WORK_DIR}"
  "TOKEN_API_LAUNCH_MODE=${LAUNCH_MODE}"
  "TOKEN_API_INSTANCE_TYPE=${INSTANCE_TYPE}"
  "TOKEN_API_ZEALOTRY=${ZEALOTRY}"
  "TOKEN_API_PARENT_INSTANCE_ID=${AUTO_PARENT_INSTANCE_ID}"
  "TOKEN_API_DISPATCH_MCP=${MCP_DECISION}"
  "TOKEN_API_DISPATCH_WITH_BROWSER=${WITH_BROWSER}"
  "TOKEN_API_DISPATCH_WITH_DESKTOP=${WITH_DESKTOP}"
  "TOKEN_API_DISPATCH_MCP_LIST=${WITH_MCP}"
)
if $DISPATCH_SELF; then
  COMMON_ENV+=("TOKEN_API_TRANSPLANT_EXPECTED=true")
fi
[[ -n "$CODEX_PROFILE" ]] && COMMON_ENV+=("TOKEN_API_CODEX_PROFILE=${CODEX_PROFILE}")
[[ -n "$CLAUDE_MODEL" ]] && COMMON_ENV+=("TOKEN_API_CLAUDE_MODEL=${CLAUDE_MODEL}")
# ``--persona mechanicus`` is the worker prompt/behavior coat for the mechanicus
# stack, not a durable singleton identity.  Exporting TOKEN_API_PERSONA=mechanicus
# makes SessionStart treat a generic worker as a primarch/persona launch; in the
# legacy alias path that previously resolved to Administratum and let the worker
# supplant the recorder row. Keep the prompt, but let token-api derive the durable
# worker identity from the mechanicus dispatch target -> FG commander trigger.
PERSONA_IDENTITY_EXPORT="$PERSONA"
if [[ "$(printf '%s' "$PERSONA" | tr '[:upper:]' '[:lower:]')" == "mechanicus" ]]; then
  case "${TARGET}:${DISPATCH_WINDOW}" in
    mechanicus:*|*:mechanicus) PERSONA_IDENTITY_EXPORT="" ;;
  esac
fi
[[ -n "$PERSONA_IDENTITY_EXPORT" ]] && COMMON_ENV+=("TOKEN_API_PERSONA=${PERSONA_IDENTITY_EXPORT}")
if [[ -n "$DISCORD_CHANNEL" ]]; then
  COMMON_ENV+=(
    "TOKEN_API_DISCORD_HOSTED=1"
    "TOKEN_API_DISCORD_CHANNEL=${DISCORD_CHANNEL}"
    "TOKEN_API_DISCORD_BOT=${DISCORD_BOT}"
  )
fi
if [[ -n "$RESUME_PRIMARCH" && -z "$PERSONA" ]]; then
  COMMON_ENV+=("TOKEN_API_PERSONA=${RESUME_PRIMARCH}")
fi
# Operational metadata (vault domain, linked session-doc) for
# the persona — forwarded as env so the agent wrapper folds it in beneath the
# rank+persona staple it now injects. The doctrine body no longer rides on the
# dispatch command line; the wrapper is the sole injector.
_op_persona="${PERSONA:-}"
[[ -z "$_op_persona" && -n "$RESUME_PRIMARCH" ]] && _op_persona="$RESUME_PRIMARCH"
if [[ -n "$_op_persona" ]]; then
  _op_meta="$(persona_operational_env "$_op_persona")"
  IFS=$'\x1f' read -r _op_vault _op_doc <<< "$_op_meta"
  [[ -n "$_op_vault" ]] && COMMON_ENV+=("TOKEN_API_VAULT_DOMAIN=${_op_vault}")
  [[ -n "$_op_doc" ]] && COMMON_ENV+=("TOKEN_API_SESSION_DOC_ID=${_op_doc}")
fi
if [[ -n "$RESUME_PARENT_INSTANCE_ID" && -z "$AUTO_PARENT_INSTANCE_ID" ]]; then
  COMMON_ENV+=("TOKEN_API_PARENT_INSTANCE_ID=${RESUME_PARENT_INSTANCE_ID}")
fi
if [[ -n "$RESUME_DISCORD_CHANNEL" && -z "$DISCORD_CHANNEL" ]]; then
  COMMON_ENV+=(
    "TOKEN_API_DISCORD_HOSTED=${RESUME_DISCORD_HOSTED:-1}"
    "TOKEN_API_DISCORD_CHANNEL=${RESUME_DISCORD_CHANNEL}"
    "TOKEN_API_DISCORD_BOT=${RESUME_DISCORD_BOT}"
  )
fi

# Identity-bearing values from the dispatcher process must never survive into a
# child launch. The child gets only the explicit COMMON_ENV values above. This is
# broader than the persona scrub: pane-scoped helpers (`instance-name`,
# `session-doc-name`) and wrapper/session plumbing also key off name/session-doc
# aliases, so scrub both TOKEN_API_* and legacy/unprefixed spellings before
# setting the worker's own env.
DISPATCH_INHERITED_ENV_SCRUB=(
  TMUX_PANE
  TOKEN_API_INSTANCE_ID
  INSTANCE_ID
  TOKEN_API_PERSONA
  PERSONA
  TOKEN_API_PARENT_INSTANCE_ID
  PARENT_INSTANCE_ID
  TOKEN_API_LEGION
  LEGION
  TOKEN_API_PERSONA_SLUG
  PERSONA_SLUG
  TOKEN_API_PERSONA_ID
  PERSONA_ID
  TOKEN_API_DISPLAY_NAME
  DISPLAY_NAME
  TOKEN_API_INSTANCE_NAME
  INSTANCE_NAME
  TOKEN_API_TAB_NAME
  TAB_NAME
  TOKEN_API_NAME
  TOKEN_API_INSTANCE_NAME_PREFIX
  INSTANCE_NAME_PREFIX
  TOKEN_API_WRAPPER_ID
  WRAPPER_ID
  TOKEN_API_WRAPPER_LAUNCH_ID
  WRAPPER_LAUNCH_ID
  TOKEN_API_VAULT_DOMAIN
  VAULT_DOMAIN
  TOKEN_API_SESSION_DOC_ID
  SESSION_DOC_ID
  TOKEN_API_SESSION_DOC
  SESSION_DOC
  TOKEN_API_SESSION_DOC_PATH
  SESSION_DOC_PATH
)

build_agent_command() {
  local -a cmd envs
  envs=("${COMMON_ENV[@]}")
  # The child env still carries a PHYSICAL pane id this PR: the wrapper, runtime
  # cleanup/stamp/enforce, and the DB tmux_pane column all consume it via raw
  # `tmux ... -t` and are not canonical-aware until PR-B. Materialize physical from
  # the canonical working id at this hand-off boundary so storage + consumers stay
  # unchanged (column stays physical, fleet launchable at every commit).
  if [[ -n "${RESOLVED_TARGET:-}" ]]; then
    local resolved_physical_pane resolved_pane_label
    resolved_physical_pane="$(materialize_physical_pane "$RESOLVED_TARGET")"
    envs+=("TOKEN_API_DISPATCH_RESOLVED_PANE=${resolved_physical_pane}")
    envs+=("TMUX_PANE=${resolved_physical_pane}")
    resolved_pane_label="$(resolve_pane_label_for_env "$resolved_physical_pane")"
    [[ -n "$resolved_pane_label" ]] && envs+=("TOKEN_API_PANE_LABEL=${resolved_pane_label}")
  fi
  if [[ -n "$RESUME_ID" ]]; then
    if [[ "$ENGINE" == "codex" ]]; then
      cmd=("${SCRIPT_DIR}/../scripts/agent-wrapper.sh" codex)
      envs+=("TOKEN_API_CODEX_RESUME_ID=${RESUME_ID}")
      [[ -n "$PROMPT" ]] && cmd+=("$PROMPT")
    else
      cmd=("${SCRIPT_DIR}/../scripts/agent-wrapper.sh" claude --dangerously-skip-permissions)
      [[ -n "$CLAUDE_MODEL" ]] && cmd+=(--model "$CLAUDE_MODEL")
      cmd+=(--resume "$RESUME_ID")
      [[ -n "$SYSTEM_PROMPT" ]] && cmd+=(--append-system-prompt "$SYSTEM_PROMPT")
      # Forward an initial prompt into the resumed interactive session (e.g. a
      # Golden Throne follow-up SOP). Codex resume already forwards PROMPT above;
      # without this, `dispatch --id <id> --prompt-file <sop>` silently dropped it.
      [[ -n "$PROMPT" ]] && cmd+=("$PROMPT")
    fi
  elif [[ "$ENGINE" == "codex" ]]; then
    cmd=("${SCRIPT_DIR}/../scripts/agent-wrapper.sh" codex)
    [[ -n "$PROMPT" ]] && cmd+=("$PROMPT")
  else
    cmd=("${SCRIPT_DIR}/../scripts/agent-wrapper.sh" claude --dangerously-skip-permissions)
    [[ -n "$CLAUDE_MODEL" ]] && cmd+=(--model "$CLAUDE_MODEL")
    if [[ -n "$PERSONA" ]]; then
      local profile_dir line
      # The rank+persona doctrine staple is injected by the agent wrapper now
      # (TOKEN_API_PERSONA → token_wrapper_system_doc), so dispatch no longer
      # appends the persona body here — that would double-inject. A caller-supplied
      # --system-prompt still rides through; the wrapper layers the staple above it.
      [[ -n "$SYSTEM_PROMPT" ]] && cmd+=(--append-system-prompt "$SYSTEM_PROMPT")
      profile_dir="$HOME/.claude/profiles/$PERSONA"
      if [[ -d "$profile_dir" ]]; then
        [[ -f "$profile_dir/.mcp.json" ]] && cmd+=(--mcp-config "$profile_dir/.mcp.json" --strict-mcp-config)
        if [[ -f "$profile_dir/disallowed-tools.txt" ]]; then
          while IFS= read -r line; do
            line="${line%%#*}"
            line="${line#"${line%%[![:space:]]*}"}"
            line="${line%"${line##*[![:space:]]}"}"
            [[ -z "$line" ]] && continue
            cmd+=(--disallowedTools "$line")
          done < "$profile_dir/disallowed-tools.txt"
        fi
        [[ -f "$profile_dir/settings.json" ]] && cmd+=(--settings "$profile_dir/settings.json")
      fi
    else
      [[ -n "$SYSTEM_PROMPT" ]] && cmd+=(--append-system-prompt "$SYSTEM_PROMPT")
    fi
    [[ -n "$PROMPT" ]] && cmd+=("$PROMPT")
  fi
  printf 'cd %q && env' "$WORK_DIR"
  local scrub_var alt_scrub_var
  for scrub_var in "${DISPATCH_INHERITED_ENV_SCRUB[@]}"; do
    alt_scrub_var=""
    case "$scrub_var" in
      TOKEN_API_*) alt_scrub_var="${scrub_var#TOKEN_API_}" ;;
      *) alt_scrub_var="TOKEN_API_${scrub_var}" ;;
    esac
    # Keep launch commands readable while still scrubbing real inherited state.
    # If either TOKEN_API_* or its legacy alias is present, unset both spellings
    # so a wrapper/helper cannot fall through to the surviving alias.
    if [[ -z "${!scrub_var+x}" ]]; then
      [[ -n "$alt_scrub_var" && -n "${!alt_scrub_var+x}" ]] || continue
    fi
    printf ' -u %q' "$scrub_var"
    [[ -n "$alt_scrub_var" ]] && printf ' -u %q' "$alt_scrub_var"
  done
  printf ' TOKEN_API_INTERNAL_DISPATCH=1'
  local e
  for e in "${envs[@]}"; do printf ' %q' "$e"; done
  local a
  for a in "${cmd[@]}"; do printf ' %q' "$a"; done
}

FINAL_COMMAND="$(LC_ALL=C; build_agent_command)"

redact_tmux_panes_for_display() {
  # Operates on `printf %q` output (FINAL_COMMAND / dispatch_command) which on
  # macOS can carry invalid UTF-8 bytes; pin LC_ALL=C so this ASCII-only %pane
  # match is byte-safe and never trips "sed: RE error: illegal byte sequence".
  LC_ALL=C sed -E 's/%[0-9]+/<tmux-pane>/g'
}

dispatch_send_text_via_tmuxctld() {
  # The launcher's back half must dogfood the daemon resolver. Token-API still
  # owns the registry/session/front-half work above; byte-bearing pane sends go
  # through tmuxctld so canonical ids (palace:E, somnium:N, mechanicus:2, …) are
  # resolved by the same oracle the rest of the fleet uses, not by raw tmux.
  local pane="$1" text="$2" settle="${DISPATCH_TMUXCTLD_SUBMIT_SETTLE_SECONDS:-0.2}"
  if ! command -v tmuxctld-ping >/dev/null 2>&1; then
    err "tmuxctld-ping is required to send dispatch launch commands to $(printf '%s' "$pane" | redact_tmux_panes_for_display)"
    return 69
  fi
  # Route through tmuxctld_result (envelope unwrap + route-specific transport
  # budget), NOT raw tmuxctld-ping with its 3s --max-time default. A launch/prompt send can
  # legitimately take tens of seconds (daemon resolver + occupancy + guard hold +
  # tmux round-trips), or minutes when the target agent is mid-tool-call. The old
  # 3s fast-fail returned curl rc28 and printed "tmuxctld send failed" on a
  # SUCCESSFUL birth — a false negative that made operators/workflows believe
  # nothing seated (Phase B trace). We now trust the daemon's own delivery
  # verdict and only hard-fail (rc70) on a genuine failure.
  local pane_display response rc=0 classify_rc=0
  pane_display="$(printf '%s' "$pane" | redact_tmux_panes_for_display)"
  if response="$(tmuxctld_result POST /send-text \
      pane="$pane" \
      text="$text" \
      submit=true \
      verify=false \
      submit_settle_seconds="$settle")"; then
    rc=0
  else
    rc=$?
  fi
  if [[ "$rc" -ne 0 ]]; then
    # ok:false (gated / human-lock / dead pane) or a transport failure —
    # tmuxctld_result already surfaced the daemon error message. Genuine failure.
    err "tmuxctld send failed for dispatch target ${pane_display} (rc=${rc})"
    return 70
  fi
  # Envelope unwrapped to the send-text result JSON. Interpret the advisory
  # delivery classification (three-outcome contract):
  #   confirmed / likely -> delivered (rc0); `likely` prints the scrape advisory
  #                          but is NOT a failure (pane-scrape is unreliable, so
  #                          we do not hard-assert against it).
  #   failed             -> the draft is stuck in the composer (submit swallowed);
  #                          the message was NOT delivered -> rc70.
  DISPATCH_SEND_RESPONSE="$response" DISPATCH_ENGINE="$ENGINE" python3 - "$pane_display" <<'PY' || classify_rc=$?
import json
import os
import sys

pane_display = sys.argv[1] if len(sys.argv) > 1 else "<pane>"
raw = os.environ.get("DISPATCH_SEND_RESPONSE", "")
try:
    result = json.loads(raw)
except (json.JSONDecodeError, TypeError):
    # Test fakes / bare scalar: nothing to classify, treat as delivered.
    raise SystemExit(0)
if not isinstance(result, dict):
    raise SystemExit(0)
delivery = str(result.get("delivery") or "").strip()
advisory = str(result.get("advisory") or "").strip()
excerpt = str(result.get("capture_excerpt") or "").strip()


def _emit(prefix: str) -> None:
    print(f"tmuxctld send to {pane_display}: {prefix}", file=sys.stderr)
    if excerpt:
        print("--- pane scrape ---", file=sys.stderr)
        print(excerpt, file=sys.stderr)


if delivery == "failed":
    engine = os.environ.get("DISPATCH_ENGINE", "")
    # Codex dispatch delivers the initial task prompt via argv inside the staged
    # launcher, not by submitting into an already-running TUI composer. A composer
    # scrape can therefore be the wrong probe for codex launch success. Do not
    # suppress verification: return success here only so the caller's launch
    # observer can verify the right signal (argv launch actually produced a live
    # codex process). If that process never appears, confirm_dispatch_launch_live()
    # still fails the dispatch.
    if engine == "codex":
        _emit(
            (advisory or "composer scrape reported submit failure")
            + "; codex launch delivery will be verified by argv launch + live process"
        )
        raise SystemExit(0)
    _emit(advisory or "submit did not clear the composer; message NOT delivered")
    raise SystemExit(70)
if delivery == "likely" and advisory:
    _emit(advisory)
raise SystemExit(0)
PY
  if [[ "$classify_rc" -ne 0 ]]; then
    return 70
  fi
  return 0
}

stamp_resume_instance_id() {
  # On resume, stamp the allocated pane with the instance UUID immediately so
  # tmuxctl resolve-instance finds it before the agent re-registers — closing
  # the pane-alloc -> SessionStart gap. No-op for fresh launches (the
  # registration hook stamps those). Cleared on agent death by the wrapper.
  # Caller passes the canonical working id; resolve to physical here, at the
  # raw-tmux boundary.
  local pane="$1" phys
  # Stamp the canonical ci.id resolved from the DB (RESUME_ID may be a session_id);
  # fall back to the raw RESUME_ID when the row was not found (--engine/--dir resume).
  local instance_id="${RESUME_INSTANCE_ID:-$RESUME_ID}"
  [[ -n "$instance_id" && -n "$pane" ]] || return 0
  command -v tmux >/dev/null 2>&1 || return 0
  phys="$(materialize_physical_pane "$pane")"
  tmux set-option -p -t "$phys" @INSTANCE_ID "$instance_id" >/dev/null 2>&1 || true
}

stage_agent_command() {
  local cmd="$1" stage
  stage="$(mktemp -t dispatch-agent.XXXXXX)"
  {
    printf '%s\n' '#!/usr/bin/env bash'
    printf '%s\n' 'set -euo pipefail'
    printf 'trap %q EXIT\n' "rm -f $stage"
    printf '%s\n' "$cmd"
  } >"$stage"
  chmod 0700 "$stage"
  printf 'bash %q' "$stage"
}

dispatch_launch_observe_timeout() {
  # Generous, configurable ceiling for how long to wait for the agent process to
  # come up before declaring a GENUINE failure (pane created but no agent ever
  # appeared). This is the real-event bound, not a row-bind clock: it only gates
  # exit 70 when liveness never confirms. Raised to cover engine-boot-bound bind latency; under fleet
  # load (2-4 panes, MCP init, worktree first-shell hooks) cold start routinely
  # exceeds the old shorter windows. Override with DISPATCH_LAUNCH_OBSERVE_TIMEOUT; 0 disables the
  # observer entirely (the dispatcher trusts the send and returns immediately).
  local value="${DISPATCH_LAUNCH_OBSERVE_TIMEOUT:-120}"
  if [[ "$value" =~ ^[0-9]+$ ]]; then
    printf '%s' "$value"
  else
    printf '%s' "120"
  fi
}

pane_tmux_option() {
  local pane="$1" option="$2" value=""
  [[ -n "$pane" && -n "$option" ]] || return 0
  command -v tmux >/dev/null 2>&1 || return 0
  value="$(tmux show-options -pv -t "$pane" "$option" 2>/dev/null || true)"
  [[ -n "$value" ]] && printf '%s' "$value"
}

pane_wrapper_launch_id() {
  local pane="$1" value=""
  for value in \
    "${TOKEN_API_WRAPPER_ID:-}" \
    "${WRAPPER_ID:-}" \
    "${TOKEN_API_WRAPPER_LAUNCH_ID:-}" \
    "${WRAPPER_LAUNCH_ID:-}" \
    "$(pane_tmux_option "$pane" @TOKEN_API_WRAPPER_ID)" \
    "$(pane_tmux_option "$pane" @TOKEN_API_WRAPPER_LAUNCH_ID)"; do
    [[ -n "$value" ]] || continue
    printf '%s' "$value"
    return 0
  done
  return 0
}

pane_stamped_instance_id() {
  local pane="$1" value=""
  value="$(pane_instance_id "$pane" || true)"
  [[ -n "$value" ]] && { printf '%s' "$value"; return 0; }
  value="$(pane_tmux_option "$pane" @INSTANCE_ID)"
  [[ -n "$value" ]] && printf '%s' "$value"
}

clear_pane_wrapper_launch_id() {
  local pane="$1"
  command -v tmux >/dev/null 2>&1 || return 0
  tmux set-option -pu -t "$pane" @TOKEN_API_WRAPPER_ID >/dev/null 2>&1 || true
  tmux set-option -pu -t "$pane" @TOKEN_API_WRAPPER_LAUNCH_ID >/dev/null 2>&1 || true
  tmux set-option -pu -t "$pane" @INSTANCE_ID >/dev/null 2>&1 || true
}


dispatch_pane_exists() {
  # True while the pane is still present. A pane that VANISHES after the send is
  # the one unambiguous negative event (the launch died) — distinct from a pane
  # that is up but whose agent has not finished cold-starting yet.
  local pane="$1"
  [[ -n "$pane" ]] || return 1
  command -v tmux >/dev/null 2>&1 || return 0
  tmux display-message -p -t "$pane" '#{pane_id}' >/dev/null 2>&1
}

dispatch_pane_agent_live() {
  # THE success criterion: is a live Claude/Codex agent process running in the
  # pane right now? Engine-agnostic and faction-agnostic — read from the process
  # tree, NOT a DB stamp (which lags, and for codex may never land). Routed
  # through tmuxctld so it reuses the same battle-tested walk that gates
  # close-lifecycle reaps without shelling the retired cold tmuxctl CLI. Falls
  # back to an in-process ps walk only when daemon transport is unavailable.
  local pane="$1" live_rc pane_pid
  [[ -n "$pane" ]] || return 1
  tmuxctld_pane_live "$pane" >/dev/null 2>&1
  live_rc=$?
  case "$live_rc" in
    0) return 0 ;;
    1) return 1 ;;
  esac
  pane_pid="$(tmux display-message -p -t "$pane" '#{pane_pid}' 2>/dev/null || true)"
  pane_has_active_agent_process "$pane_pid"
}

registry_bind_ok_for_wrapper_launch_id() {
  local wrapper_id="$1" expected_workdir="$2"
  [[ -n "$wrapper_id" ]] || return 1
  local api_url="${TOKEN_API_URL:-http://localhost:7777}"
  TOKEN_API_URL="$api_url" WRAPPER_LAUNCH_ID="$wrapper_id" EXPECTED_WORKDIR="$expected_workdir" RESUME_ID_VALUE="$RESUME_ID" python3 - <<'PYREGBIND'
import json
import os
import sys
import urllib.parse
import urllib.request

api = os.environ.get("TOKEN_API_URL", "http://localhost:7777").rstrip("/")
wrapper = os.environ.get("WRAPPER_LAUNCH_ID", "")
if not wrapper:
    sys.exit(1)
url = f"{api}/api/instances/resolve?{urllib.parse.urlencode({'wrapper_launch_id': wrapper})}"
try:
    with urllib.request.urlopen(url, timeout=1) as resp:
        row = json.loads(resp.read().decode("utf-8"))
except Exception:
    sys.exit(1)
if not isinstance(row, dict) or not (row.get("id") or row.get("instance_id")):
    sys.exit(1)
expected_workdir = os.environ.get("EXPECTED_WORKDIR", "")
if not os.environ.get("RESUME_ID_VALUE") and expected_workdir and row.get("working_dir") != expected_workdir:
    sys.exit(1)
sys.exit(0)
PYREGBIND
}

registry_instance_id_for_wrapper_launch_id() {
  local wrapper_id="$1"
  [[ -n "$wrapper_id" ]] || return 0
  local api_url="${TOKEN_API_URL:-http://localhost:7777}"
  TOKEN_API_URL="$api_url" WRAPPER_LAUNCH_ID="$wrapper_id" python3 - <<'PYREGAPI'
import json
import os
import sys
import urllib.parse
import urllib.request

api = os.environ.get("TOKEN_API_URL", "http://localhost:7777").rstrip("/")
wrapper = os.environ.get("WRAPPER_LAUNCH_ID", "")
if not wrapper:
    sys.exit(0)
url = f"{api}/api/instances/resolve?{urllib.parse.urlencode({'wrapper_launch_id': wrapper})}"
try:
    with urllib.request.urlopen(url, timeout=1) as resp:
        data = json.loads(resp.read().decode("utf-8"))
except Exception:
    sys.exit(0)
if not isinstance(data, dict):
    sys.exit(0)
value = data.get("id") or data.get("instance_id") or ""
if value:
    print(str(value), end="")
PYREGAPI
}

registry_instance_id_for_wrapper_launch_id_sqlite() {
  local wrapper_id="$1"
  [[ -n "$wrapper_id" && -f "$DB_PATH" ]] || return 0
  command -v sqlite3 >/dev/null 2>&1 || return 0
  sqlite3 -readonly "$DB_PATH" \
    "SELECT id FROM instances WHERE wrapper_launch_id = '$(sql_literal "$wrapper_id")' AND COALESCE(rank,'') != 'retired' ORDER BY last_activity DESC LIMIT 1;" \
    2>/dev/null || true
}

pane_registry_instance_id() {
  local pane="$1" wrapper_id="" instance_id=""
  wrapper_id="$(pane_wrapper_launch_id "$pane" || true)"
  [[ -n "$wrapper_id" ]] || return 0
  instance_id="$(registry_instance_id_for_wrapper_launch_id "$wrapper_id" || true)"
  [[ -n "$instance_id" ]] || instance_id="$(registry_instance_id_for_wrapper_launch_id_sqlite "$wrapper_id" || true)"
  [[ -n "$instance_id" ]] && printf '%s' "$instance_id"
}

reconcile_dispatch_registry_bind() {
  # Registration binding is control-plane truth, not an advisory. Liveness proves
  # the engine came up, but after the observation window a missing/stopped row is
  # a loud failure because downstream sends/renames depend on registry binding.
  local pane="$1" target_display="$2" emit_error="${3:-1}" instance_id row status row_workdir row_label wrapper_id
  if ! command -v sqlite3 >/dev/null 2>&1; then
    [[ "$emit_error" == "1" ]] && err "launch failed: cannot verify registry binding because sqlite3 is unavailable"
    return 1
  fi
  if [[ ! -f "$DB_PATH" ]]; then
    [[ "$emit_error" == "1" ]] && err "launch failed: cannot verify registry binding because agents DB is missing at $DB_PATH"
    return 1
  fi
  wrapper_id="$(pane_wrapper_launch_id "$pane" || true)"
  if registry_bind_ok_for_wrapper_launch_id "$wrapper_id" "$WORK_DIR"; then
    return 0
  fi
  instance_id="$(pane_registry_instance_id "$pane" || true)"
  [[ -n "$instance_id" ]] || instance_id="$(pane_instance_id "$pane")"
  if [[ -n "$instance_id" ]]; then
    row="$(sqlite3 -separator $'\t' "$DB_PATH" \
      "SELECT COALESCE(status,''), COALESCE(working_dir,''), COALESCE(pane_label,'') FROM instances WHERE id = '$(printf "%s" "$instance_id" | sed "s/'/''/g")' LIMIT 1;" \
      2>/dev/null || true)"
    if [[ -n "$row" ]]; then
      IFS=$'\t' read -r status row_workdir row_label <<< "$row"
      if [[ "$status" != "stopped" && "$status" != "archived" ]] \
        && { [[ -n "$RESUME_ID" ]] || [[ "$row_workdir" == "$WORK_DIR" ]]; } \
        ; then
        return 0
      fi
    fi
  fi
  if [[ "$emit_error" == "1" ]]; then
    err "launch failed: ${ENGINE} agent is live at ${target_display}, but its instances row did not bind within the observation window; registration is broken and reconciliation did not catch up"
  fi
  return 1
}

dispatch_ledger_check_attempts() {
  local value="${DISPATCH_LEDGER_PRODUCER_CHECK_ATTEMPTS:-8}"
  if [[ "$value" =~ ^[0-9]+$ && "$value" -gt 0 ]]; then
    printf '%s' "$value"
  else
    printf '%s' "8"
  fi
}

dispatch_ledger_check_sleep() {
  local value="${DISPATCH_LEDGER_PRODUCER_CHECK_SLEEP:-0.25}"
  if [[ "$value" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    printf '%s' "$value"
  else
    printf '%s' "0.25"
  fi
}

dispatch_ledger_note_attempted_id() {
  local name="$1" value="$2" item existing
  [[ -n "$name" && -n "$value" ]] || return 0
  item="${name}=${value}"
  for existing in "${DISPATCH_LEDGER_ATTEMPTED_IDS[@]:-}"; do
    [[ "$existing" == "$item" ]] && return 0
  done
  DISPATCH_LEDGER_ATTEMPTED_IDS+=("$item")
}

dispatch_ledger_resolve_state() {
  local key="$1" value="$2" resolved
  [[ -n "$key" && -n "$value" ]] || return 1
  resolved="$(tmuxctld_result GET /ledger/resolve "$key=$value" 2>/dev/null || true)"
  [[ -n "$resolved" ]] || return 1
  LEDGER_RESOLVE_JSON="$resolved" python3 - <<'PYLEDGERSTATE'
import json
import os
import sys

try:
    data = json.loads(os.environ.get("LEDGER_RESOLVE_JSON", ""))
except json.JSONDecodeError:
    sys.exit(1)
row = data.get("row") if isinstance(data, dict) else None
if not isinstance(row, dict):
    sys.exit(1)
state = str(row.get("state") or "")
if state in {"OPEN", "SHIPPED"}:
    print(state, end="")
    sys.exit(0)
sys.exit(1)
PYLEDGERSTATE
}

ensure_dispatch_wrapper_ledger() {
  # The #600 comms gate makes a missing wrapper-ledger row a communications
  # blackout. Dispatch therefore no longer treats the tmuxctld ledger producer as
  # passive "eventual reconciliation": after the engine is live, force daemon
  # reconcile from pane stamps and verify an OPEN/SHIPPED row. Wrapperstart and
  # pane stamping can race this check, so retry briefly and resolve by every
  # identity that can be known at this point, not just the pane's public label.
  local pane="$1" target_display="$2"
  local attempts sleep_seconds attempt pane_label wrapper_id instance_id row_state
  local attempted_display attempted_id
  [[ "${DISPATCH_LEDGER_PRODUCER_CHECK:-1}" == "1" ]] || return 0
  attempts="$(dispatch_ledger_check_attempts)"
  sleep_seconds="$(dispatch_ledger_check_sleep)"
  DISPATCH_LEDGER_ATTEMPTED_IDS=()

  for ((attempt = 1; attempt <= attempts; attempt++)); do
    tmuxctld_result POST /reconcile session=main >/dev/null 2>&1 || {
      err "launch failed: ${ENGINE} agent is live at ${target_display}, but tmuxctld ledger reconcile failed; refusing to report a comms-dead launch"
      return 1
    }

    pane_label="$(resolve_pane_label_for_env "$pane")"
    [[ -n "$pane_label" ]] || pane_label="$pane"
    dispatch_ledger_note_attempted_id pane_positional_id "$pane_label"
    row_state="$(dispatch_ledger_resolve_state pane_positional_id "$pane_label" || true)"
    [[ "$row_state" == "OPEN" || "$row_state" == "SHIPPED" ]] && return 0

    wrapper_id="$(pane_wrapper_launch_id "$pane" || true)"
    dispatch_ledger_note_attempted_id wrapper_id "$wrapper_id"
    row_state="$(dispatch_ledger_resolve_state wrapper_id "$wrapper_id" || true)"
    [[ "$row_state" == "OPEN" || "$row_state" == "SHIPPED" ]] && return 0

    instance_id="$(pane_stamped_instance_id "$pane" || true)"
    dispatch_ledger_note_attempted_id instance_id "$instance_id"
    row_state="$(dispatch_ledger_resolve_state instance_id "$instance_id" || true)"
    [[ "$row_state" == "OPEN" || "$row_state" == "SHIPPED" ]] && return 0

    (( attempt < attempts )) && sleep "$sleep_seconds"
  done

  if ((${#DISPATCH_LEDGER_ATTEMPTED_IDS[@]})); then
    attempted_display="${DISPATCH_LEDGER_ATTEMPTED_IDS[0]}"
    for attempted_id in "${DISPATCH_LEDGER_ATTEMPTED_IDS[@]:1}"; do
      attempted_display+=", ${attempted_id}"
    done
  else
    attempted_display="none"
  fi
  err "launch failed: ${ENGINE} agent is live at ${target_display}, but wrapper ledger has no OPEN/SHIPPED row after ${attempts} attempts (${attempted_display}); sends would be refused by the comms gate"
  return 1
}

dispatch_observe_finalize_on_signal() {
  # Caller-lifetime salvage. The observe loop below blocks the caller for up to
  # DISPATCH_LAUNCH_OBSERVE_TIMEOUT seconds. That window is generous ON PURPOSE
  # (codex cold start + MCP init + worktree first-shell hooks routinely run tens
  # of seconds), but it is >= every caller ceiling that runs dispatch — the
  # Claude Code Bash tool default (120000ms), the agent-to-agent send-text 60s
  # ceiling, talk/brief's 60s POST. When the caller's own ceiling elapses first
  # it sends SIGTERM (or SIGINT), and an untrapped dispatch simply dies 143/130.
  #
  # 143 is NOT dispatch's verdict — it is an undefined signal-death a retrying
  # caller can misread as "launch failed" and blindly respawn, which is exactly
  # how the duplicate-FG corruption was born (see refuse_if_worktree_has_live_agent).
  # So collapse the interrupt into dispatch's OWN contract: one final synchronous
  # confirmation using the identical success criteria (live agent + registry bind
  # + wrapper ledger). Confirmed-good at this instant => exit 0 (truthful: the
  # launch DID land; the caller just gave up at the wrong moment). Not yet
  # confirmed => exit 70 (dispatch's defined "unconfirmed" code, fail-closed) —
  # never a raw 143. The ledger sub-check is capped short here so the handler
  # finishes inside the SIGTERM->SIGKILL grace.
  # The interrupt almost always lands while a liveness/bind/ledger probe is mid
  # command-substitution ($(...)), whose pipe has captured fd1. Write the verdict
  # to the real stdout/stderr saved as fds 6/7 at loop entry so the operator (and
  # a capturing caller) actually see it, instead of it being swallowed by the
  # discarded substitution. bash 3.2 has no {var}>&1 auto-fd, hence fixed numbers.
  local sig="${1:-TERM}"
  trap - TERM INT
  if [[ -n "${OBSERVE_PANE:-}" ]] \
    && dispatch_pane_agent_live "$OBSERVE_PANE" \
    && reconcile_dispatch_registry_bind "$OBSERVE_PANE" "${OBSERVE_DISPLAY:-}" 0 \
    && DISPATCH_LEDGER_PRODUCER_CHECK_ATTEMPTS=2 \
       ensure_dispatch_wrapper_ledger "$OBSERVE_PANE" "${OBSERVE_DISPLAY:-}"; then
    printf '%s\n' "dispatched $ENGINE to ${OBSERVE_DISPLAY:-target} (confirmed live on caller interrupt SIG${sig})" >&6
    exit 0
  fi
  echo "dispatch: launch observation interrupted by SIG${sig} before ${ENGINE} launch to ${OBSERVE_DISPLAY:-target} confirmed; reporting unconfirmed (exit 70) instead of signal-death so a retrying caller fails closed and the worktree dup-guard prevents a duplicate spawn" >&7
  exit 70
}

confirm_dispatch_launch_live() {
  # Liveness-driven launch confirmation. Success = the pane is up AND a live agent
  # process is running in it AND the registry row binds by the end of the
  # observation window. A row lag with a live pane is a control-plane failure.
  local pane="$1" target_display="$2" timeout deadline saw_live=0
  timeout="$(dispatch_launch_observe_timeout)"
  # Observer disabled (0): trust the send and return immediately. Used by the
  # bulk of the hermetic CLI tests and available as a production opt-out.
  [[ "$timeout" -gt 0 ]] || return 0
  # Arm the caller-lifetime salvage for the blocking wait. A SIGTERM/SIGINT from
  # the caller's ceiling now runs one final confirmation and exits with dispatch's
  # own 0/70 contract rather than dying 143. OBSERVE_* carry the pane/display into
  # the trap handler (bash traps see enclosing-scope state, not positional args).
  OBSERVE_PANE="$pane"
  OBSERVE_DISPLAY="$target_display"
  # Snapshot the real stdout/stderr NOW, before any observe-loop command
  # substitution can redirect fd1, so the signal handler can emit its verdict to
  # them unconditionally (see dispatch_observe_finalize_on_signal).
  exec 6>&1 7>&2
  trap 'dispatch_observe_finalize_on_signal TERM' TERM
  trap 'dispatch_observe_finalize_on_signal INT' INT
  deadline=$((SECONDS + timeout))
  while (( SECONDS <= deadline )); do
    if dispatch_pane_agent_live "$pane"; then
      saw_live=1
      if reconcile_dispatch_registry_bind "$pane" "$target_display" 0; then
        ensure_dispatch_wrapper_ledger "$pane" "$target_display" || return 1
        return 0
      fi
    fi
    if ! dispatch_pane_exists "$pane"; then
      err "launch failed: the pane for ${ENGINE} launch to ${target_display} vanished before an agent came up; the staged command died on start"
      return 1
    fi
    sleep 0.3
  done
  if [[ "$saw_live" == "1" ]]; then
    if ! dispatch_pane_agent_live "$pane"; then
      err "launch failed: the ${ENGINE} agent appeared in ${target_display} but exited before registry binding completed"
      return 1
    fi
    if reconcile_dispatch_registry_bind "$pane" "$target_display" 1; then
      ensure_dispatch_wrapper_ledger "$pane" "$target_display" || return 1
      return 0
    fi
    return 1
  fi
  err "launch failed: no live ${ENGINE} agent appeared in the pane within ${timeout}s for ${target_display}; the pane is up but the staged command never started the agent (raise DISPATCH_LAUNCH_OBSERVE_TIMEOUT if cold start is slow)"
  return 1
}

refuse_if_worktree_has_live_agent() {
  # FAIL SAFE against the two-agents-one-worktree corruption (the duplicate FG hit
  # after a false exit-70 retry). Before launching into an EXISTING worktree
  # (resume / --no-worktree / --worktree resume), refuse if a live Claude/Codex
  # agent is ALREADY rooted there. Detection is by LIVENESS (process tree + pane
  # cwd via `tmuxctl live-agents`), never the DB stamp — the duplicate may itself
  # be a row-less / undercounted live agent, which is exactly the case that bit FG.
  local dir="$1" self_pane="${2:-}" matches wt_root
  [[ -n "$dir" ]] || return 0
  # Scope: this is a WORKTREE dup-guard (1 branch = 1 worktree = 1 PR). It must
  # only de-duplicate WITHIN the ~/worktrees tree, NEVER globally. Dispatching
  # several agents into a shared non-worktree checkout (e.g. the Imperium-ENV
  # vault) is legitimate and must not be refused — those dirs are not the
  # two-agents-one-worktree corruption this guard exists to prevent.
  dir="${dir%/}"
  wt_root="${IMPERIUM_WORKTREES_ROOT:-$HOME/worktrees}"
  wt_root="${wt_root%/}"
  [[ "$dir" == "$wt_root" || "$dir" == "$wt_root"/* ]] || return 0
  # Hermetic opt-out: tests set DISPATCH_WORKTREE_DUP_CHECK=0 so the suite never
  # enumerates the operator's LIVE tmux server. Default (unset) = enabled.
  [[ "${DISPATCH_WORKTREE_DUP_CHECK:-1}" == "0" ]] && return 0
  [[ "${TOKEN_API_DISPATCH_FORCE_OCCUPIED:-}" == "1" ]] && return 0
  matches="$(tmuxctld_result POST /live-agents dir="$dir" ${self_pane:+exclude_pane="$self_pane"} 2>/dev/null || true)"
  [[ -n "$matches" ]] || return 0
  err "refusing to dispatch: a live agent is already running in the target worktree $dir:"
  while IFS= read -r line; do
    [[ -n "$line" ]] && err "  $(printf '%s' "$line" | redact_tmux_panes_for_display)"
  done <<< "$matches"
  err "resume that agent (do NOT stack a second into one worktree), or launch a fresh --worktree; set TOKEN_API_DISPATCH_FORCE_OCCUPIED=1 to override"
  exit 73
}

build_dispatch_command() {
  local -a args
  if [[ -n "$RESUME_ID" ]]; then
    args=(dispatch --id "$RESUME_ID")
    [[ -n "$TARGET" ]] && args+=(--pane "$TARGET")
    [[ "$RESUME_ROW_FOUND" != true ]] && args+=(--engine "$ENGINE" --dir "$WORK_DIR")
    local a
    for a in "${args[@]}"; do printf '%q ' "$a"; done
    return
  else
    args=(dispatch --engine "$ENGINE" --dir "$WORK_DIR")
  fi
  [[ -n "$PERSONA" ]] && args+=(--persona "$PERSONA")
  [[ -n "$CLAUDE_MODEL" ]] && args+=(--model "$CLAUDE_MODEL")
  [[ -n "$WORKTREE_BRANCH" ]] && args+=(--worktree "$WORKTREE_BRANCH")
  if [[ -z "$RESUME_ID" ]]; then
    [[ -n "$SESSION_DOC" ]] && args+=(--session-doc "$SESSION_DOC")
    if $DISPATCH_SELF; then args+=(--self); elif [[ -n "$TARGET" ]]; then args+=(--target "$TARGET"); fi
  fi
  if [[ -n "$INSTANCE_TYPE_OVERRIDE" ]]; then args+=(--instance-type "$INSTANCE_TYPE_OVERRIDE"); elif $SYNC; then args+=(--sync); elif $GT_MODE; then args+=(--gt); else args+=(--no-gt); fi
  args+=(--zealotry "$ZEALOTRY")
  $WITH_BROWSER && args+=(--with-browser)
  $WITH_DESKTOP && args+=(--with-desktop)
  [[ -n "$WITH_MCP" ]] && args+=(--with-mcp "$WITH_MCP")
  [[ -n "$DISCORD_CHANNEL" ]] && args+=(--discord "$DISCORD_CHANNEL")
  [[ -n "$SYSTEM_PROMPT" ]] && args+=(--system-prompt "$SYSTEM_PROMPT")
  [[ -n "$PROMPT" ]] && args+=(--prompt "$PROMPT")
  for a in "${args[@]}"; do printf '%q ' "$a"; done
}

RESOLVED_DISPATCH_COMMAND="$(LC_ALL=C; build_dispatch_command)"
PERSONA_DISPLAY="$PERSONA"
if [[ -z "$PERSONA_DISPLAY" ]]; then
  PERSONA_DISPLAY="Astartes — $(persona_harness_label "$ENGINE")"
fi

if $DRY_RUN; then
  cat <<EOF_DRY
dispatch dry-run
  engine:          $ENGINE
  resume_id:       ${RESUME_ID:-none}
  resume_db:       $RESUME_ROW_FOUND
  dir:             $WORK_DIR
  worktree:        $WORKTREE_DECISION
  target:          $(printf '%s' "${TARGET:-current}" | redact_tmux_panes_for_display)
  resolved_target: $(printf '%s' "${RESOLVED_TARGET:-current}" | redact_tmux_panes_for_display)
  persona:         $PERSONA_DISPLAY
  instance_type:   $INSTANCE_TYPE
  zealotry:        $ZEALOTRY
  sync:            $SYNC
  claude_model:    ${CLAUDE_MODEL:-default}
  session_doc:     ${SESSION_DOC:-new session doc}
  system_prompt:   $([[ -n "$SYSTEM_PROMPT" ]] && echo provided || echo none)
  mcp:             $MCP_DECISION
  discord:         ${DISCORD_CHANNEL:-none}${DISCORD_CHANNEL:+ (bot: $DISCORD_BOT)}
  launch_env:
EOF_DRY
  for e in "${COMMON_ENV[@]}"; do printf '%s\n' "    $e" | redact_tmux_panes_for_display; done
  echo "  dispatch_command:"
  printf '%s\n' "    $RESOLVED_DISPATCH_COMMAND" | redact_tmux_panes_for_display
  echo "  final_command:"
  printf '%s\n' "    $FINAL_COMMAND" | redact_tmux_panes_for_display
  exit 0
fi

# Duplicate-refusal guard: a launch into a pre-existing worktree (resume,
# --no-worktree, or --worktree resume) must never STACK a second agent onto a
# worktree that already hosts a live one. A freshly-cut worktree is provably
# exclusive, so skip it there. The dispatcher's own pane is excluded so an agent
# launching a worker into its own dir (to a NEW pane) is not refused by itself.
if [[ "$WORKTREE_FRESHLY_CREATED" != true ]]; then
  refuse_if_worktree_has_live_agent "$WORK_DIR" "${TMUX_PANE:-}"
fi

if [[ "$LAUNCH_MODE" == "tmux_stack_new" ]]; then
  if ! command -v tmuxctld-ping >/dev/null 2>&1; then
    err "tmuxctld-ping is required for target $TARGET"
    exit 69
  fi
  session="main"
  stack="$DISPATCH_WINDOW"
  # Newborn-pane keystroke race: the first send-keys burst into a freshly
  # spawned pane can lose its leading chars (an upstream type-check guard
  # races shell-readiness). Spawn the pane with a throwaway `clear` warmup
  # that absorbs the loss, then send the real staged `. <tmpfile>` command
  # via our own send-keys after a settle — mirroring the tmux_target dance
  # below. Without this, `source <tmpfile>` arrives as e.g. `ur <tmpfile>`
  # and the agent never launches.
  # Automated dispatch should not steal the operator's camera/focus. The new pane
  # is still addressable by @PANE_ID/Token-API metadata and can be focused explicitly.
  pane_id="$(tmuxctld_stack_dispatch "$stack" "$session" "$WORK_DIR" "clear")"
  # The tmuxctl canonical-id campaign made `stack dispatch` print the canonical
  # page:index id (e.g. mechanicus:2). That id is the working identity from here
  # on — carried through env injection, stamping, and the launch send — and only
  # materialized to a physical %NNN at the raw `tmux send-keys` site below.
  pane_id="$(printf '%s\n' "$pane_id" | tail -n1)"
  # Validate the canonical contract directly (page:index). A non-canonical emit
  # (older tmuxctl, or a stack failure) is now a loud error rather than a silent
  # fallthrough — the dog-food-saturation contract.
  if [[ ! "$pane_id" =~ ^[a-z][a-z0-9-]*:[A-Za-z0-9-]+$ ]]; then
    err "stack dispatch returned a non-canonical id for $stack: '${pane_id}'"
    exit 1
  fi
  # FINAL_COMMAND was built (above) before this pane existed, so it baked the
  # allocation token (e.g. mechanicus:new) into the launch env. Now that the
  # concrete pane is known, carry it as the canonical RESOLVED_TARGET and rebuild
  # the launch env so the agent's first SessionStart registers the real pane —
  # otherwise pane_truth / assert-instance / agent-cmd cannot resolve pane→instance
  # and the orchestrator cannot drive its own child. The request token stays in
  # TOKEN_API_DISPATCH_TARGET (the row's dispatch_target field).
  RESOLVED_TARGET="$pane_id"
  stamp_resume_instance_id "$pane_id"
  FINAL_COMMAND="$(LC_ALL=C; build_agent_command)"
  sleep 0.3
  STAGED_COMMAND="$(stage_agent_command "$FINAL_COMMAND")"
  phys_pane="$(materialize_physical_pane "$pane_id")"
  clear_pane_wrapper_launch_id "$phys_pane"
  dispatch_send_text_via_tmuxctld "$pane_id" "$STAGED_COMMAND" || exit $?
  stack_display="${TARGET:-${DISPATCH_WINDOW}:new}"
  [[ "$stack_display" == %* ]] && stack_display="${DISPATCH_WINDOW}:new"
  # Success = pane up + live agent process + registry bind inside the observation
  # window. Missing bind is a loud failure, not eventual-reconciliation comfort.
  if ! confirm_dispatch_launch_live "$phys_pane" "$stack_display"; then
    exit 70
  fi
  # Liveness confirmed: reach exit 0 so the launched agent is NOT reaped/retried
  # and proceeds through its SessionStart naming step.
  printf '%s\n' "dispatched $ENGINE to $stack_display" | redact_tmux_panes_for_display
  exit 0
fi

if [[ "$LAUNCH_MODE" == "tmux_target" && -n "$TARGET" ]]; then
  if ! command -v tmux >/dev/null 2>&1; then
    err "tmux is required for target $TARGET"
    exit 69
  fi
  # Canonical working id in, physical materialized once at the raw-tmux boundary.
  # assert/stamp take the canonical id and resolve internally; the two send-keys
  # syscalls share a single materialized physical id.
  assert_dispatch_target_unoccupied "$RESOLVED_TARGET"
  stamp_resume_instance_id "$RESOLVED_TARGET"
  PHYSICAL_TARGET="$(materialize_physical_pane "$RESOLVED_TARGET")"
  dispatch_send_text_via_tmuxctld "$RESOLVED_TARGET" "clear" || exit $?
  sleep 0.2
  STAGED_COMMAND="$(stage_agent_command "$FINAL_COMMAND")"
  clear_pane_wrapper_launch_id "$PHYSICAL_TARGET"
  dispatch_send_text_via_tmuxctld "$RESOLVED_TARGET" "$STAGED_COMMAND" || exit $?
  target_display="${RESOLVED_TARGET:-$TARGET}"
  if [[ "$TARGET" == %* ]]; then
    if command -v pane_id_of >/dev/null 2>&1; then
      human_target="$(pane_id_of "$TARGET" 2>/dev/null || true)"
      [[ -n "$human_target" ]] && target_display="$human_target"
    fi
    [[ "$target_display" == %* ]] && target_display="tmux target"
  fi
  # Success = pane up + live agent process (liveness), NOT a DB-row bind clock.
  if ! confirm_dispatch_launch_live "$PHYSICAL_TARGET" "$target_display"; then
    exit 70
  fi
  echo "dispatched $ENGINE to $target_display"
  exit 0
fi

stamp_resume_instance_id "${RESOLVED_TARGET:-${TMUX_PANE:-}}"
exec bash -lc "$FINAL_COMMAND"
