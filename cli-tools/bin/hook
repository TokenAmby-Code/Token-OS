#!/usr/bin/env python3
# hook - Token-API hook subscription CLI
# TAGS: trinity, ipc, hook
# AUDIENCE: agent

from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.parse
import urllib.request
from typing import Optional

TOKEN_API_URL = os.environ.get("TOKEN_API_URL", "http://localhost:7777")


def _err(msg: str) -> None:
    print(f"hook: {msg}", file=sys.stderr)


def _request(method: str, path: str, body: Optional[dict] = None) -> dict:
    data = json.dumps(body or {}).encode("utf-8") if body is not None else None
    req = urllib.request.Request(
        f"{TOKEN_API_URL}{path}",
        data=data,
        headers={"Content-Type": "application/json"},
        method=method,
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read().decode("utf-8"))


def _print_result(result: dict, json_out: bool) -> int:
    if json_out:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        action = result.get("action") or "listed"
        if "subscription_id" in result:
            print(
                f"[hook:{action}] id={result['subscription_id']} "
                f"{result.get('target_instance_id') or result.get('target_pane')} -> "
                f"{result.get('subscriber_instance_id') or result.get('subscriber_pane')}"
            )
        elif "subscriptions" in result:
            rows = result.get("subscriptions") or []
            print(f"[hook:list] count={len(rows)}")
            for row in rows:
                print(
                    f"  #{row.get('id')} {row.get('event')} {row.get('status')} "
                    f"{row.get('target_instance_id')} ({row.get('target_pane') or '-'}) -> "
                    f"{row.get('subscriber_instance_id') or '-'} ({row.get('subscriber_pane')})"
                )
        elif result.get("action") in {"reconciled", "no_live_fabricator_general"}:
            print(
                f"[hook:{result.get('action')}] page={result.get('page')} "
                f"created={result.get('created', 0)} existing={result.get('existing', 0)} "
                f"skipped={result.get('skipped', 0)}"
            )
        else:
            print(json.dumps(result, sort_keys=True))
    return 0 if result.get("success", True) else 1


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="hook", description="Manage Token-API hook subscriptions.")
    parser.add_argument("--json", action="store_true", help="Emit JSON")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_sub = sub.add_parser("subscribe", help="Subscribe to hook events")
    p_sub.add_argument("--pane", required=True, help="Target pane/instance to watch")
    p_sub.add_argument("--on", default="stop", choices=["stop"], help="Event to subscribe to")
    p_sub.add_argument("--notify", required=True, help="Subscriber pane/instance to notify")
    p_sub.add_argument("--delivery", default="prompt", choices=["prompt", "ephemeral"])
    p_sub.add_argument("--purpose", default="generic")
    p_sub.add_argument("--payload", default=None, help="Custom prompt payload to deliver")
    p_sub.add_argument("--oneshot", action="store_true", help="Deactivate after first delivery attempt")

    p_un = sub.add_parser("unsubscribe", help="Unsubscribe from hook events")
    p_un.add_argument("--pane", required=True, help="Target pane/instance watched")
    p_un.add_argument("--on", default="stop", choices=["stop"])
    p_un.add_argument("--notify", default=None, help="Subscriber pane/instance")
    p_un.add_argument("--purpose", default=None)

    p_list = sub.add_parser("list", help="List subscriptions")
    p_list.add_argument("--pane", default=None, help="Target pane/instance")
    p_list.add_argument("--notify", default=None, help="Subscriber pane/instance")
    p_list.add_argument("--on", default="stop", choices=["stop"])
    p_list.add_argument("--all", action="store_true", help="Include inactive")
    p_list.add_argument("--purpose", default=None)

    p_rec = sub.add_parser("reconcile", help="Repair hook subscriptions for a page")
    p_rec.add_argument("--page", default="mechanicus", choices=["mechanicus"])

    args = parser.parse_args(argv)
    try:
        if args.cmd == "subscribe":
            result = _request(
                "POST",
                "/api/hooks/subscribe",
                {
                    "target_pane": args.pane,
                    "subscriber_pane": args.notify,
                    "event": args.on,
                    "delivery": args.delivery,
                    "purpose": args.purpose,
                    "payload": args.payload,
                    "oneshot": args.oneshot,
                },
            )
        elif args.cmd == "unsubscribe":
            result = _request(
                "POST",
                "/api/hooks/unsubscribe",
                {
                    "target_pane": args.pane,
                    "subscriber_pane": args.notify,
                    "event": args.on,
                    "purpose": args.purpose,
                },
            )
        elif args.cmd == "list":
            q = {"event": args.on, "status": "all" if args.all else "active"}
            if args.pane:
                q["target_pane"] = args.pane
            if args.notify:
                q["subscriber_pane"] = args.notify
            if args.purpose:
                q["purpose"] = args.purpose
            result = _request("GET", f"/api/hooks/subscriptions?{urllib.parse.urlencode(q)}")
        elif args.cmd == "reconcile":
            result = _request("POST", "/api/hooks/reconcile", {"page": args.page})
        else:
            _err(f"unknown command: {args.cmd}")
            return 1
    except Exception as exc:
        _err(str(exc))
        return 1
    return _print_result(result, args.json)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
