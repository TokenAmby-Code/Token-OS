#!/usr/bin/env bash
# tmux-plan-menu - Shift+Tab fzf action picker for Claude/Codex panes
# TAGS: tmux, plan, keybind
# AUDIENCE: human
#
# Bare Shift+Tab opens this picker: preplan / plan / compact / shift+tab / cancel.
#   preplan   -> insert the preplan leader (/preplan for Claude, $preplan for
#                Codex) at the prompt START and arm a one-shot Stop subscription
#                that delivers the plan turn after this pane next stops
#   plan      -> insert /plan    at the prompt start (universal slash, both harnesses)
#   compact   -> insert /compact at the prompt start (universal slash, both harnesses)
#   shift+tab -> forward ONE literal Shift+Tab (native mode cycle)
#   cancel    -> no-op
#
# Actions never auto-submit: each drops the command at the FRONT of the prompt
# and returns the cursor to the END (via tmuxctl invoke-skill -> insert at prompt
# start), so the operator keeps typing and submits when ready. The harness probe
# preplan needs runs in the background while the picker is open, so a preplan
# pick reads a ready answer instead of stalling on detection. Replaces the old
# tmux-plan-prefix screen-scrape-and-edit cycle.

set -euo pipefail

PANE=""
SELECTION=""
AGENT="auto"
DRY_RUN=false
API_URL=""

# Guard value-taking flags so a missing operand is a clean error, not a `set -u`
# "unbound variable $2" crash.
_require_arg() { [[ $1 -ge 2 ]] || { echo "tmux-plan-menu: $2 requires a value" >&2; exit 1; }; }

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pane) _require_arg $# --pane; PANE="$2"; shift 2 ;;
        --selection) _require_arg $# --selection; SELECTION="$2"; shift 2 ;;
        --agent) _require_arg $# --agent; AGENT="$2"; shift 2 ;;
        --dry-run) DRY_RUN=true; shift ;;
        --api-url) _require_arg $# --api-url; API_URL="$2"; shift 2 ;;
        -h|--help) sed -n '2,/^$/s/^# //p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
done

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${_script_dir}/../lib/nas-path.sh" >/dev/null 2>&1 || true
API_URL="${API_URL:-${TOKEN_API_URL:-}}"

# --- pane resolution -------------------------------------------------------
# A bare Shift+Tab routes through:  display-popup -e "BTAB_PANE=#{pane_id}"
# tmux expands #{pane_id} against the focused pane when the key is dispatched and
# exports it into the popup environment. Inside the popup neither a command-line
# #{pane_id} (display-popup does not expand its shell-command) nor $TMUX_PANE
# (unset by the popup, tmux 3.6) survive, so BTAB_PANE is the lock on the
# invoking pane. Accept only a real %id; otherwise fall back to the popup
# client's active pane, which display-message resolves to the launching pane.
_is_pane_id() { [[ "${1:-}" == %* ]]; }
if ! _is_pane_id "$PANE"; then
    if _is_pane_id "${BTAB_PANE:-}"; then
        PANE="$BTAB_PANE"
    else
        PANE=$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)
    fi
fi

# Real actions target $PANE (invoke-skill / tmux send-keys); refuse to proceed
# with an empty target. Dry-run is purely informational, so let it through.
if [[ -z "$PANE" ]] && ! $DRY_RUN; then
    echo "tmux-plan-menu: no target pane (pass --pane, set BTAB_PANE, or run inside tmux)" >&2
    exit 1
fi

# A bare Shift+Tab is the Emperor pressing a key: every action this menu fires —
# the preplan/plan/compact inserts (via `tmuxctl invoke-skill`) and the literal
# Shift+Tab forward — is direct Emperor input, NOT automation. Mark the sends
# sanctioned so they PIERCE the universal recent-typing gate instead of delaying
# behind the very keystroke that opened this menu (a delay the popup outlives, so
# the insert silently never lands). Same pierce `tmux-dictate` uses, which Discord
# active-pane injection reuses through it. Still audited by tmuxctl.send_gate as a
# send_gate_override. `${VAR:-default}` so an explicit outer disposition still wins.
export TMUX_SEND_GATE_ALLOW="${TMUX_SEND_GATE_ALLOW:-tmux-plan-menu-direct-input}"
export TMUX_SEND_GATE_POLICY="${TMUX_SEND_GATE_POLICY:-pierce}"

json_escape() {
    python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"
}

normalize_agent() {
    case "${1:-auto}" in
        codex|openai) echo codex ;;
        claude|claude-code|anthropic) echo claude ;;
        *) echo auto ;;
    esac
}

preplan_leader() {
    case "$(normalize_agent "$1")" in
        codex) echo '$preplan' ;;
        *) echo '/preplan' ;;
    esac
}

# --- background harness detection (preplan only) ---------------------------
# `tmuxctl resolve-agent` probes the instance registry, then the live pane
# process (ps on the pane tty), then the @PLANNING_AGENT hint. Kick it off while
# fzf is open so a preplan pick reads a ready answer instead of paying the probe
# latency after selection. --default auto makes it echo "auto" (not a guessed
# "claude") when detection is genuinely inconclusive, so preplan can fail closed.
# plan/compact are universal slash commands and never consult this.
_AGENT_FILE=""
_PRESTART_DONE=""
_PRESTART_OK=1   # 0 once the pre-buffer is confirmed at prompt start (set by _await_prestart)
_PROMPT_MOVED=0     # 1 once this action has moved the prompt cursor and must restore it
# Blind page-key counts: 50 each clears a multi-page draft (proven). Env-tunable so
# tests can shrink the gated-send volume (and a future "saucy" computed PgDn can
# override the restore count). PgUp-at-top / End are idempotent, so 50 is a safe floor.
PAGE_UPS="${TMUX_PLAN_MENU_PAGE_UPS:-50}"     # pre-buffer cursor->prompt start
PAGE_DOWNS="${TMUX_PLAN_MENU_PAGE_DOWNS:-50}" # generic on-exit cursor->prompt end
# Always return 0: under `set -e` a falsey final command in the EXIT trap (when a
# temp path is empty) would override the script's real exit status with 1. On the
# detached path the parent clears this trap (trap - EXIT) and the detached child
# removes the temp files at the end of run_action — see the dispatch tail.
_action_cleanup() {
    [[ -n "$_AGENT_FILE" ]] && rm -f "$_AGENT_FILE"
    [[ -n "$_PRESTART_DONE" ]] && rm -f "$_PRESTART_DONE"
    return 0
}
trap _action_cleanup EXIT

_start_agent_detect() {
    $DRY_RUN && return 0
    [[ "$(normalize_agent "$AGENT")" != auto ]] && return 0   # explicit override: no probe
    [[ -z "$PANE" ]] && return 0
    _AGENT_FILE=$(mktemp -t tmux-plan-menu-agent.XXXXXX 2>/dev/null) || { _AGENT_FILE=""; return 0; }
    # trap '' HUP so the probe survives popup teardown (display-popup -E SIGHUPs the
    # popup pane's process group on close); </dev/null detaches stdin from the dying
    # popup PTY. The detached action reads the result (sync-probe fallback if unset).
    ( trap '' HUP; "${_script_dir}/tmuxctl" resolve-agent --pane "$PANE" --agent auto --default auto \
        >"$_AGENT_FILE" 2>/dev/null || true ) </dev/null >/dev/null 2>&1 &
}

# Resolve the harness for preplan: prefer the async result (wait up to ~1s for
# the background probe), then fall back to a synchronous probe. Echoes the
# normalized harness, or "auto" when detection fails.
_detect_agent() {
    local a="" i
    if [[ -n "$_AGENT_FILE" ]]; then
        for i in $(seq 1 10); do
            a="$(normalize_agent "$(cat "$_AGENT_FILE" 2>/dev/null)")"
            [[ "$a" != auto ]] && { echo "$a"; return 0; }
            sleep 0.1
        done
    fi
    a="$(normalize_agent "$("${_script_dir}/tmuxctl" resolve-agent --pane "$PANE" --agent auto --default auto 2>/dev/null)")"
    echo "$a"
}

# One-shot Stop subscription: when this pane next stops after the operator
# submits the preplan turn, deliver the plan turn. PR#2b routes this to /compact
# when the preplan response recommends it; the payload here remains the default
# plan submission.
subscribe_preplan() {
    [[ -z "$API_URL" ]] && return 0
    local body resp rc=0 attempt
    body="{\"target_pane\":$(json_escape "$PANE"),\"subscriber_pane\":$(json_escape "$PANE"),\"event\":\"stop\",\"delivery\":\"prompt\",\"purpose\":\"preplan_plan\",\"payload\":\"/plan create the plan\",\"oneshot\":true}"
    # preplan is fail-closed: a timed-out subscribe skips the leader insert, so the
    # whole pick no-ops (the codex live-test symptom). Give the (sometimes slow)
    # endpoint real headroom (--max-time 8, was 2) and one retry on a transient
    # curl failure — DNS/connect/timeout/TLS/recv (6/7/28/35/52/55/56) — before
    # failing closed. A non-transient failure (e.g. HTTP 4xx via -f -> exit 22) is
    # not retried; it will not improve on a second attempt.
    for attempt in 1 2; do
        rc=0
        resp=$(curl -sf --max-time 8 -X POST "${API_URL}/api/hooks/subscribe" \
            -H 'Content-Type: application/json' -d "$body") || rc=$?
        (( rc == 0 )) && break
        case "$rc" in
            6|7|28|35|52|55|56) continue ;;  # transient: one retry
            *) break ;;                      # non-transient: fail now
        esac
    done
    if (( rc != 0 )); then
        echo "tmux-plan-menu: subscribe_preplan POST ${API_URL}/api/hooks/subscribe failed (curl exit $rc)" >&2
        return "$rc"
    fi
    # /api/hooks/subscribe returns HTTP 200 with {"success": false} when the pane
    # can't be resolved (target_unresolved/subscriber_unresolved), so a 2xx is not
    # enough — confirm the one-shot actually armed before the caller inserts a leader.
    if ! RESP="$resp" python3 -c '
import json, os, sys
try:
    ok = bool(json.loads(os.environ["RESP"] or "{}").get("success"))
except Exception:
    ok = False
sys.exit(0 if ok else 1)
'; then
        echo "tmux-plan-menu: subscribe_preplan did not arm (response: ${resp:-<empty>})" >&2
        return 1
    fi
}

set_planning_state() {
    local state="$1"
    tmux set-option -p -t "$PANE" @PLANNING_STATE "$state" 2>/dev/null || true
    [[ -z "$API_URL" ]] && return 0
    local body rc=0
    body="{\"tmux_pane\":$(json_escape "$PANE"),\"state\":$(json_escape "$state"),\"source\":\"tmux-plan-menu\"}"
    # Advisory/non-blocking, but the same slow-endpoint window applies; give it a
    # little slack (--max-time 3, was 1) so a transient stall does not log-noise.
    curl -sf --max-time 3 -X POST "${API_URL}/api/planning/state" \
        -H 'Content-Type: application/json' -d "$body" >/dev/null || rc=$?
    if (( rc != 0 )); then
        echo "tmux-plan-menu: set_planning_state POST ${API_URL}/api/planning/state failed (curl exit $rc)" >&2
        return "$rc"
    fi
}

# --- decomposed cursor ops (real-tmux path; pierce env inherited) -----------
# All three route through `tmuxctl` -> TmuxAdapter -> the real tmux binary with
# the in-process send gate, NOT the gating `tmux` shim in the keystroke path (the
# old tmux-plan-prefix freeze: a Python startup + gate eval per PgUp keystroke).
# They run backgrounded / detached so even their modest latency never blocks the
# popup. plan/compact insert the universal "/" leader (not codex "$").
prebuffer_prompt_start() { "${_script_dir}/tmuxctl" prompt-start --pane "$PANE" --page-ups "$PAGE_UPS"; }
insert_text()           { "${_script_dir}/tmuxctl" insert-text  --pane "$PANE" --text "$1"; }
move_prompt_end()       { "${_script_dir}/tmuxctl" prompt-end   --pane "$PANE" --page-downs "$PAGE_DOWNS"; }
sink_codex_skill()      { tmux send-keys -t "$PANE" Tab; }

# Optional pre-buffer: disabled by default.  The old default moved the prompt
# cursor while the picker was still open, which made Shift+Tab feel like a slow
# visible macro and increased the chance of stray typing into the wrong part of
# a draft.  The selected action now performs prompt-start only after selection,
# using tmux's tight repeat-count macro in tmuxctl. Set
# TMUX_PLAN_MENU_PREBUFFER=1 only for profiling the old overlap behavior.
_start_prebuffer() {
    $DRY_RUN && return 0
    [[ "${TMUX_PLAN_MENU_PREBUFFER:-0}" == "1" ]] || return 0
    [[ -z "$PANE" ]] && return 0
    _PRESTART_DONE=$(mktemp -t tmux-plan-menu-prestart.XXXXXX 2>/dev/null) || { _PRESTART_DONE=""; return 0; }
    # Write the done-marker ONLY when prompt-start actually reached the prompt
    # start. A failed move must NOT signal "done" — otherwise an insert could
    # land at the current cursor instead of prompt start. Capture tmuxctl's stderr
    # and log a failed move (previously swallowed by `2>&1`, masking half of the
    # cursor-op failures) so a missed prompt-start is diagnosable from the log.
    ( trap '' HUP
      local _ps_err
      if _ps_err="$(prebuffer_prompt_start 2>&1)"; then
          printf 'done' > "$_PRESTART_DONE"
      else
          log_failure "${SELECTION:-prebuffer}" "$(normalize_agent "$AGENT")" prompt-start "prebuffer rc=$? ${_ps_err}"
      fi ) \
        </dev/null >/dev/null 2>&1 &
}

# Block (bounded ~1.5s) until the pre-buffer signals the cursor reached the
# prompt start. Records the outcome in _PRESTART_OK (0=confirmed, 1=timeout/
# failed/none) so inserts can self-position without re-waiting, and returns it.
# Called once per run (drain point): even on a 1 the background pre-buffer has
# exited (marker written, or 1.5s elapsed), so the on-exit prompt-end restore no
# longer races a live PgUp. With no marker to wait on (dry-run / no pane) there
# is nothing to position, so it reports confirmed.
_await_prestart() {
    [[ -z "$_PRESTART_DONE" ]] && { _PRESTART_OK=1; return 1; }
    local i
    for i in $(seq 1 15); do
        [[ -s "$_PRESTART_DONE" ]] && { _PRESTART_OK=0; _PROMPT_MOVED=1; return 0; }
        sleep 0.1
    done
    _PRESTART_OK=1
    return 1
}

# Guarantee the cursor is at prompt start before an insert. Honors a confirmed
# pre-buffer; on an unconfirmed one (failure/timeout, per _PRESTART_OK) runs
# prompt-start synchronously. prompt-start is idempotent (PgUp-at-top is a
# no-op), so this is safe even if the detached pre-buffer is still draining.
# Relies on _await_prestart having already run (the run_action drain point).
_ensure_at_prompt_start() {
    _PROMPT_MOVED=1
    (( _PRESTART_OK == 0 )) && return 0
    # Capture tmuxctl's stderr and log a failed synchronous prompt-start instead of
    # swallowing it — so a cursor op that still fails after batching leaves the real
    # tmux error in the log, not just a silent missed move.
    local _ps_err _ps_rc
    _ps_err="$(prebuffer_prompt_start 2>&1)"; _ps_rc=$?
    if (( _ps_rc != 0 )); then
        log_failure "${SELECTION:-?}" "${agent:-?}" prompt-start "ensure rc=${_ps_rc} ${_ps_err}"
    fi
}

# Post-mortem-grade failure log (log-only; NO notify/TTS — a missing /plan is the
# self-evident signal). Lets an agent diagnose a failed detached action.
#   log_failure <selection> <agent> <step> <detail...>
log_failure() {
    local selection="$1" agent="$2" step="$3"; shift 3
    local detail="$*"
    local logdir="${HOME}/.claude/logs"
    mkdir -p "$logdir" 2>/dev/null || return 0
    local ts
    ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo unknown)"
    printf '%s pane=%s selection=%s agent=%s step=%s detail=%s\n' \
        "$ts" "${PANE:-?}" "$selection" "$agent" "$step" "${detail//$'\n'/ }" \
        >> "${logdir}/tmux-plan-menu.log" 2>/dev/null || true
    return 0
}

# The full selection-dependent action phase. Detached from the popup (see the
# dispatch tail) so the popup vanishes the instant Enter is pressed; this runs on
# after teardown. `set +e` makes failures log-and-continue so the post-action
# cursor restore always gets its chance to run. move_prompt_end sits in a
# "finally" position but fires only when _PROMPT_MOVED==1 — i.e. only on paths
# that actually moved the cursor to the prompt start. With the speculative
# pre-buffer off by default, cancel and literal shift+tab move nothing and so
# skip the restore entirely.
run_action() {
    set +e
    _await_prestart

    local agent rc text sub_err pe_err
    agent="$(normalize_agent "$AGENT")"

    case "$SELECTION" in
        preplan)
            if [[ "$agent" == auto ]]; then
                agent="$(_detect_agent)"
            fi
            # Fail closed: a real preplan must resolve to a concrete harness.
            # Inserting /preplan into a Codex pane (wrong leader) would mask the
            # miss, so skip the insert and log. prompt-end still restores below.
            if [[ "$agent" == auto ]]; then
                log_failure preplan auto agent-unresolved "harness detection inconclusive for pane ${PANE:-?}"
            else
                # Arm the one-shot Stop handoff BEFORE inserting so it is in place
                # by the time the operator submits the preplan turn. On failure,
                # skip the insert (no armed subscription -> no /plan ever comes)
                # and log — never insert a leader whose handoff did not arm.
                sub_err="$(subscribe_preplan 2>&1)"; rc=$?
                if (( rc != 0 )); then
                    log_failure preplan "$agent" subscribe "rc=${rc} ${sub_err}"
                else
                    set_planning_state preplanning >/dev/null 2>&1   # advisory hint
                    text="$(preplan_leader "$agent") "
                    _ensure_at_prompt_start
                    insert_text "$text" || log_failure preplan "$agent" insert "insert-text rc=$?"
                    if [[ "$agent" == codex ]]; then
                        sink_codex_skill || log_failure preplan "$agent" sink-tab "tmux send-keys Tab rc=$?"
                    fi
                fi
            fi
            ;;
        plan)
            set_planning_state planning >/dev/null 2>&1   # advisory; /plan is token-api-independent
            _ensure_at_prompt_start
            insert_text "/plan " || log_failure plan "$agent" insert "insert-text rc=$?"
            ;;
        compact)
            _ensure_at_prompt_start
            insert_text "/compact " || log_failure compact "$agent" insert "insert-text rc=$?"
            ;;
        shift+tab|shifttab)
            tmux send-keys -t "$PANE" BTab || log_failure shift+tab "$agent" send-btab "tmux send-keys rc=$?"
            ;;
        cancel)
            : ;;
        *)
            log_failure "${SELECTION:-?}" "$agent" unknown-selection "no handler for selection" ;;
    esac

    # Restore only when this action actually moved the cursor. With prebuffer off
    # by default, cancel and literal shift+tab no longer spam PgDn/End into the
    # live composer. No sleep: macro inputs are sent as a tight tmux burst.
    if (( _PROMPT_MOVED == 1 )); then
        pe_err="$(move_prompt_end 2>&1)" || log_failure "${SELECTION:-?}" "$agent" prompt-end "rc=$? ${pe_err}"
    fi

    _action_cleanup
}

# Kick off harness detection before the picker opens. Prompt cursor pre-buffer is
# opt-in only (TMUX_PLAN_MENU_PREBUFFER=1); by default no macro keys hit the pane
# until after the operator chooses an action.
_start_agent_detect
_start_prebuffer

# Pick the action via fzf unless one was supplied (--selection, for tests/scripting).
if [[ -z "$SELECTION" ]]; then
    SELECTION=$(printf '%s\n' preplan plan compact 'shift+tab' cancel \
        | fzf --reverse --no-info --height=100% --prompt='shift-tab> ' \
              --header='Shift+Tab action' 2>/dev/null || true)
fi
SELECTION="${SELECTION%%$'\t'*}"   # tolerate a tab-delimited label, keep the key
[[ -z "$SELECTION" ]] && SELECTION=cancel

# --- DRY-RUN: synchronous, print + exit (inspection + tests depend on this) ---
# preplan defaults an inconclusive harness to claude (dry-run never inserts), so
# it never fails closed here. Real actions resolve the harness inside run_action.
if $DRY_RUN; then
    case "$SELECTION" in
        preplan)
            agent_dry="$(normalize_agent "$AGENT")"
            [[ "$agent_dry" == auto ]] && agent_dry="claude"
            sink_text=""
            [[ "$agent_dry" == codex ]] && sink_text=" sink:Tab"
            printf 'pane=%s selection=preplan agent=%s insert:%s subscribe:preplan_plan state:preplanning%s\n' \
                "$PANE" "$agent_dry" "$(preplan_leader "$agent_dry")" "$sink_text"
            ;;
        plan)    printf 'pane=%s selection=plan insert:/plan state:planning\n' "$PANE" ;;
        compact) printf 'pane=%s selection=compact insert:/compact\n' "$PANE" ;;
        shift+tab|shifttab) printf 'pane=%s selection=shift+tab send-keys:BTab\n' "$PANE" ;;
        cancel)  printf 'pane=%s selection=cancel noop\n' "$PANE" ;;
        *) echo "tmux-plan-menu: unknown selection: $SELECTION" >&2; exit 1 ;;
    esac
    exit 0
fi

# --- REAL ACTION -------------------------------------------------------------
# Detach the selection-dependent action so the popup vanishes the instant Enter
# is pressed (display-popup -E closes when THIS process exits — the action must
# not run inside it). The detached child ignores the teardown SIGHUP (trap '' HUP)
# and inherits the pierce env, so every send still pierces the typing guard. If
# live testing on tmux 3.6a ever shows the child dying on teardown despite the
# trap, fall back to `tmux run-shell -b` (server-hosted, immune to pane teardown).
if [[ "${TMUX_PLAN_MENU_NO_DETACH:-}" == "1" ]]; then
    # Synchronous: tests read the send recorder after the process returns; also a
    # debug knob for diagnosing the action phase without the popup race.
    run_action
else
    # Transfer temp-file cleanup to the child: clear the parent EXIT trap so the
    # parent does not rm files the detached child still needs (it cleans up at the
    # end of run_action).
    trap - EXIT
    ( trap '' HUP; run_action ) </dev/null >/dev/null 2>&1 &
    disown 2>/dev/null || true
fi
exit 0
