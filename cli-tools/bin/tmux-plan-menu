#!/usr/bin/env bash
# tmux-plan-menu - Shift+Tab fzf action picker for Claude/Codex panes
# TAGS: tmux, plan, keybind
# AUDIENCE: human
#
# Bare Shift+Tab opens this picker: preplan / plan / compact / shift+tab / cancel.
#   preplan   -> send the preplan skill (/preplan for Claude, $preplan for Codex)
#                and arm a one-shot Stop subscription that submits the plan turn
#   plan      -> send /plan    (universal — slash for both harnesses)
#   compact   -> send /compact (universal — slash for both harnesses)
#   shift+tab -> forward ONE literal Shift+Tab (native mode cycle)
#   cancel    -> no-op
#
# Replaces the old tmux-plan-prefix in-prompt text-manipulation cycle: every
# action is a clean gated send (agent-cmd) or a single keystroke, never a
# screen-scrape-and-edit of the live prompt buffer.

set -euo pipefail

PANE=""
SELECTION=""
AGENT="auto"
DRY_RUN=false
API_URL=""

# Guard value-taking flags so a missing operand is a clean error, not a `set -u`
# "unbound variable $2" crash.
_require_arg() { [[ $1 -ge 2 ]] || { echo "tmux-plan-menu: $2 requires a value" >&2; exit 1; }; }

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pane) _require_arg $# --pane; PANE="$2"; shift 2 ;;
        --selection) _require_arg $# --selection; SELECTION="$2"; shift 2 ;;
        --agent) _require_arg $# --agent; AGENT="$2"; shift 2 ;;
        --dry-run) DRY_RUN=true; shift ;;
        --api-url) _require_arg $# --api-url; API_URL="$2"; shift 2 ;;
        -h|--help) sed -n '2,/^$/s/^# //p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
done

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${_script_dir}/../lib/nas-path.sh" >/dev/null 2>&1 || true
API_URL="${API_URL:-${TOKEN_API_URL:-}}"

if [[ -z "$PANE" ]]; then
    PANE=$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)
fi

# Real actions target $PANE (agent-cmd / tmux send-keys); refuse to proceed with
# an empty target. Dry-run is purely informational, so let it through.
if [[ -z "$PANE" ]] && ! $DRY_RUN; then
    echo "tmux-plan-menu: no target pane (pass --pane or run inside tmux)" >&2
    exit 1
fi

json_escape() {
    python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"
}

normalize_agent() {
    case "${1:-auto}" in
        codex|openai) echo codex ;;
        claude|claude-code) echo claude ;;
        *) echo auto ;;
    esac
}

preplan_leader() {
    case "$(normalize_agent "$1")" in
        codex) echo '$preplan' ;;
        *) echo '/preplan' ;;
    esac
}

# Resolve the harness bound to PANE via the instances API. Only preplan needs
# this (the leader differs); plan/compact are universal. Echoes "unknown" when it
# genuinely can't resolve (API unset/unreachable, or pane not registered) so the
# caller can fail closed instead of guessing a leader.
detect_agent() {
    [[ -z "$API_URL" ]] && { echo unknown; return; }
    local resp
    resp=$(curl -sf --max-time 2 "${API_URL}/api/instances" 2>/dev/null || true)
    [[ -z "$resp" ]] && { echo unknown; return; }
    RESP="$resp" PANE="$PANE" python3 -c '
import json, os
pane = os.environ["PANE"]
try:
    rows = json.loads(os.environ["RESP"])
except Exception:
    rows = []
for r in rows:
    if r.get("tmux_pane") == pane and r.get("status") != "stopped":
        print(r.get("engine") or r.get("agent") or "claude")
        break
else:
    print("unknown")
'
}

# One-shot Stop subscription: when this pane next stops after /preplan, deliver
# the plan turn. PR#2b routes this to /compact when the preplan response
# recommends it; the payload here remains the default plan submission.
subscribe_preplan() {
    [[ -z "$API_URL" ]] && return 0
    local body resp rc=0
    body="{\"target_pane\":$(json_escape "$PANE"),\"subscriber_pane\":$(json_escape "$PANE"),\"event\":\"stop\",\"delivery\":\"prompt\",\"purpose\":\"preplan_plan\",\"payload\":\"/plan create the plan\",\"oneshot\":true}"
    resp=$(curl -sf --max-time 2 -X POST "${API_URL}/api/hooks/subscribe" \
        -H 'Content-Type: application/json' -d "$body") || rc=$?
    if (( rc != 0 )); then
        echo "tmux-plan-menu: subscribe_preplan POST ${API_URL}/api/hooks/subscribe failed (curl exit $rc)" >&2
        return "$rc"
    fi
    # /api/hooks/subscribe returns HTTP 200 with {"success": false} when the pane
    # can't be resolved (target_unresolved/subscriber_unresolved), so a 2xx is not
    # enough — confirm the one-shot actually armed before the caller sends a leader.
    if ! RESP="$resp" python3 -c '
import json, os, sys
try:
    ok = bool(json.loads(os.environ["RESP"] or "{}").get("success"))
except Exception:
    ok = False
sys.exit(0 if ok else 1)
'; then
        echo "tmux-plan-menu: subscribe_preplan did not arm (response: ${resp:-<empty>})" >&2
        return 1
    fi
}

set_planning_state() {
    local state="$1"
    tmux set-option -p -t "$PANE" @PLANNING_STATE "$state" 2>/dev/null || true
    [[ -z "$API_URL" ]] && return 0
    local body rc=0
    body="{\"tmux_pane\":$(json_escape "$PANE"),\"state\":$(json_escape "$state"),\"source\":\"tmux-plan-menu\"}"
    curl -sf --max-time 1 -X POST "${API_URL}/api/planning/state" \
        -H 'Content-Type: application/json' -d "$body" >/dev/null || rc=$?
    if (( rc != 0 )); then
        echo "tmux-plan-menu: set_planning_state POST ${API_URL}/api/planning/state failed (curl exit $rc)" >&2
        return "$rc"
    fi
}

# agent-cmd resolves its backend from TOKEN_API_URL (nas-path.sh keeps an
# inherited non-empty value), so propagate our resolved URL that way to keep one
# action on one backend. Leave it unset when we have none, so agent-cmd resolves.
send_to_pane() {
    if [[ -n "$API_URL" ]]; then
        TOKEN_API_URL="$API_URL" "${_script_dir}/agent-cmd" --pane "$PANE" "$1"
    else
        "${_script_dir}/agent-cmd" --pane "$PANE" "$1"
    fi
}

# Pick the action via fzf unless one was supplied (--selection, for tests/scripting).
if [[ -z "$SELECTION" ]]; then
    SELECTION=$(printf '%s\n' preplan plan compact 'shift+tab' cancel \
        | fzf --reverse --no-info --height=100% --prompt='shift-tab> ' \
              --header='Shift+Tab action' 2>/dev/null || true)
fi
SELECTION="${SELECTION%%$'\t'*}"   # tolerate a tab-delimited label, keep the key
[[ -z "$SELECTION" ]] && SELECTION=cancel

# Resolve the harness only for preplan, and only when we must (skip network on dry-run).
AGENT_RESOLVED="$(normalize_agent "$AGENT")"
if [[ "$SELECTION" == "preplan" ]]; then
    if [[ "$AGENT_RESOLVED" == "auto" ]]; then
        if $DRY_RUN; then
            AGENT_RESOLVED="claude"   # dry-run never sends; default for tests/inspection
        else
            AGENT_RESOLVED="$(normalize_agent "$(detect_agent)")"
        fi
    fi
    # Fail closed: a real preplan must resolve to a concrete harness. Guessing
    # claude here would send /preplan to a Codex pane (wrong leader) and mask the
    # detection miss, so abort and point at the explicit --agent override instead.
    if [[ "$AGENT_RESOLVED" == "auto" ]]; then
        echo "tmux-plan-menu: could not detect the harness for pane ${PANE:-?}; re-run with --agent claude|codex" >&2
        exit 1
    fi
fi

case "$SELECTION" in
    preplan)
        leader="$(preplan_leader "$AGENT_RESOLVED")"
        if $DRY_RUN; then
            printf 'pane=%s selection=preplan agent=%s send:%s subscribe:preplan_plan state:preplanning\n' \
                "$PANE" "$AGENT_RESOLVED" "$leader"
            exit 0
        fi
        if ! subscribe_preplan; then
            echo "tmux-plan-menu: aborting preplan — could not arm the plan auto-submit subscription" >&2
            exit 1
        fi
        set_planning_state preplanning || true   # advisory hint; never block the leader send
        send_to_pane "$leader"
        ;;
    plan)
        if $DRY_RUN; then printf 'pane=%s selection=plan send:/plan state:planning\n' "$PANE"; exit 0; fi
        set_planning_state planning || true   # advisory hint; /plan is independent of token-api
        send_to_pane "/plan"
        ;;
    compact)
        if $DRY_RUN; then printf 'pane=%s selection=compact send:/compact\n' "$PANE"; exit 0; fi
        send_to_pane "/compact"
        ;;
    shift+tab|shifttab)
        if $DRY_RUN; then printf 'pane=%s selection=shift+tab send-keys:BTab\n' "$PANE"; exit 0; fi
        tmux send-keys -t "$PANE" BTab
        ;;
    cancel)
        if $DRY_RUN; then printf 'pane=%s selection=cancel noop\n' "$PANE"; exit 0; fi
        : # no-op
        ;;
    *)
        echo "tmux-plan-menu: unknown selection: $SELECTION" >&2
        exit 1
        ;;
esac
