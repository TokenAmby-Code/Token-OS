#!/usr/bin/env python3
# skills-sync - synchronize shared Claude/Codex skill symlinks
# TAGS: skills, claude, codex
# AUDIENCE: human, agent

from __future__ import annotations

import argparse
import json
import os
import re
import sys
from dataclasses import dataclass, asdict
from pathlib import Path
from typing import Any

SCRIPT = Path(__file__).resolve()
TOKEN_OS = SCRIPT.parents[2]
DEFAULT_CANONICAL = TOKEN_OS / "claude-config" / "skills"


@dataclass
class Finding:
    level: str
    code: str
    path: str
    message: str


def _home() -> Path:
    return Path(os.environ.get("SKILLS_SYNC_HOME") or os.environ.get("HOME") or str(Path.home()))


def _canonical() -> Path:
    return Path(os.environ.get("SKILLS_SYNC_CANONICAL") or DEFAULT_CANONICAL).expanduser()



def _same_path(a: Path, b: Path) -> bool:
    try:
        return a.samefile(b)
    except FileNotFoundError:
        return False
    except OSError:
        return _real(a) == _real(b)

def _real(path: Path) -> str:
    try:
        return str(path.resolve(strict=True))
    except FileNotFoundError:
        return str(path.absolute())


def _frontmatter(path: Path) -> dict[str, Any]:
    text = path.read_text(encoding="utf-8")
    if not text.startswith("---\n"):
        return {}
    end = text.find("\n---", 4)
    if end == -1:
        return {}
    data: dict[str, Any] = {}
    for raw in text[4:end].splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or ":" not in line:
            continue
        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip().strip('"').strip("'")
        if value.lower() == "true":
            data[key] = True
        elif value.lower() == "false":
            data[key] = False
        else:
            data[key] = value
    return data


def _openai_allow_implicit(skill: Path) -> bool | None:
    """Return agents/openai.yaml policy.allow_implicit_invocation if present.

    Keep this deliberately dependency-free; skills-sync must run in a bare
    Python install before project virtualenvs exist.
    """
    path = skill / "agents" / "openai.yaml"
    if not path.exists():
        return None
    try:
        for raw in path.read_text(encoding="utf-8").splitlines():
            line = raw.strip()
            if not line.startswith("allow_implicit_invocation:"):
                continue
            value = line.split(":", 1)[1].strip().strip('"').strip("'").lower()
            if value == "true":
                return True
            if value == "false":
                return False
    except Exception:
        return None
    return None


def _skill_dirs(canonical: Path) -> list[Path]:
    if not canonical.exists():
        return []
    return sorted(
        [p for p in canonical.iterdir() if p.is_dir() or (p.is_symlink() and p.exists())],
        key=lambda p: p.name,
    )


def _has_exact_child(parent: Path, name: str) -> bool:
    try:
        return any(child.name == name for child in parent.iterdir())
    except FileNotFoundError:
        return False


def _skill_md(skill: Path) -> Path:
    return skill / "SKILL.md"


def _legacy_skill_md(skill: Path) -> Path:
    return skill / "skill.md"


def _codex_roots(home: Path) -> list[Path]:
    # Current OpenAI docs use ~/.agents/skills; existing Imperium/Codex installs
    # also expose ~/.codex/skills and reserve ~/.codex/skills/.system.
    return [home / ".agents" / "skills", home / ".codex" / "skills"]


def _canonical_commands_root(canonical: Path) -> Path:
    # Default layout is Token-OS/claude-config/skills -> sibling commands.
    # Custom SKILLS_SYNC_CANONICAL test fixtures can still exercise this path.
    return canonical.parent / "commands"


def _check_link(path: Path, expected: Path, findings: list[Finding], code_prefix: str) -> None:
    if path.is_symlink():
        if not path.exists():
            findings.append(Finding("error", f"{code_prefix}_broken_symlink", str(path), "broken symlink"))
            return
        if not _same_path(path, expected):
            findings.append(
                Finding(
                    "error",
                    f"{code_prefix}_wrong_target",
                    str(path),
                    f"points to {_real(path)}, expected {_real(expected)}",
                )
            )
        return
    if path.exists():
        if not _same_path(path, expected):
            findings.append(
                Finding(
                    "error",
                    f"{code_prefix}_not_shared",
                    str(path),
                    f"exists but does not resolve to canonical {_real(expected)}",
                )
            )
        return
    findings.append(Finding("error", f"{code_prefix}_missing", str(path), "missing shared skill link"))


def inspect() -> dict[str, Any]:
    home = _home()
    canonical = _canonical()
    claude_root = home / ".claude" / "skills"
    claude_commands = home / ".claude" / "commands"
    canonical_commands = _canonical_commands_root(canonical)
    codex_roots = _codex_roots(home)
    findings: list[Finding] = []
    skills: list[dict[str, Any]] = []

    if not canonical.exists():
        findings.append(Finding("error", "canonical_missing", str(canonical), "canonical skills directory is missing"))
        return _result(canonical, claude_root, codex_roots, skills, findings)
    if not canonical.is_dir():
        findings.append(Finding("error", "canonical_not_directory", str(canonical), "canonical skills path is not a directory"))
        return _result(canonical, claude_root, codex_roots, skills, findings)

    if claude_root.exists() or claude_root.is_symlink():
        _check_link(claude_root, canonical, findings, "claude_root")
    else:
        findings.append(Finding("error", "claude_root_missing", str(claude_root), "~/.claude/skills is missing"))

    names: dict[str, list[str]] = {}
    for skill in _skill_dirs(canonical):
        if skill.is_symlink() and not skill.exists():
            findings.append(Finding("error", "canonical_broken_symlink", str(skill), "broken canonical skill symlink"))
            continue
        md = _skill_md(skill)
        legacy = _legacy_skill_md(skill)
        has_skill_md = _has_exact_child(skill, "SKILL.md") and md.exists()
        if not has_skill_md:
            msg = "missing SKILL.md"
            if legacy.exists():
                msg += " (legacy skill.md exists; --install can add a SKILL.md symlink)"
            findings.append(Finding("error", "skill_md_missing", str(skill), msg))
            fm: dict[str, Any] = {}
        else:
            try:
                fm = _frontmatter(md)
            except Exception as exc:
                fm = {}
                findings.append(Finding("error", "frontmatter_read_failed", str(md), str(exc)))
            if not fm.get("name"):
                findings.append(Finding("error", "frontmatter_name_missing", str(md), "missing frontmatter name"))
            if not fm.get("description"):
                findings.append(Finding("error", "frontmatter_description_missing", str(md), "missing frontmatter description"))
            disable_model_invocation = fm.get("disable-model-invocation")
            if disable_model_invocation is None:
                disable_model_invocation = fm.get("disable_model_invocation")
            if disable_model_invocation not in (None, False):
                findings.append(
                    Finding(
                        "error",
                        "codex_skill_model_invocation_disabled",
                        str(md),
                        "disable-model-invocation hides the skill from Codex literal $skill invocation; use description/policy instead",
                    )
                )
        name = str(fm.get("name") or skill.name)
        if not re.fullmatch(r"[a-z0-9][a-z0-9-]{0,63}", name):
            findings.append(Finding("error", "skill_name_invalid", str(skill), f"invalid skill name {name!r}"))
        if name != skill.name:
            findings.append(Finding("warn", "skill_folder_name_mismatch", str(skill), f"folder name differs from frontmatter name {name!r}"))
        names.setdefault(name, []).append(str(skill))

        visibility: dict[str, str] = {}
        if name == "preplan":
            if _openai_allow_implicit(skill) is not True:
                findings.append(
                    Finding(
                        "error",
                        "preplan_not_model_visible",
                        str(skill / "agents" / "openai.yaml"),
                        "preplan must remain model-visible because Shift+Tab inserts literal $preplan text in Codex",
                    )
                )
            command_path = claude_commands / "preplan.md"
            _check_link(command_path, md, findings, "claude_preplan_command")
            canonical_command_path = canonical_commands / "preplan.md"
            _check_link(canonical_command_path, md, findings, "canonical_preplan_command")
        claude_path = claude_root / skill.name
        _check_link(claude_path, skill, findings, "claude_skill")
        visibility["claude"] = _real(claude_path) if claude_path.exists() else ""
        for root in codex_roots:
            path = root / name
            prefix = "codex_agents" if root.parent.name == ".agents" else "codex_home"
            _check_link(path, skill, findings, prefix)
            visibility[str(root)] = _real(path) if path.exists() else ""
        skills.append(
            {
                "name": name,
                "folder": skill.name,
                "path": str(skill),
                "realpath": _real(skill),
                "has_SKILL_md": has_skill_md,
                "frontmatter": fm,
                "visibility": visibility,
            }
        )

    for name, paths in sorted(names.items()):
        if len(paths) > 1:
            findings.append(Finding("error", "duplicate_skill_name", name, ", ".join(paths)))

    # Check direct children symlinks in managed roots; never descend into .system.
    for root in [claude_root, *codex_roots]:
        if not root.exists():
            continue
        for child in root.iterdir():
            if child.name == ".system":
                continue
            if child.is_symlink() and not child.exists():
                findings.append(Finding("error", "visible_broken_symlink", str(child), "broken visible skill symlink"))

    return _result(canonical, claude_root, codex_roots, skills, findings)


def _result(canonical: Path, claude_root: Path, codex_roots: list[Path], skills: list[dict[str, Any]], findings: list[Finding]) -> dict[str, Any]:
    errors = [f for f in findings if f.level == "error"]
    return {
        "success": not errors,
        "canonical": str(canonical),
        "canonical_realpath": _real(canonical) if canonical.exists() else "",
        "claude_root": str(claude_root),
        "codex_roots": [str(p) for p in codex_roots],
        "skill_count": len(skills),
        "skills": skills,
        "findings": [asdict(f) for f in findings],
    }


def _safe_link(src: Path, dst: Path, findings: list[Finding]) -> bool:
    dst.parent.mkdir(parents=True, exist_ok=True)
    if dst.is_symlink():
        if dst.exists() and _same_path(dst, src):
            return True
        dst.unlink()
    elif dst.exists():
        if _same_path(dst, src):
            return True
        findings.append(Finding("error", "install_conflict", str(dst), f"exists and is not a symlink to {_real(src)}"))
        return False
    dst.symlink_to(src, target_is_directory=src.is_dir())
    return True


def install() -> dict[str, Any]:
    home = _home()
    canonical = _canonical()
    findings: list[Finding] = []
    if not canonical.exists():
        findings.append(Finding("error", "canonical_missing", str(canonical), "canonical skills directory is missing"))
        return _result(canonical, home / ".claude" / "skills", _codex_roots(home), [], findings)
    if not canonical.is_dir():
        findings.append(Finding("error", "canonical_not_directory", str(canonical), "canonical skills path is not a directory"))
        return _result(canonical, home / ".claude" / "skills", _codex_roots(home), [], findings)

    _safe_link(canonical, home / ".claude" / "skills", findings)
    claude_commands = home / ".claude" / "commands"
    canonical_commands = _canonical_commands_root(canonical)
    for root in _codex_roots(home):
        root.mkdir(parents=True, exist_ok=True)

    for skill in _skill_dirs(canonical):
        if skill.is_symlink() and not skill.exists():
            findings.append(Finding("error", "canonical_broken_symlink", str(skill), "broken canonical skill symlink"))
            continue
        md = _skill_md(skill)
        legacy = _legacy_skill_md(skill)
        if not (_has_exact_child(skill, "SKILL.md") and md.exists()) and _has_exact_child(skill, "skill.md") and legacy.exists():
            _safe_link(legacy, md, findings)
        link_name = skill.name
        if md.exists():
            try:
                link_name = str(_frontmatter(md).get("name") or skill.name)
            except Exception:
                link_name = skill.name
        if not re.fullmatch(r"[a-z0-9][a-z0-9-]{0,63}", link_name):
            findings.append(Finding("error", "skill_name_invalid", str(skill), f"invalid skill name {link_name!r}"))
            continue
        if link_name == "preplan" and md.exists():
            _safe_link(md, canonical_commands / "preplan.md", findings)
            _safe_link(md, claude_commands / "preplan.md", findings)
        for root in _codex_roots(home):
            _safe_link(skill, root / link_name, findings)

    checked = inspect()
    checked["install_findings"] = [asdict(f) for f in findings]
    if findings:
        checked["findings"] = checked.get("findings", []) + [asdict(f) for f in findings]
        checked["success"] = False
    return checked


def print_human(result: dict[str, Any]) -> None:
    status = "OK" if result.get("success") else "FAIL"
    print(f"[skills-sync:{status}] canonical={result.get('canonical_realpath') or result.get('canonical')}")
    print(f"  skills={result.get('skill_count', 0)}")
    for root in [result.get("claude_root"), *(result.get("codex_roots") or [])]:
        print(f"  root={root}")
    findings = result.get("findings") or []
    if findings:
        print("  findings:")
        for f in findings:
            print(f"  - {f['level']} {f['code']}: {f['path']} — {f['message']}")


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Synchronize canonical Claude skills into Claude and Codex skill roots.")
    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument("--check", action="store_true", help="Check skill health and visibility")
    mode.add_argument("--install", action="store_true", help="Create/repair symlinks only")
    parser.add_argument("--json", action="store_true", help="Emit JSON")
    args = parser.parse_args(argv)

    result = install() if args.install else inspect()
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print_human(result)
    return 0 if result.get("success") else 1


if __name__ == "__main__":
    raise SystemExit(main())
