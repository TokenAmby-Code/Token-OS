#!/usr/bin/env bash
# push-mobile - Push Termux config and macros to phone
# TAGS: mobile, sync, termux
# AUDIENCE: human, agent
#
# Usage:
#   push-mobile -b              # Push bashrc
#   push-mobile -p              # Push termux.properties
#   push-mobile -m              # Push macros folder
#   push-mobile -t              # Push tmux.conf + toolbar-toggle script
#   push-mobile -bp             # Push bashrc + properties
#   push-mobile -a              # Push everything
#
# Works from either WSL or Mac - just needs SSH access to phone.

set -euo pipefail

# Source machine identity for NAS paths
_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
# shellcheck source=../lib/nas-path.sh
source "${_LIB_DIR}/nas-path.sh"
MOBILE_DIR="${TOKEN_OS}/mobile"
SSH_OPTS="-o ConnectTimeout=5 -o BatchMode=yes"

PUSH_BASHRC=false
PUSH_PROPERTIES=false
PUSH_TMUX=false
PUSH_MACROS=false
DRY_RUN=false

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

log_info()  { echo -e "${BLUE}->${NC} $*"; }
log_ok()    { echo -e "  ${GREEN}OK${NC} $*"; }
log_err()   { echo -e "  ${RED}ERR${NC} $*"; }
log_dry()   { echo -e "  ${YELLOW}[dry-run]${NC} $*"; }

show_help() {
    cat << 'EOF'
push-mobile - Push Termux config and macros to phone

Usage:
    push-mobile -b, --bashrc        Push bashrc
    push-mobile -p, --properties    Push termux.properties
    push-mobile -t, --tmux          Push tmux.conf + toolbar-toggle script
    push-mobile -m, --macros        Push macros folder
    push-mobile -a, --all           Push everything
    push-mobile --dry-run           Preview without doing anything

Combine flags:  push-mobile -bpt      (bashrc + properties + tmux)

Files:
    -b  mobile/termux-bashrc-template      → phone:~/.bashrc
    -p  mobile/termux-properties-template   → phone:~/.termux/termux.properties
    -t  mobile/termux-tmux.conf            → phone:~/.tmux.conf
        mobile/termux-toolbar-toggle       → phone:~/.local/bin/termux-toolbar-toggle
    -m  mobile/macros/                      → phone:~/macros/
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) show_help; exit 0 ;;
        --bashrc) PUSH_BASHRC=true; shift ;;
        --properties) PUSH_PROPERTIES=true; shift ;;
        --tmux) PUSH_TMUX=true; shift ;;
        --macros) PUSH_MACROS=true; shift ;;
        --all) PUSH_BASHRC=true; PUSH_PROPERTIES=true; PUSH_TMUX=true; PUSH_MACROS=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        -[bpma]*)
            # Parse combined short flags: -bp, -bpm, -a, etc.
            flags="${1#-}"
            for (( i=0; i<${#flags}; i++ )); do
                case "${flags:$i:1}" in
                    b) PUSH_BASHRC=true ;;
                    p) PUSH_PROPERTIES=true ;;
                    t) PUSH_TMUX=true ;;
                    m) PUSH_MACROS=true ;;
                    a) PUSH_BASHRC=true; PUSH_PROPERTIES=true; PUSH_TMUX=true; PUSH_MACROS=true ;;
                    *) echo -e "${RED}Unknown flag: -${flags:$i:1}${NC}" >&2; exit 1 ;;
                esac
            done
            shift
            ;;
        *) echo -e "${RED}Unknown option: $1${NC}" >&2; exit 1 ;;
    esac
done

# Require at least one target
if ! $PUSH_BASHRC && ! $PUSH_PROPERTIES && ! $PUSH_TMUX && ! $PUSH_MACROS; then
    show_help
    exit 1
fi

# Check phone is reachable
if ! ssh $SSH_OPTS phone "true" 2>/dev/null; then
    log_err "Phone unreachable via SSH"
    exit 1
fi

pushed=0

if $PUSH_BASHRC; then
    src="${MOBILE_DIR}/termux-bashrc-template"
    if [[ ! -f "$src" ]]; then
        log_err "Not found: ${src}"
    elif [[ "$DRY_RUN" == true ]]; then
        log_dry "bashrc → phone:~/.bashrc"
    else
        log_info "Pushing bashrc..."
        if scp -q "$src" phone:~/.bashrc; then
            log_ok "bashrc"; ((++pushed))
        else
            log_err "bashrc failed"
        fi
    fi
fi

if $PUSH_PROPERTIES; then
    src="${MOBILE_DIR}/termux-properties-template"
    if [[ ! -f "$src" ]]; then
        log_err "Not found: ${src}"
    elif [[ "$DRY_RUN" == true ]]; then
        log_dry "properties → phone:~/.termux/termux.properties"
    else
        log_info "Pushing termux.properties..."
        ssh $SSH_OPTS phone "mkdir -p ~/.termux" 2>/dev/null
        if scp -q "$src" phone:~/.termux/termux.properties; then
            log_ok "termux.properties"
            ssh $SSH_OPTS phone "termux-reload-settings" 2>/dev/null && log_ok "settings reloaded" || true
            ((pushed++))
        else
            log_err "termux.properties failed"
        fi
    fi
fi

if $PUSH_TMUX; then
    tmux_src="${MOBILE_DIR}/termux-tmux.conf"
    toggle_src="${MOBILE_DIR}/termux-toolbar-toggle"
    if [[ ! -f "$tmux_src" ]]; then
        log_err "Not found: ${tmux_src}"
    elif [[ "$DRY_RUN" == true ]]; then
        log_dry "tmux.conf → phone:~/.tmux.conf"
        log_dry "toolbar-toggle → phone:~/.local/bin/termux-toolbar-toggle"
    else
        log_info "Pushing tmux config..."
        ssh $SSH_OPTS phone "mkdir -p ~/.local/bin" 2>/dev/null
        if scp -q "$tmux_src" phone:~/.tmux.conf; then
            log_ok "tmux.conf"; ((pushed++))
        else
            log_err "tmux.conf failed"
        fi
        if [[ -f "$toggle_src" ]]; then
            if scp -q "$toggle_src" phone:~/.local/bin/termux-toolbar-toggle; then
                ssh $SSH_OPTS phone "chmod +x ~/.local/bin/termux-toolbar-toggle" 2>/dev/null
                log_ok "toolbar-toggle"
            else
                log_err "toolbar-toggle failed"
            fi
        fi
        ssh $SSH_OPTS phone "tmux source-file ~/.tmux.conf" 2>/dev/null && log_ok "tmux reloaded" || true
    fi
fi

if $PUSH_MACROS; then
    src="${MOBILE_DIR}/macros"
    if [[ ! -d "$src" ]]; then
        log_err "Not found: ${src}/"
    elif [[ "$DRY_RUN" == true ]]; then
        count=$(find "$src" -type f 2>/dev/null | wc -l | tr -d ' ')
        log_dry "macros/ (${count} files) → phone:~/macros/"
    else
        log_info "Pushing macros..."
        ssh $SSH_OPTS phone "mkdir -p ~/macros" 2>/dev/null
        if scp -q -r "$src"/* phone:~/macros/ 2>/dev/null; then
            count=$(find "$src" -type f 2>/dev/null | wc -l | tr -d ' ')
            log_ok "macros (${count} files)"
            ((pushed++))
        else
            log_err "macros failed"
        fi
    fi
fi

echo ""
if [[ "$DRY_RUN" == true ]]; then
    echo -e "${YELLOW}Dry run complete.${NC}"
elif [[ $pushed -gt 0 ]]; then
    echo -e "${GREEN}${BOLD}Pushed ${pushed} target(s).${NC}"
    $PUSH_BASHRC && echo -e "  Run ${BOLD}source ~/.bashrc${NC} on phone to reload."
fi
