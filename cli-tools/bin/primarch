#!/usr/bin/env bash
# Primarch Launcher - Start Claude sessions with persona identity and session doc
# TAGS: instance, vault-mind, primarch
# AUDIENCE: user
#
# Source of truth: ~/.claude/agents.db (primarchs table)
# Persona files: <vault>/Personas/<name>.md
#
# AUDIENCE: deprecated
# Usage: primarch <name> [claude-flags...]
#        primarch list
#        primarch info <name>

set -euo pipefail

if [[ "${TOKEN_API_INTERNAL_DISPATCH:-0}" != "1" ]]; then
  echo "primarch has been retired. Use: dispatch --persona <name>" >&2
  exit 64
fi


DB_PATH="${PRIMARCH_DB:-$HOME/.claude/agents.db}"

detect_vault_dir() {
    local cwd
    cwd="$(pwd)"

    case "$cwd" in
        /Volumes/Civic/Pax-ENV|/Volumes/Civic/Pax-ENV/*)
            echo "/Volumes/Civic/Pax-ENV"
            return
            ;;
        /mnt/civic/Pax-ENV|/mnt/civic/Pax-ENV/*)
            echo "/mnt/civic/Pax-ENV"
            return
            ;;
    esac

    if [[ -d "/mnt/imperium/Imperium-ENV" ]]; then
        echo "/mnt/imperium/Imperium-ENV"         # WSL
    elif [[ -d "/Volumes/Imperium/Imperium-ENV" ]]; then
        echo "/Volumes/Imperium/Imperium-ENV"    # macOS (NAS mount)
    elif [[ -d "$HOME/Imperium-ENV" ]]; then
        echo "$HOME/Imperium-ENV"                # macOS (local sync)
    else
        return 1
    fi
}

VAULT_DIR="$(detect_vault_dir)" || {
    echo "ERROR: Cannot find a supported vault" >&2
    exit 1
}

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

usage() {
    cat << 'EOF'
Primarch Launcher - Start Claude sessions with persona identity

Usage:
  primarch <name> [claude-flags...]    Launch Claude as a Primarch
  primarch list                        List all registered Primarchs
  primarch info <name>                 Show Primarch details

Source of truth: ~/.claude/agents.db

Aliases:
  Short names are supported (e.g., 'fg' for 'fabricator-general').
  Shell aliases are auto-generated at shell startup.

Examples:
  primarch vulkan                      Interactive session as Vulkan
  primarch fg                          Interactive session as Fabricator-General
  primarch vulkan --model sonnet       Use specific model
  primarch fg -p "check fleet status"  Non-interactive
EOF
    exit 0
}

# Resolve name or alias to canonical name (case-insensitive)
resolve_name() {
    local input
    input=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')

    # Non-Imperium vaults can intentionally shadow DB-backed themed personas
    # with local, plain-language persona files.
    if [[ "$(basename "$VAULT_DIR")" != "Imperium-ENV" && -f "$VAULT_DIR/Personas/${input}.md" ]]; then
        echo "$input"
        return
    fi

    # Direct name match
    local match
    match=$(sqlite3 "$DB_PATH" "SELECT name FROM primarchs WHERE LOWER(name) = '$input' LIMIT 1;" 2>/dev/null)
    if [[ -n "$match" ]]; then echo "$match"; return; fi
    # Alias match via SQL JSON — avoids subshell pipe bug
    match=$(sqlite3 "$DB_PATH" "
        SELECT name FROM primarchs
        WHERE LOWER(aliases) LIKE '%\"$input\"%'
        LIMIT 1;
    " 2>/dev/null)
    if [[ -n "$match" ]]; then echo "$match"; return; fi

    # Local vault persona files are supported for non-Imperium vaults such as
    # Pax-ENV, where persona names are intentionally non-themed.
    if [[ -f "$VAULT_DIR/Personas/${input}.md" ]]; then
        echo "$input"
        return
    fi
}

# List all primarchs from DB
list_primarchs() {
    echo -e "${BOLD}Registered Primarchs${NC}\n"
    sqlite3 -separator $'\t' "$DB_PATH" "SELECT name, title, aliases, role FROM primarchs ORDER BY name;" 2>/dev/null | while IFS=$'\t' read -r pname ptitle paliases prole; do
        local alias_str
        alias_str=$(echo "$paliases" | python3 -c "import json,sys; print(', '.join(json.load(sys.stdin)))" 2>/dev/null)
        [[ -n "$alias_str" ]] && alias_str=" ($alias_str)"
        echo -e "  ${CYAN}${BOLD}${pname}${NC}${alias_str}"
        echo -e "    ${ptitle}"
        local role_display="${prole}"
        [[ ${#role_display} -gt 80 ]] && role_display="${role_display:0:80}..."
        echo -e "    ${DIM}${role_display}${NC}"
        echo
    done
}

# Show primarch info from DB
show_info() {
    local name="$1"
    local local_file="$VAULT_DIR/Personas/${name}.md"

    if [[ "$(basename "$VAULT_DIR")" != "Imperium-ENV" && -f "$local_file" ]]; then
        local title
        title="$(frontmatter_value "$local_file" "title")"
        [[ -n "$title" ]] || title="$name"
        echo -e "${CYAN}${BOLD}${title}${NC}"
        echo "Canonical name: $name"
        echo "Vault: $(basename "$VAULT_DIR")"
        echo "Role: local vault persona"
        echo "Instance prefix: $name"
        echo "Persona file: $local_file"
        return
    fi

    local row
    row=$(sqlite3 -separator $'\t' "$DB_PATH" "SELECT title, aliases, vault, role, instance_name_prefix, vault_note_path FROM primarchs WHERE name = '$name';" 2>/dev/null)
    if [[ -z "$row" ]]; then
        [[ -f "$local_file" ]] || { echo -e "${RED}Unknown primarch: $name${NC}"; exit 1; }

        local title
        title="$(frontmatter_value "$local_file" "title")"
        [[ -n "$title" ]] || title="$name"
        echo -e "${CYAN}${BOLD}${title}${NC}"
        echo "Canonical name: $name"
        echo "Vault: $(basename "$VAULT_DIR")"
        echo "Role: local vault persona"
        echo "Instance prefix: $name"
        echo "Persona file: $local_file"
        return
    fi

    local title aliases vault role prefix note_path
    IFS=$'\t' read -r title aliases vault role prefix note_path <<< "$row"
    local alias_str
    alias_str=$(echo "$aliases" | python3 -c "import json,sys; print(', '.join(json.load(sys.stdin)))" 2>/dev/null)

    echo -e "${CYAN}${BOLD}${title}${NC}"
    echo "Canonical name: $name"
    echo "Aliases: $alias_str"
    echo "Vault: $vault"
    echo "Role: $role"
    echo "Instance prefix: $prefix"
    echo "Persona file: $VAULT_DIR/$note_path"
}

# Extract ## System Prompt section from persona markdown file
extract_system_prompt() {
    local file="$1"
    [[ -f "$file" ]] || return
    python3 -c "
content = open('$file').read()
marker = '## System Prompt'
idx = content.find(marker)
if idx < 0:
    parts = content.split('---', 2)
    body = parts[2].strip() if len(parts) >= 3 else content.strip()
    print(body)
else:
    rest = content[idx + len(marker):].strip()
    next_h2 = rest.find('\n## ')
    if next_h2 >= 0: rest = rest[:next_h2].strip()
    print(rest)
" 2>/dev/null
}

frontmatter_value() {
    local file="$1"
    local key="$2"
    python3 - "$file" "$key" <<'PY' 2>/dev/null
import re
import sys

path, key = sys.argv[1], sys.argv[2]
text = open(path).read()
m = re.match(r"---\n(.*?)\n---", text, re.S)
if not m:
    raise SystemExit
for line in m.group(1).splitlines():
    if line.startswith(f"{key}:"):
        print(line.split(":", 1)[1].strip().strip('"'))
        break
PY
}

# --- Main ---

[[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]] && usage
[[ $# -eq 0 ]] && usage

case "${1:-}" in
    list|ls)
        list_primarchs
        exit 0
        ;;
    info)
        [[ -z "${2:-}" ]] && { echo -e "${RED}Usage: primarch info <name>${NC}"; exit 1; }
        canonical=$(resolve_name "$2")
        [[ -z "$canonical" ]] && { echo -e "${RED}Unknown primarch: $2${NC}"; exit 1; }
        show_info "$canonical"
        exit 0
        ;;
esac

# Resolve primarch name
PRIMARCH_NAME=$(resolve_name "$1")
if [[ -z "$PRIMARCH_NAME" ]]; then
    echo -e "${RED}Unknown primarch: $1${NC}"
    echo -e "${DIM}Use 'primarch list' to see available primarchs${NC}"
    exit 1
fi
shift

# Load from DB when present; otherwise load a local vault persona file.
ROW=$(sqlite3 -separator $'\t' "$DB_PATH" "SELECT title, vault, instance_name_prefix, vault_note_path FROM primarchs WHERE name = '$PRIMARCH_NAME';" 2>/dev/null || true)
if [[ -n "$ROW" ]]; then
    IFS=$'\t' read -r PRIMARCH_TITLE VAULT INSTANCE_PREFIX NOTE_PATH <<< "$ROW"
else
    NOTE_PATH="Personas/${PRIMARCH_NAME}.md"
    PERSONA_FILE="$VAULT_DIR/$NOTE_PATH"
    [[ -f "$PERSONA_FILE" ]] || {
        echo -e "${RED}No persona file at $PERSONA_FILE${NC}"
        exit 1
    }
    PRIMARCH_TITLE="$(frontmatter_value "$PERSONA_FILE" "title")"
    [[ -n "$PRIMARCH_TITLE" ]] || PRIMARCH_TITLE="$PRIMARCH_NAME"
    VAULT="$(basename "$VAULT_DIR")"
    INSTANCE_PREFIX="$PRIMARCH_NAME"
fi

# Extract system prompt from persona file
PERSONA_FILE="$VAULT_DIR/$NOTE_PATH"
SYSTEM_PROMPT=$(extract_system_prompt "$PERSONA_FILE")
[[ -z "$SYSTEM_PROMPT" ]] && { echo -e "${RED}No persona file at $PERSONA_FILE${NC}"; exit 1; }

# Check for active session doc link
DOC_ID=""
if [[ -n "$ROW" ]]; then
    DOC_ID=$(sqlite3 "$DB_PATH" "SELECT session_doc_id FROM primarch_session_docs WHERE primarch_name = '$PRIMARCH_NAME' AND unlinked_at IS NULL LIMIT 1;" 2>/dev/null)
fi

# Assemble prompt
FULL_PROMPT="$SYSTEM_PROMPT

Vault domain: $VAULT
Instance name prefix: $INSTANCE_PREFIX"

if [[ -n "$DOC_ID" ]]; then
    FULL_PROMPT="$FULL_PROMPT

You have a linked session document (ID: $DOC_ID). Invoke the vault-mind skill on startup to load it."
fi

FULL_PROMPT="$FULL_PROMPT

On startup, name this instance with: instance-name \"$INSTANCE_PREFIX-<task-description>\""

echo -e "${CYAN}${BOLD}⚔ ${PRIMARCH_TITLE}${NC}"
echo -e "${DIM}Vault: ${VAULT} | Prefix: ${INSTANCE_PREFIX}${NC}"
[[ -n "$DOC_ID" ]] && echo -e "${DIM}Session doc: #${DOC_ID}${NC}"
echo ""

# Export primarch identity so SessionStart hook can auto-link session docs
export TOKEN_API_PRIMARCH="$PRIMARCH_NAME"

# Resolve claude binary (may not be in PATH for SSH sessions)
CLAUDE_BIN=$(command -v claude 2>/dev/null || echo "$HOME/.local/bin/claude")
if [[ ! -x "$CLAUDE_BIN" ]]; then
    echo -e "${RED}Claude not found in PATH or ~/.local/bin/claude${NC}" >&2
    exit 1
fi

# Per-persona harness profile (~/.claude/profiles/<name>/).
# When a profile dir exists, apply its slim-harness flags. Otherwise the
# launch is unchanged. Keeps blast radius scoped to opted-in personas.
#
#   .mcp.json            — MCP allowlist (used with --strict-mcp-config)
#   disallowed-tools.txt — newline list of built-in tools to block
#   settings.json        — optional --settings override
#
# See Mars/Tasks/feature-custodes-harness-context-profile.md for rationale.
PROFILE_DIR="$HOME/.claude/profiles/$PRIMARCH_NAME"
PROFILE_FLAGS=()
if [[ -d "$PROFILE_DIR" ]]; then
    if [[ -f "$PROFILE_DIR/.mcp.json" ]]; then
        PROFILE_FLAGS+=(--mcp-config "$PROFILE_DIR/.mcp.json" --strict-mcp-config)
    fi
    if [[ -f "$PROFILE_DIR/disallowed-tools.txt" ]]; then
        DISALLOWED=()
        while IFS= read -r line; do
            line="${line%%#*}"
            line="${line#"${line%%[![:space:]]*}"}"
            line="${line%"${line##*[![:space:]]}"}"
            [[ -z "$line" ]] && continue
            DISALLOWED+=("$line")
        done < "$PROFILE_DIR/disallowed-tools.txt"
        if [[ ${#DISALLOWED[@]} -gt 0 ]]; then
            PROFILE_FLAGS+=(--disallowedTools "${DISALLOWED[@]}")
        fi
    fi
    if [[ -f "$PROFILE_DIR/settings.json" ]]; then
        PROFILE_FLAGS+=(--settings "$PROFILE_DIR/settings.json")
    fi
    [[ ${#PROFILE_FLAGS[@]} -gt 0 ]] && echo -e "${DIM}Profile: $PROFILE_DIR${NC}"
fi

# Launch claude with persona
exec "$CLAUDE_BIN" --dangerously-skip-permissions ${PROFILE_FLAGS[@]+"${PROFILE_FLAGS[@]}"} --append-system-prompt "$FULL_PROMPT" "$@"
