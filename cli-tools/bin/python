#!/usr/bin/env bash
# python — Imperium Python interpreter shim
# TAGS: python, uv, wrapper
# AUDIENCE: system, agent, user
#
# This file must remain a real-interpreter delegate. Do NOT wrap back into
# `uv run` here: uv probes the configured interpreter by executing it, so a
# python->uv shim causes uv->python->uv recursion. Agent/user policy that
# requires uv-backed Python lives in the PreToolUse hook instead.

set -euo pipefail

_INVOKED_NAME="$(basename "$0")"

_find_real_python() {
    local candidate name self_real cand_real
    self_real="$(realpath "$0" 2>/dev/null || printf '%s\n' "$0")"

    for candidate in "${IMPERIUM_PYTHON_BIN:-}" "${REAL_PYTHON:-}"; do
        if [[ -n "$candidate" && -x "$candidate" ]]; then
            cand_real="$(realpath "$candidate" 2>/dev/null || printf '%s\n' "$candidate")"
            if [[ "$cand_real" != "$self_real" ]]; then
                printf '%s\n' "$candidate"
                return 0
            fi
        fi
    done

    # Prefer Homebrew Python before PATH lookup so uv/tooling does not silently
    # downgrade to Apple/CLT Python 3.9.
    for candidate in \
        /opt/homebrew/bin/python3 /opt/homebrew/bin/python \
        /usr/local/bin/python3 /usr/local/bin/python \
        /usr/bin/python3 /usr/bin/python; do
        if [[ -x "$candidate" ]]; then
            cand_real="$(realpath "$candidate" 2>/dev/null || printf '%s\n' "$candidate")"
            if [[ "$cand_real" != "$self_real" ]]; then
                printf '%s\n' "$candidate"
                return 0
            fi
        fi
    done

    for name in "$_INVOKED_NAME" python3 python; do
        while IFS= read -r candidate; do
            [[ -n "$candidate" && -x "$candidate" ]] || continue
            cand_real="$(realpath "$candidate" 2>/dev/null || printf '%s\n' "$candidate")"
            if [[ "$cand_real" != "$self_real" ]]; then
                printf '%s\n' "$candidate"
                return 0
            fi
        done < <(type -aP "$name" 2>/dev/null || true)
    done

    echo "python: real Python interpreter not found" >&2
    return 127
}

# Legacy bypass flag from the retired uv-wrapping shim: accept and drop it so
# old callers don't hand the real interpreter an unknown option.
if [[ "${1:-}" == "--no-uv" ]]; then
    shift
fi

_REAL_PYTHON="$(_find_real_python)"
export IMPERIUM_PYTHON_BIN="$_REAL_PYTHON"
exec "$_REAL_PYTHON" "$@"
