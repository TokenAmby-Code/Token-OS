#!/usr/bin/env bash
# claude-launcher — Interactive fzf-based Claude launch TUI
# TAGS: instance, launcher, tui
# AUDIENCE: human
#
# Walks through param selection via fzf, then calls claude-dispatch.
# Fast, non-blocking — runs in current shell, finishes by exec'ing dispatch.
#
# Concept: instances always launch FROM a vault (Imperium-ENV or Pax-ENV).
# The "project" selector picks the transplant target — where the agent works
# after briefing. Worktree creation is offered inline.
#
# Usage:
#   claude-launcher              Interactive mode (full menu)

set -euo pipefail

_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

DISPATCH_BIN="$(dirname "$(readlink -f "$0")")/claude-dispatch"
CODEX_DISPATCH_BIN="$(dirname "$(readlink -f "$0")")/codex-dispatch"
IMPERIUM_ROOT="${IMPERIUM:-/Volumes/Imperium}"
CIVIC_ROOT="${CIVIC:-/Volumes/Civic}"
DB_PATH="${PRIMARCH_DB:-$HOME/.claude/agents.db}"

# --- Colors ---
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Check fzf ---
if ! command -v fzf &>/dev/null; then
    echo "fzf not found — install with: brew install fzf" >&2
    exit 1
fi

# =============================================================================
# Step 1: Transplant target selector
# =============================================================================
select_target() {
    local options=()

    # Vault-only options (no transplant — stay in vault)
    options+=("Imperium-ENV")
    [[ -d "${CIVIC_ROOT}/Pax-ENV" ]] && options+=("Pax-ENV")

    # Worktree creation options
    options+=("+ New Token-OS worktree")
    options+=("+ New askCivic worktree")

    # Existing worktrees
    for wt_parent in "$HOME/worktrees/Token-OS" "$HOME/worktrees/askCivic"; do
        [[ -d "$wt_parent" ]] || continue
        local project_name
        project_name=$(basename "$wt_parent")
        for wt in "$wt_parent"/*/; do
            [[ -d "$wt/.git" || -f "$wt/.git" ]] || continue
            local branch
            branch=$(basename "$wt")
            options+=("$project_name/$branch")
        done
    done

    # NAS project dirs (Token-OS, askCivic source)
    [[ -d "${IMPERIUM_ROOT}/Token-OS" ]] && options+=("${IMPERIUM_ROOT}/Token-OS (NAS)")
    [[ -d "${CIVIC_ROOT}/askCivic" ]] && options+=("${CIVIC_ROOT}/askCivic (NAS)")

    # Recent working dirs from token-api
    local api_url="${TOKEN_API_URL:-http://localhost:7777}"
    local recent_dirs
    recent_dirs=$(curl -sf "${api_url}/api/instances" 2>/dev/null | \
        python3 -c "
import json, sys, os
try:
    instances = json.load(sys.stdin)
    seen = set()
    for inst in sorted(instances, key=lambda x: x.get('started_at',''), reverse=True):
        d = inst.get('working_dir','')
        if d and d not in seen and '/Imperium-ENV' not in d and '/Pax-ENV' not in d:
            seen.add(d)
            if len(seen) >= 5: break
    for d in seen:
        if os.path.isdir(d):
            print(d)
except: pass
" 2>/dev/null) || true

    while IFS= read -r dir; do
        [[ -n "$dir" ]] && options+=("$dir (recent)")
    done <<< "$recent_dirs"

    local selected
    if ! selected=$(printf '%s\n' "${options[@]}" | fzf \
        --prompt="Target > " \
        --header="Where should the agent work? (transplant target)" \
        --height=~20 \
        --layout=reverse \
        --no-info \
        --cycle); then
        return 130
    fi

    echo "$selected"
}

# =============================================================================
# Handle worktree creation
# =============================================================================
create_worktree() {
    local project="$1"
    echo ""
    echo -e "${CYAN}Creating $project worktree${NC}"
    read -r "branch?Branch name: "
    if [[ -z "$branch" ]]; then
        echo "Cancelled."
        return 1
    fi
    local wt_path
    wt_path=$(worktree-setup "$branch" --project "$project" 2>&1 | tee /dev/stderr | grep "^Worktree ready:" | sed 's/^Worktree ready: //')
    if [[ -z "$wt_path" ]]; then
        # Fallback: derive path from convention
        wt_path="$HOME/worktrees/$project/$branch"
    fi
    if [[ ! -d "$wt_path" ]]; then
        echo -e "${YELLOW}Worktree creation may have failed — check output above${NC}"
        return 1
    fi
    echo "$wt_path"
}

# =============================================================================
# Step 2: Engine selector
# =============================================================================
select_engine() {
    local options=(
        "Claude — interactive AI assistant"
        "Codex — autonomous coding agent"
    )

    local selected
    if ! selected=$(printf '%s\n' "${options[@]}" | fzf \
        --prompt="Engine > " \
        --header="Select launch engine" \
        --height=~6 \
        --layout=reverse \
        --no-info \
        --cycle); then
        return 130
    fi

    case "$selected" in
        Claude*) echo "claude" ;;
        Codex*)  echo "codex" ;;
        *)       echo "claude" ;;
    esac
}

# =============================================================================
# Step 3: Persona selector (Claude only)
# =============================================================================
select_persona() {
    local engine="${1:-claude}"
    local default_label="Astartes"

    if [[ "$engine" == "codex" ]]; then
        default_label="Sisters of Battle"
    fi

    local options=("$default_label")

    if [[ -f "$DB_PATH" ]] && command -v sqlite3 &>/dev/null; then
        while IFS=$'\t' read -r name title; do
            options+=("$name — $title")
        done < <(sqlite3 -separator $'\t' "$DB_PATH" "SELECT name, title FROM primarchs ORDER BY name;" 2>/dev/null)
    fi

    local selected
    if ! selected=$(printf '%s\n' "${options[@]}" | fzf \
        --prompt="Persona > " \
        --header="Select persona" \
        --height=~15 \
        --layout=reverse \
        --no-info \
        --cycle); then
        return 130
    fi

    if [[ "$selected" == "$default_label" ]]; then
        echo ""
    else
        echo "$selected" | cut -d' ' -f1
    fi
}

# =============================================================================
# Step 4: Mode selector (Claude only)
# =============================================================================
select_mode() {
    local options=(
        "Normal — standard interactive session"
        "Sync — synchronous session with Emperor present"
        "Golden Throne — zealotry 5, maximum persistence"
    )

    local selected
    if ! selected=$(printf '%s\n' "${options[@]}" | fzf \
        --prompt="Mode > " \
        --header="Select launch mode" \
        --height=~8 \
        --layout=reverse \
        --no-info \
        --cycle); then
        return 130
    fi

    case "$selected" in
        Normal*)          echo "normal" ;;
        Sync*)            echo "sync" ;;
        "Golden Throne"*) echo "throne" ;;
        *)                echo "normal" ;;
    esac
}

# =============================================================================
# Resolve vault from target
# =============================================================================
resolve_vault() {
    local target="$1"
    # Pax-ENV or askCivic targets launch from Pax-ENV
    case "$target" in
        *Pax-ENV*|*askCivic*|*/Civic/*)
            echo "${CIVIC_ROOT}/Pax-ENV"
            ;;
        *)
            echo "${IMPERIUM_ROOT}/Imperium-ENV"
            ;;
    esac
}

# =============================================================================
# Main
# =============================================================================

clear
echo -e "${CYAN}${BOLD}Claude Launcher${NC}"
echo ""

# Step 1: Transplant target
if ! SELECTED=$(select_target); then
    echo "Cancelled."
    exit 130
fi

# Handle special selections
TRANSPLANT_DIR=""
case "$SELECTED" in
    "Imperium-ENV")
        TRANSPLANT_DIR=""  # No transplant — stay in vault
        LAUNCH_VAULT="${IMPERIUM_ROOT}/Imperium-ENV"
        ;;
    "Pax-ENV")
        TRANSPLANT_DIR=""
        LAUNCH_VAULT="${CIVIC_ROOT}/Pax-ENV"
        ;;
    "+ New Token-OS worktree")
        TRANSPLANT_DIR=$(create_worktree "Token-OS") || exit 1
        LAUNCH_VAULT="${IMPERIUM_ROOT}/Imperium-ENV"
        ;;
    "+ New askCivic worktree")
        TRANSPLANT_DIR=$(create_worktree "askCivic") || exit 1
        LAUNCH_VAULT="${CIVIC_ROOT}/Pax-ENV"
        ;;
    *)
        if [[ "$SELECTED" == */* && "$SELECTED" != /* ]]; then
            TRANSPLANT_DIR="$HOME/worktrees/$SELECTED"
        else
            TRANSPLANT_DIR=$(echo "$SELECTED" | sed 's/ ([^)]*) *$//')
        fi
        LAUNCH_VAULT=$(resolve_vault "$SELECTED")
        ;;
esac

# Step 2: Engine
if ! ENGINE=$(select_engine); then
    echo "Cancelled."
    exit 130
fi

if [[ "$ENGINE" == "codex" ]]; then
    # Codex path — no persona/mode, dispatch directly to target dir
    CODEX_DIR="${TRANSPLANT_DIR:-$LAUNCH_VAULT}"

    echo ""
    echo -e "${DIM}Launching:${NC}"
    echo -e "  ${DIM}engine:${NC}    codex"
    echo -e "  ${DIM}dir:${NC}       $CODEX_DIR"
    echo ""

    clear
    exec "$CODEX_DISPATCH_BIN" --launcher "claude-launcher" "$CODEX_DIR" ""
fi

# Claude path — continue with persona + mode selectors

# Step 3: Persona
if ! PERSONA=$(select_persona "$ENGINE"); then
    echo "Cancelled."
    exit 130
fi

# Step 4: Mode
if ! MODE=$(select_mode); then
    echo "Cancelled."
    exit 130
fi

# Build dispatch args — launch dir is always the vault
DISPATCH_ARGS=("--dir" "$LAUNCH_VAULT")

if [[ -n "$TRANSPLANT_DIR" ]]; then
    DISPATCH_ARGS+=("--prompt" "Transplant to ${TRANSPLANT_DIR} and begin work.")
fi

if [[ -n "$PERSONA" ]]; then
    DISPATCH_ARGS+=("--primarch" "$PERSONA")
fi

case "$MODE" in
    sync)   DISPATCH_ARGS+=("--sync") ;;
    throne) DISPATCH_ARGS+=("--zealotry" "5" "--sync") ;;
esac

# Summary
echo ""
echo -e "${DIM}Launching:${NC}"
echo -e "  ${DIM}engine:${NC}    claude"
echo -e "  ${DIM}vault:${NC}     $LAUNCH_VAULT"
[[ -n "$TRANSPLANT_DIR" ]] && echo -e "  ${DIM}target:${NC}    $TRANSPLANT_DIR"
[[ -n "$PERSONA" ]]        && echo -e "  ${DIM}persona:${NC}   $PERSONA"
echo -e "  ${DIM}mode:${NC}      $MODE"
echo ""

# Dispatch
exec "$DISPATCH_BIN" "${DISPATCH_ARGS[@]}"
