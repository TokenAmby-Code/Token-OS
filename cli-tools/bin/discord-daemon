#!/usr/bin/env bash
# discord-daemon - Manage the Discord CLI daemon
# TAGS: claw, discord
# AUDIENCE: human, agent
#
# Usage: discord-daemon <status|logs>           # read-only inspection
#        discord-daemon <start|stop|restart>    # delegate to launchd
#
# The daemon maintains a persistent WebSocket connection to Discord and exposes a
# local HTTP API on localhost:7779. It is launchd-supervised (ai.tokenclaw.discord).
# Mutating commands route to the AUTHORITATIVE `token-restart --discord` path; the
# old pidfile+nohup manager split-brained against launchd KeepAlive and is gone.

set -euo pipefail

DAEMON_DIR="$HOME/.discord-cli"
PID_FILE="$DAEMON_DIR/daemon.pid"
LOG_DIR="$DAEMON_DIR/logs"
DAEMON_URL="http://127.0.0.1:7779"
LABEL="ai.tokenclaw.discord"   # launchd label — restart via token-restart --discord

die() { echo "Error: $*" >&2; exit 1; }

get_pid() {
  [[ -f "$PID_FILE" ]] && cat "$PID_FILE" || echo ""
}

# start/restart/stop are launchd operations. The daemon is supervised by launchd
# (KeepAlive), so the ONLY safe restart is `launchctl kickstart`, surfaced through
# the authoritative `token-restart --discord`. The previous pidfile+nohup logic
# started a SECOND daemon that raced launchd's for port 7779 (split-brain).

cmd_restart() {
  echo "discord-daemon is launchd-supervised — delegating to the authoritative path:" >&2
  echo "  token-restart --discord" >&2
  exec token-restart --discord
}

cmd_start() {
  # kickstart starts the service if it isn't running, so start == restart here.
  cmd_restart
}

cmd_stop() {
  echo "Stopping launchd-supervised Discord daemon (ai.tokenclaw.discord)..."
  echo "(bootout disables KeepAlive — stays down until 'token-restart --discord')"
  if launchctl bootout "gui/$(id -u)/${LABEL}" 2>/dev/null; then
    echo "Daemon stopped."
  else
    echo "Daemon already stopped or not loaded."
  fi
}

cmd_status() {
  local pid
  pid=$(get_pid)

  if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
    echo "Daemon: stopped"
    [[ -n "$pid" ]] && echo "  (stale PID file: $pid)"
    exit 1
  fi

  echo "Daemon: running (PID $pid)"

  # Try health check
  if curl -sf "$DAEMON_URL/status" 2>/dev/null | jq -r '
    "  Connected: \(.connected)\n  User: \(.user // "unknown")\n  Ping: \(.ping)ms\n  Channels: \(.channels)"
  ' 2>/dev/null; then
    :
  else
    echo "  HTTP API not responding (may still be connecting)"
  fi
}

cmd_logs() {
  local log_file="$LOG_DIR/daemon-$(date +%Y-%m-%d).log"
  local lines="${1:-50}"

  if [[ ! -f "$log_file" ]]; then
    echo "No log file for today. Checking for most recent..."
    log_file=$(ls -t "$LOG_DIR"/daemon-*.log 2>/dev/null | head -1)
    [[ -z "$log_file" ]] && die "No log files found"
  fi

  if [[ "${1:-}" == "-f" || "${1:-}" == "--follow" ]]; then
    tail -f "$log_file"
  else
    tail -"$lines" "$log_file"
  fi
}

# --- Main ---

[[ $# -eq 0 ]] && {
  echo "Usage: discord-daemon <start|stop|restart|status|logs>"
  exit 1
}

case "$1" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    shift; cmd_logs "$@" ;;
  -h|--help)
    echo "Usage: discord-daemon <status|logs|start|stop|restart>"
    echo "  status, logs        read-only inspection"
    echo "  start, restart      -> token-restart --discord (authoritative, launchd)"
    echo "  stop                -> launchctl bootout (disables KeepAlive)"
    exit 0 ;;
  *) die "Unknown command: $1" ;;
esac
