#!/usr/bin/env bash
# tmux-workspace - Create the unified tmux workspace layout
# TAGS: tmux, workspace
# AUDIENCE: human
#
# WSL layout:  [side] [2×2 power grid] [side]
# Mac layout:  [2×2 power grid] [right-col] (bridge window, right col auto-runs monitor)
#
# Usage:
#   tmux-workspace              # Create 'main' session with WSL grid + mobile windows
#   tmux-workspace --attach     # Create and attach
#   tmux-workspace --mac        # Create Mac 'bridge' layout and attach
#   tmux-workspace --window     # Add WSL grid window to current session
#   tmux-workspace --mobile     # Create the mobile window (2-pane vertical split)
#   tmux-workspace --focus      # Drop all side columns, keep only the 2×2 grid
#   tmux-workspace --unfocus    # Restore side columns to their original layout

set -euo pipefail

# Source machine identity for NAS paths
_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
# shellcheck source=../lib/nas-path.sh
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

SESSION_NAME="main"
WINDOW_NAME="grid"
BRIDGE_WINDOW="bridge"
TUI_WINDOW="tui"
MOBILE_WINDOW_PREFIX="mobile"
MOBILE_WINDOW_COUNT=3
MOBILE_MONITOR_HEIGHT=6
MOBILE_SHELL_INIT="${CLI_TOOLS}/tmux/mobile-shell-init.zsh"
TOKEN_API_DIR="${TOKEN_OS}/token-api"

# --- Per-window default directories ---
# Map window names to their default working directory.
# Unmatched windows default to $HOME.
window_dir() {
    case "$1" in
        bridge)    echo "$HOME" ;;
        grid)      echo "$HOME" ;;
        tui)       echo "${TOKEN_API_DIR}" ;;
        backrooms) echo "$HOME" ;;
        mobile-1)  echo "$HOME" ;;
        mobile-2)  echo "$HOME" ;;
        mobile-3)  echo "$HOME" ;;
        *)         echo "$HOME" ;;
    esac
}

# --- Proportions ---
# Side columns: ~15% each, center grid: ~70%
# Default detached size (overridden by client on attach)
DETACHED_W=240
DETACHED_H=60

# Enable TUI pane lifecycle: remain-on-exit + auto-restart unless dirty
init_tui_lifecycle() {
    local pane="$1"
    tmux set-option -p -t "$pane" remain-on-exit on
    tmux set-hook -p -t "$pane" pane-died \
        "if -F '#{==:#{@TUI_DIRTY},true}' '' 'respawn-pane -k -t #{pane_id} tui-pane-guard'"
}

create_grid_window() {
    local session="$1"
    local window="$2"
    local wdir
    wdir="$(window_dir "${window}")"

    # Get current window width to calculate absolute sizes
    local total_w
    total_w=$(tmux display-message -t "${session}:${window}" -p '#{window_width}')
    local total_h
    total_h=$(tmux display-message -t "${session}:${window}" -p '#{window_height}')

    # Calculate column widths (subtract separators: 4 vertical splits = 4 columns lost)
    local usable=$((total_w - 5))  # 5 pane borders
    local side_w=$((usable * 20 / 100))
    local center_w=$((usable - side_w * 2))
    local center_half=$((center_w / 2))
    local half_h=$((total_h / 2))

    # Start with a single pane — this becomes the left side column
    # Split right: left side | rest
    tmux split-window -h -t "${session}:${window}.1" -l $((total_w - side_w - 1)) -c "$wdir"

    # Now pane 1 = left side, pane 2 = rest
    # Split pane 2 to carve out the right side column
    tmux split-window -h -t "${session}:${window}.2" -l "${side_w}" -c "$wdir"

    # Now: pane 1 = left side, pane 2 = center, pane 3 = right side
    # Split center into left-center and right-center
    tmux split-window -h -t "${session}:${window}.2" -l "${center_half}" -c "$wdir"

    # Now: pane 1 = left side, pane 2 = center-left, pane 3 = center-right, pane 4 = right side
    # Split center-left vertically
    tmux split-window -v -t "${session}:${window}.2" -l "${half_h}" -c "$wdir"

    # Split center-right vertically
    tmux split-window -v -t "${session}:${window}.4" -l "${half_h}" -c "$wdir"

    # Final pane layout (6 panes):
    #   1: left side column (full height)
    #   2: top-left grid
    #   3: bottom-left grid
    #   4: top-right grid
    #   5: bottom-right grid
    #   6: right side column (full height)

    # Set zone state environment variables
    tmux set-option -p -t "${session}:${window}.1" @GRID_STATE "side"
    tmux set-option -p -t "${session}:${window}.2" @GRID_STATE "small"
    tmux set-option -p -t "${session}:${window}.3" @GRID_STATE "small"
    tmux set-option -p -t "${session}:${window}.4" @GRID_STATE "small"
    tmux set-option -p -t "${session}:${window}.5" @GRID_STATE "small"
    tmux set-option -p -t "${session}:${window}.6" @GRID_STATE "side"

    for pane in 1 2 3 4 5 6; do
        tmux set-option -p -t "${session}:${window}.${pane}" @GRID_RESERVED "false"
    done

    # Tag layout origin for focus/unfocus
    tmux set-option -w -t "${session}:${window}" @LAYOUT_ORIGIN "wsl"
    tmux set-option -w -t "${session}:${window}" @FOCUSED "false"
    tmux set-option -w -t "${session}:${window}" @GRID_EXPANDED "none"

    # Focus the top-left grid pane
    tmux select-pane -t "${session}:${window}.2"
}

create_bridge_window() {
    local session="$1"
    local window="$2"
    local wdir
    wdir="$(window_dir "${window}")"

    local total_w
    total_w=$(tmux display-message -t "${session}:${window}" -p '#{window_width}')
    local total_h
    total_h=$(tmux display-message -t "${session}:${window}" -p '#{window_height}')

    # Right column: 1/3 width (enough for TUI vertical mode); 2×2 grid gets 2/3
    local usable=$((total_w - 2))  # 2 pane borders
    local right_w=$((usable * 33 / 100))
    local grid_w=$((usable - right_w))
    local grid_half=$((grid_w / 2))
    local half_h=$((total_h / 2))

    # Pane 1 starts as full width — split off right column
    tmux split-window -h -t "${session}:${window}.1" -l "${right_w}" -c "$wdir"

    # Pane 1 = left (grid area), pane 2 = right column
    # Split grid area into left and right halves
    tmux split-window -h -t "${session}:${window}.1" -l "${grid_half}" -c "$wdir"

    # Pane 1 = grid-left, pane 2 = grid-right, pane 3 = right col
    # Split each grid column vertically
    tmux split-window -v -t "${session}:${window}.1" -l "${half_h}" -c "$wdir"
    tmux split-window -v -t "${session}:${window}.3" -l "${half_h}" -c "$wdir"

    # Final layout (5 panes):
    #   1: top-left grid
    #   2: bottom-left grid
    #   3: top-right grid
    #   4: bottom-right grid
    #   5: right column (TUI monitor)

    tmux set-option -p -t "${session}:${window}.1" @GRID_STATE "small"
    tmux set-option -p -t "${session}:${window}.2" @GRID_STATE "small"
    tmux set-option -p -t "${session}:${window}.3" @GRID_STATE "small"
    tmux set-option -p -t "${session}:${window}.4" @GRID_STATE "small"
    tmux set-option -p -t "${session}:${window}.5" @GRID_STATE "side"
    tmux set-option -p -t "${session}:${window}.5" @PANE_TYPE "tui"

    for pane in 1 2 3 4 5; do
        tmux set-option -p -t "${session}:${window}.${pane}" @GRID_RESERVED "false"
    done

    # Tag layout origin for focus/unfocus
    tmux set-option -w -t "${session}:${window}" @LAYOUT_ORIGIN "mac"
    tmux set-option -w -t "${session}:${window}" @FOCUSED "false"
    tmux set-option -w -t "${session}:${window}" @GRID_EXPANDED "none"

    # TUI lifecycle: auto-restart unless intentionally closed
    init_tui_lifecycle "${session}:${window}.5"
    tmux send-keys -t "${session}:${window}.5" "exec tui-pane-guard" Enter

    # Focus top-left grid pane
    tmux select-pane -t "${session}:${window}.1"
}

create_tui_window() {
    local session="$1"
    tmux new-window -t "${session}" -n "${TUI_WINDOW}" -c "$(window_dir "${TUI_WINDOW}")"
    tmux set-option -p -t "${session}:${TUI_WINDOW}.1" @PANE_TYPE "tui"
    init_tui_lifecycle "${session}:${TUI_WINDOW}.1"
    tmux send-keys -t "${session}:${TUI_WINDOW}" "exec tui-pane-guard" Enter
}

create_backrooms_window() {
    local session="$1"
    tmux new-window -t "${session}" -n "backrooms" -d -c "$(window_dir backrooms)"
    tmux set-option -p -t "${session}:backrooms.1" @PANE_TYPE "backrooms"
}

create_mobile_windows() {
    local session="$1"
    local count="${2:-$MOBILE_WINDOW_COUNT}"

    for i in $(seq 1 "$count"); do
        local win_name="${MOBILE_WINDOW_PREFIX}-${i}"
        local wdir
        wdir="$(window_dir "${win_name}")"
        tmux new-window -t "${session}" -n "${win_name}" -c "$wdir"

        local total_h
        total_h=$(tmux display-message -t "${session}:${win_name}" -p '#{window_height}')
        local terminal_area=$((total_h - MOBILE_MONITOR_HEIGHT - 2))
        local half_terminal=$((terminal_area / 2))

        # Split off monitor at top (pane 1 stays small, pane 2 gets the rest)
        tmux split-window -v -t "${session}:${win_name}.1" -l "${terminal_area}" -c "$wdir"

        # Split the terminal area in half (pane 2 → top terminal, pane 3 → bottom terminal)
        tmux split-window -v -t "${session}:${win_name}.2" -l "${half_terminal}" -c "$wdir"

        # Final layout: pane 1 = monitor (top, crushed), pane 2 = terminal A, pane 3 = terminal B
        tmux set-option -p -t "${session}:${win_name}.1" @GRID_STATE "mini"
        tmux set-option -p -t "${session}:${win_name}.2" @GRID_STATE "small"
        tmux set-option -p -t "${session}:${win_name}.3" @GRID_STATE "small"
        tmux set-option -p -t "${session}:${win_name}.1" @PANE_TYPE "tui"
        tmux set-option -p -t "${session}:${win_name}.1" @GRID_RESERVED "true"
        tmux set-option -p -t "${session}:${win_name}.2" @GRID_RESERVED "false"
        tmux set-option -p -t "${session}:${win_name}.3" @GRID_RESERVED "false"
        tmux set-option -p -t "${session}:${win_name}.1" @PANE_CLEAN "true"
        tmux set-option -p -t "${session}:${win_name}.2" @PANE_CLEAN "true"
        tmux set-option -p -t "${session}:${win_name}.3" @PANE_CLEAN "true"

        # Init dirty bit hooks in terminal panes (not monitor — it'll run a TUI)
        tmux send-keys -t "${session}:${win_name}.2" "source ${MOBILE_SHELL_INIT} && clear" Enter
        tmux send-keys -t "${session}:${win_name}.3" "source ${MOBILE_SHELL_INIT} && clear" Enter

        # TUI lifecycle: auto-restart unless intentionally closed
        init_tui_lifecycle "${session}:${win_name}.1"
        tmux send-keys -t "${session}:${win_name}.1" "exec tui-pane-guard" Enter

        # Focus top terminal pane
        tmux select-pane -t "${session}:${win_name}.2"
    done
}

focus_mode() {
    # Drop all side-class panes from the current window.
    # Resilient: works with 0, 1, or N side panes regardless of layout.
    local session window target
    session=$(tmux display-message -p '#{session_name}')
    window=$(tmux display-message -p '#{window_index}')
    target="${session}:${window}"

    # Collect pane IDs where @GRID_STATE == "side"
    local side_panes=()
    while IFS= read -r line; do
        local pane_id state
        pane_id=$(echo "$line" | cut -d' ' -f1)
        state=$(echo "$line" | cut -d' ' -f2)
        if [[ "$state" == "side" ]]; then
            side_panes+=("$pane_id")
        fi
    done < <(tmux list-panes -t "$target" -F '#{pane_id} #{@GRID_STATE}')

    if [[ ${#side_panes[@]} -eq 0 ]]; then
        return 0
    fi

    # Record layout origin so unfocus knows what to restore.
    # "wsl" if 2 sides, "mac" if 1 side, generic count otherwise.
    local side_count=${#side_panes[@]}
    local layout_origin
    if [[ $side_count -ge 2 ]]; then
        layout_origin="wsl"
    else
        layout_origin="mac"
    fi
    tmux set-option -w -t "$target" @LAYOUT_ORIGIN "$layout_origin"
    tmux set-option -w -t "$target" @FOCUSED "true"

    # Kill side panes first (stable, immune to index renumbering)
    for pid in "${side_panes[@]}"; do
        tmux kill-pane -t "$pid"
    done

    # On WSL: snap terminal to right 50% (changes terminal dimensions)
    if [[ "$layout_origin" == "wsl" ]] && command -v wt-focus &>/dev/null; then
        wt-focus on
    fi

    # No explicit refresh needed — tmux auto-adjusts pane sizes when the
    # terminal resizes from wt-focus. The canonical reset (tmux-refresh-layout)
    # is available via prefix+e or tx refresh if manual correction is needed.
}

unfocus_mode() {
    # Restore side columns based on stored layout origin.
    local session window target
    session=$(tmux display-message -p '#{session_name}')
    window=$(tmux display-message -p '#{window_index}')
    target="${session}:${window}"

    local focused
    focused=$(tmux show-options -wv -t "$target" @FOCUSED 2>/dev/null || echo "false")
    if [[ "$focused" != "true" ]]; then
        return 0
    fi

    local layout_origin
    layout_origin=$(tmux show-options -wv -t "$target" @LAYOUT_ORIGIN 2>/dev/null || echo "")

    local total_w total_h
    total_w=$(tmux display-message -t "$target" -p '#{window_width}')
    total_h=$(tmux display-message -t "$target" -p '#{window_height}')

    # On WSL: maximize terminal first so layout calculations use full dimensions
    if [[ "$layout_origin" == "wsl" ]] && command -v wt-focus &>/dev/null; then
        wt-focus off
    fi

    # Re-read dimensions after potential maximize
    total_w=$(tmux display-message -t "$target" -p '#{window_width}')
    total_h=$(tmux display-message -t "$target" -p '#{window_height}')

    if [[ "$layout_origin" == "wsl" ]]; then
        # Restore two full-height side columns flanking the existing grid
        local usable=$((total_w - 5))
        local side_w=$((usable * 20 / 100))

        # Get the leftmost pane to split a full-height left side off of
        local first_pane
        first_pane=$(tmux list-panes -t "$target" -F '#{pane_id}' | head -1)

        # -f = full-width/height split (spans entire window, not just target pane)
        # -hb = horizontal split, new pane goes before (left)
        tmux split-window -fhb -t "$first_pane" -l "${side_w}"
        local left_side
        left_side=$(tmux display-message -t "$target" -p '#{pane_id}')
        tmux set-option -p -t "$left_side" @GRID_STATE "side"
        tmux set-option -p -t "$left_side" @GRID_RESERVED "false"

        # Get the rightmost pane to split a full-height right side off of
        local last_pane
        last_pane=$(tmux list-panes -t "$target" -F '#{pane_id}' | tail -1)

        # -fh = full-height horizontal split, new pane goes after (right)
        tmux split-window -fh -t "$last_pane" -l "${side_w}"
        local right_side
        right_side=$(tmux display-message -t "$target" -p '#{pane_id}')
        tmux set-option -p -t "$right_side" @GRID_STATE "side"
        tmux set-option -p -t "$right_side" @GRID_RESERVED "false"

    elif [[ "$layout_origin" == "mac" ]]; then
        # Restore full-height right column (1/3 width for TUI vertical mode)
        local usable=$((total_w - 2))
        local right_w=$((usable * 33 / 100))

        local last_pane
        last_pane=$(tmux list-panes -t "$target" -F '#{pane_id}' | tail -1)

        # -fh = full-height split spanning entire window
        tmux split-window -fh -t "$last_pane" -l "${right_w}"
        local right_col
        right_col=$(tmux display-message -t "$target" -p '#{pane_id}')
        tmux set-option -p -t "$right_col" @GRID_STATE "side"
        tmux set-option -p -t "$right_col" @PANE_TYPE "tui"
        tmux set-option -p -t "$right_col" @GRID_RESERVED "false"

        # TUI lifecycle: auto-restart unless intentionally closed
        init_tui_lifecycle "$right_col"
        tmux send-keys -t "$right_col" "exec tui-pane-guard" Enter

    else
        return 1
    fi

    # Rebalance grid to even sizing (grid width changed with side columns added)
    tmux-refresh-layout

    tmux set-option -w -t "$target" @FOCUSED "false"
}

# --- Parse args ---
ATTACH=false
WINDOW_ONLY=false
MOBILE_ONLY=false
# Auto-detect layout from machine config. --mac flag overrides.
MAC_MODE=false
if [[ "$(imperium_cfg tmux_layout 2>/dev/null)" == "bridge" ]]; then
    MAC_MODE=true
fi
FOCUS_MODE=false
UNFOCUS_MODE=false
PORTABLE_MODE=false
WINDOW_RESET=""
BRIDGE_RESET=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --attach)        ATTACH=true ;;
        --window)        WINDOW_ONLY=true ;;
        --mobile)        MOBILE_ONLY=true ;;
        --mac)           MAC_MODE=true; ATTACH=true ;;
        --mac-no-attach) MAC_MODE=true ;;
        --portable)      PORTABLE_MODE=true ;;
        --focus)         FOCUS_MODE=true ;;
        --unfocus)       UNFOCUS_MODE=true ;;
        --toggle-focus)
            state=$(tmux show-options -wv @FOCUSED 2>/dev/null || echo "false")
            if [[ "$state" == "true" ]]; then
                UNFOCUS_MODE=true
            else
                FOCUS_MODE=true
            fi
            ;;
        --window-reset)  WINDOW_RESET="$2"; shift ;;
        --bridge-reset)  BRIDGE_RESET="$2"; shift ;;
        -h|--help)
            echo "Usage: tmux-workspace [--attach] [--mac] [--window] [--mobile] [--focus] [--unfocus]"
            echo ""
            echo "  (no args)   Create 'main' session with WSL grid + mobile windows"
            echo "  --attach    Create and attach to session"
            echo "  --mac       Create Mac bridge layout [2×2][right-col] and attach"
            echo "  --portable  Attach to existing session with portable monitor status bar"
            echo "  --window    Add WSL grid window to current session (must be inside tmux)"
            echo "  --mobile    Add mobile window to current session"
            echo "  --focus     Drop all side columns, keep only the 2×2 grid"
            echo "  --unfocus   Restore side columns to their original layout"
            exit 0
            ;;
        *)
            echo "Unknown arg: $1" >&2
            exit 1
            ;;
    esac
    shift
done

# --- Window-only mode: add to current session ---
if $WINDOW_ONLY; then
    if [ -z "${TMUX:-}" ]; then
        echo "Error: --window requires being inside tmux" >&2
        exit 1
    fi
    session=$(tmux display-message -p '#{session_name}')
    tmux new-window -t "${session}" -n "${WINDOW_NAME}" -c "$(window_dir "${WINDOW_NAME}")"
    create_grid_window "${session}" "${WINDOW_NAME}"
    echo "Grid window added to session '${session}'"
    exit 0
fi

if $MOBILE_ONLY; then
    if [ -z "${TMUX:-}" ]; then
        echo "Error: --mobile requires being inside tmux" >&2
        exit 1
    fi
    session=$(tmux display-message -p '#{session_name}')
    create_mobile_windows "${session}"
    echo "Mobile windows (${MOBILE_WINDOW_COUNT}) added to session '${session}'"
    exit 0
fi

if $FOCUS_MODE; then
    if [ -z "${TMUX:-}" ]; then
        echo "Error: --focus requires being inside tmux" >&2
        exit 1
    fi
    focus_mode
    exit 0
fi

if $UNFOCUS_MODE; then
    if [ -z "${TMUX:-}" ]; then
        echo "Error: --unfocus requires being inside tmux" >&2
        exit 1
    fi
    unfocus_mode
    exit 0
fi

# --- Reset modes (internal, called by tmux-reset) ---
if [[ -n "$WINDOW_RESET" ]]; then
    session=$(tmux display-message -p '#{session_name}')
    create_grid_window "${session}" "${WINDOW_RESET}"
    exit 0
fi

if [[ -n "$BRIDGE_RESET" ]]; then
    session=$(tmux display-message -p '#{session_name}')
    create_bridge_window "${session}" "${BRIDGE_RESET}"
    exit 0
fi

# --- Portable monitor: grouped session with status overrides ---
if $PORTABLE_MODE; then
    if ! tmux has-session -t "${SESSION_NAME}" 2>/dev/null; then
        echo "Error: no '${SESSION_NAME}' session to attach to. Create it first." >&2
        exit 1
    fi

    PORTABLE_SESSION="portable"
    PORTABLE_STATUS="${CLI_TOOLS}/tmux/tmux-portable-status.conf"

    # Kill stale portable session if it exists
    tmux kill-session -t "${PORTABLE_SESSION}" 2>/dev/null || true

    # Grouped session: shares windows with main, independent status bar
    tmux new-session -d -t "${SESSION_NAME}" -s "${PORTABLE_SESSION}"
    tmux source-file -t "${PORTABLE_SESSION}" "${PORTABLE_STATUS}"

    # Select bridge window if it exists, otherwise stay on current
    if tmux list-windows -t "${PORTABLE_SESSION}" -F '#{window_name}' | grep -q "^${BRIDGE_WINDOW}$"; then
        tmux select-window -t "${PORTABLE_SESSION}:${BRIDGE_WINDOW}"
    fi

    exec tmux attach-session -t "${PORTABLE_SESSION}"
fi

# --- Mac bridge layout ---
if $MAC_MODE; then
    if tmux has-session -t "${SESSION_NAME}" 2>/dev/null; then
        echo "Session '${SESSION_NAME}' already exists."
        echo "Use --attach to connect, or kill it first with: tmux kill-session -t ${SESSION_NAME}"
        exit 0
    fi
    tmux new-session -d -s "${SESSION_NAME}" -n "${BRIDGE_WINDOW}" -x 220 -y 50 -c "$(window_dir "${BRIDGE_WINDOW}")"
    create_bridge_window "${SESSION_NAME}" "${BRIDGE_WINDOW}"
    create_backrooms_window "${SESSION_NAME}"
    create_mobile_windows "${SESSION_NAME}"
    tmux select-window -t "${SESSION_NAME}:${BRIDGE_WINDOW}"
    echo "Mac workspace '${SESSION_NAME}' created."
    echo "  Window '${BRIDGE_WINDOW}': [2×2] [right-col → monitor]"
    echo "  Windows '${MOBILE_WINDOW_PREFIX}-1..${MOBILE_WINDOW_COUNT}': monitor + terminal (dirty bit tracked)"
    if $ATTACH; then
        exec tmux attach-session -t "${SESSION_NAME}"
    fi
    exit 0
fi

# --- Full session creation ---
if tmux has-session -t "${SESSION_NAME}" 2>/dev/null; then
    echo "Session '${SESSION_NAME}' already exists."
    if $ATTACH; then
        exec tmux attach-session -t "${SESSION_NAME}"
    fi
    echo "Use --attach to connect, or --window to add a grid window."
    exit 0
fi

# Create session with the grid window
# -x/-y needed when no client is attached (headless creation)
tmux new-session -d -s "${SESSION_NAME}" -n "${WINDOW_NAME}" -x 240 -y 60 -c "$(window_dir "${WINDOW_NAME}")"
create_grid_window "${SESSION_NAME}" "${WINDOW_NAME}"

# Add the TUI window (dedicated for vertical monitor)
create_tui_window "${SESSION_NAME}"

# Add the backrooms window (autonomous sessions, Golden Throne resume)
create_backrooms_window "${SESSION_NAME}"

# Add the mobile windows
create_mobile_windows "${SESSION_NAME}"

# Go back to the grid window
tmux select-window -t "${SESSION_NAME}:${WINDOW_NAME}"

echo "Workspace session '${SESSION_NAME}' created."
echo "  Window '${WINDOW_NAME}': [side] [2×2] [side]"
echo "  Window '${TUI_WINDOW}': token-api TUI (vertical monitor)"
echo "  Windows '${MOBILE_WINDOW_PREFIX}-1..${MOBILE_WINDOW_COUNT}': monitor + terminal (dirty bit tracked)"

if $ATTACH; then
    exec tmux attach-session -t "${SESSION_NAME}"
else
    echo ""
    echo "Attach with: tmux attach -t ${SESSION_NAME}"
    echo "TUI:         tmux attach -t ${SESSION_NAME}:${TUI_WINDOW}"
    echo "Phone:       tmux new-session -t ${SESSION_NAME} \\; select-window -t ${MOBILE_WINDOW_PREFIX}-1"
fi
