#!/usr/bin/env bash
# Worktree Hygiene - enumerate, park, and re-anchor agent worktrees
# TAGS: git, worktree, hygiene, cd, rescue
# AUDIENCE: human, agent
#
# One-time + ongoing hygiene for the agent worktree fleet (incident 2026-06-22):
#   - worktrees left checked out *on* main jam the CD bare-main fast-forward
#   - worktrees bound to a bare in #recycle / a dated legacy archive silently
#     lose work when the recycle bin is purged
#
# Subcommands:
#   enumerate [--project NAME]
#       Evidence report over every linked worktree of the canonical bare PLUS any
#       worktree dir under WORKTREE_PARENT, with: bound-bare (canonical vs
#       QUARANTINED), branch / detached, dirty + ahead/behind, last-commit date,
#       and a short `git status` summary. READ-ONLY — this is the confirm gate.
#
#   park <worktree-path>
#       Preserve any uncommitted edits to a collision-safe wip/ branch (commit +
#       push to the canonical bare and origin), then detach the worktree off its
#       branch at the current SHA. Used to free a worktree pinned on main without
#       losing WIP. Non-destructive (nothing is removed).
#
#   reanchor <worktree-path> [--project NAME]
#       Re-point a worktree whose commondir lives in a quarantined bare back to
#       the canonical bare, in place, with NO work loss: imports the branch +
#       objects into the canonical bare, rewrites the worktree's .git pointer, and
#       verifies health. The old (quarantined) bare is left untouched — its
#       elimination is a separate, confirm-gated step.
#
# Confirm-destructive discipline (Emperor rule): this tool NEVER removes a
# worktree or a bare repo. Enumerate, then remove by hand after confirmation.

set -euo pipefail

_BIN_DIR="$(dirname "$(readlink -f "$0")")"
_LIB_DIR="${_BIN_DIR}/../lib"
# shellcheck source=/dev/null
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
log_info()  { echo -e "${BLUE}→${NC} $1" >&2; }
log_ok()    { echo -e "${GREEN}✓${NC} $1" >&2; }
log_warn()  { echo -e "${YELLOW}!${NC} $1" >&2; }
log_err()   { echo -e "${RED}✗${NC} $1" >&2; }

PROJECT="Token-OS"

usage() {
    sed -n '2,40p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

# Resolve BARE_REPO / WORKTREE_PARENT from the project config.
load_project_conf() {
    local conf="$HOME/.config/worktrees/${PROJECT}.conf"
    [[ -f "$conf" ]] || { log_err "Project config not found: $conf"; exit 1; }
    # shellcheck source=/dev/null
    source "$conf"
    CANON_BARE="${CD_BARE_REPO:-${BARE_REPO:-}}"
    CANON_BARE="$(eval echo "$CANON_BARE")"
    WORKTREE_PARENT="$(eval echo "${WORKTREE_PARENT:-}")"
    [[ -n "$CANON_BARE" ]] || { log_err "No BARE_REPO/CD_BARE_REPO in $conf"; exit 1; }
    if declare -f imperium_path_is_quarantined >/dev/null 2>&1 \
            && imperium_path_is_quarantined "$CANON_BARE"; then
        log_err "Configured canonical bare is itself quarantined: $CANON_BARE — refusing."
        exit 64
    fi
}

# True if a path is a recycle-bin / dated-legacy archive (uses the shared helper
# when sourced; a conservative inline fallback otherwise).
is_quarantined() {
    if declare -f imperium_path_is_quarantined >/dev/null 2>&1; then
        imperium_path_is_quarantined "$1"; return $?
    fi
    case "/${1#/}/" in
        *"/#recycle/"*|*"/.Trash/"*|*"/.Trashes/"*) return 0 ;;
        *.legacy-[0-9]*) return 0 ;;
    esac
    return 1
}

# ── enumerate ────────────────────────────────────────────────────────────────
cmd_enumerate() {
    load_project_conf
    log_info "Enumerating worktrees (canonical bare: $CANON_BARE)"
    echo ""
    printf '%-58s %-34s %-7s %-12s %-10s %s\n' \
        "WORKTREE" "BRANCH/HEAD" "BARE" "DIRTY/AHEAD" "LASTCOMMIT" "STATUS"
    printf '%s\n' "$(printf '─%.0s' {1..150})"

    # Collect candidate worktree paths: linked worktrees of the canonical bare +
    # any dir directly under WORKTREE_PARENT. De-dup, keep stable order.
    local -a paths=()
    local p
    while IFS= read -r p; do [[ -n "$p" ]] && paths+=("$p"); done < <(
        git --git-dir="$CANON_BARE" worktree list --porcelain 2>/dev/null \
            | awk '/^worktree /{print substr($0,10)}'
    )
    if [[ -n "${WORKTREE_PARENT:-}" && -d "$WORKTREE_PARENT" ]]; then
        while IFS= read -r p; do
            [[ -n "$p" ]] || continue
            local seen=false q
            for q in "${paths[@]:-}"; do [[ "$q" == "$p" ]] && seen=true && break; done
            $seen || paths+=("$p")
        done < <(find "$WORKTREE_PARENT" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort)
    fi

    local quarantined_count=0 on_main_count=0 total=0
    for p in "${paths[@]:-}"; do
        [[ -e "$p/.git" || -d "$p/.git" ]] || continue
        total=$((total+1))
        local common branch head dirty ahead lastc summary baretag
        common="$(git -C "$p" rev-parse --git-common-dir 2>/dev/null || echo '?')"
        # normalize to absolute for the quarantine check
        case "$common" in /*) : ;; *) common="$(cd "$p" && cd "$common" 2>/dev/null && pwd || echo "$common")" ;; esac
        if is_quarantined "$common"; then baretag="LEGACY"; quarantined_count=$((quarantined_count+1));
        elif [[ "$common" == "$CANON_BARE" ]]; then baretag="canon";
        else baretag="other"; fi
        branch="$(git -C "$p" symbolic-ref -q --short HEAD 2>/dev/null || true)"
        head="$(git -C "$p" rev-parse --short HEAD 2>/dev/null || echo '?')"
        if [[ -z "$branch" ]]; then branch="(detached $head)"; else
            [[ "$branch" == "main" || "$branch" == "master" ]] && on_main_count=$((on_main_count+1)); fi
        local dn; dn="$(git -C "$p" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
        dirty=$([[ "$dn" == "0" ]] && echo "clean" || echo "${dn} chg")
        ahead="$(git -C "$p" rev-list --count "@{u}..HEAD" 2>/dev/null || echo '-')"
        lastc="$(git -C "$p" log -1 --format=%cd --date=short 2>/dev/null || echo '?')"
        summary="$(git -C "$p" status --porcelain 2>/dev/null | head -1 | cut -c1-40)"
        printf '%-58s %-34s %-7s %-12s %-10s %s\n' \
            "${p/#$HOME/\~}" "$branch" "$baretag" "${dirty}/+${ahead}" "$lastc" "$summary"
    done
    echo ""
    log_info "Total: $total worktree(s); on main/master: $on_main_count; LEGACY-bound (quarantined bare): $quarantined_count"
    if (( quarantined_count > 0 )); then
        log_warn "LEGACY-bound worktrees resolve into a purge target — reanchor them, then confirm-remove the legacy bare (Emperor-gated)."
    fi
}

# ── park ─────────────────────────────────────────────────────────────────────
cmd_park() {
    local wt="${1:-}"
    [[ -n "$wt" && -e "$wt/.git" ]] || { log_err "park: not a worktree: $wt"; exit 1; }
    load_project_conf
    local branch head
    branch="$(git -C "$wt" symbolic-ref -q --short HEAD 2>/dev/null || true)"
    head="$(git -C "$wt" rev-parse HEAD 2>/dev/null || true)"
    [[ -n "$head" ]] || { log_err "park: cannot resolve HEAD in $wt"; exit 1; }

    if [[ -z "$(git -C "$wt" status --porcelain 2>/dev/null)" ]]; then
        log_info "park: $wt is clean; detaching off ${branch:-detached} at ${head:0:9}"
        git -C "$wt" checkout --detach >/dev/null 2>&1 || { log_err "park: detach failed"; exit 1; }
        log_ok "Parked (clean) $wt"
        return 0
    fi

    # Dirty: preserve to a collision-safe wip/ branch before detaching.
    local ts wip base suffix=0
    ts="$(date +%Y%m%d-%H%M%S)"
    base="wip/park-${branch:-detached}-${ts}-$$"
    base="${base//[^a-zA-Z0-9._\/-]/_}"
    wip="$base"
    while git --git-dir="$CANON_BARE" show-ref --verify --quiet "refs/heads/${wip}"; do
        suffix=$((suffix+1)); wip="${base}-${suffix}"
    done
    log_warn "park: $wt is dirty — preserving WIP to ${wip} before detaching"
    git -C "$wt" status --short >&2 || true
    # Commit the dirt onto a new branch, push to canonical bare + origin, then
    # detach so the working tree keeps the same files but is no longer on the branch.
    local cur_branch_existed=true
    [[ -n "$branch" ]] || cur_branch_existed=false
    git -C "$wt" checkout -b "$wip" >/dev/null 2>&1 || { log_err "park: failed to create $wip"; exit 1; }
    git -C "$wt" add -A || { log_err "park: failed to stage"; exit 1; }
    git -C "$wt" -c user.name="worktree-hygiene" -c user.email="hygiene@token-os.local" \
        commit -q -m "wip(park): preserve dirty worktree $(basename "$wt") at ${ts}" \
        || { log_err "park: commit failed"; exit 1; }
    local wip_sha; wip_sha="$(git -C "$wt" rev-parse HEAD)"
    git -C "$wt" push "$CANON_BARE" "refs/heads/${wip}:refs/heads/${wip}" >/dev/null 2>&1 \
        && log_ok "park: pushed ${wip} → canonical bare" \
        || log_warn "park: could not push ${wip} to canonical bare"
    git -C "$wt" push origin "refs/heads/${wip}:refs/heads/${wip}" >/dev/null 2>&1 \
        && log_ok "park: pushed ${wip} → origin (durable)" \
        || log_warn "park: could not push ${wip} to origin"
    git -C "$wt" checkout --detach "$wip_sha" >/dev/null 2>&1 || { log_err "park: final detach failed"; exit 1; }
    log_ok "Parked $wt — WIP preserved on ${wip} (${wip_sha:0:9}); worktree detached"
}

# ── reanchor ─────────────────────────────────────────────────────────────────
cmd_reanchor() {
    local wt="${1:-}"
    [[ -n "$wt" && -e "$wt/.git" ]] || { log_err "reanchor: not a worktree: $wt"; exit 1; }
    load_project_conf
    local common; common="$(git -C "$wt" rev-parse --git-common-dir 2>/dev/null || true)"
    [[ -n "$common" ]] || { log_err "reanchor: cannot resolve git-common-dir for $wt"; exit 1; }
    case "$common" in /*) : ;; *) common="$(cd "$wt" && cd "$common" && pwd)" ;; esac
    if [[ "$common" == "$CANON_BARE" ]]; then
        log_ok "reanchor: $wt already bound to canonical bare — nothing to do"; return 0
    fi
    is_quarantined "$common" \
        || log_warn "reanchor: current bare is not flagged quarantined ($common) — proceeding anyway"

    local branch head id admin
    branch="$(git -C "$wt" symbolic-ref -q --short HEAD 2>/dev/null || true)"
    head="$(git -C "$wt" rev-parse HEAD 2>/dev/null || true)"
    id="$(basename "$(git -C "$wt" rev-parse --git-dir 2>/dev/null)")"
    [[ -n "$head" && -n "$id" ]] || { log_err "reanchor: cannot resolve HEAD/id in $wt"; exit 1; }
    [[ -n "$branch" ]] || { log_err "reanchor: $wt is detached — re-create from canonical bare instead"; exit 1; }

    # Refuse if the canonical bare already has this branch checked out elsewhere.
    local existing
    existing="$(git --git-dir="$CANON_BARE" worktree list --porcelain 2>/dev/null \
        | awk -v b="refs/heads/$branch" '/^worktree /{p=substr($0,10)} /^branch /{if(substr($0,8)==b)print p}')"
    if [[ -n "$existing" && "$existing" != "$wt" ]]; then
        log_err "reanchor: canonical bare already has '$branch' at $existing — resolve the duplicate first"; exit 1
    fi

    log_info "reanchor: importing $branch (${head:0:9}) objects into canonical bare"
    git --git-dir="$CANON_BARE" fetch -q "$common" "refs/heads/${branch}:refs/heads/${branch}" 2>/dev/null \
        || git --git-dir="$CANON_BARE" fetch -q "$common" "${head}" 2>/dev/null || true
    if ! git --git-dir="$CANON_BARE" cat-file -e "$head" 2>/dev/null; then
        log_err "reanchor: canonical bare lacks object ${head:0:9} after import (try: fetch origin first)"; exit 1
    fi
    git --git-dir="$CANON_BARE" update-ref "refs/heads/${branch}" "$head"

    admin="$CANON_BARE/worktrees/$id"
    if [[ -e "$admin" ]]; then admin="${admin}-reanchor-$$"; id="$(basename "$admin")"; fi
    mkdir -p "$admin"
    cp "$common/worktrees/$(basename "$(git -C "$wt" rev-parse --git-dir)")/HEAD" "$admin/HEAD" 2>/dev/null \
        || printf 'ref: refs/heads/%s\n' "$branch" > "$admin/HEAD"
    local legacy_admin; legacy_admin="$(git -C "$wt" rev-parse --git-dir)"
    [[ -f "$legacy_admin/index" ]] && cp "$legacy_admin/index" "$admin/index"
    printf '../..\n' > "$admin/commondir"
    printf '%s\n' "$wt/.git" > "$admin/gitdir"

    # Backup then repoint the worktree's .git pointer.
    cp "$wt/.git" "$wt/.git.pre-reanchor.bak" 2>/dev/null || true
    printf 'gitdir: %s\n' "$admin" > "$wt/.git"

    # Verify health; restore on failure.
    local new_common new_head
    new_common="$(git -C "$wt" rev-parse --git-common-dir 2>/dev/null || true)"
    new_head="$(git -C "$wt" rev-parse HEAD 2>/dev/null || true)"
    if [[ "$new_common" == "$CANON_BARE" && "$new_head" == "$head" ]] && git -C "$wt" status >/dev/null 2>&1; then
        rm -f "$wt/.git.pre-reanchor.bak"
        git --git-dir="$CANON_BARE" worktree repair "$wt" >/dev/null 2>&1 || true
        log_ok "reanchor: $wt now bound to canonical bare (branch $branch, ${head:0:9}); edits preserved"
        log_info "Old quarantined registration remains at $common/worktrees/$(basename "$legacy_admin") — confirm-remove the legacy bare later."
    else
        [[ -f "$wt/.git.pre-reanchor.bak" ]] && mv "$wt/.git.pre-reanchor.bak" "$wt/.git"
        rm -rf "$admin"
        log_err "reanchor: verification failed (common=$new_common head=$new_head) — restored original pointer"; exit 1
    fi
}

# ── dispatch ─────────────────────────────────────────────────────────────────
[[ $# -ge 1 ]] || usage 1
SUB="$1"; shift || true
# parse a trailing --project for subcommands that take it
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --project) PROJECT="${2:?--project needs a value}"; shift 2 ;;
        -h|--help) usage 0 ;;
        *) ARGS+=("$1"); shift ;;
    esac
done
case "$SUB" in
    enumerate|list|enum) cmd_enumerate ;;
    park)                cmd_park "${ARGS[@]:-}" ;;
    reanchor)            cmd_reanchor "${ARGS[@]:-}" ;;
    -h|--help|help)      usage 0 ;;
    *) log_err "Unknown subcommand: $SUB"; usage 1 ;;
esac
