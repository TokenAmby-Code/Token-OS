#!/usr/bin/env bash
# Install/repair vendor-front-door shims so absolute claude/codex invocations
# enter Token-OS wrappers. Existing vendor target is preserved as *.token-os-real.
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="${SCRIPT_DIR}/${SCRIPT_PATH}"
done
BIN_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

install_one() {
  # Note: each `local` is on its own line. A single multi-assignment such as
  # `local engine="$1" tracked="$BIN_DIR/$engine"` expands every RHS before the
  # builtin runs, so `$engine` is still unset there and `set -u` aborts.
  local engine="$1"
  local front="$2"
  local tracked="$BIN_DIR/$engine"
  local real="${front}.token-os-real"
  [[ -e "$front" || -L "$front" || -e "$real" || -L "$real" ]] || {
    echo "skip $engine: $front does not exist" >&2
    return 0
  }
  if [[ ! -e "$real" && ! -L "$real" ]]; then
    if [[ -f "$front" ]] && grep -q 'TOKEN_API_AGENT_WRAPPER_BYPASS' "$front" 2>/dev/null; then
      echo "skip $engine: $front already looks like a Token-OS shim and no real target exists at $real" >&2
      return 0
    fi
    if [[ -e "$front" || -L "$front" ]]; then
      mv "$front" "$real"
    fi
  fi
  mkdir -p "$(dirname "$front")"
  cat >"$front" <<SHIM
#!/usr/bin/env bash
set -euo pipefail
if [[ "\${TOKEN_API_AGENT_WRAPPER_BYPASS:-}" == "1" ]]; then
  real="$real"
  if [[ ! -x "\$real" ]]; then
    echo "$engine real binary not found: \$real" >&2
    exit 127
  fi
  unset TOKEN_API_AGENT_WRAPPER_BYPASS
  exec "\$real" "\$@"
fi
exec "$tracked" "\$@"
SHIM
  chmod 0755 "$front"
  echo "installed $engine shim: $front -> $tracked (real: $real)"
}

# Front-door paths are overridable (CLAUDE_FRONT_DOOR / CODEX_FRONT_DOOR) so the
# installer can be exercised end-to-end against a sandbox in tests without
# touching the real vendor binaries.
install_one claude "${CLAUDE_FRONT_DOOR:-$HOME/.local/bin/claude}"
if [[ -n "${CODEX_FRONT_DOOR:-}" ]]; then
  _codex_front="$CODEX_FRONT_DOOR"
elif [[ -e "$HOME/.local/bin/codex" || -L "$HOME/.local/bin/codex" || -e "$HOME/.local/bin/codex.token-os-real" || -L "$HOME/.local/bin/codex.token-os-real" ]]; then
  _codex_front="$HOME/.local/bin/codex"
else
  _codex_front="/opt/homebrew/bin/codex"
fi
install_one codex "$_codex_front"
