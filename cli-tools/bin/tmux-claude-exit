#!/usr/bin/env bash
# tmux-claude-exit вҖ” Gracefully exit Claude Code and stage resume command
# TAGS: tmux, claude, exit, resume, keybind
# AUDIENCE: human
#
# Sends Ctrl+C x3 to kill the current Claude session, then captures
# the resume command from Claude's exit output, stages it in shell
# history, and clears the terminal.
#
# Usage:
#     tmux-claude-exit              # Current pane
#     tmux-claude-exit --pane %4    # Target a specific pane

set -euo pipefail

PANE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pane) PANE="$2"; shift 2 ;;
        -h|--help) sed -n '2,/^$/s/^# //p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
done

# Resolve target pane вҖ” run-shell doesn't set $TMUX_PANE but does set
# the target for display-message. Prefix with % since display-message
# inside run-shell strips the % from #{pane_id}.
if [[ -z "$PANE" ]]; then
    _id=$(tmux display-message -p '#{pane_id}' 2>/dev/null) || true
    if [[ -n "$_id" && "$_id" != %* ]]; then
        PANE="%${_id}"
    elif [[ -n "$_id" ]]; then
        PANE="$_id"
    fi
fi

# Helper: run tmux command with -t pane targeting after the subcommand
# e.g. _tmux send-keys C-c вҶ’ tmux send-keys -t %3 C-c
_tmux() {
    local subcmd="$1"; shift
    if [[ -n "$PANE" ]]; then
        tmux "$subcmd" -t "$PANE" "$@"
    else
        tmux "$subcmd" "$@"
    fi
}

# Send Ctrl+C three times with small delays
for i in 1 2 3; do
    _tmux send-keys C-c
    sleep 0.2
done

# Wait for Claude to print its exit output (resume command)
sleep 1

# Capture the resume command from Claude's exit output.
# Handles line-wrapping (panes are often 47-50 chars wide) and
# rejects RHS noise (pane borders, /buddy panel text).
RESUME_CMD=$(tmux capture-pane -p -t "$PANE" -S -20 2>/dev/null | python3 -c '
import sys, re

lines = sys.stdin.read().split("\n")
box_chars = set("в”Ӯв•ӯв•®в•°в•Ҝв”Ңв”җв””в”ҳв”ңв”Өв”¬в”ҙв”јв”Җв•ӯв•®в•Ҝв•°")

for i in range(len(lines) - 1, -1, -1):
    line = lines[i]
    if any(c in box_chars for c in line):
        continue
    if "claude --resume" not in line:
        continue

    m = re.search(r"claude --resume\s+(.*)$", line)
    if not m:
        continue

    arg = m.group(1).strip()
    cmd = "claude --resume " + arg

    # Detect truncation: unclosed quote or partial UUID
    needs_next = False
    if arg.startswith(chr(34)) and not arg.endswith(chr(34)):
        needs_next = True
    elif re.match(r"^[a-f0-9-]+$", arg) and len(arg) < 36:
        needs_next = True

    if needs_next and i + 1 < len(lines):
        nxt = lines[i + 1].strip()
        if nxt and not any(c in box_chars for c in nxt) and not re.match(r"^(tokenclaw|\$|%)", nxt):
            cmd = cmd + nxt

    print(cmd)
    sys.exit(0)
' 2>/dev/null)

if [[ -z "$RESUME_CMD" ]]; then
    RESUME_CMD="claude --resume"
fi

# Stage resume command in shell history, then clear
PANE_SHELL=$(_tmux display-message -p '#{pane_current_command}' 2>/dev/null || echo "")
case "$PANE_SHELL" in
    *zsh*)  _tmux send-keys "print -s $(printf '%q' "$RESUME_CMD") && clear" Enter ;;
    *)      _tmux send-keys "history -s $(printf '%q' "$RESUME_CMD") && clear" Enter ;;
esac
