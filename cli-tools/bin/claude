#!/usr/bin/env bash
set -euo pipefail
SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="${SCRIPT_DIR}/${SCRIPT_PATH}"
done
BIN_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
WRAPPER="${BIN_DIR}/../scripts/claude-wrapper.sh"

if [[ "${TOKEN_API_AGENT_WRAPPER_BYPASS:-}" == "1" ]]; then
  for candidate in \
    "${CLAUDE_WRAPPER_TARGET:-}" \
    "${CLAUDE_BIN:-}" \
    "$HOME/.local/bin/claude.token-os-real"
  do
    [[ -n "$candidate" && -x "$candidate" ]] || continue
    unset TOKEN_API_AGENT_WRAPPER_BYPASS
    exec "$candidate" "$@"
  done
  echo "claude real binary not found for TOKEN_API_AGENT_WRAPPER_BYPASS" >&2
  exit 127
fi

exec "$WRAPPER" "$@"
