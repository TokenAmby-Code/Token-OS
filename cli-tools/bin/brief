#!/usr/bin/env python3
# brief - One-shot inter-persona message primitive (fire-and-forget).
# TAGS: trinity, ipc, brief
# AUDIENCE: agent
"""Fire-and-forget inter-persona message delivery.

Usage:
    brief --pane <id> "message"               # one pane
    brief --pane <id> --pane <id2> "..."      # multiple panes (deduped)
    brief --page <name|index|all> "..."       # whole page/window
    brief --pane <id> --page palace "..."     # mixed (deduped across)
    brief --ephemeral --pane <id> "..."       # side-channel (/btw or /side)
    brief --json --pane <id> "..."            # machine-readable JSON

Pane addressing accepts public ids (``somnium:SE``) or full triples
(``main:2:SE``). Raw tmux ``%NNN`` ids are internal-only and are never printed
back. Page names map to tmux window names:
``palace``, ``somnium``, ``council``, ``mechanicus``, ``reservists``, ``all``,
or a window index like ``2``.

Duplicate prevention: a pane targeted by both ``--pane`` and a ``--page``
that contains it receives the brief once.

Spec: Mars/Tasks/trinity-chunk-1-talk-cli.md
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import uuid
import urllib.error
import urllib.request

TOKEN_API_URL = os.environ.get("TOKEN_API_URL", "http://localhost:7777")


def _err(msg: str) -> None:
    print(f"brief: {msg}", file=sys.stderr)


def _post(path: str, body: dict, timeout: float = 60.0) -> dict:
    url = f"{TOKEN_API_URL}{path}"
    data = json.dumps(body).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read().decode("utf-8"))


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        prog="brief",
        description="Fire-and-forget inter-persona message delivery.",
        add_help=True,
    )
    parser.add_argument(
        "--pane",
        action="append",
        default=[],
        help="Target pane (repeatable; public {page}:{id} id)",
    )
    parser.add_argument(
        "--page",
        action="append",
        default=[],
        help="Target page/window (repeatable; palace|somnium|council|mechanicus|reservists|all|<index>)",
    )
    parser.add_argument(
        "--ephemeral",
        action="store_true",
        help="Use the side-channel (/btw or /side) — no context burn on target",
    )
    parser.add_argument(
        "--caller",
        default=None,
        help="Caller pane id (defaults to $TMUX_PANE)",
    )
    parser.add_argument(
        "--json",
        dest="json_out",
        action="store_true",
        help="Emit JSON result instead of human text",
    )
    parser.add_argument("message", help="The message body")
    args = parser.parse_args(argv)

    if not args.pane and not args.page:
        parser.error("at least one --pane or --page is required")

    body = {
        "caller_pane": args.caller or os.environ.get("TMUX_PANE"),
        "panes": args.pane,
        "pages": args.page,
        "payload": args.message,
        "ephemeral": args.ephemeral,
        "message_id": os.environ.get("TOKEN_MESSAGE_ID") or str(uuid.uuid4()),
    }
    try:
        result = _post("/api/brief/send", body, timeout=60.0)
    except urllib.error.HTTPError as exc:
        try:
            detail = json.loads(exc.read().decode("utf-8")).get("detail", str(exc))
        except Exception:
            detail = str(exc)
        _err(f"send failed: {detail}")
        return 1
    except urllib.error.URLError as exc:
        _err(f"Token-API unreachable at {TOKEN_API_URL}: {exc.reason}")
        return 1

    if args.json_out:
        print(json.dumps(result, indent=2, sort_keys=True))
        return 0 if result.get("status") == "ok" else 1

    status = result.get("status")
    resolved = result.get("resolved", []) or []
    unresolved = result.get("unresolved", []) or []

    if status == "no_targets":
        _err("no targets resolved" + (f" (unresolved: {unresolved})" if unresolved else ""))
        return 1

    # Report the TRUE send result, not a never-satisfied verification: only a
    # confirmed "sent" counts as delivered. A "pending" target was accepted but
    # NOT yet delivered (gated by quiet hours / typing guard, or deferred) and
    # is surfaced distinctly so a queued brief never reads as a delivery.
    def _is_blocked(row: dict) -> bool:
        status_text = str(row.get("status") or "").lower()
        reason_text = str(row.get("reason") or row.get("error") or "").lower()
        return (
            status_text in {"blocked", "cancelled", "canceled", "gated"}
            or "typing_guard" in reason_text
            or "send_gated" in reason_text
            or "user_input_pending" in reason_text
        )

    sent = sum(1 for r in resolved if r.get("status") == "sent")
    blocked = sum(1 for r in resolved if _is_blocked(r))
    pending = sum(1 for r in resolved if r.get("status") == "pending" and not _is_blocked(r))

    targets = ", ".join(
        f"{r.get('position_id') or r.get('pane_id')}"
        for r in resolved
    )
    eph = " (ephemeral)" if args.ephemeral else ""
    suffix_parts = []
    if pending:
        suffix_parts.append(f"{pending} pending — not yet delivered")
    if blocked:
        suffix_parts.append(f"{blocked} blocked — not delivered")
    suffix = f" ({'; '.join(suffix_parts)})" if suffix_parts else ""
    print(f"[brief{eph}] delivered={sent}/{len(resolved)}{suffix} → {targets}")
    for r in resolved:
        st = r.get("status")
        label = r.get("position_id") or r.get("pane_id")
        if st == "sent":
            continue
        if _is_blocked(r):
            _err(f"  {label}: blocked ({r.get('reason') or r.get('error') or 'typing_guard'}) — not delivered")
        elif st == "pending":
            _err(f"  {label}: pending ({r.get('reason') or 'queued'}) — not yet delivered")
        else:
            _err(f"  {label}: status={st} error={r.get('error') or ''}")
    if unresolved:
        for u in unresolved:
            _err(f"  unresolved {u.get('source')}={u.get('spec')} ({u.get('reason')})")
    return 0 if (sent + pending) > 0 else 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
