#!/usr/bin/env bash
# tts - Send a TTS message via Token-API and fail closed on non-delivery
# TAGS: token-api
# AUDIENCE: agent
#
# Usage:
#   tts "Your spoken message here"
#   tts --instance-id <id> "Your spoken message"
#   tts --direct "Your spoken message"   # Do not auto-resolve an instance profile
#   tts --sync "Your spoken message"     # Default; wait for delivery verdict
#   tts --async "Your spoken message"    # Fire-and-forget; exit only means request spawned
#   tts --verbose "Your spoken message"  # Print Token-API JSON response
#   tts --enforcement "Close the app"     # Mark as live enforcement; bypass persona_silent
#
# Routes through /api/notify, the authoritative comms router. Exit 0 means the
# response reported audible delivery. Transport acceptance, queue acceptance, or
# a backgrounded curl process is not treated as delivered.
#
# The message is passed as all positional arguments after any flags, so quoting
# is optional: tts Hello world works too.
#
# JSON is built with jq so special characters (em dashes, curly quotes,
# backslashes, etc.) are escaped correctly without manual quoting tricks.

set -euo pipefail

source "$(dirname "$(readlink -f "$0")")/../lib/nas-path.sh" 2>/dev/null || true

API_URL="${TOKEN_API_URL:-http://localhost:7777}"

# Defaults
INSTANCE_ID=""
SYNC=true
DIRECT=false
VERBOSE=false
ENFORCEMENT=false

usage() {
    awk '/^#!/{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
    exit 0
}

# --- Instance resolution (shared pattern with instance-name, voice-chat) ---

_find_claude_pid() {
    local current="$PPID"
    local comm
    for _ in 1 2 3 4 5; do
        [[ -z "$current" || "$current" == "1" ]] && break
        comm=$(ps -o comm= -p "$current" 2>/dev/null || true)
        if [[ "$comm" == "claude" ]]; then
            echo "$current"
            return 0
        fi
        current=$(ps -o ppid= -p "$current" 2>/dev/null | tr -d ' ' || true)
    done
    return 1
}

_resolve_instance_id() {
    local INSTANCE_ID=""
    local INSTANCES=""

    # Method 1: PID-based cache
    local CLAUDE_PID
    CLAUDE_PID=$(_find_claude_pid 2>/dev/null || true)
    if [[ -n "$CLAUDE_PID" ]]; then
        local SESSION_PID_FILE="${HOME}/.claude/session-pids/${CLAUDE_PID}"
        if [[ -f "$SESSION_PID_FILE" ]]; then
            INSTANCE_ID=$(cat "$SESSION_PID_FILE" 2>/dev/null || true)
        fi
    fi

    # Method 2: PID field match in API
    if [[ -z "$INSTANCE_ID" && -n "${CLAUDE_PID:-}" ]]; then
        INSTANCES=$(curl -s --connect-timeout 3 "$API_URL/api/instances" 2>/dev/null || true)
        if [[ -n "$INSTANCES" ]]; then
            INSTANCE_ID=$(echo "$INSTANCES" | \
                jq -r --argjson pid "$CLAUDE_PID" \
                    '.[] | select(.pid == $pid and (.status == "processing" or .status == "idle")) | .id' 2>/dev/null | \
                head -1 || true)
        fi
    fi

    # Method 3: CWD match
    if [[ -z "$INSTANCE_ID" ]]; then
        local CWD
        CWD="$(pwd)"
        INSTANCES="${INSTANCES:-$(curl -s --connect-timeout 3 "$API_URL/api/instances" 2>/dev/null || true)}"
        if [[ -n "$INSTANCES" ]]; then
            INSTANCE_ID=$(echo "$INSTANCES" | \
                jq -r --arg cwd "$CWD" \
                    '[ .[] | select(.status == "processing" and .working_dir == $cwd) ] | .[0].id // ""' \
                    2>/dev/null || true)
            if [[ -z "$INSTANCE_ID" ]]; then
                INSTANCE_ID=$(echo "$INSTANCES" | \
                    jq -r --arg cwd "$CWD" \
                        '[ .[] | select(.status == "idle" and .working_dir == $cwd) ] | .[0].id // ""' \
                        2>/dev/null || true)
            fi
        fi
    fi

    echo "$INSTANCE_ID"
}

_delivery_ok() {
    jq -e '(.delivered == true) or (.audio_delivered == true) or (.tts.audio_delivered == true)' >/dev/null 2>&1
}

_failure_reason() {
    jq -r '
        .reason
        // .tts.reason
        // .tts.error
        // .error
        // (if .suppressed == true then "suppressed" else empty end)
        // "tts_delivery_failed"
    ' 2>/dev/null || printf 'tts_delivery_failed\n'
}

# Parse flags
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        --instance-id)
            INSTANCE_ID="$2"
            shift 2
            ;;
        --sync)
            SYNC=true
            shift
            ;;
        --async|--fire-and-forget)
            SYNC=false
            shift
            ;;
        --direct)
            DIRECT=true
            shift
            ;;
        --verbose)
            VERBOSE=true
            shift
            ;;
        --enforcement)
            ENFORCEMENT=true
            shift
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo "tts: unknown flag: $1" >&2
            echo "Run 'tts --help' for usage." >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

# Everything remaining is the message
MESSAGE="$*"

if [[ -z "$MESSAGE" ]]; then
    echo "tts: message required" >&2
    echo "Usage: tts \"Your spoken message\"" >&2
    exit 1
fi

# Resolve instance ID if not explicitly provided. --direct disables auto profile
# resolution but still uses /api/notify; there is no Mac/direct playback fallback.
if [[ -z "$INSTANCE_ID" && "$DIRECT" == "false" ]]; then
    INSTANCE_ID=$(_resolve_instance_id)
fi

ENDPOINT="/api/notify"
if [[ -n "$INSTANCE_ID" ]]; then
    JSON=$(jq -cn \
        --arg msg "$MESSAGE" \
        --arg iid "$INSTANCE_ID" \
        --argjson enforcement "$ENFORCEMENT" \
        '{"message": $msg, "instance_id": $iid, "tts": true, "enforcement": $enforcement} + (if $enforcement then {"context":{"kind":"enforcement"}} else {} end)')
else
    JSON=$(jq -cn \
        --arg msg "$MESSAGE" \
        --argjson enforcement "$ENFORCEMENT" \
        '{"message": $msg, "tts": true, "enforcement": $enforcement} + (if $enforcement then {"context":{"kind":"enforcement"}} else {} end)')
fi

if [[ "$SYNC" == "false" ]]; then
    # Explicitly unsafe for delivery truth: this only means the request process was spawned.
    curl -sf -X POST "${API_URL}${ENDPOINT}" \
        -H "Content-Type: application/json" \
        -d "$JSON" \
        >/dev/null 2>&1 &
    disown
    exit 0
fi

response=""
if ! response=$(curl -sS -f -X POST "${API_URL}${ENDPOINT}" \
    -H "Content-Type: application/json" \
    -d "$JSON"); then
    echo "tts: Token-API request failed" >&2
    exit 1
fi

if [[ "$VERBOSE" == "true" ]]; then
    printf '%s\n' "$response"
fi

if printf '%s' "$response" | _delivery_ok; then
    exit 0
fi

reason=$(printf '%s' "$response" | _failure_reason)
echo "tts: audio not delivered: ${reason}" >&2
exit 1
