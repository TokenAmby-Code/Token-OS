#!/usr/bin/env bash
# obsidian - Cross-platform Obsidian vault CLI
# TAGS: vault, obsidian
# AUDIENCE: human, agent
#
# Works on:
#   - WSL: proxies to Obsidian.exe (1.12 native CLI)
#   - macOS / Linux / VPS: filesystem-based implementation
#
# Usage:
#   obsidian vault=<name> read path="<note>.md"
#   obsidian vault=<name> search query="<term>"
#   obsidian vault=<name> search:context query="<term>"
#   obsidian vault=<name> backlinks path="<note>.md"
#   obsidian vault=<name> create path="<path>.md" content="..."
#   obsidian vault=<name> append path="<path>.md" content="..."
#   obsidian vault=<name> property:set path="<path>.md" property="key" value="val"
#   obsidian vault=<name> property:read path="<path>.md" property="key"
#   obsidian vault=<name> orphans
#   obsidian vault=<name> move path="<old>.md" to="<new>.md"
#   obsidian vault=<name> daily:read
#   obsidian vault=<name> open path="<note>.md"
#   obsidian vault=<name> session-docs <get|create|replace|append|move|delete> request=<base64-json>
#   obsidian session-docs fetch <session-doc-name>

set -euo pipefail

# --- Platform detection ---
detect_platform() {
  if [[ -f /proc/version ]] && grep -qi microsoft /proc/version 2>/dev/null; then
    echo "wsl"
  elif [[ "$(uname)" == "Darwin" ]]; then
    echo "macos"
  else
    echo "linux"
  fi
}

PLATFORM=$(detect_platform)

# Ordinary operations default to the curated ENV vault. Session-document
# operations default to Logs. Tests and isolated callers may supply both roots.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [[ -z "${IMPERIUM_VAULT:-}" || -z "${IMPERIUM_LOGS_VAULT:-}" ]]; then
  source "$SCRIPT_DIR/../lib/nas-path.sh" 2>/dev/null || true
fi

vault_pair_is_valid() {
  [[ -n "${IMPERIUM_VAULT:-}" && -n "${IMPERIUM_LOGS_VAULT:-}" ]] || return 1
  [[ "$(basename "$IMPERIUM_VAULT")" == "Imperium-ENV" ]] || return 1
  [[ "$(basename "$IMPERIUM_LOGS_VAULT")" == "Imperium-Logs" ]] || return 1
  [[ "$(dirname "$IMPERIUM_VAULT")" == "$(dirname "$IMPERIUM_LOGS_VAULT")" ]]
}

# --- WSL: proxy to Obsidian.exe if available ---
if [[ "$PLATFORM" == "wsl" ]]; then
  OBSIDIAN_EXE="/mnt/c/Users/colby/AppData/Local/Programs/obsidian/Obsidian.exe"
  if [[ -x "$OBSIDIAN_EXE" ]]; then
    exec "$OBSIDIAN_EXE" "$@" 2>&1 | grep -v "^[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\} [0-9]\{2\}:[0-9]\{2\}:[0-9]\{2\} Loading"
  fi
fi

# --- Vault resolution ---
resolve_vault() {
  local vault_name="$1"

  # Token API may supply an explicit managed root for an isolated test vault.
  # Do not treat arbitrary absolute paths as vaults: the only permitted roots
  # are the two roots configured for the managed session-doc boundary.
  if [[ "$vault_name" == /* ]]; then
    local allowed resolved candidate
    resolved=$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$vault_name")
    for candidate in "${IMPERIUM_ENV:-}" "${IMPERIUM_LOGS_ENV:-}" "${CIVIC_ENV:-}" "${IMPERIUM_VAULT:-}" "${IMPERIUM_LOGS_VAULT:-}"; do
      [[ -z "$candidate" ]] && continue
      allowed=$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$candidate")
      if [[ "$resolved" == "$allowed" && -d "$resolved" ]]; then
        echo "$resolved"
        return 0
      fi
    done
    echo "Error: explicit vault root is not a configured managed vault" >&2
    return 1
  fi

  if [[ "$vault_name" == "Imperium-ENV" || "$vault_name" == "Imperium-Logs" ]]; then
    vault_pair_is_valid || { echo "Error: Imperium ENV/Logs roots must be a colocated pair" >&2; return 1; }
    local selected="$IMPERIUM_VAULT"
    [[ "$vault_name" == "Imperium-Logs" ]] && selected="$IMPERIUM_LOGS_VAULT"
    [[ -d "$selected" ]] || { echo "Error: local vault '$vault_name' not found at $selected" >&2; return 1; }
    echo "$selected"
    return 0
  fi

  # Civic remains separately configured; Imperium vaults never probe NAS paths.
  if [[ -d "/Volumes/Civic/$vault_name" ]]; then
    echo "/Volumes/Civic/$vault_name"
    return 0
  fi
  if [[ -d "/mnt/civic/$vault_name" ]]; then
    echo "/mnt/civic/$vault_name"
    return 0
  fi

  # Check home directory
  if [[ -d "$HOME/$vault_name" ]]; then
    echo "$HOME/$vault_name"
    return 0
  fi

  # WSL: fallback to Windows documents
  if [[ "$PLATFORM" == "wsl" && -d "/mnt/c/Users/colby/Documents/Obsidian/$vault_name" ]]; then
    echo "/mnt/c/Users/colby/Documents/Obsidian/$vault_name"
    return 0
  fi

  echo "Error: vault '$vault_name' not found" >&2
  return 1
}

# --- Parse args: extract named params ---
VAULT_NAME=""
COMMAND=""
PARAM_path=""
PARAM_query=""
PARAM_content=""
PARAM_property=""
PARAM_value=""
PARAM_to=""
PARAM_request=""
SESSION_DOCS_OP=""
SESSION_DOCS_TARGET=""
ORIGINAL_ARGS=("$@")

# Human-facing session-document commands always use the Logs vault. The legacy
# `vault=<name> session-docs … request=<base64-json>` protocol remains valid.
[[ "${1:-}" == "session-docs" ]] && VAULT_NAME="Imperium-Logs"

for arg in "$@"; do
  if [[ "$arg" == vault=* ]]; then
    VAULT_NAME="${arg#vault=}"
  elif [[ "$arg" == path=* ]]; then
    val="${arg#path=}"; val="${val#\"}"; val="${val%\"}"; val="${val#\'}"; val="${val%\'}"
    PARAM_path="$val"
  elif [[ "$arg" == query=* ]]; then
    val="${arg#query=}"; val="${val#\"}"; val="${val%\"}"; val="${val#\'}"; val="${val%\'}"
    PARAM_query="$val"
  elif [[ "$arg" == content=* ]]; then
    val="${arg#content=}"; val="${val#\"}"; val="${val%\"}"; val="${val#\'}"; val="${val%\'}"
    PARAM_content="$val"
  elif [[ "$arg" == property=* ]]; then
    val="${arg#property=}"; val="${val#\"}"; val="${val%\"}"; val="${val#\'}"; val="${val%\'}"
    PARAM_property="$val"
  elif [[ "$arg" == value=* ]]; then
    val="${arg#value=}"; val="${val#\"}"; val="${val%\"}"; val="${val#\'}"; val="${val%\'}"
    PARAM_value="$val"
  elif [[ "$arg" == to=* ]]; then
    val="${arg#to=}"; val="${val#\"}"; val="${val%\"}"; val="${val#\'}"; val="${val%\'}"
    PARAM_to="$val"
  elif [[ "$arg" == request=* ]]; then
    PARAM_request="${arg#request=}"
  elif [[ "$COMMAND" == "session-docs" && -z "$SESSION_DOCS_OP" && "$arg" != *=* ]]; then
    SESSION_DOCS_OP="$arg"
  elif [[ "$COMMAND" == "session-docs" && -n "$SESSION_DOCS_OP" && -z "$SESSION_DOCS_TARGET" && "$arg" != *=* ]]; then
    SESSION_DOCS_TARGET="$arg"
  elif [[ -z "$COMMAND" && "$arg" != *=* ]]; then
    COMMAND="$arg"
  fi
done

if [[ -z "$VAULT_NAME" ]]; then
  VAULT_NAME="Imperium-ENV"
fi

VAULT_ROOT=$(resolve_vault "$VAULT_NAME")

resolve_path() {
  local p="$1"
  [[ "$p" != *.md ]] && p="${p}.md"
  echo "$VAULT_ROOT/$p"
}

# --- Same-machine flock for daily-note writes ---
# Mutating commands that touch the daily note must serialize against token-api's
# in-process writers (timer frontmatter + NOW callout). vault_lock.py derives the
# sidecar lockfile from the same code token-api uses, so the two never disagree.
LOCK_HELPER="${TOKEN_OS:-$HOME/runtimes/Token-OS/live}/token-api/vault_lock.py"

needs_lock() {
  # True when the resolved path is the daily note (Emperor's stated scope;
  # trivially broadened later by adding more path prefixes here).
  [[ "$1" == */Terra/Journal/Daily/* ]]
}

# --- Commands ---

cmd_read() {
  local path
  path=$(resolve_path "$PARAM_path")
  if [[ ! -f "$path" ]]; then
    echo "Error: note not found: $path" >&2
    return 1
  fi
  cat "$path"
}

cmd_search() {
  if [[ -z "$PARAM_query" ]]; then
    echo "Error: query= is required" >&2
    return 1
  fi
  find "$VAULT_ROOT" -name "*.md" -not -path "*/.trash/*" -not -path "*/.obsidian/*" \
    | while read -r f; do
        local bn="${f##*/}"
        bn="${bn%.md}"
        if echo "$bn" | grep -qi "$PARAM_query" 2>/dev/null; then
          echo "${f#$VAULT_ROOT/}"
        fi
      done | sort
}

cmd_search_context() {
  if [[ -z "$PARAM_query" ]]; then
    echo "Error: query= is required" >&2
    return 1
  fi
  grep -rni --include="*.md" "$PARAM_query" "$VAULT_ROOT" \
    --exclude-dir=".obsidian" --exclude-dir=".trash" \
    -C 2 2>/dev/null \
    | sed "s|$VAULT_ROOT/||g" || true
}

cmd_backlinks() {
  if [[ -z "$PARAM_path" ]]; then
    echo "Error: path= is required" >&2
    return 1
  fi
  local note_name="${PARAM_path##*/}"
  note_name="${note_name%.md}"
  grep -rn --include="*.md" "\[\[$note_name\]\]\|\[\[$note_name|" "$VAULT_ROOT" \
    --exclude-dir=".obsidian" --exclude-dir=".trash" 2>/dev/null \
    | sed "s|$VAULT_ROOT/||g" || true
  if [[ "$PARAM_path" == */* ]]; then
    local path_no_ext="${PARAM_path%.md}"
    grep -rn --include="*.md" "\[\[$path_no_ext\]\]\|\[\[$path_no_ext|" "$VAULT_ROOT" \
      --exclude-dir=".obsidian" --exclude-dir=".trash" 2>/dev/null \
      | sed "s|$VAULT_ROOT/||g" || true
  fi
}

cmd_create() {
  local path
  path=$(resolve_path "$PARAM_path")

  if [[ -f "$path" ]]; then
    echo "Error: note already exists: $path" >&2
    return 1
  fi

  mkdir -p "$(dirname "$path")"
  printf '%s\n' "$PARAM_content" > "$path"
  echo "Created: ${path#$VAULT_ROOT/}"
}

cmd_append() {
  local path
  path=$(resolve_path "$PARAM_path")

  if [[ ! -f "$path" ]]; then
    echo "Error: note not found: $path" >&2
    return 1
  fi

  printf '\n%s\n' "$PARAM_content" >> "$path"
  echo "Appended to: ${path#$VAULT_ROOT/}"
}

cmd_property_set() {
  local path
  path=$(resolve_path "$PARAM_path")

  if [[ ! -f "$path" ]]; then
    echo "Error: note not found: $path" >&2
    return 1
  fi

  if [[ -z "$PARAM_property" ]]; then
    echo "Error: property= is required" >&2
    return 1
  fi

  python3 -c "
import sys

filepath, prop, val = sys.argv[1], sys.argv[2], sys.argv[3]

with open(filepath, 'r') as f:
    content = f.read()

if not content.startswith('---'):
    content = '---\n' + prop + ': ' + val + '\n---\n' + content
else:
    end = content.index('---', 3)
    fm = content[4:end]
    rest = content[end+3:]
    lines = fm.strip().split('\n')
    found = False
    new_lines = []
    for line in lines:
        if line.startswith(prop + ':'):
            new_lines.append(f'{prop}: {val}')
            found = True
        else:
            new_lines.append(line)
    if not found:
        new_lines.append(f'{prop}: {val}')
    content = '---\n' + '\n'.join(new_lines) + '\n---' + rest

with open(filepath, 'w') as f:
    f.write(content)
print(f'Set {prop}={val} in {filepath.split(\"/\")[-1]}')
" "$path" "$PARAM_property" "$PARAM_value"
}

cmd_property_read() {
  local path
  path=$(resolve_path "$PARAM_path")

  if [[ ! -f "$path" ]]; then
    echo "Error: note not found: $path" >&2
    return 1
  fi

  python3 -c "
import sys
filepath, prop = sys.argv[1], sys.argv[2]
with open(filepath, 'r') as f:
    content = f.read()
if not content.startswith('---'):
    sys.exit(1)
end = content.index('---', 3)
fm = content[4:end]
for line in fm.strip().split('\n'):
    if line.startswith(prop + ':'):
        print(line[len(prop)+1:].strip())
        sys.exit(0)
sys.exit(1)
" "$path" "$PARAM_property"
}

cmd_orphans() {
  find "$VAULT_ROOT" -name "*.md" -not -path "*/.trash/*" -not -path "*/.obsidian/*" -not -path "*/Templates/*" \
    | while read -r note; do
        local bn="${note##*/}"
        bn="${bn%.md}"
        local count
        count=$(grep -rl --include="*.md" "\[\[$bn\]\]\|\[\[$bn|" "$VAULT_ROOT" \
          --exclude-dir=".obsidian" --exclude-dir=".trash" 2>/dev/null \
          | grep -cv "^$note$" 2>/dev/null || echo 0)
        if [[ "$count" -eq 0 ]]; then
          echo "${note#$VAULT_ROOT/}"
        fi
      done
}

cmd_move() {
  local old_path new_path
  old_path=$(resolve_path "$PARAM_path")
  new_path=$(resolve_path "$PARAM_to")

  if [[ ! -f "$old_path" ]]; then
    echo "Error: source not found: $old_path" >&2
    return 1
  fi

  mkdir -p "$(dirname "$new_path")"
  mv "$old_path" "$new_path"
  echo "Moved: ${old_path#$VAULT_ROOT/} -> ${new_path#$VAULT_ROOT/}"
}

cmd_daily_read() {
  local today
  today=$(date +%Y-%m-%d)
  PARAM_path="Terra/Journal/Daily/$today.md"
  cmd_read
}

# Open a note in the Obsidian app. Mac uses the obsidian:// URI scheme
# (launches the app or focuses the already-open window). Linux/VPS have no
# Obsidian app, so this errors. WSL is handled above by the Obsidian.exe proxy.
cmd_open() {
  if [[ -z "$PARAM_path" ]]; then
    echo "Error: path= is required" >&2
    return 1
  fi
  local rel="${PARAM_path%.md}"
  local uri
  uri=$(python3 -c "
import sys, urllib.parse
vault = urllib.parse.quote(sys.argv[1])
path  = urllib.parse.quote(sys.argv[2])
print(f'obsidian://open?vault={vault}&file={path}')
" "$VAULT_NAME" "$rel")

  case "$PLATFORM" in
    macos) open "$uri" ;;
    linux) echo "Error: obsidian open not supported on $PLATFORM (no app)" >&2; return 1 ;;
    *)     echo "Error: obsidian open not implemented for $PLATFORM" >&2; return 1 ;;
  esac
}

# Managed session-document boundary.  Token API uses this JSON protocol instead
# of filesystem calls so revision checks and path confinement are identical for
# every session lifecycle writer.  The native-container facade may replace this
# implementation, but its public contract is deliberately small and stable.
cmd_session_docs() {
  local op="${1:-}"
  if [[ -z "$op" || -z "$PARAM_request" ]]; then
    echo '{"ok":false,"error":{"code":"invalid_request","message":"operation and request= are required"}}' >&2
    return 2
  fi

  # All session-document mutations share one sidecar lock for this vault.  The
  # lock is acquired before the Python protocol performs any existence or
  # revision check, and stays held until its JSON receipt is generated.
  case "$op" in
    create|replace|append|move|delete|set-status)
      if [[ -z "${SESSION_DOCS_LOCK_HELD:-}" && -f "$LOCK_HELPER" ]]; then
        exec python3 "$LOCK_HELPER" "$VAULT_ROOT" -- env SESSION_DOCS_LOCK_HELD=1 "$0" "${ORIGINAL_ARGS[@]}"
      fi
      ;;
  esac
  python3 - "$VAULT_ROOT" "$op" "$PARAM_request" <<'PY'
import base64, hashlib, json, os, sys
from pathlib import Path

root = Path(sys.argv[1]).resolve()
op = sys.argv[2]
try:
    request = json.loads(base64.b64decode(sys.argv[3]).decode("utf-8"))
except Exception as exc:
    print(json.dumps({"ok": False, "error": {"code": "invalid_request", "message": str(exc)}}))
    raise SystemExit(2)

def fail(code, message, **extra):
    print(json.dumps({"ok": False, "error": {"code": code, "message": message, **extra}}))
    raise SystemExit(3 if code == "revision_conflict" else 2)

def path_for(value):
    if not isinstance(value, str) or not value:
        fail("invalid_path", "path is required")
    candidate = (root / value).resolve()
    if candidate == root or root not in candidate.parents or candidate.suffix != ".md":
        fail("invalid_path", "path must be a vault-relative markdown path")
    return candidate

def revision(content):
    return hashlib.sha256(content.encode("utf-8")).hexdigest()

def result(path, content=None, **extra):
    data = {"path": str(path.relative_to(root))}
    if content is not None:
        data.update({"content": content, "revision": revision(content)})
    data.update(extra)
    print(json.dumps({"ok": True, "data": data}))

path = path_for(request.get("path"))
if op == "get":
    if not path.is_file(): fail("not_found", "note not found")
    result(path, path.read_text(encoding="utf-8"))
elif op == "create":
    if path.exists(): fail("already_exists", "note already exists")
    content = request.get("content")
    if not isinstance(content, str): fail("invalid_request", "content must be a string")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    result(path, content, created=True)
elif op in ("replace", "append"):
    if not path.is_file(): fail("not_found", "note not found")
    current = path.read_text(encoding="utf-8")
    expected = request.get("expected_revision")
    actual = revision(current)
    if expected is not None and expected != actual:
        fail("revision_conflict", "note changed since it was read", expected_revision=expected, actual_revision=actual)
    content = request.get("content")
    if not isinstance(content, str): fail("invalid_request", "content must be a string")
    updated = content if op == "replace" else current + content
    path.write_text(updated, encoding="utf-8")
    result(path, updated)
elif op == "move":
    if not path.is_file(): fail("not_found", "note not found")
    target = path_for(request.get("to"))
    if target.exists(): fail("already_exists", "destination already exists")
    target.parent.mkdir(parents=True, exist_ok=True)
    path.rename(target)
    result(target, target.read_text(encoding="utf-8"), moved_from=str(path.relative_to(root)))
elif op == "delete":
    if not path.is_file(): fail("not_found", "note not found")
    path.unlink()
    result(path, deleted=True)
elif op == "set-status":
    if not path.is_file(): fail("not_found", "note not found")
    status = request.get("status")
    if not isinstance(status, str) or not status:
        fail("invalid_request", "status must be a non-empty string")
    current = path.read_text(encoding="utf-8")
    expected = request.get("expected_revision")
    actual = revision(current)
    if expected is not None and expected != actual:
        fail("revision_conflict", "note changed since it was read", expected_revision=expected, actual_revision=actual)
    if not current.startswith("---") or "\n---" not in current[3:]:
        fail("invalid_frontmatter", "managed session doc has no frontmatter")
    head, tail = current[3:].split("\n---", 1)
    lines = head.splitlines()
    replaced = False
    for index, line in enumerate(lines):
        if line.startswith("status:"):
            lines[index] = f"status: {status}"
            replaced = True
            break
    if not replaced: lines.append(f"status: {status}")
    updated = "---" + "\n".join(lines) + "\n---" + tail
    path.write_text(updated, encoding="utf-8")
    result(path, updated, status=status)
else:
    fail("invalid_operation", f"unsupported session-docs operation: {op}")
PY
}

cmd_session_docs_fetch() {
  local target="${1:-}" env_root
  if [[ -z "$target" || "$target" == */* || "$target" == "." || "$target" == ".." ]]; then
    echo "fetch requires a session-document filename, not a path" >&2
    return 2
  fi
  [[ "$target" == *.md ]] || target="$target.md"
  env_root="$(resolve_vault "Imperium-ENV")"

  python3 - "$VAULT_ROOT" "$env_root" "$target" <<'PY'
from __future__ import annotations

from datetime import UTC, datetime, timedelta
from pathlib import Path
import sys

logs_root = Path(sys.argv[1]).resolve()
env_root = Path(sys.argv[2]).resolve()
filename = sys.argv[3]
search_roots = (logs_root / "Sessions", logs_root / "Terra" / "Sessions", logs_root / "Mars" / "Sessions")
matches = []
for directory in search_roots:
    if directory.is_dir():
        matches.extend(path for path in directory.rglob(filename) if path.is_file() and ".obsidian" not in path.parts)
matches = sorted(set(matches))
if not matches:
    raise SystemExit(f"session document not found in Imperium-Logs: {filename}")
if len(matches) != 1:
    rendered = ", ".join(str(path.relative_to(logs_root)) for path in matches)
    raise SystemExit(f"ambiguous session document '{filename}': {rendered}")

source = matches[0]
source_rel = source.relative_to(logs_root)
destination = env_root / "Embassy" / source_rel
destination.parent.mkdir(parents=True, exist_ok=True)
content = source.read_text(encoding="utf-8")
now = datetime.now(UTC)
metadata = {
    "embassy": "true",
    "embassy_source_vault": "Imperium-Logs",
    "embassy_source_path": str(source_rel),
    "embassy_fetched_at": now.isoformat(),
    "embassy_expires_at": (now + timedelta(hours=1)).isoformat(),
}

if content.startswith("---\n"):
    end = content.find("\n---", 4)
    if end != -1:
        frontmatter, body = content[4:end], content[end + 4:]
        retained = [line for line in frontmatter.splitlines() if line.split(":", 1)[0] not in metadata]
        content = "---\n" + "\n".join(retained + [f"{key}: {value}" for key, value in metadata.items()]) + "\n---" + body
    else:
        content = "---\n" + "\n".join(f"{key}: {value}" for key, value in metadata.items()) + "\n---\n\n" + content
else:
    content = "---\n" + "\n".join(f"{key}: {value}" for key, value in metadata.items()) + "\n---\n\n" + content

temporary = destination.with_suffix(destination.suffix + ".tmp")
temporary.write_text(content, encoding="utf-8")
temporary.replace(destination)
print(destination.relative_to(env_root))
PY
}

# --- Auto-flock daily-note mutations ---
# Re-exec the whole invocation under vault_lock.py so the flock is held for the
# real write, then set OBSIDIAN_LOCK_HELD=1 to prevent infinite re-exec. Graceful
# degrade: if the helper is absent (WSL/VPS with no token-api), skip locking and
# write directly — cross-machine is out of scope and Obsidian Sync merges there.
case "$COMMAND" in
  append|create|property:set|move)
    if [[ -z "${OBSIDIAN_LOCK_HELD:-}" && -n "$PARAM_path" ]]; then
      resolved=$(resolve_path "$PARAM_path")
      if needs_lock "$resolved" && [[ -f "$LOCK_HELPER" ]]; then
        exec python3 "$LOCK_HELPER" "$resolved" -- env OBSIDIAN_LOCK_HELD=1 "$0" "$@"
      fi
    fi
    ;;
esac

# --- Dispatch ---
case "$COMMAND" in
  session-docs)
    if [[ "$SESSION_DOCS_OP" == "fetch" ]]; then
      cmd_session_docs_fetch "$SESSION_DOCS_TARGET"
    else
      cmd_session_docs "$SESSION_DOCS_OP"
    fi
    ;;
  read)           cmd_read ;;
  search)         cmd_search ;;
  search:context) cmd_search_context ;;
  backlinks)      cmd_backlinks ;;
  create)         cmd_create ;;
  append)         cmd_append ;;
  property:set)   cmd_property_set ;;
  property:read)  cmd_property_read ;;
  orphans)        cmd_orphans ;;
  move)           cmd_move ;;
  daily:read)     cmd_daily_read ;;
  open)           cmd_open ;;
  ""|help|-h|--help)
    awk '/^#!/{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
    ;;
  *)
    echo "Error: unknown command '$COMMAND'" >&2
    echo "Commands: read, search, search:context, backlinks, create, append, property:set, property:read, orphans, move, daily:read, open, session-docs" >&2
    echo "Session docs: obsidian session-docs fetch <session-doc-name>" >&2
    exit 1
    ;;
esac
