#!/usr/bin/env bash
# tmux-audit — Workspace state coherence checker
# TAGS: tmux, lifecycle, audit
# AUDIENCE: system (called by tmux-shuttle, tx, dispatch, and stale-check fallback)
#
# Single sweeper that validates system-level assertions about workspace state.
# Event-driven primary (called after pane-interactive ops) with a lazy stale
# fallback. Each assertion is a self-contained function.
#
# Assertions:
#   backburner  — No extra idle shells in stack windows
#   grid        — Palace (6 panes) and somnium (5 panes) grids have expected pane counts
#   tui         — TUI monitor panes are alive, not dead/stuck
#   layout      — Pane proportions haven't drifted
#
# Usage:
#   tmux-audit                   # Run all assertions (debounced)
#   tmux-audit --force           # Skip debounce
#   tmux-audit --stale N         # Only run if last audit was > N minutes ago
#   tmux-audit --only backburner # Run a single assertion

set -eo pipefail

STAMP_FILE="/tmp/.tmux-audit-last-run"
DEBOUNCE_SECONDS=5
SESSION="main"

# --- Args ---
FORCE=false
STALE_MINUTES=""
ONLY=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --force) FORCE=true; shift ;;
        --stale) STALE_MINUTES="$2"; shift 2 ;;
        --only)  ONLY="$2"; shift 2 ;;
        *) shift ;;
    esac
done

# --- Stale check ---
if [[ -n "$STALE_MINUTES" && -f "$STAMP_FILE" ]]; then
    last_run=$(cat "$STAMP_FILE" 2>/dev/null || echo "0")
    now=$(date +%s)
    elapsed=$(( (now - last_run) / 60 ))
    if [[ $elapsed -lt $STALE_MINUTES ]]; then
        exit 0
    fi
fi

# --- Debounce ---
if [[ "$FORCE" != "true" && -f "$STAMP_FILE" ]]; then
    last_run=$(cat "$STAMP_FILE" 2>/dev/null || echo "0")
    now=$(date +%s)
    if [[ $(( now - last_run )) -lt $DEBOUNCE_SECONDS ]]; then
        exit 0
    fi
fi

date +%s > "$STAMP_FILE"

# --- Guard: tmux must be running ---
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    exit 0
fi

# ============================================================
# ASSERTION: backburner
# No extra idle shells in stack windows. The first legion/mechanicus panes are
# orchestrator slots, not synthetic backstops; when promoted, those slots should
# be occupied by tombstones.
# ============================================================
assert_backburner() {
    local IDLE_SHELLS="bash zsh sh fish"

    is_idle_shell() {
        local cmd="$1"
        for s in $IDLE_SHELLS; do
            [[ "$cmd" == "$s" ]] && return 0
        done
        return 1
    }

    for win in legion mechanicus mars kreig; do
        local pane_data
        pane_data=$(tmux list-panes -t "${SESSION}:${win}" \
            -F '#{pane_id}	#{pane_current_command}	#{@PANE_TYPE}	#{@PANE_ID}' 2>/dev/null) || continue

        local idle_panes=() real_panes=()

        while IFS=$'\t' read -r pid cmd ptype pane_label; do
            [[ -z "$pid" ]] && continue
            if [[ "$ptype" == "tombstone" ]]; then
                real_panes+=("$pid")
            elif is_idle_shell "$cmd"; then
                idle_panes+=("$pid")
            else
                real_panes+=("$pid")
            fi
        done <<< "$pane_data"

        local total=$(( ${#idle_panes[@]} + ${#real_panes[@]} ))
        local changed=false

        # Preserve the final pane in a stack window; it is the orchestrator slot
        # or its tombstone. Cull only surplus idle shells.
        for pid in "${idle_panes[@]}"; do
            [[ $total -le 1 ]] && continue
            tmux kill-pane -t "$pid" 2>/dev/null || true
            (( total-- )) || true
            changed=true
        done

        if [[ "$changed" == "true" ]]; then
            tmux select-layout -t "${SESSION}:${win}" tiled 2>/dev/null || true
        fi
    done
}

# ============================================================
# ASSERTION: grid
# Palace and somnium grids each have their expected pane count.
#   palace  → 4 panes (W | N/S | E)
#   somnium → 5 panes (W | N/NE/S/SE)
# ============================================================
assert_grid() {
    local win expected actual focused
    declare -A expected_for=(
        [palace]=4
        [somnium]=5
    )

    for win in palace somnium; do
        tmux list-panes -t "${SESSION}:${win}" -F '' 2>/dev/null || continue
        expected="${expected_for[$win]}"

        focused=$(tmux show-options -wv -t "${SESSION}:${win}" @FOCUS_GRID_ACTIVE 2>/dev/null || echo "false")
        if [[ "$focused" == "true" ]]; then
            # Grid focus stashes only grid siblings; side/tall panes remain visible.
            if [[ "$win" == "palace" ]]; then
                expected=3
            else
                expected=2
            fi
        fi

        actual=$(tmux list-panes -t "${SESSION}:${win}" -F '' 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$actual" -ne "$expected" ]]; then
            echo "grid: ${win} has $actual panes, expected $expected"
        fi
    done
}

# ============================================================
# ASSERTION: tui
# TUI monitor panes are alive (not remain-on-exit dead state).
# ============================================================
assert_tui() {
    while IFS=$'\t' read -r pid ptype dead win; do
        [[ "$ptype" != "tui" ]] && continue
        if [[ "$dead" == "1" ]]; then
            # Check dirty flag — if intentionally stopped, leave it
            local dirty
            dirty=$(tmux show-options -pv -t "$pid" @TUI_DIRTY 2>/dev/null || echo "false")
            if [[ "$dirty" != "true" ]]; then
                tmux respawn-pane -k -t "$pid" "tui-pane-guard" 2>/dev/null || true
                echo "tui: respawned dead TUI pane $pid in $win"
            fi
        fi
    done < <(tmux list-panes -s -t "$SESSION" \
        -F '#{pane_id}	#{@PANE_TYPE}	#{pane_dead}	#{window_name}' 2>/dev/null || true)
}

# ============================================================
# ASSERTION: layout
# Palace + somnium pane proportions haven't drifted from canonical sizing.
# Light check: only flags, doesn't auto-fix (refresh-layout is destructive
# if the user intentionally resized).
# ============================================================
assert_layout() {
    local win expanded focused
    for win in palace somnium; do
        tmux list-panes -t "${SESSION}:${win}" -F '' 2>/dev/null || continue

        expanded=$(tmux show-options -wv -t "${SESSION}:${win}" @GRID_EXPANDED 2>/dev/null || echo "none")
        if [[ "$expanded" != "none" && -n "$expanded" ]]; then
            continue
        fi

        focused=$(tmux show-options -wv -t "${SESSION}:${win}" @FOCUSED 2>/dev/null || echo "false")
        if [[ "$focused" == "true" ]]; then
            continue
        fi

        while IFS=$'\t' read -r pid w h state; do
            [[ "$state" != "small" ]] && continue
            if [[ "$w" -lt 10 || "$h" -lt 5 ]]; then
                echo "layout: ${win} grid pane $pid is ${w}x${h} — may need refresh"
            fi
        done < <(tmux list-panes -t "${SESSION}:${win}" \
            -F '#{pane_id}	#{pane_width}	#{pane_height}	#{@GRID_STATE}' 2>/dev/null || true)
    done
}

# ============================================================
# RUN ASSERTIONS
# ============================================================
run_assertion() {
    local name="$1"
    case "$name" in
        backburner) assert_backburner ;;
        grid)       assert_grid ;;
        tui)        assert_tui ;;
        layout)     assert_layout ;;
        *) echo "Unknown assertion: $name" ;;
    esac
}

if [[ -n "$ONLY" ]]; then
    run_assertion "$ONLY"
else
    assert_backburner
    assert_grid
    assert_tui
    assert_layout
fi
