#!/usr/bin/env bash
# tx — Clean top-level tmux wrapper for the Imperium workspace
# TAGS: tmux, workspace, wrapper
# AUDIENCE: human
#
# Wraps all major tmux functions into a single beginner-friendly command.
# Workspace creation/teardown lives in the Python tmuxctl planner; this script
# also routes to tmux-reset, tmux-grid-expand, tmux-resume, tmux-focus, and
# tmux-refresh-layout as needed.
#
# Usage:
#   tx                    # Show session status (or start if not in tmux)
#   tx start              # Create/attach to main workspace session
#   tx restart [-r]       # Kill session and recreate workspace (asks to confirm; -y/--force skips)
#   tx restart-pane       # Reset active pane to default state
#   tx restart-page       # Reset current window/page to default layout
#   tx exit               # Detach from tmux
#   tx status             # Show session/pane overview
#   tx reset              # Reset current window layout (menu)
#   tx expand             # Toggle expand/retract active pane
#   tx focus              # Drop side columns, keep 2×2 grid only
#   tx unfocus            # Restore side columns
#   tx resume [...]       # Inject prompt into Claude pane
#   tx inspect [...]      # Inspect typed workspace state
#   tx doctor             # Diagnose managed workspace drift
#   tx normalize [...]    # Reserved Python normalize path
#   tx refresh            # Reset panes to canonical proportions
#   tx list               # List all tmux sessions
#   tx kill [session]     # Kill a session (default: main)
#   tx mechanicus "prompt" # Dispatch background task (aliases: tx mech, tx mars)
#   tx legion bump        # Bump current pane to legion window
#   tx legion recall      # Recall pane from legion to somnium
#   tx legion focus       # Enforce focused regiment layout
#   tx help               # Show this help

set -euo pipefail

# Source machine identity (IMPERIUM_MACHINE, NAS paths, etc.)
_LIB_DIR="$(dirname "$(readlink -f "$0")")/../lib"
# shellcheck source=../lib/nas-path.sh
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true
# shellcheck source=../lib/pane-id.sh
source "${_LIB_DIR}/pane-id.sh" 2>/dev/null || true

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

log_info()    { echo -e "${CYAN}▸${RESET} $*" >&2; }
log_success() { echo -e "${GREEN}✓${RESET} $*" >&2; }
log_warn()    { echo -e "${YELLOW}▸${RESET} $*" >&2; }
log_error()   { echo -e "${RED}✗${RESET} $*" >&2; }

SESSION_NAME="main"

# --- Workspace flag detection ---
# Legacy workspace flags (now mapped to tx subcommands or removed).
# If someone does `tx --focus`, route to the right subcommand.
WORKSPACE_FLAGS=(--attach --portable --focus --unfocus --toggle-focus)

is_workspace_flag() {
    local flag="$1"
    for wf in "${WORKSPACE_FLAGS[@]}"; do
        [[ "$flag" == "$wf" ]] && return 0
    done
    return 1
}

# --- Check if inside tmux ---
in_tmux() { [[ -n "${TMUX:-}" ]]; }

tmuxctl_python() {
    local candidate
    for candidate in "${TMUXCTL_PYTHON:-}" python3.14 python3.13 python3.12 python3.11 python3; do
        [[ -n "$candidate" ]] || continue
        if command -v "$candidate" >/dev/null 2>&1 && "$candidate" -c 'from datetime import UTC' >/dev/null 2>&1; then
            command -v "$candidate"
            return 0
        fi
    done
    log_error "tmuxctl requires Python 3.11+ (datetime.UTC unavailable)"
    return 1
}

run_tmuxctl() {
    local py
    py=$(tmuxctl_python)
    PYTHONPATH="${_LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" "$py" -m tmuxctl.cli "$@"
}

workspace_needs_repair() {
    local session="${1:-$SESSION_NAME}"

    tmux has-session -t "$session" 2>/dev/null || return 1

    local window count roles expected role
    for window in palace somnium legion mechanicus; do
        if ! tmux list-windows -t "$session" -F '#W' 2>/dev/null | grep -Fxq "$window"; then
            return 0
        fi
    done

    count=$(tmux list-panes -t "${session}:palace" 2>/dev/null | wc -l | tr -d ' ')
    [[ "$count" == "4" ]] || return 0
    count=$(tmux list-panes -t "${session}:somnium" 2>/dev/null | wc -l | tr -d ' ')
    [[ "$count" == "5" ]] || return 0
    count=$(tmux list-panes -t "${session}:legion" 2>/dev/null | wc -l | tr -d ' ')
    [[ "$count" -ge 1 ]] || return 0
    count=$(tmux list-panes -t "${session}:mechanicus" 2>/dev/null | wc -l | tr -d ' ')
    [[ "$count" -ge 1 ]] || return 0

    roles=$(tmux list-panes -t "${session}:palace" -F '#{@PANE_ID}' 2>/dev/null || true)
    for expected in palace:W palace:N palace:S palace:E; do
        grep -Fxq "$expected" <<<"$roles" || return 0
    done

    roles=$(tmux list-panes -t "${session}:somnium" -F '#{@PANE_ID}' 2>/dev/null || true)
    for expected in somnium:W somnium:N somnium:S somnium:NE somnium:SE; do
        grep -Fxq "$expected" <<<"$roles" || return 0
    done

    role=$(tmux list-panes -t "${session}:legion" -F '#{@PANE_ID}' 2>/dev/null | head -1)
    [[ "$role" == "legion:custodes" ]] || return 0
    role=$(tmux list-panes -t "${session}:mechanicus" -F '#{@PANE_ID}' 2>/dev/null | head -1)
    [[ "$role" == "mechanicus:fabricator-general" ]] || return 0

    return 1
}

ensure_workspace_before_attach() {
    local session="${1:-$SESSION_NAME}"

    if ! tmux has-session -t "$session" 2>/dev/null; then
        return 0
    fi

    if workspace_needs_repair "$session"; then
        log_warn "Session '${session}' is not the managed full layout; rebuilding it."
        if ! run_tmuxctl restart --execute --session "$session"; then
            log_warn "Managed restart failed; replacing malformed session '${session}'."
            tmux kill-session -t "$session" 2>/dev/null || true
            run_tmuxctl create --session "$session"
        fi
    fi
}

# --- Help ---
show_help() {
    # Detect terminal width, default to 80
    local cols
    cols=$(tput cols 2>/dev/null || echo 80)

    if [[ $cols -lt 60 ]]; then
        # Compact layout for narrow terminals
        cat <<'EOF'
tx — tmux wrapper

SESSION
  tx              status / start
  tx start        create + attach
  tx restart (-r) kill + recreate (confirms; -y skips)
  tx restart-pane   reset pane
  tx restart-page   reset page
  tx exit         detach
  tx status       overview
  tx list         all sessions
  tx kill [name]  kill session

LAYOUT
  tx focus     drop side columns
  tx unfocus   restore sides
  tx expand    toggle pane size
  tx inspect   inspect typed state
  tx resolve ID resolve pane id (1:N, palace:N)
    restart-plan   inspect restart registry/restore plan
  tx doctor    diagnose drift
  tx normalize reserved Python path
  tx refresh   reset proportions
  tx reset     reset menu

AGENTS
  tx resume "prompt"
    inject into Claude pane
  tx resume --find-claude "..."
    auto-find Claude pane

MECHANICUS
  tx mech "prompt"   dispatch task
  tx mech status     list panes
  tx mech cleanup    kill dead

LEGION
  tx legion bump    move pane out
  tx legion recall  bring pane back
  tx legion focus   expand selected regiment
  tx legion status  list reservists
  tx legion cleanup kill dead

KEYBINDS (prefix = Ctrl-Space)
  h/j/k/l   navigate panes
  H/J/K/L   resize panes
  W         launch workspace
  R         reset workspace
  F         toggle focus
  e         expand/retract
  s         toggle status bar
  r         reload config
  Ctrl-k    scroll mode
EOF
    else
        # Full layout for wide terminals
        cat <<'EOF'
tx — Imperium tmux wrapper

Session:
  tx                  status, or start if no tmux
  tx start            create + attach workspace
  tx restart, tx -r   kill + recreate session (asks to confirm; -y/--force skips)
  tx restart-pane     reset active pane to default state
  tx restart-page     reset current window/page to default layout
  tx exit             detach (session stays alive)
  tx status           session/pane overview
  tx list             list all sessions
  tx kill [name]      kill session (default: main)

Layout:
  tx focus            drop side columns
  tx unfocus          restore side columns
  tx expand           toggle pane expand/retract
  tx inspect          inspect typed workspace state
  tx resolve ID       resolve stable pane id to live %pane
    restart-plan      inspect restart registry/restore plan
  tx doctor           diagnose managed workspace drift
  tx normalize        reserved Python normalize path
  tx refresh          reset canonical proportions
  tx reset            interactive reset menu

Agents:
  tx resume "prompt"  inject into Claude pane
    --find-claude     auto-detect Claude pane

Mechanicus:
  tx mechanicus "prompt"    dispatch task to new pane (aliases: tx mech, tx mars)
    --label name            custom label (auto-derived if omitted)
    --dir path              working directory (default: Imperium-ENV)
  tx mechanicus status      list all mechanicus panes
  tx mechanicus cleanup     kill dead panes, re-tile survivors
    --all                   kill ALL panes (including running)

Legion:
  tx legion bump [--pane %id]   move pane to legion (default: current)
  tx legion recall [--pane %id] move pane back to somnium
  tx legion focus [--pane %id]  expand selected regiment
  tx legion status              list all legion panes
  tx legion cleanup             kill dead panes
    --all                       kill ALL panes (including running)

Keybinds (prefix = Ctrl-Space):
  h/j/k/l     navigate    H/J/K/L  resize
  W  workspace   R  reset   F  focus
  e  expand      s  status  r  reload
  Ctrl-k  scroll/copy mode
EOF
    fi
}

# --- Subcommands ---

cmd_start() {
    if in_tmux; then
        log_warn "Already inside tmux (session: $(tmux display-message -p '#{session_name}'))"
        return 0
    fi

    if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
        ensure_workspace_before_attach "$SESSION_NAME"
        log_info "Attaching to existing session '${SESSION_NAME}'"
        exec env IMPERIUM_TMUX_RAW=1 tmux attach-session -t "$SESSION_NAME"
    fi

    log_info "Creating workspace session '${SESSION_NAME}'"
    run_tmuxctl create --session "$SESSION_NAME"
    exec env IMPERIUM_TMUX_RAW=1 tmux attach-session -t "$SESSION_NAME"
}

cmd_restart_pane() {
    # Reset the active pane to its default state (fresh shell + default command)
    if ! in_tmux; then
        log_error "Must be inside tmux to restart a pane."
        return 1
    fi

    local pane_id
    pane_id=$(tmux display-message -p '#{pane_id}')
    local grid_state
    grid_state=$(tmux show-options -pv -t "$pane_id" @GRID_STATE 2>/dev/null || echo "")
    local pane_type
    pane_type=$(tmux show-options -pv -t "$pane_id" @PANE_TYPE 2>/dev/null || echo "")

    # Kill current process and respawn a fresh shell
    tmux respawn-pane -k -t "$pane_id"

    log_success "Pane ${pane_id} restarted (${pane_type:-$grid_state})"
}

cmd_restart_page() {
    if ! in_tmux; then
        log_error "Must be inside tmux to restart a page."
        return 1
    fi
    run_tmuxctl rebuild-window --window current
}

cmd_restart() {
    local session="$SESSION_NAME"

    # --- Destructive-action guard -------------------------------------------
    # `tx restart` tears down and rebuilds the ENTIRE workspace — every pane and
    # every agent instance. It must never fire flippantly, and never from an
    # agent / hook / cron, which have repeatedly wiped live work unbidden.
    # Require an explicit interactive confirmation; FAIL CLOSED when there is no
    # controlling TTY (a tool-invoked Bash, a hook, a background job all lack
    # one). `--force`/`-y` is the deliberate escape hatch for scripted callers.
    local force=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -y|--yes|--force) force=1; shift ;;
            *) shift ;;
        esac
    done

    if [[ -z "$force" ]]; then
        if [[ ! -t 0 || ! -t 1 ]]; then
            log_error "tx restart wipes & rebuilds the whole '${session}' workspace (all panes/instances)."
            log_error "Refusing: no interactive terminal to confirm. Re-run with --force if you really mean it."
            return 1
        fi
        log_warn "tx restart will KILL and rebuild the entire '${session}' session — every pane and agent instance."
        printf "Type 'restart' to confirm: " >&2
        local reply=""
        read -r reply || true
        if [[ "$reply" != "restart" ]]; then
            log_info "Aborted — nothing was restarted."
            return 1
        fi
    fi
    # ------------------------------------------------------------------------

    # Snapshot active instances for resurrection. The Python executor handles
    # client park/detach/restore + teardown + rebuild + resume internally.
    tmux-resurrect snapshot 2>/dev/null || true

    if in_tmux; then
        local current_session group
        current_session=$(tmux display-message -p '#{session_name}')
        group=$(tmux display-message -p '#{session_group}')
        session="${group:-$current_session}"
    fi

    log_info "Restarting session '${session}' via tmuxctl…"

    if in_tmux; then
        # tmuxctl will detach this client; run it as a server background job so
        # the script doesn't die mid-restart with the parent client.
        local cli_dir
        cli_dir="$(dirname "$(readlink -f "$0")")"
        tmux run-shell -b "tmux-run bash -c '\"${cli_dir}/tx\" __tmuxctl_restart \"$session\"'"
        return 0
    fi

    run_tmuxctl restart --execute --session "$session" || true
    tmux-resurrect restore 2>/dev/null || true
    exec env IMPERIUM_TMUX_RAW=1 tmux attach-session -t "$SESSION_NAME"
}

# Internal: invoked by `tx restart` via run-shell -b inside tmux. Runs the
# Python restart, resurrects, then re-attaches whichever clients survived.
cmd_internal_tmuxctl_restart() {
    local session="$1"
    run_tmuxctl restart --execute --session "$session" || true
    tmux-resurrect restore 2>/dev/null || true
}

cmd_exit() {
    if ! in_tmux; then
        log_error "Not inside tmux — nothing to detach from."
        return 1
    fi
    tmux detach-client
}

cmd_status() {
    if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null && ! in_tmux; then
        log_warn "No tmux session running."
        echo ""
        echo -e "  Run ${BOLD}tx start${RESET} to create one."
        return 0
    fi

    local session="$SESSION_NAME"
    if in_tmux; then
        session=$(tmux display-message -p '#{session_name}')
    fi

    echo -e "${BOLD}Session:${RESET} ${session}"
    echo ""

    # List windows
    echo -e "${BOLD}Windows:${RESET}"
    tmux list-windows -t "$session" -F "  #I: #W (#{window_panes} panes)#{?window_active, ← active,}" 2>/dev/null || true
    echo ""

    # If inside tmux, show current window pane details
    if in_tmux; then
        local target window_name
        target="${session}:$(tmux display-message -p '#{window_index}')"
        window_name=$(tmux display-message -p '#{window_name}')
        local focused
        focused=$(tmux show-options -wv -t "$target" @FOCUSED 2>/dev/null || echo "false")
        local expanded
        expanded=$(tmux show-options -wv -t "$target" @GRID_EXPANDED 2>/dev/null || echo "none")

        echo -e "${BOLD}Current window:${RESET}"
        echo -e "  Window: ${window_name}  |  Focused: ${focused}  |  Expanded: ${expanded}"
        echo ""

        echo -e "${BOLD}Panes:${RESET}"
        tmux list-panes -t "$target" \
            -F "  #{pane_id}  #{@PANE_ID}  #{@GRID_STATE}  #{pane_width}x#{pane_height}  #{pane_current_command}#{?@GRID_RESERVED, [reserved],}" \
            2>/dev/null || true
    fi
}

cmd_list() {
    if ! tmux list-sessions 2>/dev/null; then
        log_warn "No tmux sessions running."
    fi
}

cmd_mechanicus() {
    local subcmd="${1:-status}"
    shift 2>/dev/null || true

    local TOKEN_API="${TOKEN_API_URL:-http://localhost:7777}"

    case "$subcmd" in
        # tx mechanicus "prompt text" — dispatch a single task
        status|cleanup)
            # handled below
            ;;
        *)
            # Anything else is a prompt — dispatch it
            local prompt="$subcmd${*:+ $*}"
            if [[ -z "$prompt" ]]; then
                log_error "Usage: tx mechanicus \"prompt text\" [--label name] [--dir path]"
                return 1
            fi

            # Parse optional flags from remaining args (already shifted once)
            local label="" working_dir="/Volumes/Imperium/Imperium-ENV"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --label) label="$2"; shift 2 ;;
                    --dir)   working_dir="$2"; shift 2 ;;
                    *)       prompt="$prompt $1"; shift ;;
                esac
            done

            # Auto-generate label from first few words if not provided
            if [[ -z "$label" ]]; then
                label=$(echo "$prompt" | tr -d '"'"'" | cut -c1-40 | tr ' ' '-' | tr '[:upper:]' '[:lower:]')
            fi

            log_info "Dispatching to mechanicus: ${label}"

            local payload
            payload=$(python3 -c "
import json, sys
print(json.dumps({
    'tasks': [{
        'label': sys.argv[1],
        'prompt': sys.argv[2],
        'working_dir': sys.argv[3],
        'source': 'tx-mechanicus'
    }]
}))
" "$label" "$prompt" "$working_dir")

            local result
            result=$(curl -s -X POST "${TOKEN_API}/api/kreig/dispatch" \
                -H "Content-Type: application/json" \
                -d "$payload" 2>/dev/null)

            if [[ $? -ne 0 ]] || [[ -z "$result" ]]; then
                log_error "Token-API not responding at ${TOKEN_API}"
                return 1
            fi

            local pane_id status_val
            pane_id=$(echo "$result" | python3 -c "import sys,json; r=json.load(sys.stdin)['results'][0]; print(r.get('pane_id',''))" 2>/dev/null)
            status_val=$(echo "$result" | python3 -c "import sys,json; r=json.load(sys.stdin)['results'][0]; print(r.get('status',''))" 2>/dev/null)

            if [[ "$status_val" == "launched" ]]; then
                log_success "Launched in pane ${pane_id}"
                # Rebalance the mechanicus window
                tmux select-layout -t "main:mechanicus" tiled 2>/dev/null || true
            else
                local err
                err=$(echo "$result" | python3 -c "import sys,json; r=json.load(sys.stdin)['results'][0]; print(r.get('error','unknown'))" 2>/dev/null)
                log_error "Dispatch failed: ${err}"
                return 1
            fi
            return 0
            ;;
    esac

    case "$subcmd" in
        status)
            local result
            result=$(curl -s "${TOKEN_API}/api/kreig/status" 2>/dev/null)
            if [[ $? -ne 0 ]] || [[ -z "$result" ]]; then
                log_error "Token-API not responding"
                return 1
            fi

            local total
            total=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['total'])" 2>/dev/null)

            if [[ "$total" == "0" ]]; then
                log_info "No mechanicus panes active."
                return 0
            fi

            echo -e "${BOLD}Mechanicus${RESET} (${total} panes):"
            echo ""
            echo "$result" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for p in data['panes']:
    status = '🟢 running' if p['claude_running'] else '⚪ idle'
    task = p.get('task') or '(no label)'
    inst = ''
    if p.get('instance'):
        i = p['instance']
        inst = f\" [{i.get('tab_name','')}]\"
    print(f\"  {p['pane_id']}  {status}  {task}{inst}\")
" 2>/dev/null
            ;;

        cleanup)
            local kill_all=""
            [[ "${1:-}" == "--all" ]] && kill_all='true'

            local body="{}"
            [[ -n "$kill_all" ]] && body='{"kill_all": true}'

            local result
            result=$(curl -s -X POST "${TOKEN_API}/api/kreig/cleanup" \
                -H "Content-Type: application/json" \
                -d "$body" 2>/dev/null)

            local killed surviving
            killed=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['killed'])" 2>/dev/null)
            surviving=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['surviving'])" 2>/dev/null)
            log_success "Cleaned up: ${killed} killed, ${surviving} surviving"
            ;;
    esac
}

cmd_legion() {
    local subcmd="${1:-status}"
    shift 2>/dev/null || true

    local TOKEN_API="${TOKEN_API_URL:-http://localhost:7777}"

    case "$subcmd" in
        bump)
            # Default to current pane
            local target_pane=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --pane) target_pane="$2"; shift 2 ;;
                    *)      shift ;;
                esac
            done

            if [[ -z "$target_pane" ]]; then
                if ! in_tmux; then
                    log_error "Must be inside tmux or specify --pane"
                    return 1
                fi
                target_pane=$(tmux display-message -p '#{pane_id}')
            fi

            local result
            result=$(curl -s -X POST "${TOKEN_API}/api/legion/bump" \
                -H "Content-Type: application/json" \
                -d "{\"pane_id\": \"${target_pane}\"}" 2>/dev/null)

            if [[ $? -ne 0 ]] || [[ -z "$result" ]]; then
                log_error "Token-API not responding at ${TOKEN_API}"
                return 1
            fi

            local status_val
            status_val=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))" 2>/dev/null)
            if [[ "$status_val" == "bumped" ]]; then
                log_success "Pane ${target_pane} bumped to legion"
            else
                local err
                err=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('error','unknown'))" 2>/dev/null)
                log_error "Bump failed: ${err}"
                return 1
            fi
            ;;

        recall)
            local target_pane=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --pane) target_pane="$2"; shift 2 ;;
                    *)      shift ;;
                esac
            done

            if [[ -z "$target_pane" ]]; then
                log_error "Usage: tx legion recall --pane %ID"
                return 1
            fi

            local result
            result=$(curl -s -X POST "${TOKEN_API}/api/legion/recall" \
                -H "Content-Type: application/json" \
                -d "{\"pane_id\": \"${target_pane}\"}" 2>/dev/null)

            if [[ $? -ne 0 ]] || [[ -z "$result" ]]; then
                log_error "Token-API not responding at ${TOKEN_API}"
                return 1
            fi

            local status_val
            status_val=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))" 2>/dev/null)
            if [[ "$status_val" == "recalled" ]]; then
                log_success "Pane ${target_pane} recalled to somnium"
            else
                local err
                err=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('error','unknown'))" 2>/dev/null)
                log_error "Recall failed: ${err}"
                return 1
            fi
            ;;

        status)
            local result
            result=$(curl -s "${TOKEN_API}/api/legion/status" 2>/dev/null)
            if [[ $? -ne 0 ]] || [[ -z "$result" ]]; then
                log_error "Token-API not responding"
                return 1
            fi

            local total
            total=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['total'])" 2>/dev/null)

            if [[ "$total" == "0" ]]; then
                log_info "No legion panes active."
                return 0
            fi

            echo -e "${BOLD}Legion${RESET} (${total} panes):"
            echo ""
            echo "$result" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for p in data['panes']:
    status = '🟢 running' if p['claude_running'] else '⚪ idle'
    inst = ''
    if p.get('instance'):
        i = p['instance']
        inst = f\" [{i.get('tab_name','')}]\"
    print(f\"  {p['pane_id']}  {status}{inst}\")
" 2>/dev/null
            ;;

        cleanup)
            local kill_all=""
            [[ "${1:-}" == "--all" ]] && kill_all='true'

            local body="{}"
            [[ -n "$kill_all" ]] && body='{"kill_all": true}'

            local result
            result=$(curl -s -X POST "${TOKEN_API}/api/legion/cleanup" \
                -H "Content-Type: application/json" \
                -d "$body" 2>/dev/null)

            local killed surviving
            killed=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['killed'])" 2>/dev/null)
            surviving=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['surviving'])" 2>/dev/null)
            log_success "Cleaned up: ${killed} killed, ${surviving} surviving"
            ;;

        focus)
            local target_pane=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --pane) target_pane="$2"; shift 2 ;;
                    *)      shift ;;
                esac
            done
            if [[ -z "$target_pane" ]]; then
                if ! in_tmux; then
                    log_error "Must be inside tmux or specify --pane"
                    return 1
                fi
                target_pane=$(tmux display-message -p '#{pane_id}')
            fi
            run_tmuxctl legion focus-selected --pane "$target_pane"
            ;;

        *)
            log_error "Unknown legion subcommand: ${subcmd}"
            echo -e "  Use: ${BOLD}tx legion bump|recall|focus|status|cleanup${RESET}" >&2
            return 1
            ;;
    esac
}

cmd_kill() {
    local target="${1:-$SESSION_NAME}"

    if ! tmux has-session -t "$target" 2>/dev/null; then
        log_error "No session '${target}' to kill."
        return 1
    fi

    # If we're inside the session we're killing, detach first
    if in_tmux; then
        local current
        current=$(tmux display-message -p '#{session_name}')
        if [[ "$current" == "$target" ]]; then
            log_info "Detaching before killing current session '${target}'..."
            # Use switch-client if other sessions exist, otherwise kill directly
            local session_count
            session_count=$(tmux list-sessions 2>/dev/null | wc -l)
            if [[ "$session_count" -gt 1 ]]; then
                tmux switch-client -n
            fi
        fi
    fi

    tmux kill-session -t "$target"
    log_success "Session '${target}' killed."
}

# --- Main dispatch ---

# No args: show status or start
if [[ $# -eq 0 ]]; then
    if in_tmux; then
        cmd_status
    else
        cmd_start
    fi
    exit 0
fi

CMD="$1"
shift

# Catch legacy workspace flags
if is_workspace_flag "$CMD"; then
    log_warn "'${CMD}' is not a tx flag."
    case "$CMD" in
        --focus)        echo -e "  Use: ${BOLD}tx focus${RESET}" >&2; exit 1 ;;
        --unfocus)      echo -e "  Use: ${BOLD}tx unfocus${RESET}" >&2; exit 1 ;;
        --toggle-focus) echo -e "  Use: ${BOLD}tx toggle-focus${RESET}" >&2; exit 1 ;;
        --attach)       echo -e "  Use: ${BOLD}tx start${RESET}" >&2; exit 1 ;;
        --portable)     echo -e "  Use: ${BOLD}tx portable${RESET}  (deprecated)" >&2; exit 1 ;;
        *)              echo -e "  See: ${BOLD}tx help${RESET}" >&2; exit 1 ;;
    esac
fi

# Catch raw tmux flags (e.g., `tx -t`, `tx attach`, `tx new-session`)
# that belong to the real tmux binary
case "$CMD" in
    attach|attach-session|new-session|new|switch-client|send-keys|display-message|split-window|select-pane|resize-pane|list-panes|list-windows|set-option|show-options|source-file|has-session|kill-pane|kill-window|kill-server|run-shell|copy-mode)
        log_warn "'${CMD}' is a raw tmux command."
        echo -e "  For raw tmux: ${BOLD}tmux ${CMD} $*${RESET}"
        echo -e "  For tx help:  ${BOLD}tx help${RESET}"
        exit 1
        ;;
esac

case "$CMD" in
    __tmuxctl_restart)
        cmd_internal_tmuxctl_restart "$@"
        ;;
    start)
        cmd_start "$@"
        ;;
    restart|-r)
        case "${1:-}" in
            --pane|--page)
                log_error "restart is reserved for full session rebuilds"
                echo -e "  Use: ${BOLD}tx restart-pane${RESET} or ${BOLD}tx restart-page${RESET}" >&2
                exit 1
                ;;
            *)
                cmd_restart "$@"
                ;;
        esac
        ;;
    restart-pane)
        cmd_restart_pane
        ;;
    restart-page)
        cmd_restart_page
        ;;
    exit|detach)
        cmd_exit
        ;;
    status)
        cmd_status
        ;;
    list|ls)
        cmd_list
        ;;
    kill)
        cmd_kill "$@"
        ;;
    reset)
        exec tmux-reset "$@"
        ;;
    expand)
        exec tmux-grid-expand "$@"
        ;;
    focus)
        if ! in_tmux; then
            log_error "Must be inside tmux to toggle focus."
            exit 1
        fi
        exec tmux-focus focus-grid
        ;;
    unfocus)
        if ! in_tmux; then
            log_error "Must be inside tmux to toggle unfocus."
            exit 1
        fi
        exec tmux-focus unfocus-grid
        ;;
    toggle-focus)
        if ! in_tmux; then
            log_error "Must be inside tmux to toggle focus."
            exit 1
        fi
        exec tmux-focus toggle
        ;;
    resume)
        exec tmux-resume "$@"
        ;;
    inspect)
        run_tmuxctl inspect "$@"
        ;;
    restart-plan)
        run_tmuxctl inspect restart-plan "$@"
        ;;
    resolve|resolve-pane)
        if [[ $# -eq 0 ]]; then
            log_error "Usage: tx resolve <pane-id>"
            exit 1
        fi
        run_tmuxctl resolve-pane --format id "$1"
        ;;
    doctor)
        run_tmuxctl doctor "$@"
        ;;
    normalize)
        run_tmuxctl normalize "$@"
        ;;
    resurrect)
        exec tmux-resurrect "$@"
        ;;
    mechanicus|mech|mars|kreig|kr)
        cmd_mechanicus "$@"
        ;;
    legion)
        cmd_legion "$@"
        ;;
    refresh)
        if [[ $# -gt 0 ]]; then
            run_tmuxctl normalize --window "$1"
        else
            run_tmuxctl normalize --window current
        fi
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        log_error "Unknown command: ${CMD}"
        echo ""
        echo -e "  Run ${BOLD}tx help${RESET} for available commands."
        exit 1
        ;;
esac
