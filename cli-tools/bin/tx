#!/usr/bin/env bash
# tx — human memory-aid alias for the canonical tmuxctld startup path.
# TAGS: tmux, alias
# AUDIENCE: human

set -euo pipefail

_THIS="$(readlink -f "$0")"
_BIN_DIR="$(dirname "$_THIS")"
_CTL="${TMUXCTLD_CTL_BIN:-${_BIN_DIR}/tmuxctld-ctl}"

case "${1:-}" in
  ""|start|attach)
    shift || true
    if [[ $# -ne 0 ]]; then
      echo "tx: only 'tx', 'tx start', and 'tx attach' are supported; use tmuxctld-ctl attach or tmuxctld-ctl workspace --rebuild." >&2
      exit 64
    fi
    exec "$_CTL" attach
    ;;
  *)
    echo "tx: unsupported command '${1}'. Use 'tmuxctld-ctl attach' or 'tmuxctld-ctl workspace --rebuild'." >&2
    exit 64
    ;;
esac
