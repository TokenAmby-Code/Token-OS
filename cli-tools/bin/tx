#!/usr/bin/env bash
# tx — human tmux autopilot
#
# The one remembered entrypoint for the managed workspace. It accepts no
# parameters: attach first, perform the bounded daemon recovery walk on a
# failure, then hand its report to one directly launched Codex session if the
# workspace is still unavailable.

set -u

CTL="${TMUXCTLD_CTL_BIN:-tmuxctld-ctl}"
CODEX="${CODEX_BIN:-codex}"
REPORT_DIR="${TX_REPORT_DIR:-$HOME/.claude/tx-reports}"

usage() {
  printf 'tx is the human tmux autopilot. Run it with no arguments.\n' >&2
}

human_terminal() {
  [[ -t 0 && -t 1 && -t 2 ]]
}

append_step() {
  local title="$1"
  {
    printf '\n## %s\n' "$title"
    printf '$ %q' "$CTL"
    shift
    printf ' %q' "$@"
    printf '\n'
    "$CTL" "$@"
    printf '[exit %s]\n' "$?"
  } >>"$REPORT" 2>&1
}

[[ $# -eq 0 ]] || { usage; exit 64; }
human_terminal || {
  printf 'tx requires an interactive human terminal.\n' >&2
  exit 64
}

# A successful attach execs through tmuxctld-ctl and never returns here.
"$CTL" attach && exit 0
initial_rc=$?

mkdir -p "$REPORT_DIR" || {
  printf 'tx: cannot create report directory: %s\n' "$REPORT_DIR" >&2
  exit 1
}
REPORT="$(mktemp "$REPORT_DIR/tx-rote-walk.XXXXXX.txt")" || exit 1
{
  printf '# tx rote walk\n'
  printf 'timestamp: %s\n' "$(date -Is)"
  printf 'initial attach exit: %s\n' "$initial_rc"
} >"$REPORT"

# Bounded recovery: inspect the supervised daemon, kick it through launchd,
# re-check it, and make one final blessed attach attempt. No raw tmux lifecycle
# operation is performed here.
append_step 'daemon status before recovery' status
append_step 'launchd recovery' start
append_step 'daemon status after recovery' status
append_step 'recent daemon stderr' logs err 80
append_step 'final managed attach' attach

printf 'tx could not restore the managed workspace. Starting Codex with %s\n' "$REPORT" >&2
prompt="The tx tmux autopilot could not restore the managed workspace. Read the rote-walk report at '$REPORT', diagnose the failure, and report findings. Do not modify tmux state or launch agents."
exec "$CODEX" "$prompt"
