#!/usr/bin/env bash
# tmux-instance-exit — close the current managed agent instance via tmuxctl.
# TAGS: tmux, agent, claude, codex, exit, close, keybind
# AUDIENCE: human
set -euo pipefail

PANE=""
LIFECYCLE_ACTION=""
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
_LIB_DIR="${SCRIPT_DIR}/../lib"
# shellcheck source=../lib/nas-path.sh
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true
TMUXCTL_BIN="${SCRIPT_DIR}/tmuxctl"
[[ -x "$TMUXCTL_BIN" ]] || TMUXCTL_BIN="tmuxctl"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pane) PANE="${2:-}"; shift 2 ;;
        --lifecycle) LIFECYCLE_ACTION="${2:-}"; shift 2 ;;
        -h|--help) sed -n '2,/^$/s/^# //p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
done

if [[ -z "$PANE" ]]; then
    _id="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
    if [[ -n "$_id" && "$_id" != %* ]]; then
        PANE="%${_id}"
    else
        PANE="$_id"
    fi
fi
if [[ -z "$PANE" ]]; then
    echo "tmux-instance-exit: no target pane" >&2
    exit 1
fi

_show_close_menu() {
    local quoted_pane
    quoted_pane="$(printf '%q' "$PANE")"
    local -a menu_args=(
        "Retire instance" r "run-shell \"tmux-run tmux-instance-exit --pane ${quoted_pane} --lifecycle retire\""
        "Archive session doc" a "run-shell \"tmux-run tmux-instance-exit --pane ${quoted_pane} --lifecycle archive-session-doc\""
        "Banish" b "run-shell \"tmux-run tmux-instance-exit --pane ${quoted_pane} --lifecycle banish\""
        ""
        "Cancel" q ""
    )
    tmux display-menu -T "Close instance" -x C -y C "${menu_args[@]}"
}

_normalize_lifecycle() {
    case "${1:-}" in
        ""|none|cancel) printf '%s\n' "" ;;
        retire|retire-only) printf '%s\n' "retire" ;;
        archive|archive-doc|archive-session-doc|retire-and-archive) printf '%s\n' "archive-session-doc" ;;
        banish) printf '%s\n' "banish" ;;
        *) echo "tmux-instance-exit: unknown lifecycle: $1" >&2; return 1 ;;
    esac
}

INSTANCE_ID="$(tmux show-options -pv -t "$PANE" @INSTANCE_ID 2>/dev/null || true)"
if [[ -z "$LIFECYCLE_ACTION" && -n "$INSTANCE_ID" ]]; then
    _show_close_menu
    exit 0
fi

LIFECYCLE="$(_normalize_lifecycle "$LIFECYCLE_ACTION")"
[[ -n "$LIFECYCLE" ]] || exit 0
if [[ -z "$INSTANCE_ID" ]]; then
    tmux display-message "tmux-instance-exit: pane has no @INSTANCE_ID" 2>/dev/null || true
    echo "tmux-instance-exit: pane has no @INSTANCE_ID" >&2
    exit 1
fi

if IMPERIUM_TMUX_AUTOMATION=1 "$TMUXCTL_BIN" close --instance-id "$INSTANCE_ID" --pane "$PANE" --lifecycle "$LIFECYCLE" --mode now; then
    tmux display-message "tmux-instance-exit: $LIFECYCLE executed" 2>/dev/null || true
else
    tmux display-message "tmux-instance-exit: $LIFECYCLE failed" 2>/dev/null || true
    exit 1
fi
