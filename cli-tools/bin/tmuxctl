#!/usr/bin/env bash
# tmuxctl — entrypoint for the Python tmux control plane.

# 410-on-touch shim: this cold CLI/keybind path is retired.  The dead body
# below is intentionally retained for the separately-gated atomic wipe.
echo "tmuxctl: HTTP 410 Gone — cold tmuxctl CLI is retired; call tmuxctld through tmuxctld-ping or the HTTP API." >&2
exit 154  # 410 modulo POSIX shell's 8-bit exit status

set -euo pipefail
_BIN_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
_REPO_ROOT="${TOKEN_OS:-$(cd "${_BIN_DIR}/../.." && pwd)}"
_LIB_DIR="${TMUXCTLD_LIB:-${_REPO_ROOT}/tmuxctld/lib}"
_CLI_LIB_DIR="${_REPO_ROOT}/cli-tools/lib"

tmuxctl_python() {
    local candidate
    for candidate in python3.14 python3.13 python3.12 python3.11 python3; do
        if command -v "$candidate" >/dev/null 2>&1 && "$candidate" -c 'from datetime import UTC' >/dev/null 2>&1; then
            command -v "$candidate"
            return 0
        fi
    done
    echo "tmuxctl requires Python 3.11+" >&2
    return 1
}

PYTHONPATH="${_LIB_DIR}:${_CLI_LIB_DIR}${PYTHONPATH:+:$PYTHONPATH}" exec "$(tmuxctl_python)" -m tmuxctl.cli "$@"
