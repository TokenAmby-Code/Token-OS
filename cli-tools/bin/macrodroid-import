#!/usr/bin/env python3
# macrodroid-import - gated MacroDroid .macro import launcher with verification
# TAGS: mobile, macrodroid
# AUDIENCE: human, agent
"""
Validate, stage, and launch a MacroDroid .macro file import via Android's
first-class file VIEW intent. This intentionally does not use Shizuku/root/ADB.

The tool is fail-closed: it requires MACRODROID_AUTO_IMPORT=1 before touching the
phone, refuses duplicate macro names by default, and returns non-zero unless a
fresh macrodroid-state pull confirms the macro exists after the launch.
"""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import json
import os
import re
import shlex
import subprocess
import sys
import time
from pathlib import Path
from typing import Any
from urllib.error import URLError
from urllib.request import urlopen

SSH_HOST = os.environ.get("MACRODROID_SSH_HOST", "phone")
REMOTE_STAGE_DIR = os.environ.get(
    "MACRODROID_IMPORT_STAGE", "~/storage/downloads/MacroDroid/auto-import"
)
STATE_SCRATCHPAD = Path(os.environ.get("SCRATCHPAD", "/tmp/macrodroid-state"))
EXPORT_PATH = Path(os.environ.get("MACRODROID_STATE_EXPORT", str(STATE_SCRATCHPAD / "EXPORT.mdr")))
LOG_PATH = Path(
    os.environ.get(
        "MACRODROID_IMPORT_LOG",
        str(Path.home() / ".cache" / "macrodroid-import" / "import.log"),
    )
)
MACRODROID_COMPONENT = "com.arlosoft.macrodroid/.filehandler.FileHandlerProxy"
DEFAULT_MIME = "application/octet-stream"
AUTO_ACCEPT_TTL_SECONDS = 30 * 60
AUTO_ACCEPT_DELAY_SECONDS = 2.0


def phone_http_base() -> str:
    explicit = os.environ.get("MACRODROID_PHONE_HTTP_BASE")
    if explicit:
        return explicit.rstrip("/")
    phone_ip = os.environ.get("PHONE_TAILSCALE_IP")
    if not phone_ip:
        try:
            sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))
            from imperium_config import cfg  # type: ignore

            phone_ip = cfg("tailscale_ip", "phone")
        except Exception:
            phone_ip = ""
    if not phone_ip:
        phone_ip = "100.102.92.24"
    return f"http://{phone_ip}:7777"


def run(
    cmd: list[str],
    *,
    input_text: str | None = None,
    timeout: int | None = None,
    check: bool = False,
) -> subprocess.CompletedProcess[str]:
    try:
        proc = subprocess.run(
            cmd, input=input_text, text=True, capture_output=True, timeout=timeout
        )
    except subprocess.TimeoutExpired as exc:
        stdout = (
            exc.stdout
            if isinstance(exc.stdout, str)
            else (exc.stdout or b"").decode(errors="replace")
        )
        stderr = (
            exc.stderr
            if isinstance(exc.stderr, str)
            else (exc.stderr or b"").decode(errors="replace")
        )
        return subprocess.CompletedProcess(
            cmd, 124, stdout, stderr or f"timed out after {timeout}s"
        )
    except OSError as exc:
        return subprocess.CompletedProcess(cmd, 127, "", str(exc))
    if check and proc.returncode != 0:
        raise RuntimeError(
            f"command failed ({proc.returncode}): {' '.join(shlex.quote(c) for c in cmd)}\n"
            f"stdout: {proc.stdout.strip()}\nstderr: {proc.stderr.strip()}"
        )
    return proc


def log_event(event: dict[str, Any]) -> None:
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    event = {"ts": dt.datetime.now(dt.UTC).isoformat(), **event}
    with LOG_PATH.open("a", encoding="utf-8") as f:
        f.write(json.dumps(event, sort_keys=True) + "\n")


def macro_name(macro_file: Path) -> tuple[str, dict[str, Any]]:
    try:
        data = json.loads(macro_file.read_text(encoding="utf-8"))
    except Exception as exc:
        raise SystemExit(f"ERROR: invalid JSON: {exc}") from exc
    macro = data.get("macro") if isinstance(data, dict) else None
    if not isinstance(macro, dict):
        raise SystemExit("ERROR: .macro wrapper has no macro object")
    name = macro.get("m_name")
    if not isinstance(name, str) or not name.strip():
        raise SystemExit("ERROR: macro.m_name missing or empty")
    return name.strip(), data


def safe_remote_name(local: Path) -> str:
    base = local.name or "import.macro"
    base = re.sub(r"[^A-Za-z0-9._-]+", "-", base).strip(".-") or "import.macro"
    if not base.lower().endswith(".macro"):
        base += ".macro"
    digest = hashlib.sha256(local.read_bytes()).hexdigest()[:12]
    stem = base[:-6]
    return f"{stem}-{digest}.macro"


def sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


VOLATILE_SEMANTIC_KEYS = {
    "m_GUID",
    "m_SIGUID",
    "lastEditedTimestamp",
    "disabledTimestamp",
    "forceEvenIfNotEnabledTimestamp",
    "breakpoints",
    "exportedActionBlocks",
    "m_excludeLog",
    "m_headingColor",
    "m_descriptionOpen",
    "isFavourite",
    "isExtra",
    "isActionBlock",
    "localVarsAlphabetical",
}


def stable_macro_guid(macro: dict[str, Any]) -> Any:
    guid = macro.get("m_GUID")
    return guid if guid not in (None, 0, "0", "") else None


MACRODROID_VARIABLE_CURRENT_VALUE_KEYS = {
    "m_booleanValue",
    "m_intValue",
    "m_stringValue",
    "m_decimalValue",
}


def is_macrodroid_variable_object(value: Any) -> bool:
    return (
        isinstance(value, dict)
        and isinstance(value.get("m_name"), str)
        and isinstance(value.get("m_type"), int)
        and (
            "isLocalVar" in value
            or "isLocalVariable" in value
            or "supportsInput" in value
            or "supportsOutput" in value
        )
    )


def semantic_projection(value: Any, template: Any) -> Any:
    """Project a live macro onto the candidate-provided semantic shape.

    MacroDroid adds GUIDs, timestamps, UI/editor defaults, variable current
    values, and sometimes fields absent from importable .macro JSON.
    Verification should compare the trigger/action/constraint structure and the
    values the candidate actually supplied, not whole-export noise.
    """
    if isinstance(template, dict):
        if not isinstance(value, dict):
            return {"__type_mismatch__": type(value).__name__}
        projected: dict[str, Any] = {}
        template_is_variable = is_macrodroid_variable_object(template)
        for key in sorted(template):
            if key in VOLATILE_SEMANTIC_KEYS:
                continue
            if template_is_variable and key in MACRODROID_VARIABLE_CURRENT_VALUE_KEYS:
                continue
            projected[key] = semantic_projection(value.get(key), template[key])
        return projected
    if isinstance(template, list):
        if not isinstance(value, list):
            return {"__type_mismatch__": type(value).__name__}
        return {
            "__len__": len(value),
            "items": [
                semantic_projection(value[i], item_template)
                if i < len(value)
                else {"__missing__": True}
                for i, item_template in enumerate(template)
            ],
        }
    return value


def macro_semantic_fingerprint(
    macro: dict[str, Any], template: dict[str, Any] | None = None
) -> str:
    tmpl = template if template is not None else macro
    projection = semantic_projection(macro, tmpl)
    return hashlib.sha256(
        json.dumps(projection, sort_keys=True, separators=(",", ":")).encode("utf-8")
    ).hexdigest()


def semantic_matches(candidate_macro: dict[str, Any], live_macro: dict[str, Any]) -> bool:
    return macro_semantic_fingerprint(candidate_macro) == macro_semantic_fingerprint(
        live_macro, candidate_macro
    )


def semantic_macros_named(
    state: dict[str, Any], name: str, candidate_macro: dict[str, Any]
) -> list[dict[str, Any]]:
    return [m for m in macros_named(state, name) if semantic_matches(candidate_macro, m)]


def newly_added_semantic_matches(
    before_matches: list[dict[str, Any]], after_matches: list[dict[str, Any]]
) -> list[dict[str, Any]]:
    before_guids = {
        stable_macro_guid(m) for m in before_matches if stable_macro_guid(m) is not None
    }
    if before_guids:
        return [m for m in after_matches if stable_macro_guid(m) not in before_guids]
    return after_matches[len(before_matches) :]


def validate(local: Path) -> None:
    proc = run(["macrodroid-validate", "--quiet", str(local)], timeout=30)
    if proc.stdout:
        print(proc.stdout, end="")
    if proc.stderr:
        print(proc.stderr, end="", file=sys.stderr)
    if proc.returncode != 0:
        raise SystemExit("ERROR: validation failed; refusing phone interaction")


def pull_state() -> tuple[dict[str, Any], Path]:
    proc = run(["macrodroid-state", "--pull"], timeout=45)
    if proc.returncode != 0:
        raise RuntimeError(
            f"macrodroid-state --pull failed\nstdout: {proc.stdout}\nstderr: {proc.stderr}"
        )

    path = EXPORT_PATH
    if not path.exists():
        candidate = proc.stdout.strip().splitlines()[-1] if proc.stdout.strip() else ""
        if candidate and Path(candidate).exists():
            path = Path(candidate)
        else:
            raise RuntimeError(f"pulled export not found at {EXPORT_PATH}")

    with path.open("r", encoding="utf-8") as f:
        data = json.load(f)
    if not isinstance(data, dict) or not isinstance(data.get("macroList"), list):
        raise RuntimeError(f"not a MacroDroid export: {path}")
    return data, path


def macros_named(state: dict[str, Any], name: str) -> list[dict[str, Any]]:
    needle = name.casefold()
    return [
        m
        for m in state.get("macroList", [])
        if isinstance(m, dict) and str(m.get("m_name", "")).casefold() == needle
    ]


def describe_matches(matches: list[dict[str, Any]]) -> str:
    lines = []
    for i, macro in enumerate(matches, 1):
        lines.append(
            f"  {i}. name={macro.get('m_name')!r} "
            f"category={macro.get('m_category', 'Uncategorized')!r} "
            f"enabled={bool(macro.get('m_enabled'))} "
            f"guid={macro.get('m_GUID')}"
        )
    return "\n".join(lines)


def stage_file(local: Path, remote_name: str) -> str:
    if REMOTE_STAGE_DIR == "~":
        qdir = "$HOME"
    elif REMOTE_STAGE_DIR.startswith("~/"):
        qdir = "$HOME/" + shlex.quote(REMOTE_STAGE_DIR[2:])
    else:
        qdir = shlex.quote(REMOTE_STAGE_DIR)
    proc = run(["ssh", SSH_HOST, f"mkdir -p {qdir} && cd -P {qdir} && pwd"], timeout=20, check=True)
    remote_dir = proc.stdout.strip().splitlines()[-1]
    remote_path = f"{remote_dir.rstrip('/')}/{remote_name}"
    run(["scp", "-q", str(local), f"{SSH_HOST}:{remote_path}"], timeout=45, check=True)
    return remote_path


def launch_view_intent(remote_path: str, mime: str, wait: bool) -> subprocess.CompletedProcess[str]:
    # Use Termux's `am` wrapper, not /system/bin/am. /system/bin/am runs as an
    # app uid but claims com.android.shell on recent Android and is rejected.
    cmd = (
        "am start "
        + ("-W " if wait else "")
        + "--user 0 "
        + f"-n {shlex.quote(MACRODROID_COMPONENT)} "
        + "-a android.intent.action.VIEW "
        + f"-d {shlex.quote('file://' + remote_path)} "
        + f"-t {shlex.quote(mime)}"
    )
    return run(["ssh", SSH_HOST, cmd], timeout=30)


def summarize_state(state: dict[str, Any], export_path: Path) -> tuple[int, str]:
    digest = sha256(export_path) if export_path.exists() else ""
    return len(state.get("macroList", [])), digest


def evaluate_import_result(
    *,
    replace: bool,
    allow_existing: bool,
    candidate_macro: dict[str, Any],
    before_state: dict[str, Any],
    after_state: dict[str, Any],
    before_count: int,
    after_count: int,
) -> tuple[bool, bool, dict[str, Any]]:
    """Return (success, wiped, diagnostics) for semantic import verification."""
    name = str(candidate_macro.get("m_name", ""))
    before_same_name = macros_named(before_state, name)
    after_same_name = macros_named(after_state, name)
    before_semantic = [m for m in before_same_name if semantic_matches(candidate_macro, m)]
    after_semantic = [m for m in after_same_name if semantic_matches(candidate_macro, m)]
    new_semantic = newly_added_semantic_matches(before_semantic, after_semantic)
    wiped = after_count < before_count and not replace

    diagnostics = {
        "before_same_name": len(before_same_name),
        "after_same_name": len(after_same_name),
        "before_semantic": len(before_semantic),
        "after_semantic": len(after_semantic),
        "new_semantic": len(new_semantic),
    }

    if replace:
        stable_noop = False
        if len(before_same_name) == 1 and len(after_same_name) == 1:
            before_guid = stable_macro_guid(before_same_name[0])
            after_guid = stable_macro_guid(after_same_name[0])
            stable_noop = (
                before_guid is not None
                and before_guid == after_guid
                and semantic_matches(candidate_macro, before_same_name[0])
                and semantic_matches(candidate_macro, after_same_name[0])
            )
        success = len(after_same_name) == 1 and len(after_semantic) == 1 and not stable_noop
    elif allow_existing:
        success = after_count == before_count + 1 and len(new_semantic) == 1
    else:
        success = (
            after_count == before_count + 1 and len(after_semantic) == 1 and len(new_semantic) == 1
        )
    return success, wiped, diagnostics


def auto_accept_request(endpoint: str, *, timeout: int = 5) -> tuple[bool, int | None, str]:
    url = f"{phone_http_base()}/{endpoint.lstrip('/')}"
    try:
        with urlopen(url, timeout=timeout) as response:
            body = response.read().decode("utf-8", errors="replace")
            return True, response.status, body
    except TimeoutError:
        return True, None, "timed out waiting for MacroDroid HTTP response"
    except (URLError, OSError) as exc:
        if isinstance(getattr(exc, "reason", None), TimeoutError):
            return True, None, "timed out waiting for MacroDroid HTTP response"
        return False, None, str(exc)


def main() -> int:
    parser = argparse.ArgumentParser(
        description=(
            "Validate, stage, launch, and verify a MacroDroid .macro import. "
            "Requires MACRODROID_AUTO_IMPORT=1."
        )
    )
    parser.add_argument("macro_file", nargs="?", help="official MacroDroid .macro wrapper JSON")
    parser.add_argument(
        "--allow-existing",
        action="store_true",
        help="legacy duplicate test mode: allow same-name macros and accept an added duplicate as success",
    )
    parser.add_argument(
        "--replace",
        action="store_true",
        help="clean replacement mode: allow existing same-name macros, but succeed only if exactly one target macro remains",
    )
    parser.add_argument(
        "--mime", default=DEFAULT_MIME, help=f"VIEW intent MIME type (default: {DEFAULT_MIME})"
    )
    parser.add_argument(
        "--wait-seconds", type=float, default=8.0, help="seconds to wait before verification pull"
    )
    parser.add_argument("--no-launch-wait", action="store_true", help="do not pass -W to am start")
    parser.add_argument(
        "--validate-only",
        action="store_true",
        help="only run local validation and duplicate/name parsing; no phone interaction",
    )
    parser.add_argument(
        "--auto-accept",
        action="store_true",
        help="arm the on-phone MacroDroid import harness, launch import UI, then call /macrodroid-import-accept",
    )
    parser.add_argument(
        "--auto-accept-delay",
        type=float,
        default=AUTO_ACCEPT_DELAY_SECONDS,
        help=f"seconds between import UI launch and accept endpoint call (default: {AUTO_ACCEPT_DELAY_SECONDS})",
    )
    parser.add_argument(
        "--disarm-auto-accept",
        action="store_true",
        help="call /macrodroid-import-disarm and exit; macro_file is not required",
    )
    parser.add_argument(
        "--before-export",
        help="use this existing MacroDroid export as the pre-import state instead of pulling",
    )
    parser.add_argument(
        "--write-after-export",
        help="write the verified post-import export JSON to this path for batch chaining",
    )
    args = parser.parse_args()
    if args.allow_existing and args.replace:
        parser.error("--allow-existing and --replace are mutually exclusive")

    if args.disarm_auto_accept:
        ok, status, body = auto_accept_request("macrodroid-import-disarm")
        log_event({"result": "auto_accept_disarm", "ok": ok, "status": status, "body": body[-500:]})
        print(body.strip() if body else f"auto-accept disarm status={status} ok={ok}")
        return 0 if ok else 10

    if not args.macro_file:
        parser.error("macro_file is required unless --disarm-auto-accept is used")

    local = Path(args.macro_file).expanduser().resolve()
    if not local.exists():
        print(f"ERROR: file not found: {local}", file=sys.stderr)
        return 2

    validate(local)
    name, data = macro_name(local)
    candidate_macro = data["macro"]
    digest = sha256(local)

    if args.validate_only:
        print(f"OK: {name} sha256={digest}")
        return 0

    if os.environ.get("MACRODROID_AUTO_IMPORT") != "1":
        log_event({"result": "refused_env", "file": str(local), "macro": name, "sha256": digest})
        print(
            "ERROR: refusing phone interaction; set MACRODROID_AUTO_IMPORT=1 to enable gated import attempts",
            file=sys.stderr,
        )
        return 3

    try:
        if args.before_export:
            before_path = Path(args.before_export).expanduser().resolve()
            with before_path.open("r", encoding="utf-8") as f:
                before = json.load(f)
            if not isinstance(before, dict) or not isinstance(before.get("macroList"), list):
                raise RuntimeError(f"not a MacroDroid export: {before_path}")
        else:
            before, before_path = pull_state()
    except RuntimeError as exc:
        log_event(
            {
                "result": "state_pull_failed",
                "file": str(local),
                "macro": name,
                "sha256": digest,
                "error": str(exc),
            }
        )
        print(f"ERROR: {exc}", file=sys.stderr)
        return 8
    before_count, before_hash = summarize_state(before, before_path)
    before_matches = macros_named(before, name)
    if before_matches and not (args.allow_existing or args.replace):
        log_event(
            {
                "result": "refused_duplicate",
                "file": str(local),
                "macro": name,
                "sha256": digest,
                "before_count": before_count,
                "before_hash": before_hash,
                "existing_matches": len(before_matches),
            }
        )
        print(
            f"ERROR: macro already exists on phone: {name!r}; refusing duplicate import",
            file=sys.stderr,
        )
        print(describe_matches(before_matches), file=sys.stderr)
        print(
            "Delete/replace the existing macro in MacroDroid, or use --replace for an explicit clean replacement attempt.",
            file=sys.stderr,
        )
        return 4

    remote_name = safe_remote_name(local)
    try:
        remote_path = stage_file(local, remote_name)
    except RuntimeError as exc:
        log_event(
            {
                "result": "stage_failed",
                "file": str(local),
                "macro": name,
                "sha256": digest,
                "before_count": before_count,
                "before_hash": before_hash,
                "error": str(exc),
            }
        )
        print(f"ERROR: {exc}", file=sys.stderr)
        return 8
    print(f"Staged {name!r} to {remote_path}")

    if args.auto_accept:
        ok, status, body = auto_accept_request("macrodroid-import-arm")
        log_event(
            {
                "result": "auto_accept_arm",
                "ok": ok,
                "status": status,
                "body": body[-500:],
                "macro": name,
            }
        )
        if not ok:
            print(f"ERROR: failed to arm MacroDroid import harness: {body}", file=sys.stderr)
            return 10
        print(
            f"Armed MacroDroid import auto-accept TTL ({AUTO_ACCEPT_TTL_SECONDS // 60} min): {body.strip()}"
        )

    launched = launch_view_intent(remote_path, args.mime, wait=not args.no_launch_wait)
    if launched.stdout:
        print(launched.stdout, end="")
    if launched.stderr:
        print(launched.stderr, end="", file=sys.stderr)
    if launched.returncode != 0:
        log_event(
            {
                "result": "launch_failed",
                "file": str(local),
                "remote_path": remote_path,
                "macro": name,
                "sha256": digest,
                "before_count": before_count,
                "before_hash": before_hash,
                "am_returncode": launched.returncode,
                "am_stdout": launched.stdout[-1000:],
                "am_stderr": launched.stderr[-1000:],
            }
        )
        print("ERROR: MacroDroid file VIEW intent launch failed", file=sys.stderr)
        return 5

    if args.auto_accept:
        if args.auto_accept_delay > 0:
            time.sleep(args.auto_accept_delay)
        ok, status, body = auto_accept_request("macrodroid-import-accept")
        log_event(
            {
                "result": "auto_accept_click",
                "ok": ok,
                "status": status,
                "body": body[-500:],
                "macro": name,
            }
        )
        print(body.strip() if body else f"auto-accept click status={status} ok={ok}")
        # Only the pre-click delay is intentional: it lets MacroDroid render the
        # import prompt before the harness click.  Do not add a blind post-click
        # sleep here; verification below triggers a fresh export and observes the
        # resulting state.
    elif args.wait_seconds > 0:
        time.sleep(args.wait_seconds)

    try:
        after, after_path = pull_state()
    except RuntimeError as exc:
        log_event(
            {
                "result": "verify_pull_failed",
                "file": str(local),
                "remote_path": remote_path,
                "macro": name,
                "sha256": digest,
                "before_count": before_count,
                "before_hash": before_hash,
                "error": str(exc),
            }
        )
        print(f"ERROR: {exc}", file=sys.stderr)
        return 8
    after_count, after_hash = summarize_state(after, after_path)
    if args.write_after_export:
        Path(args.write_after_export).expanduser().write_text(
            json.dumps(after, sort_keys=True), encoding="utf-8"
        )
    after_matches = macros_named(after, name)
    success, wiped, diagnostics = evaluate_import_result(
        replace=args.replace,
        allow_existing=args.allow_existing,
        candidate_macro=candidate_macro,
        before_state=before,
        after_state=after,
        before_count=before_count,
        after_count=after_count,
    )

    event = {
        "result": "success" if success else "not_confirmed",
        "file": str(local),
        "remote_path": remote_path,
        "macro": name,
        "category": (data.get("macro") or {}).get("m_category"),
        "sha256": digest,
        "before_count": before_count,
        "after_count": after_count,
        "before_hash": before_hash,
        "after_hash": after_hash,
        "matches_before": len(before_matches),
        "matches_after": len(after_matches),
        "semantic_diagnostics": diagnostics,
        "candidate_fingerprint": macro_semantic_fingerprint(candidate_macro),
        "replace": args.replace,
        "allow_existing": args.allow_existing,
        "mime": args.mime,
    }
    log_event(event)

    if wiped:
        print(
            f"ERROR: macro count decreased ({before_count} -> {after_count}); investigate before retrying",
            file=sys.stderr,
        )
        return 6
    if success:
        print(f"OK: verified imported macro {name!r} ({before_count} -> {after_count})")
        return 0
    if args.replace and len(after_matches) > 1:
        print(
            f"ERROR: replacement left {len(after_matches)} same-name macros; delete duplicates in MacroDroid.",
            file=sys.stderr,
        )
        print(describe_matches(after_matches), file=sys.stderr)
        print(f"Log: {LOG_PATH}", file=sys.stderr)
        return 9

    print(
        "ERROR: import not verified after launching MacroDroid file handler. "
        "This likely means MacroDroid is waiting on its review/Add UI; no human picker was used, "
        "but no non-UI confirmation path has been proven.",
        file=sys.stderr,
    )
    print(
        f"State: before_count={before_count} after_count={after_count} matches_after={len(after_matches)} semantic={diagnostics}",
        file=sys.stderr,
    )
    print(f"Log: {LOG_PATH}", file=sys.stderr)
    return 7


if __name__ == "__main__":
    raise SystemExit(main())
