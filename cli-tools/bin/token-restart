# ============ Plist Update ============

# token-api's file-descriptor ceiling, repo-managed here so it is no longer a
# hand-edited live-plist invariant. A fd/connection burst that hits the old
# soft=4096 ceiling makes the SessionStart registration POST fail with EMFILE,
# stranding a live persona pane with no registry row. This is INSURANCE (a
# band-aid for bursts) — the real fix is finding the burst source — but it buys
# wide headroom: 16384/32768 sits well under kern.maxfilesperproc (61440).
FD_SOFT_LIMIT=16384
FD_HARD_LIMIT=32768

# Idempotently pin the fd resource limits in the LaunchAgent plist. Returns 0 if
# the plist already carries the target limits (no-op), 1 if it was modified — the
# caller must then bootout+bootstrap so launchd re-reads the resource limits
# (`kickstart -k` alone reuses the already-bootstrapped service definition).
ensure_plist_resource_limits() {
    [[ -f "$PLIST" ]] || return 0
    /usr/bin/python3 - "$PLIST" "$FD_SOFT_LIMIT" "$FD_HARD_LIMIT" << 'PYEOF'
import sys, plistlib
plist_path, soft, hard = sys.argv[1], int(sys.argv[2]), int(sys.argv[3])
with open(plist_path, 'rb') as f:
    data = plistlib.load(f)
soft_block = data.get('SoftResourceLimits') or {}
hard_block = data.get('HardResourceLimits') or {}
changed = soft_block.get('NumberOfFiles') != soft or hard_block.get('NumberOfFiles') != hard
if changed:
    soft_block['NumberOfFiles'] = soft
    hard_block['NumberOfFiles'] = hard
    data['SoftResourceLimits'] = soft_block
    data['HardResourceLimits'] = hard_block
    with open(plist_path, 'wb') as f:
        plistlib.dump(data, f, fmt=plistlib.FMT_XML, sort_keys=False)
sys.exit(1 if changed else 0)
PYEOF
}

# Idempotently reconcile the LaunchAgent plist to the socket-activation shape:
#   * ProgramArguments = [<python>, "main.py"]  (NOT `-m uvicorn …`), so main.py's
#     launchd-fd shim runs (token-api/launchd_socket.py) and serves on the
#     launchd-owned socket.
#   * a `Sockets` dict so launchd — not uvicorn — owns the listening socket; its
#     kernel accept backlog then survives every uvicorn restart, so a deploy
#     stalls incoming hooks briefly instead of connection-refusing (and dropping)
#     them. The canonical reference is cli-tools/launchd/ai.openclaw.tokenapi.plist.
# Preserves EnvironmentVariables (secrets), resource limits, and the configured
# interpreter (ProgramArguments[0]). Returns 0 if already canonical (no-op), 1 if
# modified — the caller must then bootout+bootstrap, because a Sockets /
# ProgramArguments change is NOT picked up by `kickstart -k` (it reuses the
# already-bootstrapped service definition).
ensure_plist_socket_activation() {
    [[ -f "$PLIST" ]] || return 0
    /usr/bin/python3 - "$PLIST" "$MAC_PORT" << 'PYEOF'
import sys, plistlib
plist_path, port = sys.argv[1], sys.argv[2]
with open(plist_path, 'rb') as f:
    data = plistlib.load(f)
changed = False

args = data.get('ProgramArguments') or []
# Preserve the configured interpreter (index 0); collapse the rest to main.py.
python = args[0] if args else '/Users/tokenclaw/.local/venvs/token-api/bin/python'
desired_args = [python, 'main.py']
if args != desired_args:
    data['ProgramArguments'] = desired_args
    changed = True

desired_sockets = {
    'Listeners': {
        'SockServiceName': port,
        'SockType': 'stream',
        'SockFamily': 'IPv4',
    }
}
if data.get('Sockets') != desired_sockets:
    data['Sockets'] = desired_sockets
    changed = True

if changed:
    with open(plist_path, 'wb') as f:
        plistlib.dump(data, f, fmt=plistlib.FMT_XML, sort_keys=False)
sys.exit(1 if changed else 0)
PYEOF
}

update_plist() {
    local service_dir="$1"
    local python_path="$service_dir/.venv/bin/python"

    if [[ ! -f "$python_path" ]]; then
        echo -e "  ${RED}✗${NC} Python not found at $python_path"
        echo "  Run: uv sync --project '$service_dir' first"
        return 1
    fi

    echo -e "${BLUE}→${NC} Updating plist: $service_dir"
    /usr/bin/python3 - "$PLIST" "$python_path" "$service_dir" << 'PYEOF'
import sys, plistlib
plist_path, python_path, working_dir = sys.argv[1], sys.argv[2], sys.argv[3]
with open(plist_path, 'rb') as f:
    data = plistlib.load(f)
data['ProgramArguments'][0] = python_path
data['WorkingDirectory'] = working_dir
with open(plist_path, 'wb') as f:
    plistlib.dump(data, f, fmt=plistlib.FMT_XML, sort_keys=False)
PYEOF
    ensure_plist_resource_limits || true
    ensure_plist_socket_activation || true
    echo -e "  ${GREEN}✓${NC} Plist updated"
}

# ============ Mobile ============

restart_mobile() {
    echo -e "${BLUE}→${NC} Deploying mobile (push-mobile -a)..."
    # Resolve PATH-first (the standard cli-tools push-mobile), falling back to our
    # sibling in _BIN_DIR if PATH doesn't carry it (e.g. a bare CD environment).
    local push_mobile
    push_mobile="$(command -v push-mobile 2>/dev/null || true)"
    [[ -n "$push_mobile" ]] || push_mobile="${_BIN_DIR}/push-mobile"
    if [[ ! -x "$push_mobile" ]]; then
        echo -e "  ${YELLOW}⚠${NC} push-mobile not found — skipping mobile deploy"
        return 0
    fi
    # push-mobile validates + pushes the mobile/ tree to the phone. Fire it but
    # never let a phone-unreachable push fail the whole deploy.
    if "$push_mobile" -a; then
        echo -e "  ${GREEN}✓${NC} push-mobile completed"
    else
        echo -e "  ${YELLOW}⚠${NC} push-mobile failed (continuing)"
    fi
}

# ============ Git-aware service mapping ============
#
# Map the files a sync just pulled (SYNC_CHANGED_PATHS, one path per line) to the
# services that must restart, setting the RESTART_* globals. This is the SINGLE
# SOURCE OF TRUTH for path→service routing: deploy-prod.yml no longer filters
# paths — it just hits the restart endpoint and lets this script decide from git.
#
# NOTE: in bash `case` patterns, `*` matches `/` (unlike filename globbing), so
# `token-api/*.py` covers nested files too. Order matters — the first matching
# arm wins, so specific paths (satellite, ops) precede the general .py arm.

map_changed_to_services() {
    local path
    while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        case "$path" in
            cli-tools/tmux/*)
                # The deploy sync updates the on-disk tmux config, but the running
                # tmux server does not read it until source-file. Source once after
                # the sync (no sweep/timer/poll), using the real tmux binary.
                TMUX_CONFIG_CHANGED=true
                ;;
            cli-tools/launchd/ai.tokenclaw.tmuxctld.plist)
                # The daemon's LaunchAgent plist changed. kickstart -k won't reload
                # a changed plist, so flag a reinstall (cp + bootout + bootstrap of
                # the freshly-synced copy). MUST precede the cli-tools/lib/* WSL arm.
                RESTART_TMUXCTLD=true
                TMUXCTLD_PLIST_CHANGED=true
                ;;
            cli-tools/lib/tmuxctl/*)
                # tmuxctld daemon code area (the loopback tmux control plane:
                # daemon.py + the service/adapter/api modules it imports). Python is
                # not hot-reloaded, so new daemon code lands via main→live sync but
                # the running process must be bounced to load it. This arm MUST
                # precede the general cli-tools/lib/* arm below, which otherwise
                # swallows cli-tools/lib/tmuxctl/* into the WSL-only route. The
                # tmuxctl subtree lives under cli-tools/lib, which the WSL arm
                # refreshes today — keep that WSL refresh (purely additive) so this
                # change never regresses the satellite's cli-tools sync.
                RESTART_TMUXCTLD=true
                RESTART_WSL=true
                REFRESH_WSL=true
                ;;
            cli-tools/bin/tmuxctld)
                # The daemon entrypoint (the single source of truth for the
                # interpreter the plist invokes). Mac-local; unmapped today, so it
                # routes to the daemon restart only — no WSL refresh.
                RESTART_TMUXCTLD=true
                ;;
            token-api/token-satellite.py | token-api/scripts/token-satellite-refresh | ahk/* | cli-tools/bin/dispatch | cli-tools/lib/* | config/deskflow/*)
                # WSL-hosted runtime dependencies. Push the target SHA into the
                # WSL-local runtime/AHK cache instead of merely restarting NAS code.
                RESTART_WSL=true
                REFRESH_WSL=true
                ;;
            token-api/ui/ops/* | token-api/web/ops/*)
                # Ops cockpit is served by token-api; a restart bumps the build-id
                # so connected browsers reload, and we also refresh open tabs.
                RESTART_OPS=true
                RESTART_TOKENAPI=true
                ;;
            token-api/uv.lock | token-api/pyproject.toml)
                RESTART_TOKENAPI=true
                RESTART_WSL=true
                REFRESH_WSL=true
                ;;
            token-api/*.py)
                RESTART_TOKENAPI=true
                ;;
            discord-daemon/*)
                RESTART_DISCORD=true
                ;;
            mobile/*)
                RESTART_MOBILE=true
                ;;
            *)
                : # unmapped (docs, workflows, tmux, hammerspoon, non-runtime files):
                  # no long-lived service to bounce — nothing to do.
                ;;
        esac
    done <<< "$SYNC_CHANGED_PATHS"
    return 0
}

# True when a newer webhook arrived while this holder was deploying. In last-merge
# wins mode, the current restart set is now stale: the code is losslessly included
# in the newer main tip, so drop the old deploy and let the trailing re-sync deploy
# the newest SHA instead of serializing obsolete restarts.
deploy_superseded() {
    [[ "$DEPLOY_LOCK_HELD" == true && -f "$DEPLOY_LOCKDIR/redeploy-pending" ]]
}

abort_deploy_if_superseded() {
    local stage="${1:-deploy}"
    if deploy_superseded; then
        echo -e "${YELLOW}⚠${NC} deploy superseded during ${stage} — dropping current restart set; trailing re-sync will deploy newest main"
        return 0
    fi
    return 1
}

# ============ Full Restart ============

full_restart() {
    echo -e "${BOLD}=== Token Restart ===${NC}"
    echo ""

    # 0. Git sync (default): ff-only pull the live checkout so a merge ships
    #    before we restart. Sets SYNC_DID_ADVANCE + SYNC_CHANGED_PATHS. Always
    #    degrades gracefully — a failed/uneventful sync just leaves the flags off.
    if [[ "$SYNC_BEFORE_RESTART" == true ]]; then
        if ! sync_live_checkout; then
            echo -e "${RED}✗${NC} CD-sync failed; aborting restart so protected runtime is not ambiguous."
            return 1
        fi
        echo ""
        abort_deploy_if_superseded "sync" && return 0
    fi

    # 0b. Reconcile process state with checkout state. Deciding what to restart
    #     from SYNC_DID_ADVANCE alone conflates "git is at SHA X" with "the
    #     process is serving SHA X" — they diverge whenever the checkout advanced
    #     without a paired restart (skipped/contended deploy). token-api
    #     self-reports its launched SHA via /health; if that != the checkout HEAD
    #     (or /health is unreachable), the live process is stale and MUST bounce
    #     regardless of whether THIS invocation advanced git.
    local token_api_stale=false _checkout_sha _running_sha
    _checkout_sha="$(git -C "$(runtime_root)" rev-parse -q --verify HEAD 2>/dev/null || true)"
    _running_sha="$(mac_running_git_sha)"
    [[ -z "$_running_sha" || "$_running_sha" != "$_checkout_sha" ]] && token_api_stale=true

    # 1. Decide what to restart.
    if [[ "$SYNC_DID_ADVANCE" == true ]]; then
        # Smart deploy: restart changed services, and ALWAYS bounce token-api for
        # every advanced merge so /health.git_sha becomes a deploy-verification
        # proof for the merged SHA. Without this, docs/discord/mobile-only merges
        # could update the runtime checkout while live /health kept reporting an
        # older process SHA, creating an unguarded merge→live gap.
        map_changed_to_services
        source_tmux_config_if_changed || return 1
        RESTART_TOKENAPI=true
        if [[ "$RESTART_TOKENAPI" != true && "$RESTART_DISCORD" != true \
            && "$RESTART_WSL" != true && "$RESTART_MOBILE" != true \
            && "$RESTART_TMUXCTLD" != true ]]; then
            echo -e "${GREEN}✓${NC} No deployable services changed — nothing to restart."
            return 0
        fi
        local changed_list=""
        [[ "$RESTART_TOKENAPI" == true ]] && changed_list+=" token-api"
        [[ "$RESTART_OPS" == true ]] && changed_list+=" ops-ui"
        [[ "$RESTART_DISCORD" == true ]] && changed_list+=" discord"
        [[ "$RESTART_TMUXCTLD" == true ]] && changed_list+=" tmuxctld"
        [[ "$RESTART_WSL" == true ]] && changed_list+=" wsl"
        [[ "$RESTART_MOBILE" == true ]] && changed_list+=" mobile"
        echo -e "${BLUE}→${NC} Changed services:${changed_list}"
        echo ""
    elif [[ "$DEPLOY_COALESCE_TRAILING" == true ]]; then
        # Trailing coalescing re-run that found nothing new: the primary deploy
        # already landed the newest SHA. Normally converged — but if the live
        # token-api is STALE (checkout advanced without a paired restart, e.g.
        # the primary deploy skipped the bounce), the deploy is NOT finished.
        # Bounce token-api ONLY (Discord/WSL stay false → token-api-only scope)
        # and fall through to the restart section; do NOT return early.
        if [[ "$token_api_stale" == true ]]; then
            echo -e "${YELLOW}⚠${NC} Runtime at ${_checkout_sha:-?} but live token-api serving '${_running_sha:-unreachable}' — restarting token-api."
            RESTART_TOKENAPI=true
        else
            echo -e "${GREEN}✓${NC} Trailing re-sync: runtime already at newest main — nothing further to redeploy."
            return 0
        fi
    else
        # No new commits (already current / --no-sync / sync degraded): full
        # restart of the standard set — the human "restart my stuff now" path.
        RESTART_TOKENAPI=true
        RESTART_DISCORD=true
        RESTART_WSL=true
    fi

    # 2. Mac token-api
    abort_deploy_if_superseded "before token-api restart" && return 0
    if [[ "$RESTART_TOKENAPI" == true ]]; then
        restart_mac || return 1
        abort_deploy_if_superseded "after token-api restart" && return 0
        verify_mac_git_sha || return 1
        echo ""
    fi

    # 3. Discord daemon (Mac-only, launchd-supervised)
    abort_deploy_if_superseded "before discord restart" && return 0
    if [[ "$RESTART_DISCORD" == true ]]; then
        restart_discord || true
        abort_deploy_if_superseded "after discord restart" && return 0
        echo ""
    fi

    # 3b. tmuxctld daemon (Mac-only, launchd-supervised loopback control plane).
    #     Fail-soft like Discord: a daemon that won't come back must not abort the
    #     rest of the deploy.
    abort_deploy_if_superseded "before tmuxctld restart" && return 0
    if [[ "$RESTART_TMUXCTLD" == true ]]; then
        restart_tmuxctld || true
        abort_deploy_if_superseded "after tmuxctld restart" && return 0
        echo ""
    fi

    # 4. WSL satellite (background; never blocks the deploy)
    abort_deploy_if_superseded "before WSL refresh" && return 0
    local wsl_pid=""
    if [[ "$RESTART_WSL" == true ]]; then
        restart_wsl &
        wsl_pid=$!
    fi

    # 5. Mobile (phone push)
    abort_deploy_if_superseded "before mobile push" && return 0
    if [[ "$RESTART_MOBILE" == true ]]; then
        restart_mobile || true
        echo ""
    fi

    [[ -n "$wsl_pid" ]] && { wait "$wsl_pid" 2>/dev/null || true; }
    abort_deploy_if_superseded "after async WSL refresh" && return 0

    # 6. Browser cockpit refresh — only if token-api was (re)started and healthy.
    if [[ "$RESTART_TOKENAPI" == true ]] && check_mac_health; then
        refresh_ops_browser_gui || true
    fi

    # 7. Summary — report only what we touched.
    echo ""
    echo -e "${BOLD}=== Summary ===${NC}"
    if [[ "$RESTART_TOKENAPI" == true ]]; then
        if check_mac_health; then
            echo -e "  Mac:     ${GREEN}●${NC} healthy"
        else
            echo -e "  Mac:     ${RED}●${NC} not responding"
        fi
    fi
    if [[ "$RESTART_DISCORD" == true ]]; then
        if check_discord_health; then
            echo -e "  Discord: ${GREEN}●${NC} connected"
        else
            echo -e "  Discord: ${RED}●${NC} not responding"
        fi
    fi
    if [[ "$RESTART_TMUXCTLD" == true ]]; then
        if check_tmuxctld_health; then
            echo -e "  tmuxctld:${GREEN}●${NC} healthy"
        else
            echo -e "  tmuxctld:${YELLOW}○${NC} not responding"
        fi
    fi
    if [[ "$RESTART_WSL" == true ]]; then
        if check_wsl_health; then
            echo -e "  WSL:     ${GREEN}●${NC} healthy"
        else
            echo -e "  WSL:     ${YELLOW}○${NC} unknown"
        fi
    fi
    if [[ "$RESTART_MOBILE" == true ]]; then
        echo -e "  Mobile:  ${GREEN}●${NC} push-mobile dispatched"
    fi
}

# ============ Parse Arguments ============

ACTION="restart"
DEPLOY_FROM=""
# Sync is the DEFAULT now (the git-aware deploy mantra: always ship fresh code).
# --no-sync opts out; --sync is an accepted no-op alias.
SYNC_BEFORE_RESTART=true
# Set by sync_live_checkout() when the pull advances HEAD, plus the changed paths.
SYNC_DID_ADVANCE=false
SYNC_CHANGED_PATHS=""
SYNC_TARGET_SHA=""
TMUX_CONFIG_CHANGED=false
# Stderr from the last failed ff-merge attempt — surfaced on a genuine non-ff so the
# failure is never silent (see _cd_sync_ff_with_retry / sync_live_checkout).
CD_SYNC_MERGE_ERR=""
# Which services to restart — set by map_changed_to_services() (smart mode) or
# forced on in the full-restart fallback. Must be initialised for `set -u`.
RESTART_TOKENAPI=false
RESTART_OPS=false
RESTART_DISCORD=false
# tmuxctld daemon: set by map_changed_to_services() when the daemon area changed.
# TMUXCTLD_PLIST_CHANGED forces a reinstall (bootout+bootstrap) vs a kickstart.
RESTART_TMUXCTLD=false
TMUXCTLD_PLIST_CHANGED=false
RESTART_WSL=false
REFRESH_WSL=false
RESTART_MOBILE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        --sync)
            # Explicit alias: sync is the default. Kept so existing callers
            # (e.g. the CD webhook, which passes --sync explicitly) don't break.
            SYNC_BEFORE_RESTART=true
            shift
            ;;
        --sha)
            if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == -* ]]; then
                echo "Error: --sha requires a commit SHA" >&2
                exit 1
            fi
            TOKEN_RESTART_TARGET_SHA="$2"
            shift 2
            ;;
        --no-sync)
            # Opt out of the git sync: full restart on whatever is checked out.
            SYNC_BEFORE_RESTART=false
            shift
            ;;
        --kill)
            ACTION="kill"
            shift
            ;;
        --watch)
            ACTION="watch"
            shift
            ;;
        --status)
            ACTION="status"
            shift
            ;;
        --wsl-only)
            ACTION="wsl-only"
            shift
            ;;
        --discord)
            ACTION="discord"
            shift
            ;;
        --no-push)
            # Legacy flag, ignored (no sync needed in NAS era)
            shift
            ;;
        --from)
            if [[ $# -lt 2 ]]; then
                echo "Error: --from requires a path" >&2
                exit 1
            fi
            DEPLOY_FROM="$(cd "$2" && pwd)"
            shift 2
            ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Use --help for usage" >&2
            exit 1
            ;;
    esac
done

# Only dispatch when executed directly — when sourced (e.g. by unit tests that
# exercise individual functions like ensure_plist_socket_activation), define the
# functions but do not run the restart.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    # Remote proxy: if not on Mac, forward to Mac via SSH
    if ! is_mac; then
        case "$ACTION" in
            status)
                remote_status
                ;;
            *)
                remote_restart
                ;;
        esac
        exit $?
    fi

    # Execute action (Mac only from here)
    case "$ACTION" in
        status)
            get_status_all
            ;;
        kill)
            kill_server
            ;;
        watch)
            run_coalesced_deploy
            watch_logs
            ;;
        wsl-only)
            restart_wsl
            ;;
        discord)
            restart_discord
            ;;
        restart)
            if [[ -n "$DEPLOY_FROM" ]]; then
                update_plist "$DEPLOY_FROM" || exit 1
            fi
            run_coalesced_deploy
            ;;
    esac
fi
