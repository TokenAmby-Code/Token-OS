#!/usr/bin/env bash
# token-restart - Multi-device restart orchestrator
# TAGS: token-api
# AUDIENCE: human, agent
#
# Usage:
#   token-restart              # Git-aware smart deploy: sync the live checkout,
#                              #   then restart ONLY the services whose files changed
#   token-restart --no-sync    # Skip the git sync; full restart on current code
#   token-restart --discord    # Restart the Discord daemon only (launchd)
#   token-restart --from <dir> # Update plist to serve from <dir>, then restart
#   token-restart --wsl-only   # WSL satellite only
#   token-restart --kill       # Just kill Mac server, don't restart
#   token-restart --watch      # Restart and monitor startup logs
#   token-restart --status     # All-device status
#   token-restart --sync       # Accepted no-op alias (sync is now the default)
#
# When run from WSL or phone, proxies the restart to Mac via HTTP.
# After healthy restart, reloads any open /ui/ops browser tabs on Mac.
#
# GIT-AWARE SMART DEPLOY (the mantra: a merge to main → one restart endpoint hit →
# this script syncs + intelligently restarts):
#   By DEFAULT token-restart fast-forwards the CD bare cache
#   (CD_BARE_REPO, distinct from the worktree BARE_REPO) from GitHub main, then updates
#   the deploy-owned runtime checkout detached to the
#   requested SHA (or the new bare main). It DIFFS old runtime HEAD → target SHA and
#   restarts ONLY the affected services (token-api / ops-ui / discord / WSL
#   satellite / mobile) — see map_changed_to_services(). Runtime checkouts are
#   deploy artifacts: a dirty tree is auto-preserved to a wip/live-dirty-<ts>
#   branch (pushed to the bare cache) and never blocks the deploy.

set -euo pipefail

# Resolve from BASH_SOURCE (not $0) so the lib paths resolve correctly whether the
# script is executed directly or sourced (e.g. by unit tests exercising functions).
_BIN_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
_LIB_DIR="${_BIN_DIR}/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true
source "${_LIB_DIR}/worktree-park.sh" 2>/dev/null || true

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# Network config
MAC_HOST="$(imperium_cfg tailscale_ip mac)"
MAC_PORT=7777
WSL_HOST="$(imperium_cfg tailscale_ip wsl)"
WSL_PORT=7777

# Mac-only config (only used when running on Mac)
LABEL="ai.openclaw.tokenapi"
# TOKEN_RESTART_PLIST overrides the target plist — used by tests so the in-place
# plist reconcilers (ensure_plist_resource_limits / ensure_plist_socket_activation)
# operate on a throwaway file and can never mutate the live LaunchAgent.
PLIST="${TOKEN_RESTART_PLIST:-$HOME/Library/LaunchAgents/${LABEL}.plist}"

# Discord daemon — launchd-supervised, Mac-only. token-restart is the
# AUTHORITATIVE restart path: launchctl kickstart against KeepAlive. Never use
# `discord-daemon start/restart` (pidfile+nohup) — it split-brains against launchd.
DISCORD_LABEL="ai.tokenclaw.discord"
DISCORD_PLIST="$HOME/Library/LaunchAgents/${DISCORD_LABEL}.plist"
DISCORD_URL="http://127.0.0.1:7779"

# tmuxctld daemon — launchd-supervised, Mac-only, loopback HTTP control plane on
# 127.0.0.1:7778 (ai.tokenclaw.tmuxctld, KeepAlive). Like Discord, token-restart
# bounces it via launchctl DIRECTLY (not `tmuxctld-ctl restart`) so the deploy's
# launchctl calls stay uniform and stub-testable, and so a deploy never shells out
# to the tmux/tmuxctl/tx tooling (the CD "never wipe the fleet" invariant). The
# daemon CODE lands via the normal main→live sync, but Python is not hot-reloaded,
# so the running process must be restarted to pick it up. A PLIST change
# additionally needs bootout+bootstrap of the freshly-synced plist (kickstart -k
# reuses the already-bootstrapped service definition) — mirroring restart_mac's
# plist path and what `tmuxctld-ctl install` does.
TMUXCTLD_LABEL="ai.tokenclaw.tmuxctld"
TMUXCTLD_URL="${TMUXCTLD_URL:-http://127.0.0.1:7778}"
# Source plist ships in the runtime checkout (token-restart runs from there in
# production, so _BIN_DIR resolves to the synced copy); installed copy lives in
# LaunchAgents. Both overridable so tests redirect them off the live LaunchAgent.
TMUXCTLD_SRC_PLIST="${TMUXCTLD_SRC_PLIST:-${_BIN_DIR}/../launchd/${TMUXCTLD_LABEL}.plist}"
TMUXCTLD_PLIST="${TMUXCTLD_PLIST:-$HOME/Library/LaunchAgents/${TMUXCTLD_LABEL}.plist}"

# Local CD topology. Values can be overridden for tests/emergency deploys, or via
# ~/.config/worktrees/Token-OS.conf. The bare repo is the read-only skeleton; the
# runtime checkout is deploy-owned and must stay clean.
conf_value() {
    local conf="$1" name="$2"
    ( BARE_REPO=""; CD_BARE_REPO=""; WORKTREE_PARENT=""; SECRETS_DIR=""; PROTECTED_ROOT=""; RUNTIME_CHECKOUT=""; CD_RUNTIME_CHECKOUT=""; LOCAL_BARE_MAIN_SYNC=""
      # shellcheck disable=SC1090
      [[ -f "$conf" ]] && source "$conf" 2>/dev/null || true
      eval "printf '%s' \"\${$name:-}\"" )
}

TOKEN_OS_WORKTREE_CONF="${TOKEN_OS_WORKTREE_CONF:-$HOME/.config/worktrees/Token-OS.conf}"
TOKEN_OS_BARE_REPO="${TOKEN_OS_BARE_REPO:-${CD_BARE_REPO:-$(conf_value "$TOKEN_OS_WORKTREE_CONF" CD_BARE_REPO)}}"
TOKEN_OS_BARE_REPO="${TOKEN_OS_BARE_REPO:-$(conf_value "$TOKEN_OS_WORKTREE_CONF" BARE_REPO)}"
TOKEN_OS_BARE_REPO="${TOKEN_OS_BARE_REPO:-$HOME/runtimes/Token-OS/token-os.git}"
TOKEN_OS_RUNTIME_CHECKOUT="${TOKEN_OS_RUNTIME_CHECKOUT:-${CD_RUNTIME_CHECKOUT:-$(conf_value "$TOKEN_OS_WORKTREE_CONF" CD_RUNTIME_CHECKOUT)}}"
TOKEN_OS_RUNTIME_CHECKOUT="${TOKEN_OS_RUNTIME_CHECKOUT:-$(conf_value "$TOKEN_OS_WORKTREE_CONF" RUNTIME_CHECKOUT)}"
TOKEN_OS_RUNTIME_CHECKOUT="${TOKEN_OS_RUNTIME_CHECKOUT:-$HOME/runtimes/Token-OS/live}"
TOKEN_OS_SECRETS_DIR="${TOKEN_OS_SECRETS_DIR:-$(conf_value "$TOKEN_OS_WORKTREE_CONF" SECRETS_DIR)}"
TOKEN_RESTART_TARGET_SHA="${TOKEN_RESTART_TARGET_SHA:-}"
TOKEN_SATELLITE_REFRESH_SECRET="${TOKEN_SATELLITE_REFRESH_SECRET:-}"

is_mac() {
    [[ "$IMPERIUM_MACHINE" == "mac" ]]
}

show_help() {
    cat << 'EOF'
token-restart - Git-aware smart deploy + multi-device restart orchestrator

Usage:
    token-restart              Sync live checkout, restart ONLY changed services
    token-restart --no-sync    Skip git sync; full restart on current code
    token-restart --discord    Restart the Discord daemon only (launchd)
    token-restart --from <dir> Update plist to serve from <dir>, then restart
    token-restart --wsl-only   WSL satellite only
    token-restart --kill       Kill Mac process (launchd auto-restarts)
    token-restart --watch      Restart and monitor startup logs
    token-restart --status     All-device status
    token-restart --sync       Accepted alias (sync is the default)
    token-restart --sha <sha>   Deploy this commit after syncing bare main
    token-restart -h, --help   Show this help

    When run from a non-Mac device, proxies to Mac via SSH.

Smart-deploy flow (default):
    0. ff-only sync local bare main from GitHub; update runtime checkout detached
       to --sha/TOKEN_RESTART_TARGET_SHA or bare main. A dirty runtime is
       auto-preserved to a wip/live-dirty-<ts> branch (never blocks the deploy).
    1. If runtime HEAD advanced: diff old→new and restart ONLY the services
       whose files changed:
         token-api/**/*.py|uv.lock|pyproject.toml  → Mac token-api
         token-api/{ui,web}/ops/**                  → token-api + reload ops tabs
         discord-daemon/**                          → Discord daemon (launchd)
         WSL runtime paths (satellite/AHK/cli-tools/refresh helper) → WSL /runtime/refresh
         mobile/**                                    → push-mobile -a (phone)
    2. If the pull was a no-op (already current) or --no-sync: full restart of
       the standard set (Mac token-api → Discord → WSL), preserving the human
       "restart my stuff now" workflow.
    3. Health-check what was restarted, print summary.

Notes:
    - Sync is ff-only at the bare skeleton and detached at the runtime checkout.
      A dirty runtime NEVER blocks deploy: stray WIP is auto-committed to a
      timestamped wip/live-dirty-<ts> branch and pushed to the bare cache, then
      the tree is reset onto the target SHA. The WIP is recoverable from there.
    - WSL restart is fire-and-forget if unreachable
    - WSL satellite self-restarts via systemd (Restart=always)
    - Mac server managed by launchd (ai.openclaw.tokenapi)
    - Discord daemon managed by launchd (ai.tokenclaw.discord) — this is the
      AUTHORITATIVE restart path; do NOT use `discord-daemon restart`
    - Open /ui/ops browser tabs are reloaded after a healthy restart
EOF
}

# ============ Remote Proxy ============
# When run from WSL or phone, proxy to Mac which orchestrates everything

remote_restart() {
    echo -e "${BOLD}=== Token Restart (remote → Mac) ===${NC}"
    echo ""

    echo -e "${BLUE}→${NC} Proxying restart to Mac ($MAC_HOST)..."

    # Pass through relevant flags. Sync is the default on the Mac side, so only
    # the opt-out needs forwarding.
    local flags=""
    [[ "${ACTION}" == "wsl-only" ]] && flags="$flags --wsl-only"
    [[ "${ACTION}" == "discord" ]] && flags="$flags --discord"
    [[ "${SYNC_BEFORE_RESTART}" == false ]] && flags="$flags --no-sync"

    local remote_cmd="$(imperium_cfg nas_imperium mac)/runtimes/token-os/live/cli-tools/bin/token-restart"
    if ssh -o ConnectTimeout=5 -o BatchMode=yes mini "${remote_cmd}${flags}" 2>&1; then
        echo ""
        echo -e "  ${GREEN}✓${NC} Remote restart completed"
    else
        echo -e "  ${RED}✗${NC} Failed to reach Mac via SSH"
        echo "  Ensure 'mini' SSH host is configured and reachable"
        return 1
    fi
}

remote_status() {
    echo -e "${BOLD}=== Multi-Device Status (via Mac) ===${NC}"
    echo ""
    local remote_cmd="$(imperium_cfg nas_imperium mac)/runtimes/token-os/live/cli-tools/bin/token-restart"
    ssh -o ConnectTimeout=5 -o BatchMode=yes mini "${remote_cmd} --status" 2>&1 || {
        echo -e "  ${RED}✗${NC} Cannot reach Mac via SSH"
        # Fall back to direct health checks
        echo ""
        echo -e "${BOLD}Direct checks:${NC}"
        if curl -sf --connect-timeout 2 "http://${MAC_HOST}:${MAC_PORT}/health" > /dev/null 2>&1; then
            echo -e "  Mac:   ${GREEN}●${NC} healthy"
        else
            echo -e "  Mac:   ${RED}●${NC} not responding"
        fi
        if curl -sf --connect-timeout 2 "http://${WSL_HOST}:${WSL_PORT}/health" > /dev/null 2>&1; then
            echo -e "  WSL:   ${GREEN}●${NC} healthy"
        else
            echo -e "  WSL:   ${YELLOW}○${NC} unknown"
        fi
    }
}

# ============ Mac ============

check_mac_health() {
    curl -sf "${TOKEN_API_URL:-http://localhost:7777}/health" > /dev/null 2>&1
}

# Git SHA the LIVE token-api process launched from, self-reported via /health.
# Used to detect a stale process (checkout advanced without a paired restart).
# Matches the QUOTED string value of git_sha; an unquoted `null`, an absent
# field, or an unreachable server all yield empty -> treated as stale by the
# caller (a down server is the worst stale state). `[^"]*` (not `[0-9a-f]*`) so
# the captured token is the SHA verbatim regardless of charset.
mac_running_git_sha() {
    curl -sf "${TOKEN_API_URL:-http://localhost:7777}/health" 2>/dev/null \
        | sed -n 's/.*"git_sha"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
}

# PID of the launchd-managed token-api process, asked of launchd directly
# (authoritative). The process now runs as `python main.py` (not `-m uvicorn …`),
# so the old uvicorn-by-port pgrep pattern no longer matches the command line.
mac_server_pid() {
    launchctl print "gui/$(id -u)/${LABEL}" 2>/dev/null \
        | awk '$1 == "pid" && $2 == "=" { print $3; exit }'
}

get_mac_status() {
    echo -e "${BOLD}Mac token-api${NC}"

    if launchctl print gui/501/${LABEL} > /dev/null 2>&1; then
        echo -e "  Launchd: ${GREEN}loaded${NC}"
    else
        echo -e "  Launchd: ${RED}not loaded${NC}"
    fi

    local pid
    pid=$(mac_server_pid)
    if [[ -n "$pid" ]]; then
        echo -e "  Process: ${GREEN}running${NC} (PID: $pid)"
    else
        echo -e "  Process: ${RED}not running${NC}"
    fi

    if check_mac_health; then
        echo -e "  Health:  ${GREEN}●${NC} healthy"
    else
        echo -e "  Health:  ${RED}●${NC} not responding"
    fi
}

kill_server() {
    echo "Stopping Token-API..."

    local pid
    pid=$(mac_server_pid)
    if [[ -z "$pid" ]]; then
        echo "No process found"
    else
        kill -TERM "$pid" 2>/dev/null && echo "Sent SIGTERM to token-api (PID: $pid)"
        sleep 1
        # Only escalate if the SAME pid is still alive — launchd's KeepAlive may
        # have already respawned a fresh process, which we must not force-kill.
        if kill -0 "$pid" 2>/dev/null; then
            echo -e "${YELLOW}Warning: Process still running, force killing...${NC}"
            kill -9 "$pid" 2>/dev/null || true
        fi
    fi

    echo -e "${GREEN}Server stopped${NC}"
    echo "Note: launchd will auto-restart unless you 'launchctl bootout gui/501/${LABEL}'"
}

runtime_root() {
    printf '%s\n' "${TOKEN_OS_RUNTIME_CHECKOUT}"
}

runtime_write_protect_bin() {
    local candidate="${_BIN_DIR}/../scripts/runtime-write-protect.sh"
    if [[ -x "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    candidate="${TOKEN_OS_RUNTIME_CHECKOUT}/cli-tools/scripts/runtime-write-protect.sh"
    if [[ -x "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    return 1
}

runtime_write_unlock_for_deploy() {
    local dir="$1" helper
    helper="$(runtime_write_protect_bin 2>/dev/null || true)"
    [[ -n "$helper" ]] || return 0
    [[ -e "$dir" ]] || return 0
    "$helper" unlock "$dir" >/dev/null || {
        echo -e "  ${RED}✗${NC} CD-sync: failed to unlock runtime checkout for deploy: $dir"
        return 1
    }
}

runtime_write_lock_after_deploy() {
    local dir="$1" helper
    helper="$(runtime_write_protect_bin 2>/dev/null || true)"
    [[ -n "$helper" ]] || return 0
    [[ -e "$dir" ]] || return 0
    if "$helper" lock "$dir" >/dev/null; then
        echo -e "  ${GREEN}✓${NC} CD-sync: runtime write-protected: $dir"
    else
        echo -e "  ${RED}✗${NC} CD-sync: failed to write-protect runtime checkout: $dir"
        return 1
    fi
}

runtime_write_lock_after_signal() {
    local sig="$1" dir="$2"
    runtime_write_lock_after_deploy "$dir" >/dev/null 2>&1 || true
    # A killed deploy must free BOTH the runtime write-lock and the deploy mutex,
    # so a stale lockdir never blocks the next deploy. No-op if we don't hold it.
    deploy_lock_release
    trap - "$sig"
    kill -s "$sig" "$$"
}

# ============ Deploy mutex (single-runner + trailing coalescing) ============
#
# Two concurrent token-restart deploys — the token-api CD webhook spawn plus a
# manual run, or two rapid back-to-back merges — race on the same uchg-locked
# runtime .git: ref-`.lock` contention during the bare-mirror fetch, and transient
# git `.lock` files vanishing mid-`chflags`-freeze → a false "failed to fetch bare
# refs" / "failed to write-protect" (chflags ENOENT) even though one actor
# deployed cleanly. macOS ships no flock(1), so we serialize with an atomic
# `mkdir` lockdir (portable Mac + Linux satellites, zero deps).
#
# The holder runs full_restart. A contender that finds a LIVE holder drops a
# redeploy-pending sentinel and exits 0 (never races, never stacks). After the
# holder finishes it re-runs the sync+restart once more per queued contender
# (capped) — and because sync_live_checkout re-fetches GitHub main and re-resolves
# the target every call, the trailing run always lands the NEWEST merged SHA. If
# the runtime is already at that SHA the trailing run no-ops. Convergent, bounded,
# and coalescing rather than preemptive: we never interrupt an in-flight
# git/chflags freeze (which could leave a half-locked or partial tree).
DEPLOY_LOCKDIR="${TOKEN_OS_DEPLOY_LOCKDIR:-${TMPDIR:-/tmp}/token-os-cd-deploy.lock}"
DEPLOY_LOCKDIR="${DEPLOY_LOCKDIR%/}"
DEPLOY_LOCK_HELD=false
# Cap on trailing coalescing re-runs so a pathological touch-storm can't loop
# forever; each re-run re-resolves the newest main, so a small cap still converges.
DEPLOY_REDEPLOY_MAX=3
# Set true around a trailing coalescing re-run so full_restart skips the
# no-advance → full-restart fallback (a trailing run that finds nothing new must
# no-op, not bounce every service).
DEPLOY_COALESCE_TRAILING=false

# PID recorded in the lockdir owner file ("<pid> <sha>"), or empty/unreadable.
deploy_lock_owner_pid() {
    local owner="$DEPLOY_LOCKDIR/owner" pid
    [[ -f "$owner" ]] || return 1
    pid="$(cut -d' ' -f1 "$owner" 2>/dev/null || true)"
    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "$pid"
}

deploy_lock_release() {
    [[ "$DEPLOY_LOCK_HELD" == true ]] || return 0
    rm -rf "$DEPLOY_LOCKDIR" 2>/dev/null || true
    DEPLOY_LOCK_HELD=false
}

# Graceful release for the normal end of a deploy. Closes the lost-wakeup race in
# the window between the trailing loop's final sentinel check and the release: a
# contender that touches redeploy-pending there would otherwise see us alive,
# bow out trusting us to re-sync, and have its sentinel rm-rf'd unseen.
#
# We unlink the well-known lock path ATOMICALLY by renaming it aside, which splits
# every interleaving cleanly:
#   - contender touched BEFORE the rename → its sentinel rode into $sealed; we see
#     it, restore the lock (mv back), and report pending so the caller drains it;
#   - contender touches AFTER the rename → its `touch` hits a vanished path and
#     its own `[[ -d $DEPLOY_LOCKDIR ]]` recheck fails, so it stops trusting us and
#     loops to mkdir a fresh lock — becoming the new holder and converging itself.
# Returns 0 if released, 1 if a re-sync is still queued (lock retained; drain it).
deploy_lock_release_graceful() {
    [[ "$DEPLOY_LOCK_HELD" == true ]] || return 0
    local sealed="${DEPLOY_LOCKDIR}.releasing.$$"
    if ! mv "$DEPLOY_LOCKDIR" "$sealed" 2>/dev/null; then
        # Lock path already gone (shouldn't happen while we hold it) — force-release.
        deploy_lock_release
        return 0
    fi
    if [[ -f "$sealed/redeploy-pending" ]]; then
        # A contender queued a re-sync just before we sealed. Keep holding and drain
        # it. If restore fails, a contender already mkdir'd a fresh lock and is the
        # new holder — let it converge and release ours.
        if mv "$sealed" "$DEPLOY_LOCKDIR" 2>/dev/null; then
            return 1
        fi
        rm -rf "$sealed" 2>/dev/null || true
        DEPLOY_LOCK_HELD=false
        return 0
    fi
    rm -rf "$sealed" 2>/dev/null || true
    DEPLOY_LOCK_HELD=false
    return 0
}

# Acquire the deploy mutex. Returns 0 if we now hold it (caller runs full_restart);
# returns 1 if a LIVE deploy holds it — in which case we've queued a trailing
# re-sync and the caller must exit 0 without deploying.
deploy_lock_acquire() {
    local target="${1:-}"
    local tries=0 missing_owner=0
    local max_tries=100
    while (( tries < max_tries )); do
        tries=$((tries + 1))
        if mkdir "$DEPLOY_LOCKDIR" 2>/dev/null; then
            DEPLOY_LOCK_HELD=true
            # The owner file IS the lock's identity: a contender reads it to decide
            # live-vs-stale. If we can't write it, the lockdir would be an
            # unidentifiable held lock that a contender reclaims out from under us
            # (→ two concurrent holders). Release and fail acquisition instead.
            if ! printf '%s %s\n' "$$" "$target" > "$DEPLOY_LOCKDIR/owner" 2>/dev/null; then
                echo -e "  ${RED}✗${NC} deploy mutex: failed to write owner file; releasing lock" >&2
                deploy_lock_release
                return 1
            fi
            return 0
        fi

        local pid
        pid="$(deploy_lock_owner_pid 2>/dev/null || true)"

        if [[ -z "$pid" ]]; then
            # Lockdir exists but no owner yet: either a holder still initialising
            # (owner is written immediately after mkdir) or a crashed deploy that
            # never wrote one. Grace a few polls before reclaiming so we never blow
            # away a live holder mid-init.
            missing_owner=$((missing_owner + 1))
            if (( missing_owner < 5 )); then
                sleep 0.1
                continue
            fi
            rm -rf "$DEPLOY_LOCKDIR" 2>/dev/null || true
            missing_owner=0
            continue
        fi
        missing_owner=0

        if kill -0 "$pid" 2>/dev/null; then
            # A live deploy holds the lock: queue a trailing re-sync and bow out so
            # the holder converges on the newest main after it finishes.
            touch "$DEPLOY_LOCKDIR/redeploy-pending" 2>/dev/null || true
            # Close the holder-release race: if the holder vanished right after we
            # queued (our sentinel possibly rm-rf'd with the dir), loop and try to
            # become the holder ourselves rather than dropping the deploy.
            if [[ -d "$DEPLOY_LOCKDIR" ]] && kill -0 "$pid" 2>/dev/null; then
                local osha=""
                [[ -f "$DEPLOY_LOCKDIR/owner" ]] && \
                    osha="$(cut -d' ' -f2 "$DEPLOY_LOCKDIR/owner" 2>/dev/null || true)"
                echo -e "${YELLOW}⚠${NC} deploy already in progress (pid=${pid}, sha=${osha:0:9}) — queued a trailing re-sync; exiting"
                return 1
            fi
            continue
        fi

        # Owner PID is dead → stale lock from a crashed deploy. Reclaim and retry.
        echo -e "${YELLOW}⚠${NC} deploy mutex: reclaiming stale lock from dead pid ${pid}" >&2
        rm -rf "$DEPLOY_LOCKDIR" 2>/dev/null || true
    done

    echo -e "  ${RED}✗${NC} deploy mutex: gave up acquiring ${DEPLOY_LOCKDIR}" >&2
    return 1
}

# Reset the per-run sync/restart globals so a trailing coalescing re-run starts
# clean and re-resolves the newest target instead of inheriting the prior run.
_reset_deploy_run_state() {
    # A queued trailing re-sync must converge on the newest fetched main, not stay
    # pinned to the first webhook's TOKEN_RESTART_TARGET_SHA. Leaving the target
    # env set made rapid merges falsely report "already at newest" while the bare
    # repo had advanced past the pinned SHA.
    TOKEN_RESTART_TARGET_SHA=""
    SYNC_DID_ADVANCE=false
    SYNC_CHANGED_PATHS=""
    SYNC_TARGET_SHA=""
    TMUX_CONFIG_CHANGED=false
    RESTART_TOKENAPI=false
    RESTART_OPS=false
    RESTART_DISCORD=false
    RESTART_TMUXCTLD=false
    TMUXCTLD_PLIST_CHANGED=false
    RESTART_WSL=false
    REFRESH_WSL=false
    RESTART_MOBILE=false
}

# Serialize full_restart under the deploy mutex with trailing coalescing. If a
# live deploy already holds the mutex, we queued a trailing re-sync inside
# deploy_lock_acquire and return 0 without deploying. Otherwise we hold the mutex,
# run full_restart, then re-run it once per queued contender (bounded) so rapid
# merges converge on the newest bare-main SHA. The mutex (and runtime write-lock)
# are freed on every exit path — normal, error, or signal.
run_coalesced_deploy() {
    # Best-effort target SHA for the owner file (diagnostics only; the authoritative
    # target is re-resolved inside sync_live_checkout on every run).
    local target="${TOKEN_RESTART_TARGET_SHA:-}"
    [[ -n "$target" ]] || \
        target="$(git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse -q --verify refs/heads/main 2>/dev/null || true)"

    if ! deploy_lock_acquire "$target"; then
        return 0
    fi

    local quoted_root
    printf -v quoted_root '%q' "$(runtime_root)"
    trap 'deploy_lock_release' EXIT
    trap "runtime_write_lock_after_signal INT $quoted_root" INT
    trap "runtime_write_lock_after_signal TERM $quoted_root" TERM

    # Primary deploy. Run inside an if so `set -e` does not abort before we capture
    # the status; the primary run's status is what the whole command returns.
    local rc=0
    if full_restart; then rc=0; else rc=$?; fi

    # Trailing coalescing: converge on any merge a contender flagged mid-deploy.
    # The inner loop drains queued re-syncs (clearing the sentinel BEFORE each
    # re-run so a merge landing DURING it re-arms it). The outer loop closes the
    # release-window race: deploy_lock_release_graceful retains the lock and
    # reports pending=1 if a contender queued one between the inner loop's exit
    # test and the release — so we drain that too instead of dropping it.
    local iter=0
    while true; do
        while [[ -f "$DEPLOY_LOCKDIR/redeploy-pending" && "$iter" -lt "$DEPLOY_REDEPLOY_MAX" ]]; do
            rm -f "$DEPLOY_LOCKDIR/redeploy-pending" 2>/dev/null || true
            iter=$((iter + 1))
            echo ""
            echo -e "${BLUE}→${NC} deploy: trailing re-sync ${iter}/${DEPLOY_REDEPLOY_MAX} (a concurrent invocation queued one) — converging on newest main"
            _reset_deploy_run_state
            DEPLOY_COALESCE_TRAILING=true
            full_restart || echo -e "  ${YELLOW}⚠${NC} deploy: trailing re-sync ${iter} did not complete cleanly (primary deploy already applied)"
            DEPLOY_COALESCE_TRAILING=false
        done

        if (( iter >= DEPLOY_REDEPLOY_MAX )); then
            # Bounded: a pathological touch-storm hit the cap. Force-release and let
            # the queuing merge's own deploy trigger reconverge.
            if [[ -f "$DEPLOY_LOCKDIR/redeploy-pending" ]]; then
                echo -e "  ${YELLOW}⚠${NC} deploy: trailing re-sync cap (${DEPLOY_REDEPLOY_MAX}) reached; the next deploy trigger will reconverge"
            fi
            deploy_lock_release
            break
        fi

        if deploy_lock_release_graceful; then
            break
        fi
        # graceful retained the lock: a re-sync was queued in the release window —
        # loop back to drain it.
    done

    trap - EXIT INT TERM
    return "$rc"
}

sync_venv_if_needed() {
    local root
    root="$(runtime_root)"
    local lockfile="${root}/token-api/uv.lock"
    local checksum_file="$HOME/.local/venvs/token-api/.uv-lock-checksum"
    local venv_dir="$HOME/.local/venvs/token-api"

    if [[ ! -f "$lockfile" ]]; then
        return 0
    fi

    local current_checksum
    current_checksum=$(shasum -a 256 "$lockfile" 2>/dev/null | cut -d' ' -f1)
    local stored_checksum=""
    [[ -f "$checksum_file" ]] && stored_checksum=$(cat "$checksum_file" 2>/dev/null)

    if [[ "$current_checksum" != "$stored_checksum" ]]; then
        echo -e "${BLUE}→${NC} uv.lock changed, syncing venv..."
        if (cd "${root}/token-api" && UV_PROJECT_ENVIRONMENT="$venv_dir" uv sync 2>&1); then
            echo "$current_checksum" > "$checksum_file"
            echo -e "  ${GREEN}✓${NC} Venv synced"
        else
            echo -e "  ${YELLOW}⚠${NC} Venv sync failed (continuing with existing venv)"
        fi
    fi
}

# ============ Code-sync (default; opt out with --no-sync) ============
#
# Before restarting, synchronize the local bare skeleton from GitHub main and
# update the deploy-owned runtime checkout detached to the requested target SHA
# (or bare main). On a successful runtime advance it records SYNC_DID_ADVANCE +
# SYNC_CHANGED_PATHS so full_restart() can restart only the services changed.
#
# SAFETY (load-bearing):
#   - Bare main fast-forwards only. We never force local main to a non-ancestor.
#   - A dirty runtime checkout NEVER blocks the deploy. Stray WIP is an
#     operational error, but instead of aborting, CD auto-commits it to a
#     timestamped wip/live-dirty-<ts> branch and pushes that to the durable bare
#     cache, THEN resets the tree onto the deploy target. The WIP is recoverable
#     from the bare cache; deploys can never jam on dirt (the new invariant that
#     replaces the #280 dirty-tree-abort / hard-reconcile).
#   - On sync failure, abort the restart loudly instead of running ambiguous code.

resolve_live_checkout() {
    # Backward-compatible test/emergency override. In the new topology this means
    # runtime checkout, not protected main checkout.
    if [[ -n "${CD_LIVE_CHECKOUT:-}" && -d "${CD_LIVE_CHECKOUT}" ]]; then
        printf '%s
' "${CD_LIVE_CHECKOUT}"
        return 0
    fi
    printf '%s\n' "${TOKEN_OS_RUNTIME_CHECKOUT}"
}

ensure_bare_repo() {
    if [[ ! -d "$TOKEN_OS_BARE_REPO" ]]; then
        echo -e "  ${RED}✗${NC} CD-sync: bare repo not found: $TOKEN_OS_BARE_REPO"
        return 1
    fi
    if [[ "$(git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse --is-bare-repository 2>/dev/null)" != "true" ]]; then
        echo -e "  ${RED}✗${NC} CD-sync: not a bare repo: $TOKEN_OS_BARE_REPO"
        return 1
    fi
}

ensure_runtime_aux_files() {
    local dir="$1"
    local exclude="$dir/.git/info/exclude"
    if [[ -f "$exclude" ]]; then
        grep -qxF 'discord-daemon/node_modules' "$exclude" 2>/dev/null || cat >> "$exclude" <<'EOF'
discord-daemon/node_modules
.smbdelete*
config.json
token-api/.env
EOF
    fi
    if [[ -n "$TOKEN_OS_SECRETS_DIR" && -d "$TOKEN_OS_SECRETS_DIR" ]]; then
        [[ -e "$dir/config.json" || ! -e "$TOKEN_OS_SECRETS_DIR/config.json" ]] || \
            ln -s "$TOKEN_OS_SECRETS_DIR/config.json" "$dir/config.json"
        [[ -e "$dir/token-api/.env" || ! -e "$TOKEN_OS_SECRETS_DIR/token-api/.env" ]] || \
            ln -s "$TOKEN_OS_SECRETS_DIR/token-api/.env" "$dir/token-api/.env"
    fi
}

runtime_is_dirty() {
    local dir="$1"
    [[ -d "$dir/.git" || -f "$dir/.git" ]] || return 1
    [[ -n "$(git -C "$dir" status --porcelain 2>/dev/null)" ]]
}

sync_bare_main() {
    # Reconciler park-sweep (incident 2026-06-22): any agent worktree left checked
    # out *on* main/master pins the branch ref and jams the bare-main fast-forward
    # (`git fetch … main:main` / `pull --ff-only` refuse a worktree-held branch).
    # Park them off main first — detach in place at the current SHA, preserving any
    # uncommitted edits. The detached deploy runtime is never matched. Best-effort.
    if declare -f park_worktrees_off_main >/dev/null 2>&1; then
        local _parked
        _parked="$(park_worktrees_off_main "$TOKEN_OS_BARE_REPO" 2>/dev/null || true)"
        if [[ -n "$_parked" ]]; then
            echo -e "${YELLOW}⚠${NC} CD-sync: parked worktree(s) off main before fast-forward:"
            printf '  %s\n' "$_parked" >&2
        fi
    fi
    echo -e "${BLUE}→${NC} CD-sync: fetching GitHub main into bare skeleton $TOKEN_OS_BARE_REPO..."
    if ! git --git-dir="$TOKEN_OS_BARE_REPO" fetch origin main >/dev/null 2>&1; then
        echo -e "  ${RED}✗${NC} CD-sync: 'git fetch origin main' failed for bare skeleton"
        return 1
    fi
    local old_main new_main
    old_main="$(git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse -q --verify refs/heads/main 2>/dev/null || true)"
    new_main="$(git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse FETCH_HEAD 2>/dev/null || true)"
    [[ -n "$new_main" ]] || { echo -e "  ${RED}✗${NC} CD-sync: FETCH_HEAD did not resolve"; return 1; }
    if [[ -n "$old_main" && "$old_main" != "$new_main" ]]; then
        if ! git --git-dir="$TOKEN_OS_BARE_REPO" merge-base --is-ancestor "$old_main" "$new_main"; then
            echo -e "  ${RED}✗${NC} CD-sync: bare main is not a fast-forward (${old_main:0:9} → ${new_main:0:9})"
            return 1
        fi
    fi
    git --git-dir="$TOKEN_OS_BARE_REPO" update-ref refs/heads/main "$new_main"
    git --git-dir="$TOKEN_OS_BARE_REPO" update-ref refs/remotes/origin/main "$new_main" 2>/dev/null || true
    if [[ "$old_main" == "$new_main" ]]; then
        echo -e "  ${GREEN}✓${NC} CD-sync: bare main already current (${new_main:0:9})"
    else
        echo -e "  ${GREEN}✓${NC} CD-sync: bare main fast-forwarded ${old_main:0:9} → ${new_main:0:9}"
    fi
}

resolve_deploy_target() {
    local target="${TOKEN_RESTART_TARGET_SHA:-}"
    [[ -n "$target" ]] || target="$(git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse refs/heads/main 2>/dev/null || true)"
    [[ -n "$target" ]] || { echo -e "  ${RED}✗${NC} CD-sync: no deploy target resolved"; return 1; }
    if ! git --git-dir="$TOKEN_OS_BARE_REPO" cat-file -e "$target^{commit}" 2>/dev/null; then
        echo -e "  ${RED}✗${NC} CD-sync: requested deploy target is not present in bare repo: $target"
        return 1
    fi
    git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse "$target^{commit}"
}

validate_runtime_checkout_path() {
    local dir="$1"
    if [[ -L "$dir" ]]; then
        echo -e "  ${RED}✗${NC} CD-sync: runtime path must not be a symlink: $dir"
        return 1
    fi
    if [[ -e "$dir" && ! -d "$dir/.git" && ! -f "$dir/.git" ]]; then
        echo -e "  ${RED}✗${NC} CD-sync: runtime path exists but is not a git checkout: $dir"
        return 1
    fi
}

ensure_runtime_checkout() {
    local dir="$1"
    validate_runtime_checkout_path "$dir" || return 1
    if [[ ! -e "$dir" ]]; then
        echo -e "${BLUE}→${NC} CD-sync: creating runtime checkout $dir..."
        mkdir -p "$(dirname "$dir")"
        git clone "$TOKEN_OS_BARE_REPO" "$dir" >/dev/null 2>&1 || {
            echo -e "  ${RED}✗${NC} CD-sync: failed to clone runtime checkout"
            return 1
        }
    fi
    # Aux symlinks are best-effort — never let a missing secrets file fail the
    # deploy (this runs under `set +e`, so swallow its exit explicitly).
    ensure_runtime_aux_files "$dir"
    # NOTE: a dirty tree is NOT an error here — _sync_live_checkout_unlocked()
    # shunts any uncommitted WIP to a wip/live-dirty-<ts> branch before deploy.
    return 0
}

# Dirty-shunt: auto-preserve any uncommitted runtime work so it can NEVER block a
# deploy. Commits the dirt (tracked edits + non-ignored untracked) onto a
# timestamped wip/live-dirty-<ts> branch and pushes it to the durable bare cache,
# leaving the working tree clean for the caller to reset onto the deploy target.
# Ignored files (config.json, token-api/.env, node_modules, …) are never touched.
# The timestamp comes from runtime `date`, never hardcoded. Returns non-zero only
# if the WIP could not be safely staged, committed, AND pushed — in which case we
# abort rather than reset over dirt we failed to preserve (never silent data loss).
shunt_dirty_runtime() {
    local dir="$1" ts base branch wip_sha suffix=0
    ts="$(date +%Y%m%d-%H%M%S)"
    # Seed with the PID so two concurrent deploys never collide, then make the name
    # unique against the actual push target (the bare cache) so a same-second retry
    # can't reuse an existing ref — a collision would fail checkout-b/push and bring
    # back a deploy-blocking path, defeating the whole invariant.
    base="wip/live-dirty-${ts}-$$"
    branch="$base"
    while git --git-dir="$TOKEN_OS_BARE_REPO" show-ref --verify --quiet "refs/heads/${branch}"; do
        suffix=$((suffix + 1))
        branch="${base}-${suffix}"
    done

    echo -e "${YELLOW}⚠${NC} CD-sync: runtime is dirty; auto-preserving WIP to ${branch} before deploy"
    git -C "$dir" status --short >&2 || true

    # Branch off the current (detached) HEAD, keeping the working-tree changes, so
    # the commit captures exactly the dirt that made the tree dirty.
    if ! git -C "$dir" checkout -b "$branch" >/dev/null 2>&1; then
        echo -e "  ${RED}✗${NC} CD-sync: failed to create WIP branch ${branch}"
        return 1
    fi
    # A partial `git add` would let the commit/push succeed while the later hard
    # reset silently drops the unstaged dirt — so a staging failure must abort,
    # never be swallowed.
    if ! git -C "$dir" add -A; then
        echo -e "  ${RED}✗${NC} CD-sync: failed to stage dirty runtime changes for ${branch}"
        return 1
    fi
    if ! git -C "$dir" \
            -c user.name="token-cd" -c user.email="cd@token-os.local" \
            commit -q -m "wip(live): auto-preserved dirty runtime at deploy ${ts}" >/dev/null 2>&1; then
        echo -e "  ${RED}✗${NC} CD-sync: failed to commit dirty runtime to ${branch}"
        return 1
    fi
    wip_sha="$(git -C "$dir" rev-parse HEAD 2>/dev/null || true)"

    # Push to the durable bare cache so the WIP survives the upcoming reset and is
    # recoverable later. If we can't preserve it durably, abort rather than risk
    # discarding uncommitted work in the reset.
    if ! git -C "$dir" push "$TOKEN_OS_BARE_REPO" "refs/heads/${branch}:refs/heads/${branch}" >/dev/null 2>&1; then
        echo -e "  ${RED}✗${NC} CD-sync: failed to push ${branch} to bare cache; aborting to avoid losing WIP"
        return 1
    fi
    echo -e "  ${GREEN}✓${NC} CD-sync: preserved dirty runtime → ${branch} (${wip_sha:0:9}); pushed to bare cache"

    # Detach off the WIP branch so the caller's reset doesn't move the branch ref.
    git -C "$dir" checkout --detach "$wip_sha" >/dev/null 2>&1 || true
    return 0
}

_sync_live_checkout_unlocked() {
    local dir="$1" target="$2" old_head changed_paths

    ensure_runtime_checkout "$dir" || return 1

    old_head="$(git -C "$dir" rev-parse -q --verify HEAD 2>/dev/null || true)"

    # Mirror the bare refs into the runtime's refs/remotes/local-bare/* for
    # convenience/inspection only — the deploy checkout reads objects directly from
    # $TOKEN_OS_BARE_REPO (the `git checkout --detach "$target"` below), not from
    # these refs. A partial mirror-fetch (e.g. transient ref-`.lock` contention)
    # must therefore NOT abort an otherwise-valid deploy; warn like the origin
    # refresh below and continue.
    if ! git -C "$dir" fetch "$TOKEN_OS_BARE_REPO" '+refs/heads/*:refs/remotes/local-bare/*' >/dev/null 2>&1; then
        echo -e "  ${YELLOW}⚠${NC} CD-sync: failed to mirror bare refs into runtime (continuing; deploy reads objects directly from the bare repo)"
    fi
    if ! git -C "$dir" fetch origin --prune >/dev/null 2>&1; then
        echo -e "  ${YELLOW}⚠${NC} CD-sync: failed to refresh runtime origin refs (continuing)"
    fi

    # Dirty-shunt (the new invariant): if the runtime has uncommitted WIP, preserve
    # it to a wip/live-dirty-<ts> branch + push, then deploy over the now-clean tree.
    # A dirty runtime NEVER blocks the deploy. This replaces the #280 abort path.
    local did_shunt=false
    if runtime_is_dirty "$dir"; then
        shunt_dirty_runtime "$dir" || return 1
        did_shunt=true
    fi

    # Only short-circuit when the tree is already exactly the target AND we did not
    # have to shunt — after a shunt the HEAD has moved, so we must reset onto target.
    if [[ "$old_head" == "$target" && "$did_shunt" == false ]]; then
        echo -e "  ${GREEN}✓${NC} CD-sync: runtime already at ${target:0:9} — no sync needed"
        return 0
    fi

    echo -e "${BLUE}→${NC} CD-sync: updating runtime $dir detached → ${target:0:9}..."
    git -C "$dir" checkout --detach "$target" >/dev/null 2>&1 || {
        echo -e "  ${RED}✗${NC} CD-sync: failed to checkout runtime target ${target:0:9}"
        return 1
    }
    git -C "$dir" reset --hard "$target" >/dev/null 2>&1 || {
        echo -e "  ${RED}✗${NC} CD-sync: failed to hard-reset runtime target ${target:0:9}"
        return 1
    }

    if [[ "$old_head" == "$target" ]]; then
        # Shunt-only deploy: code is unchanged, we just reclaimed a clean tree.
        changed_paths=""
        echo -e "  ${GREEN}✓${NC} CD-sync: runtime cleaned to ${target:0:9} (WIP shunted; code unchanged)"
    elif [[ -n "$old_head" ]]; then
        changed_paths="$(git --git-dir="$TOKEN_OS_BARE_REPO" diff --name-only "$old_head" "$target" 2>/dev/null || true)"
        echo -e "  ${GREEN}✓${NC} CD-sync: runtime advanced ${old_head:0:9} → ${target:0:9}"
    else
        changed_paths="$(git --git-dir="$TOKEN_OS_BARE_REPO" ls-tree -r --name-only "$target" 2>/dev/null || true)"
        echo -e "  ${GREEN}✓${NC} CD-sync: runtime initialized at ${target:0:9}"
    fi

    SYNC_DID_ADVANCE=true
    SYNC_CHANGED_PATHS="$changed_paths"
    return 0
}

sync_live_checkout() {
    ensure_bare_repo || return 1
    sync_bare_main || return 1

    local dir target rc lock_rc
    dir="$(resolve_live_checkout)" || return 1
    target="$(resolve_deploy_target)" || return 1
    SYNC_TARGET_SHA="$target"

    validate_runtime_checkout_path "$dir" || return 1
    runtime_write_unlock_for_deploy "$dir" || return 1

    # Re-lock the runtime on signal during the unlocked deploy window. Capture any
    # outer INT/TERM traps (the deploy-mutex handlers from run_coalesced_deploy)
    # and RESTORE them afterwards rather than resetting to default, so a signal
    # arriving later in full_restart still frees the mutex.
    local quoted_dir prev_int prev_term
    printf -v quoted_dir '%q' "$dir"
    prev_int="$(trap -p INT)"
    prev_term="$(trap -p TERM)"
    trap "runtime_write_lock_after_signal INT $quoted_dir" INT
    trap "runtime_write_lock_after_signal TERM $quoted_dir" TERM

    set +e
    _sync_live_checkout_unlocked "$dir" "$target"
    rc=$?
    runtime_write_lock_after_deploy "$dir"
    lock_rc=$?
    eval "${prev_int:-trap - INT}"
    eval "${prev_term:-trap - TERM}"
    set -e
    [[ "$rc" -eq 0 ]] || return "$rc"
    return "$lock_rc"
}

real_tmux_binary() {
    # Match tmuxctl.tmux_adapter._tmux_binary: honor explicit real-binary env
    # overrides first, then skip this repo's optional cli-tools/bin/tmux shim.
    local env_name candidate wrapper
    for env_name in IMPERIUM_TMUX_BIN REAL_TMUX TMUX_BIN; do
        candidate="${!env_name:-}"
        if [[ -n "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    wrapper="${_BIN_DIR}/tmux"
    for candidate in \
        "$(command -v tmux 2>/dev/null || true)" \
        "/opt/homebrew/bin/tmux" \
        "/usr/local/bin/tmux" \
        "/usr/bin/tmux" \
        "/bin/tmux"
    do
        [[ -n "$candidate" && -x "$candidate" ]] || continue
        if [[ -e "$wrapper" ]]; then
            local resolved_candidate resolved_wrapper
            resolved_candidate="$(readlink -f "$candidate" 2>/dev/null || printf '%s' "$candidate")"
            resolved_wrapper="$(readlink -f "$wrapper" 2>/dev/null || printf '%s' "$wrapper")"
            [[ "$resolved_candidate" == "$resolved_wrapper" ]] && continue
        fi
        printf '%s\n' "$candidate"
        return 0
    done
    printf '%s\n' "tmux"
}

source_tmux_config_if_changed() {
    [[ "${TMUX_CONFIG_CHANGED:-false}" == true ]] || return 0
    [[ "${SYNC_DID_ADVANCE:-false}" == true ]] || return 0

    local tmux_bin tmux_conf
    tmux_bin="$(real_tmux_binary)"
    tmux_conf="$HOME/.tmux.conf"

    if [[ ! -f "$tmux_conf" ]]; then
        echo -e "  ${YELLOW}⚠${NC} tmux config changed, but $tmux_conf is missing — skipping live source"
        return 0
    fi

    if ! "$tmux_bin" has-session >/dev/null 2>&1; then
        echo -e "  ${YELLOW}○${NC} tmux config changed, but no running tmux server is available — skipping live source"
        return 0
    fi

    echo -e "${BLUE}→${NC} tmux config changed — sourcing ${tmux_conf} into the running server..."
    if "$tmux_bin" source-file "$tmux_conf"; then
        echo -e "  ${GREEN}✓${NC} tmux config sourced"
        return 0
    fi
    echo -e "  ${RED}✗${NC} tmux source-file failed: ${tmux_conf}"
    return 1
}


verify_mac_git_sha() {
    local expected="${SYNC_TARGET_SHA:-${TOKEN_RESTART_TARGET_SHA:-}}"
    [[ -n "$expected" ]] || return 0

    local attempts=0 running=""
    while [[ $attempts -lt 15 ]]; do
        running="$(mac_running_git_sha)"
        if [[ "$running" == "$expected" ]]; then
            echo -e "  ${GREEN}✓${NC} deploy verified: /health git_sha=${expected:0:9}"
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 1
    done

    echo -e "  ${RED}✗${NC} DEPLOY VERIFY ALARM: /health git_sha='${running:-unreachable}' != expected ${expected}"
    return 1
}

restart_mac() {
    echo -e "${BLUE}→${NC} Restarting Mac token-api..."

    sync_venv_if_needed

    # Reconcile the plist (fd limits + socket activation). A plist change is NOT
    # honored by kickstart/SIGTERM — launchd reuses the already-bootstrapped
    # service definition — so a change forces a bootout+bootstrap, which also
    # starts a fresh process on the (now launchd-owned) socket.
    local plist_changed=false
    if ! ensure_plist_resource_limits; then
        echo -e "  ${BLUE}→${NC} fd limits updated (soft=${FD_SOFT_LIMIT}/hard=${FD_HARD_LIMIT})"
        plist_changed=true
    fi
    if ! ensure_plist_socket_activation; then
        echo -e "  ${BLUE}→${NC} socket activation reconciled (launchd owns port ${MAC_PORT})"
        plist_changed=true
    fi

    # old_pid lets the health poll below confirm the NEW process is serving
    # rather than the old one still draining (which keeps answering /health 200).
    # Empty => no incumbent to outlive (bootout/bootstrap or cold start), so the
    # poll falls back to plain health.
    local old_pid=""
    if [[ "$plist_changed" == true ]]; then
        echo -e "  ${BLUE}→${NC} reloading service (plist changed)"
        launchctl bootout gui/501/${LABEL} 2>/dev/null || true
        launchctl bootstrap gui/501 "$PLIST" 2>/dev/null || true
    else
        # Graceful drain: SIGTERM lets uvicorn finish in-flight requests (bounded
        # by main.py's timeout_graceful_shutdown) before exiting; launchd's
        # KeepAlive then respawns it onto the retained, launchd-owned socket.
        # New connections queue in the kernel accept backlog meanwhile — they
        # stall briefly, never connection-refused. (kickstart -k would SIGKILL
        # and reset every in-flight request.)
        old_pid=$(mac_server_pid)
        if [[ -n "$old_pid" ]]; then
            echo -e "  ${BLUE}→${NC} draining in-flight requests (SIGTERM pid=$old_pid), launchd will respawn…"
            kill -TERM "$old_pid" 2>/dev/null || true
        else
            echo "  Service not loaded, bootstrapping..."
            launchctl bootstrap gui/501 "$PLIST" 2>/dev/null || true
        fi
    fi

    local attempts=0
    # Allow for the worst-case graceful drain (timeout_graceful_shutdown=10s) plus
    # fresh-process startup before declaring failure.
    local max_attempts=20

    while [[ $attempts -lt $max_attempts ]]; do
        sleep 1
        # In the graceful path, wait for a respawned pid (different from the one we
        # signalled) before trusting /health — the old process keeps answering 200
        # while it drains, so health alone would report the stale process as "up".
        if [[ -n "$old_pid" ]]; then
            local cur_pid
            cur_pid=$(mac_server_pid)
            if [[ -z "$cur_pid" || "$cur_pid" == "$old_pid" ]]; then
                attempts=$((attempts + 1))
                echo "  Waiting for respawn... ($attempts/$max_attempts)"
                continue
            fi
        fi
        if check_mac_health; then
            echo -e "  ${GREEN}✓${NC} Mac server is up and healthy"
            return 0
        fi
        attempts=$((attempts + 1))
        echo "  Waiting... ($attempts/$max_attempts)"
    done

    echo -e "  ${RED}✗${NC} Mac server failed to start within ${max_attempts}s"
    echo "  Check logs: tail ~/.claude/token-api-stderr.log"
    return 1
}

# ============ Discord ============

check_discord_health() {
    # Healthy = daemon up AND actually connected to Discord. A 200 from /status
    # alone isn't enough (the HTTP API binds before the gateway connects), so
    # require "connected": true in the body.
    curl -sf "${DISCORD_URL}/status" 2>/dev/null \
        | grep -q '"connected"[[:space:]]*:[[:space:]]*true'
}

get_discord_status() {
    echo -e "${BOLD}Discord daemon${NC} (${DISCORD_URL})"

    if launchctl print "gui/$(id -u)/${DISCORD_LABEL}" > /dev/null 2>&1; then
        echo -e "  Launchd: ${GREEN}loaded${NC}"
    else
        echo -e "  Launchd: ${RED}not loaded${NC}"
    fi

    if check_discord_health; then
        echo -e "  Health:  ${GREEN}●${NC} connected"
    else
        echo -e "  Health:  ${RED}●${NC} not responding"
    fi
}

restart_discord() {
    echo -e "${BLUE}→${NC} Restarting Discord daemon (launchd)..."

    launchctl kickstart -k "gui/$(id -u)/${DISCORD_LABEL}" 2>/dev/null || {
        echo "  Service not loaded, bootstrapping..."
        launchctl bootstrap "gui/$(id -u)" "$DISCORD_PLIST" 2>/dev/null || true
    }

    # The kickstart above already succeeded — launchd (KeepAlive) now owns
    # liveness. This loop only waits to CONFIRM the daemon is back. Cold-start
    # from the NAS is slow (node loads node_modules over SMB in an uninterruptible
    # read, ~1-3 min on a cold mount cache), so confirmation is best-effort.
    local attempts=0
    local max_attempts=45

    printf '  waiting for Discord daemon'
    while [[ $attempts -lt $max_attempts ]]; do
        sleep 1
        if check_discord_health; then
            printf '\n'
            echo -e "  ${GREEN}✓${NC} Discord daemon is up and connected"
            return 0
        fi
        printf '.'
        attempts=$((attempts + 1))
    done
    printf '\n'

    echo -e "  ${YELLOW}○${NC} Kickstart issued; daemon still cold-loading from NAS."
    echo -e "    launchd will bring it up — confirm with: discord-daemon status"
    return 0
}

# ============ tmuxctld daemon ============

check_tmuxctld_health() {
    curl -sf "${TMUXCTLD_URL}/health" > /dev/null 2>&1
}

get_tmuxctld_status() {
    echo -e "${BOLD}tmuxctld daemon${NC} (${TMUXCTLD_URL})"

    if launchctl print "gui/$(id -u)/${TMUXCTLD_LABEL}" > /dev/null 2>&1; then
        echo -e "  Launchd: ${GREEN}loaded${NC}"
    else
        echo -e "  Launchd: ${RED}not loaded${NC}"
    fi

    if check_tmuxctld_health; then
        echo -e "  Health:  ${GREEN}●${NC} healthy"
    else
        echo -e "  Health:  ${RED}●${NC} not responding"
    fi
}

# Restart the launchd-supervised tmuxctld daemon to pick up freshly-synced code.
# Fail-soft: a daemon that won't come back must NOT abort the rest of the deploy
# (mirrors restart_discord — launchd KeepAlive owns liveness; this only confirms).
restart_tmuxctld() {
    echo -e "${BLUE}→${NC} Restarting tmuxctld daemon (launchd)..."

    if [[ "${TMUXCTLD_PLIST_CHANGED:-false}" == true ]]; then
        # A changed plist is NOT honored by `kickstart -k` (launchd reuses the
        # already-bootstrapped service definition), so reinstall: copy the synced
        # plist into LaunchAgents, then bootout+bootstrap. Same shape as
        # restart_mac's plist-changed path and `tmuxctld-ctl install`.
        echo -e "  ${BLUE}→${NC} plist changed — reinstalling (bootout+bootstrap)"
        if [[ -f "$TMUXCTLD_SRC_PLIST" ]]; then
            mkdir -p "$(dirname "$TMUXCTLD_PLIST")"
            cp "$TMUXCTLD_SRC_PLIST" "$TMUXCTLD_PLIST" 2>/dev/null \
                || echo -e "  ${YELLOW}⚠${NC} could not copy plist → $TMUXCTLD_PLIST (continuing)"
        else
            echo -e "  ${YELLOW}⚠${NC} source plist not found: $TMUXCTLD_SRC_PLIST (continuing)"
        fi
        launchctl bootout "gui/$(id -u)/${TMUXCTLD_LABEL}" 2>/dev/null || true
        launchctl bootstrap "gui/$(id -u)" "$TMUXCTLD_PLIST" 2>/dev/null || true
    else
        # Code-only change: kickstart -k restarts the running process (or starts it
        # if down). Bootstrap the plist as a fallback if the service isn't loaded.
        launchctl kickstart -k "gui/$(id -u)/${TMUXCTLD_LABEL}" 2>/dev/null || {
            echo "  Service not loaded, bootstrapping..."
            launchctl bootstrap "gui/$(id -u)" "$TMUXCTLD_PLIST" 2>/dev/null || true
        }
    fi

    # Best-effort confirmation only — launchd (KeepAlive) already owns liveness.
    local attempts=0
    local max_attempts=15
    while [[ $attempts -lt $max_attempts ]]; do
        sleep 1
        if check_tmuxctld_health; then
            echo -e "  ${GREEN}✓${NC} tmuxctld daemon is up and healthy"
            return 0
        fi
        attempts=$((attempts + 1))
    done

    echo -e "  ${YELLOW}○${NC} Restart issued; tmuxctld not yet healthy — launchd will bring it up."
    echo -e "    confirm with: tmuxctld-ctl status"
    return 0
}

# ============ WSL ============

check_wsl_health() {
    curl -sf --connect-timeout 2 "http://${WSL_HOST}:${WSL_PORT}/health" > /dev/null 2>&1
}

get_wsl_status() {
    echo -e "${BOLD}WSL satellite${NC} (${WSL_HOST}:${WSL_PORT})"

    if check_wsl_health; then
        echo -e "  Health:  ${GREEN}●${NC} healthy"
    else
        echo -e "  Health:  ${RED}●${NC} not responding"
    fi

    if ssh -o ConnectTimeout=2 -o BatchMode=yes wsl 'true' 2>/dev/null; then
        echo -e "  SSH:     ${GREEN}●${NC} reachable"
    else
        echo -e "  SSH:     ${RED}●${NC} unreachable"
    fi
}

restart_wsl() {
    if [[ "${REFRESH_WSL:-false}" == true ]]; then
        refresh_wsl_runtime
        return $?
    fi

    echo -e "${BLUE}→${NC} Restarting WSL satellite..."

    # Try HTTP restart first
    local http_ok=false
    if curl -sf --connect-timeout 2 -X POST "http://${WSL_HOST}:${WSL_PORT}/restart" > /dev/null 2>&1; then
        http_ok=true
        echo -e "  ${GREEN}✓${NC} HTTP restart sent (satellite will restart)"
    else
        # Timeout is expected (satellite exits), check if we got a connection at all
        local http_code
        http_code=$(curl -s --connect-timeout 2 -o /dev/null -w '%{http_code}' -X POST "http://${WSL_HOST}:${WSL_PORT}/restart" 2>/dev/null || echo "000")
        if [[ "$http_code" == "000" ]]; then
            echo -e "  ${YELLOW}⚠${NC} HTTP unreachable, trying SSH fallback..."
        else
            # Got a response (or timeout after connection) — restart is happening
            http_ok=true
            echo -e "  ${GREEN}✓${NC} HTTP restart sent (timeout expected)"
        fi
    fi

    # SSH fallback if HTTP failed to connect
    if [[ "$http_ok" == false ]]; then
        if ssh -o ConnectTimeout=3 -o BatchMode=yes wsl \
            'systemctl --user restart token-satellite' 2>/dev/null; then
            echo -e "  ${GREEN}✓${NC} SSH fallback: systemd restart"
        else
            echo -e "  ${YELLOW}⚠${NC} WSL unreachable (HTTP + SSH failed), skipping"
            return 0
        fi
    fi

    # Health-check loop
    local attempts=0
    local max_attempts=8
    sleep 2  # Give satellite time to restart
    while [[ $attempts -lt $max_attempts ]]; do
        if check_wsl_health; then
            echo -e "  ${GREEN}✓${NC} WSL satellite is healthy"
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 1
    done

    echo -e "  ${YELLOW}⚠${NC} WSL satellite not yet healthy (may still be starting)"
    return 0
}

refresh_wsl_runtime() {
    local sha="${SYNC_TARGET_SHA:-${TOKEN_RESTART_TARGET_SHA:-}}"
    [[ -n "$sha" ]] || sha="$(git -C "$(runtime_root)" rev-parse -q --verify HEAD 2>/dev/null || true)"
    if [[ -z "$sha" ]]; then
        echo -e "  ${YELLOW}⚠${NC} WSL refresh target SHA unknown; falling back to /restart"
        local old_refresh="$REFRESH_WSL"
        REFRESH_WSL=false
        restart_wsl
        REFRESH_WSL="$old_refresh"
        return 0
    fi
    if [[ -z "$TOKEN_SATELLITE_REFRESH_SECRET" ]]; then
        echo -e "  ${YELLOW}⚠${NC} TOKEN_SATELLITE_REFRESH_SECRET unset; falling back to /restart"
        local old_refresh="$REFRESH_WSL"
        REFRESH_WSL=false
        restart_wsl
        REFRESH_WSL="$old_refresh"
        return 0
    fi

    echo -e "${BLUE}→${NC} Refreshing WSL local runtime → ${sha:0:9}..."
    local payload
    payload=$(python3 - "$sha" <<'PY'
import json, os, sys
sha = sys.argv[1]
paths = [p for p in os.environ.get("SYNC_CHANGED_PATHS", "").splitlines() if p]
print(json.dumps({"sha": sha, "changed_paths": paths}, separators=(",", ":")))
PY
)
    local http_code
    http_code=$(curl -sS --connect-timeout 3 -o /tmp/token-wsl-refresh.out -w '%{http_code}' \
        -X POST "http://${WSL_HOST}:${WSL_PORT}/runtime/refresh" \
        -H "Authorization: Bearer ${TOKEN_SATELLITE_REFRESH_SECRET}" \
        -H "Content-Type: application/json" \
        --data "$payload" 2>/tmp/token-wsl-refresh.err || echo "000")
    if [[ "$http_code" =~ ^2 ]]; then
        echo -e "  ${GREEN}✓${NC} WSL runtime refresh scheduled"
    else
        echo -e "  ${YELLOW}⚠${NC} WSL refresh failed (HTTP ${http_code}); falling back to /restart"
        [[ -s /tmp/token-wsl-refresh.err ]] && sed 's/^/    /' /tmp/token-wsl-refresh.err >&2 || true
        local old_refresh="$REFRESH_WSL"
        REFRESH_WSL=false
        restart_wsl
        REFRESH_WSL="$old_refresh"
    fi
}


# ============ Ops Browser UI ============

refresh_ops_browser_gui() {
    # Best-effort Mac GUI refresh. This replaces legacy TUI restart signaling:
    # the cockpit is a browser surface, so existing /ui/ops tabs should reload
    # after Token-API comes back healthy. Frontend build-id polling handles
    # Android/other browsers that this local AppleScript cannot reach.
    if ! command -v osascript >/dev/null 2>&1; then
        return 0
    fi

    echo -e "${BLUE}→${NC} Refreshing Ops browser tabs..."
    local total=0
    local count
    local app

    for app in "Helium" "Vivaldi" "Google Chrome" "Chromium" "Brave Browser" "Microsoft Edge"; do
        count=$(osascript 2>/dev/null <<OSA || echo 0
tell application "System Events"
    set isRunning to (exists process "$app")
end tell
if isRunning then
    tell application "$app"
        set reloadCount to 0
        repeat with w in windows
            repeat with t in tabs of w
                try
                    if ((URL of t) as text) contains "/ui/ops" then
                        reload t
                        set reloadCount to reloadCount + 1
                    end if
                end try
            end repeat
        end repeat
    end tell
    return reloadCount
else
    return 0
end if
OSA
)
        count="${count//$'\n'/}"
        [[ "$count" =~ ^[0-9]+$ ]] || count=0
        total=$((total + count))
    done

    count=$(osascript 2>/dev/null <<'OSA' || echo 0
tell application "System Events"
    set isRunning to (exists process "Safari")
end tell
if isRunning then
    tell application "Safari"
        set reloadCount to 0
        repeat with d in documents
            try
                if ((URL of d) as text) contains "/ui/ops" then
                    do JavaScript "window.location.reload()" in d
                    set reloadCount to reloadCount + 1
                end if
            end try
        end repeat
    end tell
    return reloadCount
else
    return 0
end if
OSA
)
    count="${count//$'\n'/}"
    [[ "$count" =~ ^[0-9]+$ ]] || count=0
    total=$((total + count))

    if [[ "$total" -gt 0 ]]; then
        echo -e "  ${GREEN}✓${NC} Reloaded ${total} Ops browser tab(s)"
    else
        echo -e "  ${YELLOW}○${NC} No open /ui/ops browser tabs found"
    fi
}

