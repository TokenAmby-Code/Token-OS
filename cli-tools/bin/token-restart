#!/usr/bin/env bash
# token-restart - Multi-device restart orchestrator
# TAGS: token-api
# AUDIENCE: human, agent
#
# Usage:
#   token-restart              # Git-aware smart deploy: sync the live checkout,
#                              #   then restart ONLY the services whose files changed
#   token-restart --no-sync    # Skip the git sync; full restart on current code
#   token-restart --discord    # Restart the Discord daemon only (launchd)
#   token-restart --from <dir> # Update plist to serve from <dir>, then restart
#   token-restart --wsl-only   # WSL satellite only
#   token-restart --kill       # Just kill Mac server, don't restart
#   token-restart --watch      # Restart and monitor startup logs
#   token-restart --status     # All-device status
#   token-restart --sync       # Accepted no-op alias (sync is now the default)
#
# When run from WSL or phone, proxies the restart to Mac via HTTP.
# After healthy restart, reloads any open /ui/ops browser tabs on Mac.
#
# GIT-AWARE SMART DEPLOY (the mantra: a merge to main → one restart endpoint hit →
# this script syncs + intelligently restarts):
#   By DEFAULT token-restart fast-forwards the local bare skeleton
#   (/Volumes/Imperium/token-os.git) from GitHub main, then updates the deploy-owned
#   runtime checkout (/Volumes/Imperium/runtimes/token-os/live) detached to the
#   requested SHA (or the new bare main). It DIFFS old runtime HEAD → target SHA and
#   restarts ONLY the affected services (token-api / ops-ui / discord / WSL
#   satellite / mobile) — see map_changed_to_services(). Runtime checkouts are
#   deploy artifacts: dirty state is a hard error, never stashed.

set -euo pipefail

_BIN_DIR="$(dirname "$(readlink -f "$0")")"
_LIB_DIR="${_BIN_DIR}/../lib"
source "${_LIB_DIR}/nas-path.sh" 2>/dev/null || true

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# Network config
MAC_HOST="$(imperium_cfg tailscale_ip mac)"
MAC_PORT=7777
WSL_HOST="$(imperium_cfg tailscale_ip wsl)"
WSL_PORT=7777

# Mac-only config (only used when running on Mac)
LABEL="ai.openclaw.tokenapi"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"

# Discord daemon — launchd-supervised, Mac-only. token-restart is the
# AUTHORITATIVE restart path: launchctl kickstart against KeepAlive. Never use
# `discord-daemon start/restart` (pidfile+nohup) — it split-brains against launchd.
DISCORD_LABEL="ai.tokenclaw.discord"
DISCORD_PLIST="$HOME/Library/LaunchAgents/${DISCORD_LABEL}.plist"
DISCORD_URL="http://127.0.0.1:7779"

# Local CD topology. Values can be overridden for tests/emergency deploys, or via
# ~/.config/worktrees/Token-OS.conf. The bare repo is the read-only skeleton; the
# runtime checkout is deploy-owned and must stay clean.
conf_value() {
    local conf="$1" name="$2"
    ( BARE_REPO=""; WORKTREE_PARENT=""; SECRETS_DIR=""; PROTECTED_ROOT=""; RUNTIME_CHECKOUT=""; LOCAL_BARE_MAIN_SYNC=""
      # shellcheck disable=SC1090
      [[ -f "$conf" ]] && source "$conf" 2>/dev/null || true
      eval "printf '%s' \"\${$name:-}\"" )
}

TOKEN_OS_WORKTREE_CONF="${TOKEN_OS_WORKTREE_CONF:-$HOME/.config/worktrees/Token-OS.conf}"
TOKEN_OS_BARE_REPO="${TOKEN_OS_BARE_REPO:-${CD_BARE_REPO:-$(conf_value "$TOKEN_OS_WORKTREE_CONF" BARE_REPO)}}"
TOKEN_OS_BARE_REPO="${TOKEN_OS_BARE_REPO:-/Volumes/Imperium/token-os.git}"
TOKEN_OS_RUNTIME_CHECKOUT="${TOKEN_OS_RUNTIME_CHECKOUT:-${CD_RUNTIME_CHECKOUT:-$(conf_value "$TOKEN_OS_WORKTREE_CONF" RUNTIME_CHECKOUT)}}"
TOKEN_OS_RUNTIME_CHECKOUT="${TOKEN_OS_RUNTIME_CHECKOUT:-/Volumes/Imperium/runtimes/token-os/live}"
TOKEN_RESTART_TARGET_SHA="${TOKEN_RESTART_TARGET_SHA:-}"

is_mac() {
    [[ "$IMPERIUM_MACHINE" == "mac" ]]
}

show_help() {
    cat << 'EOF'
token-restart - Git-aware smart deploy + multi-device restart orchestrator

Usage:
    token-restart              Sync live checkout, restart ONLY changed services
    token-restart --no-sync    Skip git sync; full restart on current code
    token-restart --discord    Restart the Discord daemon only (launchd)
    token-restart --from <dir> Update plist to serve from <dir>, then restart
    token-restart --wsl-only   WSL satellite only
    token-restart --kill       Kill Mac process (launchd auto-restarts)
    token-restart --watch      Restart and monitor startup logs
    token-restart --status     All-device status
    token-restart --sync       Accepted alias (sync is the default)
    token-restart --sha <sha>   Deploy this commit after syncing bare main
    token-restart -h, --help   Show this help

    When run from a non-Mac device, proxies to Mac via SSH.

Smart-deploy flow (default):
    0. ff-only sync local bare main from GitHub; update runtime checkout detached
       to --sha/TOKEN_RESTART_TARGET_SHA or bare main. Dirty runtime aborts.
    1. If runtime HEAD advanced: diff old→new and restart ONLY the services
       whose files changed:
         token-api/**/*.py|uv.lock|pyproject.toml  → Mac token-api
         token-api/{ui,web}/ops/**                  → token-api + reload ops tabs
         discord-daemon/**                          → Discord daemon (launchd)
         token-api/token-satellite.py               → WSL satellite
         mobile/**                                  → push-mobile -a (phone)
    2. If the pull was a no-op (already current) or --no-sync: full restart of
       the standard set (Mac token-api → Discord → WSL), preserving the human
       "restart my stuff now" workflow.
    3. Health-check what was restarted, print summary.

Notes:
    - Sync is ff-only at the bare skeleton and detached at the runtime checkout.
      Runtime WIP is never stashed or preserved; dirty runtime state aborts deploy.
    - WSL restart is fire-and-forget if unreachable
    - WSL satellite self-restarts via systemd (Restart=always)
    - Mac server managed by launchd (ai.openclaw.tokenapi)
    - Discord daemon managed by launchd (ai.tokenclaw.discord) — this is the
      AUTHORITATIVE restart path; do NOT use `discord-daemon restart`
    - Open /ui/ops browser tabs are reloaded after a healthy restart
EOF
}

# ============ Remote Proxy ============
# When run from WSL or phone, proxy to Mac which orchestrates everything

remote_restart() {
    echo -e "${BOLD}=== Token Restart (remote → Mac) ===${NC}"
    echo ""

    echo -e "${BLUE}→${NC} Proxying restart to Mac ($MAC_HOST)..."

    # Pass through relevant flags. Sync is the default on the Mac side, so only
    # the opt-out needs forwarding.
    local flags=""
    [[ "${ACTION}" == "wsl-only" ]] && flags="$flags --wsl-only"
    [[ "${ACTION}" == "discord" ]] && flags="$flags --discord"
    [[ "${SYNC_BEFORE_RESTART}" == false ]] && flags="$flags --no-sync"

    local remote_cmd="$(imperium_cfg nas_imperium mac)/runtimes/token-os/live/cli-tools/bin/token-restart"
    if ssh -o ConnectTimeout=5 -o BatchMode=yes mini "${remote_cmd}${flags}" 2>&1; then
        echo ""
        echo -e "  ${GREEN}✓${NC} Remote restart completed"
    else
        echo -e "  ${RED}✗${NC} Failed to reach Mac via SSH"
        echo "  Ensure 'mini' SSH host is configured and reachable"
        return 1
    fi
}

remote_status() {
    echo -e "${BOLD}=== Multi-Device Status (via Mac) ===${NC}"
    echo ""
    local remote_cmd="$(imperium_cfg nas_imperium mac)/runtimes/token-os/live/cli-tools/bin/token-restart"
    ssh -o ConnectTimeout=5 -o BatchMode=yes mini "${remote_cmd} --status" 2>&1 || {
        echo -e "  ${RED}✗${NC} Cannot reach Mac via SSH"
        # Fall back to direct health checks
        echo ""
        echo -e "${BOLD}Direct checks:${NC}"
        if curl -sf --connect-timeout 2 "http://${MAC_HOST}:${MAC_PORT}/health" > /dev/null 2>&1; then
            echo -e "  Mac:   ${GREEN}●${NC} healthy"
        else
            echo -e "  Mac:   ${RED}●${NC} not responding"
        fi
        if curl -sf --connect-timeout 2 "http://${WSL_HOST}:${WSL_PORT}/health" > /dev/null 2>&1; then
            echo -e "  WSL:   ${GREEN}●${NC} healthy"
        else
            echo -e "  WSL:   ${YELLOW}○${NC} unknown"
        fi
    }
}

# ============ Mac ============

check_mac_health() {
    curl -sf "${TOKEN_API_URL:-http://localhost:7777}/health" > /dev/null 2>&1
}

get_mac_status() {
    echo -e "${BOLD}Mac token-api${NC}"

    if launchctl print gui/501/${LABEL} > /dev/null 2>&1; then
        echo -e "  Launchd: ${GREEN}loaded${NC}"
    else
        echo -e "  Launchd: ${RED}not loaded${NC}"
    fi

    local pid
    pid=$(pgrep -f 'uvicorn.*7777' 2>/dev/null || true)
    if [[ -n "$pid" ]]; then
        echo -e "  Process: ${GREEN}running${NC} (PID: $pid)"
    else
        echo -e "  Process: ${RED}not running${NC}"
    fi

    if check_mac_health; then
        echo -e "  Health:  ${GREEN}●${NC} healthy"
    else
        echo -e "  Health:  ${RED}●${NC} not responding"
    fi
}

kill_server() {
    echo "Stopping Token-API..."

    if pkill -f 'uvicorn.*7777' 2>/dev/null; then
        echo "Killed uvicorn process"
    else
        echo "No process found"
    fi

    sleep 1

    if pgrep -f 'uvicorn.*7777' > /dev/null 2>&1; then
        echo -e "${YELLOW}Warning: Process still running, force killing...${NC}"
        pkill -9 -f 'uvicorn.*7777' 2>/dev/null || true
    fi

    echo -e "${GREEN}Server stopped${NC}"
    echo "Note: launchd will auto-restart unless you 'launchctl bootout gui/501/${LABEL}'"
}

runtime_root() {
    printf '%s
' "${TOKEN_OS_RUNTIME_CHECKOUT}"
}

sync_venv_if_needed() {
    local root
    root="$(runtime_root)"
    local lockfile="${root}/token-api/uv.lock"
    local checksum_file="$HOME/.local/venvs/token-api/.uv-lock-checksum"
    local venv_dir="$HOME/.local/venvs/token-api"

    if [[ ! -f "$lockfile" ]]; then
        return 0
    fi

    local current_checksum
    current_checksum=$(shasum -a 256 "$lockfile" 2>/dev/null | cut -d' ' -f1)
    local stored_checksum=""
    [[ -f "$checksum_file" ]] && stored_checksum=$(cat "$checksum_file" 2>/dev/null)

    if [[ "$current_checksum" != "$stored_checksum" ]]; then
        echo -e "${BLUE}→${NC} uv.lock changed, syncing venv..."
        if (cd "${root}/token-api" && UV_PROJECT_ENVIRONMENT="$venv_dir" uv sync 2>&1); then
            echo "$current_checksum" > "$checksum_file"
            echo -e "  ${GREEN}✓${NC} Venv synced"
        else
            echo -e "  ${YELLOW}⚠${NC} Venv sync failed (continuing with existing venv)"
        fi
    fi
}

# ============ Code-sync (default; opt out with --no-sync) ============
#
# Before restarting, synchronize the local bare skeleton from GitHub main and
# update the deploy-owned runtime checkout detached to the requested target SHA
# (or bare main). On a successful runtime advance it records SYNC_DID_ADVANCE +
# SYNC_CHANGED_PATHS so full_restart() can restart only the services changed.
#
# SAFETY (load-bearing):
#   - Bare main fast-forwards only. We never force local main to a non-ancestor.
#   - Runtime checkout must be clean. Runtime WIP is an operational error; CD
#     never stashes it and never deploys over it.
#   - On sync failure, abort the restart loudly instead of running ambiguous code.

resolve_live_checkout() {
    # Backward-compatible test/emergency override. In the new topology this means
    # runtime checkout, not protected main checkout.
    if [[ -n "${CD_LIVE_CHECKOUT:-}" && -d "${CD_LIVE_CHECKOUT}" ]]; then
        printf '%s
' "${CD_LIVE_CHECKOUT}"
        return 0
    fi
    printf '%s
' "${TOKEN_OS_RUNTIME_CHECKOUT}"
}

ensure_bare_repo() {
    if [[ ! -d "$TOKEN_OS_BARE_REPO" ]]; then
        echo -e "  ${RED}✗${NC} CD-sync: bare repo not found: $TOKEN_OS_BARE_REPO"
        return 1
    fi
    if [[ "$(git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse --is-bare-repository 2>/dev/null)" != "true" ]]; then
        echo -e "  ${RED}✗${NC} CD-sync: not a bare repo: $TOKEN_OS_BARE_REPO"
        return 1
    fi
}

runtime_is_dirty() {
    local dir="$1"
    [[ -d "$dir/.git" || -f "$dir/.git" ]] || return 1
    [[ -n "$(git -C "$dir" status --porcelain 2>/dev/null)" ]]
}

sync_bare_main() {
    echo -e "${BLUE}→${NC} CD-sync: fetching GitHub main into bare skeleton $TOKEN_OS_BARE_REPO..."
    if ! git --git-dir="$TOKEN_OS_BARE_REPO" fetch origin main >/dev/null 2>&1; then
        echo -e "  ${RED}✗${NC} CD-sync: 'git fetch origin main' failed for bare skeleton"
        return 1
    fi
    local old_main new_main
    old_main="$(git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse -q --verify refs/heads/main 2>/dev/null || true)"
    new_main="$(git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse FETCH_HEAD 2>/dev/null || true)"
    [[ -n "$new_main" ]] || { echo -e "  ${RED}✗${NC} CD-sync: FETCH_HEAD did not resolve"; return 1; }
    if [[ -n "$old_main" && "$old_main" != "$new_main" ]]; then
        if ! git --git-dir="$TOKEN_OS_BARE_REPO" merge-base --is-ancestor "$old_main" "$new_main"; then
            echo -e "  ${RED}✗${NC} CD-sync: bare main is not a fast-forward (${old_main:0:9} → ${new_main:0:9})"
            return 1
        fi
    fi
    git --git-dir="$TOKEN_OS_BARE_REPO" update-ref refs/heads/main "$new_main"
    git --git-dir="$TOKEN_OS_BARE_REPO" update-ref refs/remotes/origin/main "$new_main" 2>/dev/null || true
    if [[ "$old_main" == "$new_main" ]]; then
        echo -e "  ${GREEN}✓${NC} CD-sync: bare main already current (${new_main:0:9})"
    else
        echo -e "  ${GREEN}✓${NC} CD-sync: bare main fast-forwarded ${old_main:0:9} → ${new_main:0:9}"
    fi
}

resolve_deploy_target() {
    local target="${TOKEN_RESTART_TARGET_SHA:-}"
    [[ -n "$target" ]] || target="$(git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse refs/heads/main 2>/dev/null || true)"
    [[ -n "$target" ]] || { echo -e "  ${RED}✗${NC} CD-sync: no deploy target resolved"; return 1; }
    if ! git --git-dir="$TOKEN_OS_BARE_REPO" cat-file -e "$target^{commit}" 2>/dev/null; then
        echo -e "  ${RED}✗${NC} CD-sync: requested deploy target is not present in bare repo: $target"
        return 1
    fi
    git --git-dir="$TOKEN_OS_BARE_REPO" rev-parse "$target^{commit}"
}

ensure_runtime_checkout() {
    local dir="$1"
    if [[ -e "$dir" && ! -d "$dir/.git" && ! -f "$dir/.git" ]]; then
        echo -e "  ${RED}✗${NC} CD-sync: runtime path exists but is not a git checkout: $dir"
        return 1
    fi
    if [[ ! -e "$dir" ]]; then
        echo -e "${BLUE}→${NC} CD-sync: creating runtime checkout $dir..."
        mkdir -p "$(dirname "$dir")"
        git clone "$TOKEN_OS_BARE_REPO" "$dir" >/dev/null 2>&1 || {
            echo -e "  ${RED}✗${NC} CD-sync: failed to clone runtime checkout"
            return 1
        }
    fi
    if runtime_is_dirty "$dir"; then
        echo -e "  ${RED}✗${NC} CD-sync: runtime checkout is dirty; aborting deploy (no stash in runtime): $dir"
        git -C "$dir" status --short >&2 || true
        return 1
    fi
}

sync_live_checkout() {
    ensure_bare_repo || return 1
    sync_bare_main || return 1

    local dir target old_head changed_paths
    dir="$(resolve_live_checkout)" || return 1
    target="$(resolve_deploy_target)" || return 1
    ensure_runtime_checkout "$dir" || return 1

    old_head="$(git -C "$dir" rev-parse -q --verify HEAD 2>/dev/null || true)"
    if [[ "$old_head" == "$target" ]]; then
        echo -e "  ${GREEN}✓${NC} CD-sync: runtime already at ${target:0:9} — no sync needed"
        return 0
    fi

    echo -e "${BLUE}→${NC} CD-sync: updating runtime $dir detached → ${target:0:9}..."
    git -C "$dir" fetch "$TOKEN_OS_BARE_REPO" '+refs/heads/*:refs/remotes/local-bare/*' >/dev/null 2>&1 || {
        echo -e "  ${RED}✗${NC} CD-sync: failed to fetch bare refs into runtime"
        return 1
    }
    git -C "$dir" checkout --detach "$target" >/dev/null 2>&1 || {
        echo -e "  ${RED}✗${NC} CD-sync: failed to checkout runtime target ${target:0:9}"
        return 1
    }

    if [[ -n "$old_head" ]]; then
        changed_paths="$(git --git-dir="$TOKEN_OS_BARE_REPO" diff --name-only "$old_head" "$target" 2>/dev/null || true)"
        echo -e "  ${GREEN}✓${NC} CD-sync: runtime advanced ${old_head:0:9} → ${target:0:9}"
    else
        changed_paths="$(git --git-dir="$TOKEN_OS_BARE_REPO" ls-tree -r --name-only "$target" 2>/dev/null || true)"
        echo -e "  ${GREEN}✓${NC} CD-sync: runtime initialized at ${target:0:9}"
    fi

    SYNC_DID_ADVANCE=true
    SYNC_CHANGED_PATHS="$changed_paths"
    return 0
}

restart_mac() {
    echo -e "${BLUE}→${NC} Restarting Mac token-api..."

    sync_venv_if_needed

    launchctl kickstart -k gui/501/${LABEL} 2>/dev/null || {
        echo "  Service not loaded, bootstrapping..."
        launchctl bootstrap gui/501 "$PLIST" 2>/dev/null || true
    }

    local attempts=0
    local max_attempts=10

    while [[ $attempts -lt $max_attempts ]]; do
        sleep 1
        if check_mac_health; then
            echo -e "  ${GREEN}✓${NC} Mac server is up and healthy"
            return 0
        fi
        attempts=$((attempts + 1))
        echo "  Waiting... ($attempts/$max_attempts)"
    done

    echo -e "  ${RED}✗${NC} Mac server failed to start within ${max_attempts}s"
    echo "  Check logs: tail ~/.claude/token-api-stderr.log"
    return 1
}

# ============ Discord ============

check_discord_health() {
    # Healthy = daemon up AND actually connected to Discord. A 200 from /status
    # alone isn't enough (the HTTP API binds before the gateway connects), so
    # require "connected": true in the body.
    curl -sf "${DISCORD_URL}/status" 2>/dev/null \
        | grep -q '"connected"[[:space:]]*:[[:space:]]*true'
}

get_discord_status() {
    echo -e "${BOLD}Discord daemon${NC} (${DISCORD_URL})"

    if launchctl print "gui/$(id -u)/${DISCORD_LABEL}" > /dev/null 2>&1; then
        echo -e "  Launchd: ${GREEN}loaded${NC}"
    else
        echo -e "  Launchd: ${RED}not loaded${NC}"
    fi

    if check_discord_health; then
        echo -e "  Health:  ${GREEN}●${NC} connected"
    else
        echo -e "  Health:  ${RED}●${NC} not responding"
    fi
}

restart_discord() {
    echo -e "${BLUE}→${NC} Restarting Discord daemon (launchd)..."

    launchctl kickstart -k "gui/$(id -u)/${DISCORD_LABEL}" 2>/dev/null || {
        echo "  Service not loaded, bootstrapping..."
        launchctl bootstrap "gui/$(id -u)" "$DISCORD_PLIST" 2>/dev/null || true
    }

    # The kickstart above already succeeded — launchd (KeepAlive) now owns
    # liveness. This loop only waits to CONFIRM the daemon is back. Cold-start
    # from the NAS is slow (node loads node_modules over SMB in an uninterruptible
    # read, ~1-3 min on a cold mount cache), so confirmation is best-effort.
    local attempts=0
    local max_attempts=45

    printf '  waiting for Discord daemon'
    while [[ $attempts -lt $max_attempts ]]; do
        sleep 1
        if check_discord_health; then
            printf '\n'
            echo -e "  ${GREEN}✓${NC} Discord daemon is up and connected"
            return 0
        fi
        printf '.'
        attempts=$((attempts + 1))
    done
    printf '\n'

    echo -e "  ${YELLOW}○${NC} Kickstart issued; daemon still cold-loading from NAS."
    echo -e "    launchd will bring it up — confirm with: discord-daemon status"
    return 0
}

# ============ WSL ============

check_wsl_health() {
    curl -sf --connect-timeout 2 "http://${WSL_HOST}:${WSL_PORT}/health" > /dev/null 2>&1
}

get_wsl_status() {
    echo -e "${BOLD}WSL satellite${NC} (${WSL_HOST}:${WSL_PORT})"

    if check_wsl_health; then
        echo -e "  Health:  ${GREEN}●${NC} healthy"
    else
        echo -e "  Health:  ${RED}●${NC} not responding"
    fi

    if ssh -o ConnectTimeout=2 -o BatchMode=yes wsl 'true' 2>/dev/null; then
        echo -e "  SSH:     ${GREEN}●${NC} reachable"
    else
        echo -e "  SSH:     ${RED}●${NC} unreachable"
    fi
}

restart_wsl() {
    echo -e "${BLUE}→${NC} Restarting WSL satellite..."

    # Try HTTP restart first
    local http_ok=false
    if curl -sf --connect-timeout 2 -X POST "http://${WSL_HOST}:${WSL_PORT}/restart" > /dev/null 2>&1; then
        http_ok=true
        echo -e "  ${GREEN}✓${NC} HTTP restart sent (satellite will restart)"
    else
        # Timeout is expected (satellite exits), check if we got a connection at all
        local http_code
        http_code=$(curl -s --connect-timeout 2 -o /dev/null -w '%{http_code}' -X POST "http://${WSL_HOST}:${WSL_PORT}/restart" 2>/dev/null || echo "000")
        if [[ "$http_code" == "000" ]]; then
            echo -e "  ${YELLOW}⚠${NC} HTTP unreachable, trying SSH fallback..."
        else
            # Got a response (or timeout after connection) — restart is happening
            http_ok=true
            echo -e "  ${GREEN}✓${NC} HTTP restart sent (timeout expected)"
        fi
    fi

    # SSH fallback if HTTP failed to connect
    if [[ "$http_ok" == false ]]; then
        if ssh -o ConnectTimeout=3 -o BatchMode=yes wsl \
            'systemctl --user restart token-satellite' 2>/dev/null; then
            echo -e "  ${GREEN}✓${NC} SSH fallback: systemd restart"
        else
            echo -e "  ${YELLOW}⚠${NC} WSL unreachable (HTTP + SSH failed), skipping"
            return 0
        fi
    fi

    # Health-check loop
    local attempts=0
    local max_attempts=8
    sleep 2  # Give satellite time to restart
    while [[ $attempts -lt $max_attempts ]]; do
        if check_wsl_health; then
            echo -e "  ${GREEN}✓${NC} WSL satellite is healthy"
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 1
    done

    echo -e "  ${YELLOW}⚠${NC} WSL satellite not yet healthy (may still be starting)"
    return 0
}


# ============ Ops Browser UI ============

refresh_ops_browser_gui() {
    # Best-effort Mac GUI refresh. This replaces legacy TUI restart signaling:
    # the cockpit is a browser surface, so existing /ui/ops tabs should reload
    # after Token-API comes back healthy. Frontend build-id polling handles
    # Android/other browsers that this local AppleScript cannot reach.
    if ! command -v osascript >/dev/null 2>&1; then
        return 0
    fi

    echo -e "${BLUE}→${NC} Refreshing Ops browser tabs..."
    local total=0
    local count
    local app

    for app in "Helium" "Vivaldi" "Google Chrome" "Chromium" "Brave Browser" "Microsoft Edge"; do
        count=$(osascript 2>/dev/null <<OSA || echo 0
tell application "System Events"
    set isRunning to (exists process "$app")
end tell
if isRunning then
    tell application "$app"
        set reloadCount to 0
        repeat with w in windows
            repeat with t in tabs of w
                try
                    if ((URL of t) as text) contains "/ui/ops" then
                        reload t
                        set reloadCount to reloadCount + 1
                    end if
                end try
            end repeat
        end repeat
    end tell
    return reloadCount
else
    return 0
end if
OSA
)
        count="${count//$'\n'/}"
        [[ "$count" =~ ^[0-9]+$ ]] || count=0
        total=$((total + count))
    done

    count=$(osascript 2>/dev/null <<'OSA' || echo 0
tell application "System Events"
    set isRunning to (exists process "Safari")
end tell
if isRunning then
    tell application "Safari"
        set reloadCount to 0
        repeat with d in documents
            try
                if ((URL of d) as text) contains "/ui/ops" then
                    do JavaScript "window.location.reload()" in d
                    set reloadCount to reloadCount + 1
                end if
            end try
        end repeat
    end tell
    return reloadCount
else
    return 0
end if
OSA
)
    count="${count//$'\n'/}"
    [[ "$count" =~ ^[0-9]+$ ]] || count=0
    total=$((total + count))

    if [[ "$total" -gt 0 ]]; then
        echo -e "  ${GREEN}✓${NC} Reloaded ${total} Ops browser tab(s)"
    else
        echo -e "  ${YELLOW}○${NC} No open /ui/ops browser tabs found"
    fi
}

# ============ Phone ============

get_phone_status() {
    echo -e "${BOLD}Phone${NC}"
    if ssh -o ConnectTimeout=3 -o BatchMode=yes phone 'true' 2>/dev/null; then
        echo -e "  SSH:     ${GREEN}●${NC} reachable"
    else
        echo -e "  SSH:     ${RED}●${NC} unreachable"
    fi
}

# ============ Status ============

get_status_all() {
    echo "=== Multi-Device Status ==="
    echo ""
    get_mac_status
    echo ""
    get_discord_status
    echo ""
    get_wsl_status
    echo ""
    get_phone_status
}

# ============ Watch ============

watch_logs() {
    echo "Tailing logs (Ctrl+C to stop)..."
    tail -f ~/.claude/token-api-stderr.log
}

# ============ Plist Update ============

update_plist() {
    local service_dir="$1"
    local python_path="$service_dir/.venv/bin/python"

    if [[ ! -f "$python_path" ]]; then
        echo -e "  ${RED}✗${NC} Python not found at $python_path"
        echo "  Run: uv sync --project '$service_dir' first"
        return 1
    fi

    echo -e "${BLUE}→${NC} Updating plist: $service_dir"
    /usr/bin/python3 - "$PLIST" "$python_path" "$service_dir" << 'PYEOF'
import sys, plistlib
plist_path, python_path, working_dir = sys.argv[1], sys.argv[2], sys.argv[3]
with open(plist_path, 'rb') as f:
    data = plistlib.load(f)
data['ProgramArguments'][0] = python_path
data['WorkingDirectory'] = working_dir
with open(plist_path, 'wb') as f:
    plistlib.dump(data, f, fmt=plistlib.FMT_XML, sort_keys=False)
PYEOF
    echo -e "  ${GREEN}✓${NC} Plist updated"
}

# ============ Mobile ============

restart_mobile() {
    echo -e "${BLUE}→${NC} Deploying mobile (push-mobile -a)..."
    # Resolve PATH-first (the standard cli-tools push-mobile), falling back to our
    # sibling in _BIN_DIR if PATH doesn't carry it (e.g. a bare CD environment).
    local push_mobile
    push_mobile="$(command -v push-mobile 2>/dev/null || true)"
    [[ -n "$push_mobile" ]] || push_mobile="${_BIN_DIR}/push-mobile"
    if [[ ! -x "$push_mobile" ]]; then
        echo -e "  ${YELLOW}⚠${NC} push-mobile not found — skipping mobile deploy"
        return 0
    fi
    # push-mobile validates + pushes the mobile/ tree to the phone. Fire it but
    # never let a phone-unreachable push fail the whole deploy.
    if "$push_mobile" -a; then
        echo -e "  ${GREEN}✓${NC} push-mobile completed"
    else
        echo -e "  ${YELLOW}⚠${NC} push-mobile failed (continuing)"
    fi
}

# ============ Git-aware service mapping ============
#
# Map the files a sync just pulled (SYNC_CHANGED_PATHS, one path per line) to the
# services that must restart, setting the RESTART_* globals. This is the SINGLE
# SOURCE OF TRUTH for path→service routing: deploy-prod.yml no longer filters
# paths — it just hits the restart endpoint and lets this script decide from git.
#
# NOTE: in bash `case` patterns, `*` matches `/` (unlike filename globbing), so
# `token-api/*.py` covers nested files too. Order matters — the first matching
# arm wins, so specific paths (satellite, ops) precede the general .py arm.

map_changed_to_services() {
    local path
    while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        case "$path" in
            token-api/token-satellite.py)
                # Satellite code lives under token-api/ but runs on WSL. (Also a
                # *.py, so token-api restarts too — matches old paths-filter.)
                RESTART_WSL=true
                RESTART_TOKENAPI=true
                ;;
            token-api/ui/ops/* | token-api/web/ops/*)
                # Ops cockpit is served by token-api; a restart bumps the build-id
                # so connected browsers reload, and we also refresh open tabs.
                RESTART_OPS=true
                RESTART_TOKENAPI=true
                ;;
            token-api/*.py | token-api/uv.lock | token-api/pyproject.toml)
                RESTART_TOKENAPI=true
                ;;
            discord-daemon/*)
                RESTART_DISCORD=true
                ;;
            mobile/*)
                RESTART_MOBILE=true
                ;;
            *)
                : # unmapped (docs, cli-tools, workflows, tmux/ahk/hammerspoon):
                  # no long-lived service to bounce — nothing to do.
                ;;
        esac
    done <<< "$SYNC_CHANGED_PATHS"
    return 0
}

# ============ Full Restart ============

full_restart() {
    echo -e "${BOLD}=== Token Restart ===${NC}"
    echo ""

    # 0. Git sync (default): ff-only pull the live checkout so a merge ships
    #    before we restart. Sets SYNC_DID_ADVANCE + SYNC_CHANGED_PATHS. Always
    #    degrades gracefully — a failed/uneventful sync just leaves the flags off.
    if [[ "$SYNC_BEFORE_RESTART" == true ]]; then
        if ! sync_live_checkout; then
            echo -e "${RED}✗${NC} CD-sync failed; aborting restart so protected runtime is not ambiguous."
            return 1
        fi
        echo ""
    fi

    # 1. Decide what to restart.
    if [[ "$SYNC_DID_ADVANCE" == true ]]; then
        # Smart deploy: restart ONLY the services whose files the pull changed.
        map_changed_to_services
        if [[ "$RESTART_TOKENAPI" != true && "$RESTART_DISCORD" != true \
            && "$RESTART_WSL" != true && "$RESTART_MOBILE" != true ]]; then
            echo -e "${GREEN}✓${NC} No deployable services changed — nothing to restart."
            return 0
        fi
        local changed_list=""
        [[ "$RESTART_TOKENAPI" == true ]] && changed_list+=" token-api"
        [[ "$RESTART_OPS" == true ]] && changed_list+=" ops-ui"
        [[ "$RESTART_DISCORD" == true ]] && changed_list+=" discord"
        [[ "$RESTART_WSL" == true ]] && changed_list+=" wsl"
        [[ "$RESTART_MOBILE" == true ]] && changed_list+=" mobile"
        echo -e "${BLUE}→${NC} Changed services:${changed_list}"
        echo ""
    else
        # No new commits (already current / --no-sync / sync degraded): full
        # restart of the standard set — the human "restart my stuff now" path.
        RESTART_TOKENAPI=true
        RESTART_DISCORD=true
        RESTART_WSL=true
    fi

    # 2. Mac token-api
    if [[ "$RESTART_TOKENAPI" == true ]]; then
        restart_mac || true
        echo ""
    fi

    # 3. Discord daemon (Mac-only, launchd-supervised)
    if [[ "$RESTART_DISCORD" == true ]]; then
        restart_discord || true
        echo ""
    fi

    # 4. WSL satellite (background; never blocks the deploy)
    local wsl_pid=""
    if [[ "$RESTART_WSL" == true ]]; then
        restart_wsl &
        wsl_pid=$!
    fi

    # 5. Mobile (phone push)
    if [[ "$RESTART_MOBILE" == true ]]; then
        restart_mobile || true
        echo ""
    fi

    [[ -n "$wsl_pid" ]] && { wait "$wsl_pid" 2>/dev/null || true; }

    # 6. Browser cockpit refresh — only if token-api was (re)started and healthy.
    if [[ "$RESTART_TOKENAPI" == true ]] && check_mac_health; then
        refresh_ops_browser_gui || true
    fi

    # 7. Summary — report only what we touched.
    echo ""
    echo -e "${BOLD}=== Summary ===${NC}"
    if [[ "$RESTART_TOKENAPI" == true ]]; then
        if check_mac_health; then
            echo -e "  Mac:     ${GREEN}●${NC} healthy"
        else
            echo -e "  Mac:     ${RED}●${NC} not responding"
        fi
    fi
    if [[ "$RESTART_DISCORD" == true ]]; then
        if check_discord_health; then
            echo -e "  Discord: ${GREEN}●${NC} connected"
        else
            echo -e "  Discord: ${RED}●${NC} not responding"
        fi
    fi
    if [[ "$RESTART_WSL" == true ]]; then
        if check_wsl_health; then
            echo -e "  WSL:     ${GREEN}●${NC} healthy"
        else
            echo -e "  WSL:     ${YELLOW}○${NC} unknown"
        fi
    fi
    if [[ "$RESTART_MOBILE" == true ]]; then
        echo -e "  Mobile:  ${GREEN}●${NC} push-mobile dispatched"
    fi
}

# ============ Parse Arguments ============

ACTION="restart"
DEPLOY_FROM=""
# Sync is the DEFAULT now (the git-aware deploy mantra: always ship fresh code).
# --no-sync opts out; --sync is an accepted no-op alias.
SYNC_BEFORE_RESTART=true
# Set by sync_live_checkout() when the pull advances HEAD, plus the changed paths.
SYNC_DID_ADVANCE=false
SYNC_CHANGED_PATHS=""
# Stderr from the last failed ff-merge attempt — surfaced on a genuine non-ff so the
# failure is never silent (see _cd_sync_ff_with_retry / sync_live_checkout).
CD_SYNC_MERGE_ERR=""
# Which services to restart — set by map_changed_to_services() (smart mode) or
# forced on in the full-restart fallback. Must be initialised for `set -u`.
RESTART_TOKENAPI=false
RESTART_OPS=false
RESTART_DISCORD=false
RESTART_WSL=false
RESTART_MOBILE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        --sync)
            # Explicit alias: sync is the default. Kept so existing callers
            # (e.g. the CD webhook, which passes --sync explicitly) don't break.
            SYNC_BEFORE_RESTART=true
            shift
            ;;
        --sha)
            if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == -* ]]; then
                echo "Error: --sha requires a commit SHA" >&2
                exit 1
            fi
            TOKEN_RESTART_TARGET_SHA="$2"
            shift 2
            ;;
        --no-sync)
            # Opt out of the git sync: full restart on whatever is checked out.
            SYNC_BEFORE_RESTART=false
            shift
            ;;
        --kill)
            ACTION="kill"
            shift
            ;;
        --watch)
            ACTION="watch"
            shift
            ;;
        --status)
            ACTION="status"
            shift
            ;;
        --wsl-only)
            ACTION="wsl-only"
            shift
            ;;
        --discord)
            ACTION="discord"
            shift
            ;;
        --no-push)
            # Legacy flag, ignored (no sync needed in NAS era)
            shift
            ;;
        --from)
            if [[ $# -lt 2 ]]; then
                echo "Error: --from requires a path" >&2
                exit 1
            fi
            DEPLOY_FROM="$(cd "$2" && pwd)"
            shift 2
            ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Use --help for usage" >&2
            exit 1
            ;;
    esac
done

# Remote proxy: if not on Mac, forward to Mac via SSH
if ! is_mac; then
    case "$ACTION" in
        status)
            remote_status
            ;;
        *)
            remote_restart
            ;;
    esac
    exit $?
fi

# Execute action (Mac only from here)
case "$ACTION" in
    status)
        get_status_all
        ;;
    kill)
        kill_server
        ;;
    watch)
        full_restart
        watch_logs
        ;;
    wsl-only)
        restart_wsl
        ;;
    discord)
        restart_discord
        ;;
    restart)
        if [[ -n "$DEPLOY_FROM" ]]; then
            update_plist "$DEPLOY_FROM" || exit 1
        fi
        full_restart
        ;;
esac
