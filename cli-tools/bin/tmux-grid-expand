#!/usr/bin/env bash
# tmux-grid-expand - Toggle native tmux pane zoom.
# TAGS: tmux, zoom, expand
# AUDIENCE: human + script
#
# Usage:
#   tmux-grid-expand              # Toggle native zoom for the active pane
#   tmux-grid-expand --pane %12   # Toggle native zoom for a specific pane
#   tmux-grid-expand --retract    # Unzoom the target window if zoomed
#   tmux-grid-expand --expand     # Zoom the target window if not already zoomed

set -euo pipefail

TARGET_PANE=""
RETRACT=false
EXPAND=false
CLIENT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pane)
            TARGET_PANE="${2:-}"
            if [[ -z "$TARGET_PANE" ]]; then
                tmux display-message "expand: --pane requires a pane id"
                exit 1
            fi
            shift 2
            ;;
        --client)
            CLIENT="${2:-}"
            shift 2
            ;;
        --retract)
            RETRACT=true
            shift
            ;;
        --expand)
            EXPAND=true
            shift
            ;;
        -h|--help)
            sed -n '2,14p' "$0"
            exit 0
            ;;
        *)
            tmux display-message "expand: unknown option $1"
            exit 1
            ;;
    esac
done

if [[ -z "$TARGET_PANE" ]]; then
    TARGET_PANE=$(tmux display-message -p '#{pane_id}')
fi

if ! tmux display-message -t "$TARGET_PANE" -p '' >/dev/null 2>&1; then
    tmux display-message "expand: pane not found: $TARGET_PANE"
    exit 1
fi

# Native tmux zoom is the canonical expand implementation. It preserves pane
# identity, window membership, running processes, and explicit send-keys targets.
# The old audience/tombstone and pane-stash expansion paths are intentionally not
# used here; they complicated automation and made pane resolution harder.

TARGET_WINDOW=$(tmux display-message -t "$TARGET_PANE" -p '#{session_name}:#{window_index}')
WINDOW_ZOOMED=$(tmux display-message -t "$TARGET_WINDOW" -p '#{window_zoomed_flag}')

# Clear legacy expansion markers so audit/reset tooling does not think panes are
# stashed after the implementation switched to tmux's built-in zoom.
tmux set-option -w -t "$TARGET_WINDOW" @GRID_EXPANDED "none" 2>/dev/null || true
tmux set-option -w -t "$TARGET_WINDOW" @GRID_STASH "" 2>/dev/null || true
tmux set-option -w -t "$TARGET_WINDOW" @GENERIC_EXPANDED "none" 2>/dev/null || true
tmux set-option -w -t "$TARGET_WINDOW" @GENERIC_STASH "" 2>/dev/null || true
tmux set-option -w -t "$TARGET_WINDOW" @SIDE_EXPANDED "none" 2>/dev/null || true

if [[ "$RETRACT" == true ]]; then
    if [[ "$WINDOW_ZOOMED" == "1" ]]; then
        tmux resize-pane -Z -t "$TARGET_PANE"
    fi
    exit 0
fi

if [[ "$EXPAND" == true ]]; then
    if [[ "$WINDOW_ZOOMED" != "1" ]]; then
        tmux resize-pane -Z -t "$TARGET_PANE"
    fi
    exit 0
fi

tmux resize-pane -Z -t "$TARGET_PANE"
