#!/usr/bin/env bash
# tmux-grid-expand - Expand/retract panes in the workspace
# TAGS: tmux, grid, expand
# AUDIENCE: human + script
#
# Two independent expansion axes, toggled with the same key (prefix + e):
#
#   Grid expansion (@GRID_EXPANDED):
#     Active grid pane goes true fullscreen within the grid area. The other
#     3 grid panes are moved to a hidden _grid_stash window (processes keep
#     running). Retract brings them back and restores the 2x2 layout.
#
#   Side expansion (@SIDE_EXPANDED):
#     WSL: close the other side panel, shift the grid, expand this terminal
#          into the freed space. Grid panes stay the same size.
#     Mac: compress the grid proportionally to give the monitor more room.
#
# Both can be active simultaneously. Side panes are never touched by grid
# expansion — only grid panes are stashed/restored.
#
# Usage:
#   tmux-grid-expand              # Toggle expand/retract for active pane
#   tmux-grid-expand --retract    # Force full reset to canonical

set -euo pipefail

MAC_SIDE_EXPAND_RATIO=50

SESSION=$(tmux display-message -p '#{session_name}')
WINDOW=$(tmux display-message -p '#{window_index}')
TARGET="${SESSION}:${WINDOW}"
ACTIVE_PANE=$(tmux display-message -p '#{pane_id}')

# Per-window stash prevents races when multiple windows expand simultaneously.
# Strip parenthetical suffix from window name (e.g. "palace(3)" → "palace").
WINDOW_NAME_RAW=$(tmux display-message -p '#{window_name}')
WINDOW_BASE="${WINDOW_NAME_RAW%%(*}"
STASH_WINDOW="_stash_${WINDOW_BASE}"

# ─── Helpers ─────────────────────────────────────────────────────────

get_all_panes() {
    tmux list-panes -t "$TARGET" \
        -F '#{pane_id}	#{@GRID_STATE}	#{pane_left}	#{pane_top}	#{pane_width}	#{pane_height}'
}

get_grid_panes() {
    get_all_panes | awk -F'\t' '$2 == "small" { print $1"\t"$3"\t"$4"\t"$5"\t"$6 }'
}

get_side_panes() {
    get_all_panes | awk -F'\t' '$2 == "side" { print $1"\t"$3"\t"$4"\t"$5"\t"$6 }'
}

# Compute grid bounding box from current geometry.
# Sets: GRID_W, GRID_H, GRID_LEFT, GRID_RIGHT, GRID_TOP, GRID_BOTTOM
compute_grid_bounds() {
    GRID_LEFT=99999 GRID_RIGHT=0 GRID_TOP=99999 GRID_BOTTOM=0
    while IFS=$'\t' read -r pid pleft ptop pwidth pheight; do
        local pr=$((pleft + pwidth)) pb=$((ptop + pheight))
        (( pleft < GRID_LEFT )) && GRID_LEFT=$pleft
        (( pr > GRID_RIGHT )) && GRID_RIGHT=$pr
        (( ptop < GRID_TOP )) && GRID_TOP=$ptop
        (( pb > GRID_BOTTOM )) && GRID_BOTTOM=$pb
    done < <(get_grid_panes)
    GRID_W=$((GRID_RIGHT - GRID_LEFT))
    GRID_H=$((GRID_BOTTOM - GRID_TOP))
}

# Find origin-column and far-column top panes.
# Sets: ORIGIN_COL, ORIGIN_COL_W, FAR_COL, FAR_COL_W
find_grid_cols() {
    local min_left=99999 min_top=99999
    while IFS=$'\t' read -r pid pleft ptop pwidth pheight; do
        (( pleft < min_left )) && min_left=$pleft
        (( ptop < min_top )) && min_top=$ptop
    done < <(get_grid_panes)

    ORIGIN_COL="" ORIGIN_COL_W=0
    FAR_COL="" FAR_COL_W=0
    while IFS=$'\t' read -r pid pleft ptop pwidth pheight; do
        if (( ptop == min_top )); then
            if (( pleft == min_left )); then
                ORIGIN_COL="$pid"; ORIGIN_COL_W=$pwidth
            else
                FAR_COL="$pid"; FAR_COL_W=$pwidth
            fi
        fi
    done < <(get_grid_panes)
}

# Find the target's grid partners by relative position.
#   H_PARTNER: same column, other row
#   V_PARTNER: same row, other column
#   DIAGONAL:  other row, other column
find_partners() {
    local target="$1"
    local pids=() lefts=() tops=()
    local t_idx=-1 i=0

    while IFS=$'\t' read -r pid pleft ptop pwidth pheight; do
        pids+=("$pid"); lefts+=("$pleft"); tops+=("$ptop")
        [[ "$pid" == "$target" ]] && t_idx=$i
        i=$((i + 1))
    done < <(get_grid_panes)

    local t_left=${lefts[$t_idx]} t_top=${tops[$t_idx]}
    TARGET_LEFT=$t_left TARGET_TOP=$t_top

    H_PARTNER="" V_PARTNER="" DIAGONAL=""

    for ((j=0; j<${#pids[@]}; j++)); do
        [[ $j -eq $t_idx ]] && continue
        local same_col=false same_row=false
        local dl=$(( ${lefts[$j]} - t_left )) dt=$(( ${tops[$j]} - t_top ))
        (( dl > -5 && dl < 5 )) && same_col=true
        (( dt > -5 && dt < 5 )) && same_row=true

        if [[ "$same_col" == true && "$same_row" == false ]]; then
            H_PARTNER="${pids[$j]}"
        elif [[ "$same_col" == false && "$same_row" == true ]]; then
            V_PARTNER="${pids[$j]}"
        elif [[ "$same_col" == false && "$same_row" == false ]]; then
            DIAGONAL="${pids[$j]}"
        fi
    done
}

# ─── Side Expansion ─────────────────────────────────────────────────

do_side_expand() {
    local target_side="$1"
    local origin
    origin=$(tmux show-options -wv -t "$TARGET" @LAYOUT_ORIGIN 2>/dev/null || echo "")

    if [[ "$origin" == "wsl" ]]; then
        do_side_expand_wsl "$target_side"
    elif [[ "$origin" == "mac" ]]; then
        do_side_expand_mac "$target_side"
    fi
}

do_side_expand_wsl() {
    local target_side="$1"

    local other_side="" target_w=0 other_w=0 target_left=0 other_left=0
    while IFS=$'\t' read -r pid pleft ptop pwidth pheight; do
        if [[ "$pid" == "$target_side" ]]; then
            target_w=$pwidth; target_left=$pleft
        else
            other_side="$pid"; other_w=$pwidth; other_left=$pleft
        fi
    done < <(get_side_panes)

    [[ -z "$other_side" ]] && return

    find_grid_cols
    local saved_origin_w=$ORIGIN_COL_W
    local saved_far_w=$FAR_COL_W

    local desired=$((target_w + other_w - 1))

    if (( target_left < other_left )); then
        tmux resize-pane -t "$target_side" -x "$desired"
    else
        tmux resize-pane -t "$other_side" -x 1
    fi

    tmux resize-pane -t "$ORIGIN_COL" -x "$saved_origin_w"
    tmux resize-pane -t "$FAR_COL" -x "$saved_far_w"
}

do_side_expand_mac() {
    local target_side="$1"
    local win_w
    win_w=$(tmux display-message -t "$TARGET" -p '#{window_width}')

    local new_monitor_w=$((win_w * MAC_SIDE_EXPAND_RATIO / 100))

    find_grid_cols
    compute_grid_bounds
    local new_grid_w=$((win_w - new_monitor_w - 1))
    local new_origin_w=$((ORIGIN_COL_W * new_grid_w / GRID_W))

    tmux resize-pane -t "$target_side" -x "$new_monitor_w"
    tmux resize-pane -t "$ORIGIN_COL" -x "$new_origin_w"
}

# ─── Grid Expansion (True Fullscreen) ───────────────────────────────

# Determine quadrant position of a pane relative to grid center.
# Returns "col:row" where col/row are 0 (origin/top) or 1 (far/bottom).
pane_quadrant() {
    local pid="$1" target_left="$2" target_top="$3"
    local pids=() lefts=() tops=()

    while IFS=$'\t' read -r p pleft ptop pwidth pheight; do
        pids+=("$p"); lefts+=("$pleft"); tops+=("$ptop")
    done < <(get_grid_panes)

    # Find grid origin (min left, min top)
    local min_left=99999 min_top=99999
    for ((i=0; i<${#lefts[@]}; i++)); do
        (( ${lefts[$i]} < min_left )) && min_left=${lefts[$i]}
        (( ${tops[$i]} < min_top )) && min_top=${tops[$i]}
    done

    local col=0 row=0
    local dl=$((target_left - min_left))
    local dt=$((target_top - min_top))
    (( dl > 5 )) && col=1
    (( dt > 5 )) && row=1

    echo "${col}:${row}"
}

do_grid_expand() {
    local target_pane="$1"

    local pane_count
    pane_count=$(get_grid_panes | wc -l)
    if [[ "$pane_count" -ne 4 ]]; then
        tmux display-message "Cannot expand grid: not a 2x2 grid ($pane_count panes)"
        return 1
    fi

    # Identify partners and their positions
    find_partners "$target_pane"

    # Capture side pane widths BEFORE stashing — when grid panes are moved out,
    # tmux gives their horizontal space to tree siblings (side panes). We restore
    # side panes to original width after, forcing the grid pane to absorb the space.
    local side_pane_ids=() side_pane_widths=()
    while IFS=$'\t' read -r pid pleft ptop pwidth pheight; do
        side_pane_ids+=("$pid")
        side_pane_widths+=("$pwidth")
    done < <(get_side_panes)

    # Build stash manifest: pane_id:col:row for each non-active grid pane
    local stash_entries=()
    while IFS=$'\t' read -r pid pleft ptop pwidth pheight; do
        [[ "$pid" == "$target_pane" ]] && continue
        local quad
        quad=$(pane_quadrant "$pid" "$pleft" "$ptop")
        stash_entries+=("${pid}:${quad}")
    done < <(get_grid_panes)

    local stash_manifest
    stash_manifest=$(IFS=','; echo "${stash_entries[*]}")
    tmux set-option -w -t "$TARGET" @GRID_STASH "$stash_manifest"

    # Create stash window if it doesn't exist
    if ! tmux list-windows -t "$SESSION" -F '#{window_name}' | grep -q "^${STASH_WINDOW}$"; then
        tmux new-window -d -t "$SESSION" -n "$STASH_WINDOW"
    fi

    # Move the 3 non-active grid panes to stash window
    for entry in "${stash_entries[@]}"; do
        local pid="${entry%%:*}"
        tmux move-pane -d -t "${SESSION}:${STASH_WINDOW}" -s "$pid" 2>/dev/null || true
    done

    # Kill the initial empty pane in stash window (from new-window) if it exists.
    local stash_panes
    stash_panes=$(tmux list-panes -t "${SESSION}:${STASH_WINDOW}" \
        -F '#{pane_id}	#{@GRID_STATE}' 2>/dev/null || true)
    while IFS=$'\t' read -r spid sstate; do
        if [[ -z "$sstate" || "$sstate" == "" ]]; then
            local total
            total=$(echo "$stash_panes" | wc -l)
            if (( total > 1 )); then
                tmux kill-pane -t "$spid" 2>/dev/null || true
            fi
        fi
    done <<< "$stash_panes"

    # Restore side panes to their pre-stash widths. tmux gave them the vacated
    # grid column's space — pushing it back forces the expanded pane to fill
    # the full grid area instead.
    for ((i=0; i<${#side_pane_ids[@]}; i++)); do
        tmux resize-pane -t "${side_pane_ids[$i]}" -x "${side_pane_widths[$i]}" 2>/dev/null || true
    done
}

do_grid_retract() {
    local stash_manifest
    stash_manifest=$(tmux show-options -wv -t "$TARGET" @GRID_STASH 2>/dev/null || echo "")
    [[ -z "$stash_manifest" ]] && return

    local expanded_pane
    expanded_pane=$(tmux show-options -wv -t "$TARGET" @GRID_EXPANDED 2>/dev/null || echo "none")
    [[ "$expanded_pane" == "none" ]] && return

    # Parse stash manifest into arrays
    local pane_ids=() pane_cols=() pane_rows=()
    IFS=',' read -ra entries <<< "$stash_manifest"
    for entry in "${entries[@]}"; do
        local pid col row
        pid="${entry%%:*}"
        local rest="${entry#*:}"
        col="${rest%%:*}"
        row="${rest#*:}"
        pane_ids+=("$pid")
        pane_cols+=("$col")
        pane_rows+=("$row")
    done

    # Determine which quadrant the expanded pane is in
    # (it's the only grid pane left in the window)
    local exp_left exp_top
    exp_left=$(tmux display-message -t "$expanded_pane" -p '#{pane_left}')
    exp_top=$(tmux display-message -t "$expanded_pane" -p '#{pane_top}')
    local exp_w exp_h
    exp_w=$(tmux display-message -t "$expanded_pane" -p '#{pane_width}')
    exp_h=$(tmux display-message -t "$expanded_pane" -p '#{pane_height}')

    # Reconstruct 2x2 grid by joining panes back.
    # Strategy: we need to rebuild the column-first tree structure.
    #
    # The expanded pane currently fills the grid area. We need to:
    # 1. Find the pane that belongs in the other column (same row as expanded)
    #    → join-pane -h to split into two columns
    # 2. Find the pane for the expanded pane's column (other row)
    #    → join-pane -v into the expanded pane's column
    # 3. Find the pane for the other column (other row)
    #    → join-pane -v into the other column

    # Figure out expanded pane's quadrant from stash context.
    # The expanded pane is whichever quadrant is NOT in the stash.
    local exp_col exp_row
    local found_cols=() found_rows=()
    for ((i=0; i<${#pane_ids[@]}; i++)); do
        found_cols+=("${pane_cols[$i]}")
        found_rows+=("${pane_rows[$i]}")
    done

    # With 3 stashed panes from a 2x2, one quadrant is missing = the expanded pane
    for c in 0 1; do
        for r in 0 1; do
            local found=false
            for ((i=0; i<${#pane_ids[@]}; i++)); do
                if [[ "${pane_cols[$i]}" == "$c" && "${pane_rows[$i]}" == "$r" ]]; then
                    found=true
                    break
                fi
            done
            if [[ "$found" == false ]]; then
                exp_col=$c
                exp_row=$r
                break 2
            fi
        done
    done

    # Find panes by role relative to expanded pane
    local v_partner="" h_partner="" diagonal=""
    for ((i=0; i<${#pane_ids[@]}; i++)); do
        local c="${pane_cols[$i]}" r="${pane_rows[$i]}"
        if [[ "$c" != "$exp_col" && "$r" == "$exp_row" ]]; then
            v_partner="${pane_ids[$i]}"  # same row, other column
        elif [[ "$c" == "$exp_col" && "$r" != "$exp_row" ]]; then
            h_partner="${pane_ids[$i]}"  # same column, other row
        elif [[ "$c" != "$exp_col" && "$r" != "$exp_row" ]]; then
            diagonal="${pane_ids[$i]}"   # other column, other row
        fi
    done

    # Verify stashed panes still exist
    for pid in "$v_partner" "$h_partner" "$diagonal"; do
        if [[ -n "$pid" ]] && ! tmux display-message -t "$pid" -p '' 2>/dev/null; then
            tmux display-message "Cannot retract: stashed pane $pid no longer exists"
            tmux set-option -w -t "$TARGET" @GRID_EXPANDED "none"
            tmux set-option -w -t "$TARGET" @GRID_STASH ""
            return 1
        fi
    done

    # Step 1: Join v_partner (same row, other column) → creates second column
    # If expanded is in col 0, v_partner goes to the right (-h, no -b)
    # If expanded is in col 1, v_partner goes to the left (-h -b)
    if [[ -n "$v_partner" ]]; then
        if [[ "$exp_col" == "0" ]]; then
            tmux join-pane -d -h -t "$expanded_pane" -s "$v_partner"
        else
            tmux join-pane -d -h -b -t "$expanded_pane" -s "$v_partner"
        fi
    fi

    # Step 2: Join h_partner (same column, other row) into expanded pane's column
    # If expanded is in row 0, h_partner goes below (-v, no -b)
    # If expanded is in row 1, h_partner goes above (-v -b)
    if [[ -n "$h_partner" ]]; then
        if [[ "$exp_row" == "0" ]]; then
            tmux join-pane -d -v -t "$expanded_pane" -s "$h_partner"
        else
            tmux join-pane -d -v -b -t "$expanded_pane" -s "$h_partner"
        fi
    fi

    # Step 3: Join diagonal (other column, other row) into v_partner's column
    # If diagonal is in same row as expanded → goes below/above v_partner
    # diagonal row != exp_row, so:
    #   If exp_row == 0 → diagonal is row 1 → goes below v_partner
    #   If exp_row == 1 → diagonal is row 0 → goes above v_partner
    if [[ -n "$diagonal" && -n "$v_partner" ]]; then
        if [[ "$exp_row" == "0" ]]; then
            tmux join-pane -d -v -t "$v_partner" -s "$diagonal"
        else
            tmux join-pane -d -v -b -t "$v_partner" -s "$diagonal"
        fi
    fi

    # Ensure all restored panes have @GRID_STATE "small"
    for pid in "$v_partner" "$h_partner" "$diagonal"; do
        [[ -n "$pid" ]] && tmux set-option -p -t "$pid" @GRID_STATE "small" 2>/dev/null || true
    done

    # Clear expansion state
    tmux set-option -w -t "$TARGET" @GRID_EXPANDED "none"
    tmux set-option -w -t "$TARGET" @GRID_STASH ""

    # Kill stash window if it still exists (may have other stashed content)
    if tmux list-windows -t "$SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${STASH_WINDOW}$"; then
        local stash_pane_count
        stash_pane_count=$(tmux list-panes -t "${SESSION}:${STASH_WINDOW}" 2>/dev/null | wc -l | tr -d ' ')
        if [[ "${stash_pane_count:-0}" -le 1 ]]; then
            tmux kill-window -t "${SESSION}:${STASH_WINDOW}" 2>/dev/null || true
        fi
    fi

    # Refresh to canonical proportions
    tmux-refresh-layout "$TARGET"
}

# ─── Layered Apply ──────────────────────────────────────────────────

# Apply side expansion (independent of grid state).
apply_side_expansion() {
    local side_exp
    side_exp=$(tmux show-options -wv -t "$TARGET" @SIDE_EXPANDED 2>/dev/null || echo "none")

    # Validate target still exists
    if [[ "$side_exp" != "none" ]] && ! tmux display-message -t "$side_exp" -p '' 2>/dev/null; then
        side_exp="none"
        tmux set-option -w -t "$TARGET" @SIDE_EXPANDED "none" 2>/dev/null || true
    fi

    if [[ "$side_exp" != "none" ]]; then
        # Reset side to canonical first, then expand
        tmux-refresh-layout "$TARGET"
        # Restore side state (refresh clears it)
        tmux set-option -w -t "$TARGET" @SIDE_EXPANDED "$side_exp" 2>/dev/null || true
        # Also preserve grid state through refresh
        local grid_exp
        grid_exp=$(tmux show-options -wv -t "$TARGET" @GRID_EXPANDED 2>/dev/null || echo "none")
        tmux set-option -w -t "$TARGET" @GRID_EXPANDED "$grid_exp" 2>/dev/null || true
        local grid_stash
        grid_stash=$(tmux show-options -wv -t "$TARGET" @GRID_STASH 2>/dev/null || echo "")
        tmux set-option -w -t "$TARGET" @GRID_STASH "$grid_stash" 2>/dev/null || true
        do_side_expand "$side_exp"
    fi
}

# Clear panes where SIGWINCH redraws have stacked identical prompt lines.
clear_stale_prompts() {
    local all_panes
    all_panes=$(get_all_panes)

    while IFS=$'\t' read -r pid state pleft ptop pwidth pheight; do
        [[ "$state" == "small" || "$state" == "side" ]] || continue

        local lines
        lines=$(tmux capture-pane -t "$pid" -p 2>/dev/null | sed '/^$/d')
        [[ -z "$lines" ]] && continue

        local line_count unique_count
        line_count=$(echo "$lines" | tail -5 | wc -l)
        unique_count=$(echo "$lines" | tail -5 | sort -u | wc -l)

        if (( line_count >= 4 && unique_count == 1 )); then
            tmux send-keys -t "$pid" C-l
        fi
    done <<< "$all_panes"
}

# ─── Generic Expansion (non-palace windows) ─────────────────────────

# Expand the active pane by stashing all non-reserved sibling panes.
# Reserved panes (@GRID_RESERVED == "true") stay in place (e.g. TUI monitor on warp).
do_generic_expand() {
    local target_pane="$1"

    # Collect non-reserved panes that aren't the target
    local stash_entries=()
    local stash_index=0
    while IFS=$'\t' read -r pid reserved; do
        [[ "$pid" == "$target_pane" ]] && continue
        if [[ "$reserved" != "true" ]]; then
            stash_entries+=("${pid}:${stash_index}")
            stash_index=$((stash_index + 1))
        fi
    done < <(tmux list-panes -t "$TARGET" -F '#{pane_id}	#{@GRID_RESERVED}')

    if [[ ${#stash_entries[@]} -eq 0 ]]; then
        tmux display-message "Nothing to expand (no non-reserved siblings)"
        tmux set-option -w -t "$TARGET" @GENERIC_EXPANDED "none"
        return
    fi

    local stash_manifest
    stash_manifest=$(IFS=','; echo "${stash_entries[*]}")
    tmux set-option -w -t "$TARGET" @GENERIC_STASH "$stash_manifest"

    # Capture reserved pane dimensions for restoration after stash
    local reserved_panes=() reserved_widths=() reserved_heights=()
    while IFS=$'\t' read -r pid reserved pwidth pheight; do
        if [[ "$reserved" == "true" ]]; then
            reserved_panes+=("$pid")
            reserved_widths+=("$pwidth")
            reserved_heights+=("$pheight")
        fi
    done < <(tmux list-panes -t "$TARGET" -F '#{pane_id}	#{@GRID_RESERVED}	#{pane_width}	#{pane_height}')

    # Create stash window if needed
    if ! tmux list-windows -t "$SESSION" -F '#{window_name}' | grep -q "^${STASH_WINDOW}$"; then
        tmux new-window -d -t "$SESSION" -n "$STASH_WINDOW"
    fi

    # Move non-reserved siblings to stash
    for entry in "${stash_entries[@]}"; do
        local pid="${entry%%:*}"
        tmux move-pane -d -t "${SESSION}:${STASH_WINDOW}" -s "$pid" 2>/dev/null || true
    done

    # Kill the initial empty pane in stash window if it exists
    local stash_panes
    stash_panes=$(tmux list-panes -t "${SESSION}:${STASH_WINDOW}" \
        -F '#{pane_id}	#{@GRID_RESERVED}' 2>/dev/null || true)
    while IFS=$'\t' read -r spid sres; do
        if [[ -z "$sres" || "$sres" == "" ]]; then
            local total
            total=$(echo "$stash_panes" | wc -l)
            if (( total > 1 )); then
                tmux kill-pane -t "$spid" 2>/dev/null || true
            fi
        fi
    done <<< "$stash_panes"

    # Restore reserved panes to their pre-stash dimensions
    for ((i=0; i<${#reserved_panes[@]}; i++)); do
        tmux resize-pane -t "${reserved_panes[$i]}" -y "${reserved_heights[$i]}" 2>/dev/null || true
    done
}

do_generic_retract() {
    local stash_manifest
    stash_manifest=$(tmux show-options -wv -t "$TARGET" @GENERIC_STASH 2>/dev/null || echo "")
    [[ -z "$stash_manifest" ]] && return

    local expanded_pane
    expanded_pane=$(tmux show-options -wv -t "$TARGET" @GENERIC_EXPANDED 2>/dev/null || echo "none")
    [[ "$expanded_pane" == "none" ]] && return

    # Parse manifest: pid:index entries
    IFS=',' read -ra entries <<< "$stash_manifest"

    # Verify stashed panes still exist
    for entry in "${entries[@]}"; do
        local pid="${entry%%:*}"
        if ! tmux display-message -t "$pid" -p '' 2>/dev/null; then
            tmux display-message "Cannot retract: stashed pane $pid no longer exists"
            tmux set-option -w -t "$TARGET" @GENERIC_EXPANDED "none"
            tmux set-option -w -t "$TARGET" @GENERIC_STASH ""
            return 1
        fi
    done

    # Join stashed panes back as vertical splits below the expanded pane
    for entry in "${entries[@]}"; do
        local pid="${entry%%:*}"
        tmux join-pane -d -v -t "$expanded_pane" -s "$pid" 2>/dev/null || true
    done

    # Rebalance the non-reserved panes evenly
    local non_reserved=()
    while IFS=$'\t' read -r pid reserved; do
        if [[ "$reserved" != "true" ]]; then
            non_reserved+=("$pid")
        fi
    done < <(tmux list-panes -t "$TARGET" -F '#{pane_id}	#{@GRID_RESERVED}')

    if [[ ${#non_reserved[@]} -gt 1 ]]; then
        # Get total height available to non-reserved panes
        local total_h=0
        for pid in "${non_reserved[@]}"; do
            local ph
            ph=$(tmux display-message -t "$pid" -p '#{pane_height}')
            total_h=$((total_h + ph))
        done
        # Account for separators between panes
        local separators=$(( ${#non_reserved[@]} - 1 ))
        local usable=$((total_h + separators))
        local even_h=$(( (usable - separators) / ${#non_reserved[@]} ))

        # Resize all but the last (last absorbs remainder)
        for ((i=0; i<${#non_reserved[@]}-1; i++)); do
            tmux resize-pane -t "${non_reserved[$i]}" -y "$even_h" 2>/dev/null || true
        done
    fi

    # Clear state
    tmux set-option -w -t "$TARGET" @GENERIC_EXPANDED "none"
    tmux set-option -w -t "$TARGET" @GENERIC_STASH ""

    # Kill stash window if empty
    if tmux list-windows -t "$SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${STASH_WINDOW}$"; then
        local stash_pane_count
        stash_pane_count=$(tmux list-panes -t "${SESSION}:${STASH_WINDOW}" 2>/dev/null | wc -l | tr -d ' ')
        if [[ "${stash_pane_count:-0}" -le 1 ]]; then
            tmux kill-window -t "${SESSION}:${STASH_WINDOW}" 2>/dev/null || true
        fi
    fi
}

# ─── Dispatch ────────────────────────────────────────────────────────

case "${1:-}" in
    --retract)
        # Force retract: restore stashed panes if any, then canonical reset
        local_grid_exp=$(tmux show-options -wv -t "$TARGET" @GRID_EXPANDED 2>/dev/null || echo "none")
        if [[ "$local_grid_exp" != "none" ]]; then
            do_grid_retract
        fi
        # Also retract generic expansion if active
        local_generic_exp=$(tmux show-options -wv -t "$TARGET" @GENERIC_EXPANDED 2>/dev/null || echo "none")
        if [[ "$local_generic_exp" != "none" ]]; then
            do_generic_retract
        fi
        tmux set-option -w -t "$TARGET" @SIDE_EXPANDED "none" 2>/dev/null || true
        tmux-refresh-layout "$TARGET"
        ;;
    *)
        active_state=$(tmux show-options -pv -t "$ACTIVE_PANE" @GRID_STATE 2>/dev/null || echo "")

        # Check for existing grid expansion FIRST — when expanded, panes are stashed
        # so grid_pane_count will be 1, not 4. Must retract before re-counting.
        current_grid=$(tmux show-options -wv -t "$TARGET" @GRID_EXPANDED 2>/dev/null || echo "none")

        if [[ "$current_grid" != "none" && "$active_state" == "small" ]]; then
            # Grid expansion active — handle retract or swap
            if [[ "$current_grid" == "$ACTIVE_PANE" ]]; then
                do_grid_retract
                apply_side_expansion
                clear_stale_prompts
            else
                # Different pane — retract first, then expand new
                do_grid_retract
                tmux set-option -w -t "$TARGET" @GRID_EXPANDED "$ACTIVE_PANE"
                do_grid_expand "$ACTIVE_PANE"
                apply_side_expansion
            fi

        elif [[ "$active_state" == "small" ]]; then
            # No active grid expansion — check if we have a proper 2x2 for palace expand
            grid_pane_count=$(get_grid_panes | wc -l | tr -d ' ')

            if [[ "$grid_pane_count" -eq 4 ]]; then
                # Palace 2x2 grid pane: expand to true fullscreen
                tmux set-option -w -t "$TARGET" @GRID_EXPANDED "$ACTIVE_PANE"
                do_grid_expand "$ACTIVE_PANE"
                apply_side_expansion
            else
                # Non-palace window with "small" panes (warp, etc.) → generic expand
                active_reserved=$(tmux show-options -pv -t "$ACTIVE_PANE" @GRID_RESERVED 2>/dev/null || echo "false")
                if [[ "$active_reserved" == "true" ]]; then
                    tmux display-message "Cannot expand reserved pane"
                    exit 0
                fi

                generic_exp=$(tmux show-options -wv -t "$TARGET" @GENERIC_EXPANDED 2>/dev/null || echo "none")
                if [[ "$generic_exp" == "$ACTIVE_PANE" ]]; then
                    do_generic_retract
                elif [[ "$generic_exp" != "none" ]]; then
                    do_generic_retract
                    tmux set-option -w -t "$TARGET" @GENERIC_EXPANDED "$ACTIVE_PANE"
                    do_generic_expand "$ACTIVE_PANE"
                else
                    tmux set-option -w -t "$TARGET" @GENERIC_EXPANDED "$ACTIVE_PANE"
                    do_generic_expand "$ACTIVE_PANE"
                fi
            fi

        elif [[ "$active_state" == "side" ]]; then
            # Side pane: toggle side expansion (proportional, unchanged)
            current=$(tmux show-options -wv -t "$TARGET" @SIDE_EXPANDED 2>/dev/null || echo "none")
            if [[ "$current" == "$ACTIVE_PANE" ]]; then
                tmux set-option -w -t "$TARGET" @SIDE_EXPANDED "none"
            else
                tmux set-option -w -t "$TARGET" @SIDE_EXPANDED "$ACTIVE_PANE"
            fi
            apply_side_expansion
            clear_stale_prompts

        else
            # Generic expand: works on any window (warp, kreig, legion, etc.)
            # Stashes non-reserved sibling panes, preserves reserved ones (TUI monitor).
            # Skip if active pane is reserved (e.g. TUI monitor — nothing useful to expand into).
            active_reserved=$(tmux show-options -pv -t "$ACTIVE_PANE" @GRID_RESERVED 2>/dev/null || echo "false")
            if [[ "$active_reserved" == "true" ]]; then
                tmux display-message "Cannot expand reserved pane"
                exit 0
            fi

            generic_exp=$(tmux show-options -wv -t "$TARGET" @GENERIC_EXPANDED 2>/dev/null || echo "none")

            if [[ "$generic_exp" == "$ACTIVE_PANE" ]]; then
                # Already expanded — retract
                do_generic_retract
            elif [[ "$generic_exp" != "none" ]]; then
                # Different pane expanded — retract first, then expand new
                do_generic_retract
                tmux set-option -w -t "$TARGET" @GENERIC_EXPANDED "$ACTIVE_PANE"
                do_generic_expand "$ACTIVE_PANE"
            else
                # Nothing expanded — expand
                tmux set-option -w -t "$TARGET" @GENERIC_EXPANDED "$ACTIVE_PANE"
                do_generic_expand "$ACTIVE_PANE"
            fi
        fi
        ;;
esac
