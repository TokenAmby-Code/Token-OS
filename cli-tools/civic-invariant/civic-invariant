#!/usr/bin/env bash
#
# civic-invariant — keep exactly ONE healthy askCivic instance alive in the
# background, and let other civic work assert the invariant before it starts.
#
#   "I need one civic instance running before I can work on other stuff."
#
# The invariant is satisfied when:
#   - the Cloud SQL Auth Proxy is listening on 127.0.0.1:5432, AND
#   - exactly one askCivic backend is LISTENing on :8080 and returns HTTP 200 on
#     GET /health.
#
# Liveness is defined by the HEALTH HTTP RESPONSE + PORT OWNERSHIP, never by mere
# process existence — the app's uvicorn reloader can linger after the worker dies,
# so a PID check alone lies. The OS guarantees at most one listener on :8080, which
# is what enforces "exactly one".
#
# Mount note: the worktree, .venv, proxy binary and SA key are all on LOCAL disk,
# so keep-alive / respawn of the already-built instance works even when the Civic
# AES-256 mount is LOCKED. Only a from-scratch rebuild (worktree-setup) needs Civic
# unlocked.
#
# Subcommands:
#   status      human-readable state of proxy + app + health (exit 0 if satisfied)
#   check       quiet; exit 0 iff invariant satisfied (for scripts/guards)
#   ensure|up   idempotent: start proxy if down, start app if down/unhealthy,
#               reap any duplicate app processes. The keep-alive action.
#   require     guard for civic work: ensure + check; exit 0 if alive, else nonzero
#   restart     stop then ensure
#   stop|down   stop the app (and proxy with --proxy)
#   logs        tail the instance log (--proxy for proxy log)
#
set -uo pipefail

# ---- Config (override via env) ----------------------------------------------
WORKTREE="${CIVIC_INVARIANT_WORKTREE:-$HOME/worktrees/askCivic/wt-civic-invariant}"
PORT="${CIVIC_INVARIANT_PORT:-8080}"
PROXY_PORT="${CIVIC_INVARIANT_PROXY_PORT:-5432}"
INSTANCE_CONNECTION_NAME="${CIVIC_INVARIANT_ICN:-pax-dev-469018:us-central1:pax-sql}"
STATE_DIR="${CIVIC_INVARIANT_STATE:-$HOME/.civic-invariant}"
HEALTH_TIMEOUT="${CIVIC_INVARIANT_HEALTH_TIMEOUT:-6}"
START_WAIT="${CIVIC_INVARIANT_START_WAIT:-75}"   # max seconds to wait for /health

# server.py ships next to this script (repo) and is also installed into $STATE_DIR.
# Resolve it next to the script first, then fall back to the runtime state dir.
_SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER_PY="${CIVIC_INVARIANT_SERVER:-$( [ -f "$_SELF_DIR/server.py" ] && echo "$_SELF_DIR/server.py" || echo "$STATE_DIR/server.py" )}"
APP_PID_FILE="$STATE_DIR/instance.pid"
APP_LOG="$STATE_DIR/instance.log"
PROXY_PID_FILE="$STATE_DIR/proxy.pid"
PROXY_LOG="$STATE_DIR/proxy.log"
EVENT_LOG="$STATE_DIR/harness.log"
HEALTH_URL="http://127.0.0.1:${PORT}/health"
SA_KEY="$WORKTREE/deploy/dev-service-account.json"

mkdir -p "$STATE_DIR"

# ---- Logging ----------------------------------------------------------------
ts() { date '+%Y-%m-%d %H:%M:%S'; }
event() { printf '[%s] %s\n' "$(ts)" "$*" >>"$EVENT_LOG"; }
say()   { printf '%s\n' "$*"; }

# ---- Probes -----------------------------------------------------------------
# PID listening on a TCP port (empty if none).
port_pid() { lsof -nP -iTCP:"$1" -sTCP:LISTEN -t 2>/dev/null | head -1; }

# HTTP status code from /health ("000" = no response).
health_code() {
  curl -s -m "$HEALTH_TIMEOUT" -o /dev/null -w "%{http_code}" "$HEALTH_URL" 2>/dev/null
}

# Overall health JSON body (best-effort).
health_body() { curl -s -m "$HEALTH_TIMEOUT" "$HEALTH_URL" 2>/dev/null; }

proxy_up() { [ -n "$(port_pid "$PROXY_PORT")" ]; }

# App is "alive" iff something owns :8080 AND /health answers with any HTTP code.
app_alive() {
  [ -n "$(port_pid "$PORT")" ] || return 1
  local c; c=$(health_code)
  [ "$c" != "000" ] && [ -n "$c" ]
}

# Invariant: proxy up AND app alive AND health overall not failing.
invariant_ok() {
  proxy_up || return 1
  app_alive || return 1
  # Treat HTTP 200 as satisfied; degraded/5xx still means "a process is alive"
  # but the invariant wants a usable instance, so require 200.
  [ "$(health_code)" = "200" ]
}

# ---- Duplicate reaping ------------------------------------------------------
# Our app processes = python running server.py. The canonical one owns :8080.
# Anything else matching is an orphan (failed start / stale reloader) -> kill.
reap_duplicates() {
  local keeper; keeper=$(port_pid "$PORT")
  local pids; pids=$(pgrep -f "$SERVER_PY" 2>/dev/null)
  for p in $pids; do
    # keep the port owner and (if uv-wrapped) its parent chain is fine; only kill
    # processes that are NOT the keeper and NOT the keeper's parent.
    [ "$p" = "$keeper" ] && continue
    # If this pid is the parent of the keeper, keep it (uv wrapper).
    if [ -n "$keeper" ] && [ "$(ps -o ppid= -p "$keeper" 2>/dev/null | tr -d ' ')" = "$p" ]; then
      continue
    fi
    event "reaping duplicate/orphan app pid $p"
    kill "$p" 2>/dev/null
  done
}

# ---- Start / stop -----------------------------------------------------------
start_proxy() {
  if proxy_up; then return 0; fi
  if [ ! -x "$(command -v cloud-sql-proxy || true)" ]; then
    event "ERROR cloud-sql-proxy not found (brew install cloud-sql-proxy)"
    say   "✗ cloud-sql-proxy not installed"; return 1
  fi
  if [ ! -f "$SA_KEY" ]; then
    event "ERROR SA key missing at $SA_KEY (Civic mount locked? worktree not built?)"
    say   "✗ SA key missing: $SA_KEY"; return 1
  fi
  event "starting cloud-sql-proxy on 127.0.0.1:$PROXY_PORT"
  nohup cloud-sql-proxy "$INSTANCE_CONNECTION_NAME" \
        --address 127.0.0.1 --port "$PROXY_PORT" \
        --credentials-file "$SA_KEY" >"$PROXY_LOG" 2>&1 &
  echo $! >"$PROXY_PID_FILE"
  local i
  for i in $(seq 1 10); do proxy_up && return 0; sleep 1; done
  event "ERROR proxy failed to listen on $PROXY_PORT"
  say "✗ proxy failed to start (see $PROXY_LOG)"; return 1
}

start_app() {
  if app_alive; then return 0; fi
  if [ ! -d "$WORKTREE/.venv" ]; then
    event "ERROR venv missing at $WORKTREE/.venv (worktree not built / Civic locked)"
    say   "✗ askCivic worktree not built: $WORKTREE/.venv"; return 1
  fi
  event "starting askCivic instance (port $PORT)"
  ( cd "$WORKTREE" && \
    nohup env ENVIRONMENT=local-dev UV_PROJECT_ENVIRONMENT=.venv UV_NO_SYNC=1 \
          uv run python "$SERVER_PY" >"$APP_LOG" 2>&1 & echo $! >"$APP_PID_FILE" )
  local i code
  for i in $(seq 1 "$START_WAIT"); do
    code=$(health_code)
    if [ "$code" = "200" ]; then event "instance healthy (HTTP 200) after ${i}s"; return 0; fi
    # fast-fail if process died and port never came up
    sleep 1
  done
  event "ERROR instance did not become healthy within ${START_WAIT}s"
  say "✗ instance did not become healthy in ${START_WAIT}s (see $APP_LOG)"; return 1
}

stop_app() {
  local p; p=$(port_pid "$PORT")
  [ -n "$p" ] && { event "stopping app port-owner pid $p"; kill "$p" 2>/dev/null; }
  [ -f "$APP_PID_FILE" ] && { kill "$(cat "$APP_PID_FILE")" 2>/dev/null; rm -f "$APP_PID_FILE"; }
  pkill -f "$SERVER_PY" 2>/dev/null
  sleep 1
}

stop_proxy() {
  local p; p=$(port_pid "$PROXY_PORT")
  [ -n "$p" ] && { event "stopping proxy pid $p"; kill "$p" 2>/dev/null; }
  [ -f "$PROXY_PID_FILE" ] && { kill "$(cat "$PROXY_PID_FILE")" 2>/dev/null; rm -f "$PROXY_PID_FILE"; }
}

# ---- Commands ---------------------------------------------------------------
cmd_status() {
  local pp ap code body
  pp=$(port_pid "$PROXY_PORT"); ap=$(port_pid "$PORT")
  code=$(health_code); body=$(health_body)
  say "civic-invariant status"
  say "  worktree : $WORKTREE"
  say "  proxy    : $( [ -n "$pp" ] && echo "UP (pid $pp, 127.0.0.1:$PROXY_PORT)" || echo "DOWN" )"
  say "  app      : $( [ -n "$ap" ] && echo "UP (pid $ap, :$PORT)" || echo "DOWN" )"
  say "  health   : HTTP ${code:-000}"
  [ -n "$body" ] && say "  detail   : $body"
  if invariant_ok; then say "  INVARIANT: ✅ satisfied"; return 0
  else say "  INVARIANT: ❌ NOT satisfied"; return 1; fi
}

cmd_check() { invariant_ok; }

cmd_ensure() {
  start_proxy || return 1
  start_app   || return 1
  reap_duplicates
  invariant_ok || { say "✗ invariant still not satisfied after ensure"; return 1; }
  event "ensure: invariant satisfied"
  say "✅ civic invariant satisfied (proxy + one healthy askCivic on :$PORT)"
}

cmd_require() {
  if invariant_ok; then
    say "✅ civic invariant already satisfied"
    return 0
  fi
  say "… invariant not satisfied — ensuring one civic instance is alive"
  cmd_ensure
}

cmd_restart() { stop_app; cmd_ensure; }

cmd_stop() {
  stop_app
  [ "${1:-}" = "--proxy" ] && stop_proxy
  say "stopped askCivic instance${1:+ $1}"
}

cmd_logs() {
  if [ "${1:-}" = "--proxy" ]; then tail -n 40 -f "$PROXY_LOG"; else tail -n 40 -f "$APP_LOG"; fi
}

case "${1:-status}" in
  status)        shift; cmd_status "$@" ;;
  check)         shift; cmd_check  "$@" ;;
  ensure|up)     shift; cmd_ensure "$@" ;;
  require)       shift; cmd_require "$@" ;;
  restart)       shift; cmd_restart "$@" ;;
  stop|down)     shift; cmd_stop   "$@" ;;
  logs)          shift; cmd_logs   "$@" ;;
  *) say "usage: civic-invariant {status|check|ensure|require|restart|stop|logs}"; exit 2 ;;
esac
