#!/usr/bin/env bash
# pre-commit — belt-and-suspenders ruff gate installed per-worktree by worktree-setup.
#
# The PostToolUse format-on-save hook (cli-tools/scripts/post-tool-format.sh) is the
# first line of defense — the agent's edit *is* the save. But settings.json is
# copied-not-symlinked, so that hook can go stale. This pre-commit makes that
# staleness non-fatal: every commit is reformatted to match CI before it lands.
#
# Single source of truth = uv.lock via `uv run --python 3.11 --group dev ruff` —
# byte-identical to push.yml/pr.yml. We do NOT hardcode a ruff@X.Y.Z (that would be
# a second thing that can drift from the lock).
#
# Ergonomics: fix-then-final-check. For each staged *.py we run `ruff format`
# (mutate) + `git add`, then `ruff check --fix` + `git add`, then a final
# `ruff format --check` that BLOCKS the commit if anything still differs — so the
# committed tree is guaranteed to pass CI's format gate.

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
[[ -z "$REPO_ROOT" ]] && exit 0
cd "$REPO_ROOT" || exit 0

# Collect staged Python files (added/copied/modified — never deletions), routed by
# project prefix. CI only gates cli-tools/ and token-api/; *.py outside both has no
# pyproject/venv, so we leave it alone.
declare -a TOKEN_API_FILES=()
declare -a CLI_TOOLS_FILES=()

while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    [[ -f "$f" ]] || continue  # tolerate odd staged states
    case "$f" in
        token-api/*) TOKEN_API_FILES+=("$f") ;;
        cli-tools/*) CLI_TOOLS_FILES+=("$f") ;;
        *) : ;;  # outside a ruff-gated project — skip
    esac
done < <(git diff --cached --name-only --diff-filter=ACM -- '*.py')

if [[ ${#TOKEN_API_FILES[@]} -eq 0 && ${#CLI_TOOLS_FILES[@]} -eq 0 ]]; then
    exit 0
fi

# --force-exclude makes ruff honor [tool.ruff] exclude even for explicitly-passed
# paths, so the hook never touches a file CI's directory-mode (`ruff … .`) would skip.
RUFF=(uv run --python 3.11 --group dev ruff)
FORCE=(--force-exclude)
FAILED=0

# fix_project <project-dir> <file...>  — paths are repo-relative; ruff runs with cwd
# = project dir (so it picks the right venv/lock + [tool.ruff] config) on paths made
# relative to that dir.
fix_project() {
    local proj="$1"; shift
    local -a rels=()
    local f
    for f in "$@"; do
        rels+=("${f#"$proj"/}")
    done

    # Auto-fix: format, then lint-fix, then format again. The second format is load-
    # bearing — `check --fix` can remove unused imports / collapse code in ways that
    # leave formatting drift (e.g. stray blank lines), so we re-settle before staging.
    ( cd "$proj" && "${RUFF[@]}" format "${FORCE[@]}" "${rels[@]}" ) || {
        echo "pre-commit: ruff format errored in $proj (venv synced? try: cd $proj && uv sync --group dev)" >&2
        FAILED=1
    }
    ( cd "$proj" && "${RUFF[@]}" check --fix "${FORCE[@]}" "${rels[@]}" ) || true  # lint findings may be unfixable; don't block here
    ( cd "$proj" && "${RUFF[@]}" format "${FORCE[@]}" "${rels[@]}" ) || true        # settle formatting disturbed by --fix
    git add -- "$@"

    # Final gate: the staged tree MUST pass CI's format check. Block if it doesn't.
    if ! ( cd "$proj" && "${RUFF[@]}" format --check "${FORCE[@]}" "${rels[@]}" ); then
        echo "pre-commit: $proj still has ruff format drift after auto-fix — commit blocked." >&2
        echo "            Re-stage and recommit (the formatter already ran), or run:" >&2
        echo "            (cd $proj && uv run --python 3.11 --group dev ruff format .)" >&2
        FAILED=1
    fi
}

[[ ${#TOKEN_API_FILES[@]} -gt 0 ]] && fix_project token-api "${TOKEN_API_FILES[@]}"
[[ ${#CLI_TOOLS_FILES[@]} -gt 0 ]] && fix_project cli-tools "${CLI_TOOLS_FILES[@]}"

if [[ "$FAILED" -ne 0 ]]; then
    exit 1
fi
exit 0
